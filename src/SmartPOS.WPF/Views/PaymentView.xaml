<UserControl x:Class="SmartPOS.WPF.Views.PaymentView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:viewmodels="clr-namespace:SmartPOS.WPF.ViewModels"
             mc:Ignorable="d"
             d:DataContext="{d:DesignInstance Type=viewmodels:PaymentViewModel}"
             Background="{StaticResource SidebarBackgroundBrush}"
             d:DesignHeight="768" d:DesignWidth="1024">

    <UserControl.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis"/>

        <!-- Quick Cash Button Style -->
        <Style x:Key="QuickCashButton" TargetType="Button">
            <Setter Property="Background" Value="#F8FAFC"/>
            <Setter Property="Foreground" Value="#0F172A"/>
            <Setter Property="BorderBrush" Value="#E2E8F0"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="FontFamily" Value="Consolas"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Height" Value="48"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="6">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#DBEAFE"/>
                                <Setter Property="BorderBrush" Value="#173bab"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter Property="Background" Value="#BFDBFE"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Opacity" Value="0.5"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Confirm Button Style -->
        <Style x:Key="ConfirmButton" TargetType="Button">
            <Setter Property="Background" Value="#16A34A"/>
            <Setter Property="Foreground" Value="#FFFFFF"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="FontSize" Value="15"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Height" Value="52"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                CornerRadius="10">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Background" Value="#CBD5E1"/>
                                <Setter Property="Foreground" Value="#94A3B8"/>
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Opacity" Value="0.92"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Amount TextBox Style -->
        <Style x:Key="AmountTextBox" TargetType="TextBox">
            <Setter Property="Background" Value="#FFFFFF"/>
            <Setter Property="Foreground" Value="#0F172A"/>
            <Setter Property="BorderBrush" Value="#E2E8F0"/>
            <Setter Property="BorderThickness" Value="2"/>
            <Setter Property="FontSize" Value="24"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Height" Value="60"/>
            <Setter Property="Padding" Value="12,0,48,0"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="HorizontalContentAlignment" Value="Right"/>
            <Setter Property="CaretBrush" Value="#00288e"/>
            <Setter Property="SelectionBrush" Value="#DBEAFE"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TextBox">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="10">
                            <ScrollViewer x:Name="PART_ContentHost"
                                          Margin="{TemplateBinding Padding}"
                                          VerticalAlignment="{TemplateBinding VerticalContentAlignment}"
                                          HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsFocused" Value="True">
                                <Setter Property="BorderBrush" Value="#00288e"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </UserControl.Resources>

    <!-- Dark overlay background -->
    <Grid>
        <!-- Payment form — visible when not done -->
        <Grid>
            <Grid.Style>
                <Style TargetType="Grid">
                    <Setter Property="Visibility" Value="Visible"/>
                    <Style.Triggers>
                        <DataTrigger Binding="{Binding IsPaymentDone}" Value="True">
                            <Setter Property="Visibility" Value="Collapsed"/>
                        </DataTrigger>
                    </Style.Triggers>
                </Style>
            </Grid.Style>

            <!-- Centered modal card -->
            <Border Width="520"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Center"
                    Background="White"
                    CornerRadius="12"
                    Margin="16">
                <Border.Effect>
                    <DropShadowEffect BlurRadius="40" ShadowDepth="8" Opacity="0.35" Color="#000000"/>
                </Border.Effect>

                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <!-- Modal Header -->
                    <Border Grid.Row="0"
                            Background="#F4F2FC"
                            CornerRadius="12,12,0,0"
                            Padding="24,18">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>

                            <!-- Left: Icon + title -->
                            <StackPanel Grid.Column="0" Orientation="Horizontal">
                                <Border Width="40" Height="40"
                                        Background="{StaticResource SuccessLightBrush}"
                                        CornerRadius="20">
                                    <TextBlock Text="💵"
                                               FontSize="20"
                                               HorizontalAlignment="Center"
                                               VerticalAlignment="Center"/>
                                </Border>
                                <StackPanel Margin="12,0,0,0" VerticalAlignment="Center">
                                    <TextBlock Text="Thanh Toán Tiền Mặt"
                                               FontSize="17" FontWeight="Bold"
                                               Foreground="{StaticResource TextPrimaryBrush}"/>
                                    <TextBlock FontSize="12" Foreground="{StaticResource TextMutedBrush}" Margin="0,2,0,0">
                                        <Run Text="Tổng đơn hàng"/>
                                    </TextBlock>
                                </StackPanel>
                            </StackPanel>

                            <!-- Right: Total Amount -->
                            <StackPanel Grid.Column="1" HorizontalAlignment="Right" VerticalAlignment="Center">
                                <TextBlock Text="Tổng tiền"
                                           FontSize="11" Foreground="{StaticResource TextMutedBrush}"
                                           HorizontalAlignment="Right"/>
                                <TextBlock FontSize="22" FontWeight="Black" Foreground="{StaticResource TextPrimaryBrush}"
                                           HorizontalAlignment="Right">
                                    <Run Text="{Binding TotalAmount, StringFormat={}{0:N0}, Mode=OneWay}"/>
                                    <Run Text=" đ" FontSize="14" Foreground="{StaticResource TextMutedBrush}"/>
                                </TextBlock>
                            </StackPanel>
                        </Grid>
                    </Border>

                    <!-- Error bar: Visible by default, hidden when ErrorMessage is empty -->
                    <Border Grid.Row="1" Padding="20,10" Background="#FEF2F2">
                        <Border.Style>
                            <Style TargetType="Border">
                                <Setter Property="Visibility" Value="Visible"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding ErrorMessage}" Value="">
                                        <Setter Property="Visibility" Value="Collapsed"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Border.Style>
                        <TextBlock Text="{Binding ErrorMessage}"
                                   Foreground="#DC2626"
                                   FontSize="13"
                                   TextWrapping="Wrap"/>
                    </Border>

                    <!-- Modal Body -->
                    <StackPanel Grid.Row="2" Margin="24,20,24,0">

                        <!-- Amount Received input -->
                        <TextBlock Text="SỐ TIỀN KHÁCH ĐƯA"
                                   FontSize="11" FontWeight="SemiBold"
                                   Foreground="{StaticResource TextMutedBrush}"
                                   Margin="0,0,0,8"/>

                        <Grid>
                            <TextBox Style="{StaticResource AmountTextBox}"
                                     Text="{Binding AmountReceived, UpdateSourceTrigger=PropertyChanged}"
                                     IsEnabled="{Binding IsPaymentInputEnabled}"/>
                            <TextBlock Text="đ"
                                       FontSize="16" FontWeight="SemiBold"
                                       Foreground="{StaticResource TextMutedBrush}"
                                       HorizontalAlignment="Right"
                                       VerticalAlignment="Center"
                                       Margin="0,0,16,0"
                                       IsHitTestVisible="False"/>
                        </Grid>

                        <!-- Quick Cash Buttons -->
                        <UniformGrid Rows="1" Columns="5" Margin="0,16,0,0">
                            <Button Content="50K" Style="{StaticResource QuickCashButton}" Margin="0,0,6,0"
                                    Command="{Binding AddQuickCashCommand}" CommandParameter="50000"
                                    IsEnabled="{Binding IsPaymentInputEnabled}"/>
                            <Button Content="100K" Style="{StaticResource QuickCashButton}" Margin="0,0,6,0"
                                    Command="{Binding AddQuickCashCommand}" CommandParameter="100000"
                                    IsEnabled="{Binding IsPaymentInputEnabled}"/>
                            <Button Content="200K" Style="{StaticResource QuickCashButton}" Margin="0,0,6,0"
                                    Command="{Binding AddQuickCashCommand}" CommandParameter="200000"
                                    IsEnabled="{Binding IsPaymentInputEnabled}"/>
                            <Button Content="500K" Style="{StaticResource QuickCashButton}" Margin="0,0,6,0"
                                    Command="{Binding AddQuickCashCommand}" CommandParameter="500000"
                                    IsEnabled="{Binding IsPaymentInputEnabled}"/>
                            <Button Content="1M" Style="{StaticResource QuickCashButton}"
                                    Command="{Binding AddQuickCashCommand}" CommandParameter="1000000"
                                    IsEnabled="{Binding IsPaymentInputEnabled}"/>
                        </UniformGrid>

                        <StackPanel Margin="0,16,0,0">
                            <TextBlock Text="{Binding PaymentMethodMessage}"
                                       FontSize="12"
                                       Foreground="{StaticResource TextMutedBrush}"
                                       FontWeight="SemiBold"/>
                            <Border Margin="0,10,0,0"
                                    Background="#EFF6FF"
                                    BorderBrush="#BFDBFE"
                                    BorderThickness="1"
                                    CornerRadius="10"
                                    Padding="14"
                                    Visibility="{Binding HasPaymentUrl, Converter={StaticResource BoolToVis}}">
                                <StackPanel HorizontalAlignment="Center">
                                    <TextBlock Text="Quét mã QR để thanh toán VNPay"
                                               FontSize="12"
                                               FontWeight="SemiBold"
                                               Foreground="#1D4ED8"
                                               HorizontalAlignment="Center"/>
                                    <Border Background="White"
                                            BorderBrush="#DBEAFE"
                                            BorderThickness="1"
                                            CornerRadius="8"
                                            Padding="10"
                                            Margin="0,10,0,0">
                                        <Image Source="{Binding PaymentQrImage}"
                                               Width="220"
                                               Height="220"
                                               Stretch="Uniform"/>
                                    </Border>
                                </StackPanel>
                            </Border>
                            <Button Content="Tạo thanh toán VNPay"
                                    Margin="0,10,0,0"
                                    Background="#2563EB"
                                    Foreground="White"
                                    BorderThickness="0"
                                    Height="44"
                                    FontWeight="SemiBold"
                                    Cursor="Hand"
                                    Command="{Binding CreateVNPayCommand}"
                                    IsEnabled="{Binding CanCreateVNPay}"/>
                        </StackPanel>

                        <!-- Change Due card -->
                        <Border Margin="0,16,0,20"
                                Background="#F0FDF4"
                                BorderBrush="#BBF7D0"
                                BorderThickness="1"
                                CornerRadius="10"
                                Padding="20,16">
                            <StackPanel HorizontalAlignment="Center">
                                <TextBlock Text="TIỀN THỪA TRẢ KHÁCH"
                                           FontSize="11" FontWeight="Bold"
                                           Foreground="{StaticResource SuccessBrush}"
                                           HorizontalAlignment="Center"
                                           Margin="0,0,0,6"/>
                                <TextBlock HorizontalAlignment="Center"
                                           FontSize="28" FontWeight="Black"
                                           Foreground="{StaticResource SuccessBrush}">
                                    <Run Text="{Binding ChangeAmount, StringFormat={}{0:N0}, Mode=OneWay}"/>
                                    <Run Text=" đ" FontSize="16"/>
                                </TextBlock>
                                <TextBlock Text="{Binding ChangeHint}"
                                           FontSize="12" Foreground="{StaticResource TextMutedBrush}"
                                           FontStyle="Italic"
                                           HorizontalAlignment="Center"
                                           Margin="0,4,0,0"/>
                            </StackPanel>
                        </Border>
                    </StackPanel>

                    <!-- Modal Footer -->
                    <Border Grid.Row="3"
                            BorderBrush="{StaticResource BorderMediumBrush}"
                            BorderThickness="0,1,0,0"
                            Padding="24,16,24,20">
                        <StackPanel>
                            <Button Content="Xác nhận thanh toán"
                                    Style="{StaticResource ConfirmButton}"
                                    Command="{Binding ConfirmPaymentCommand}"
                                    IsEnabled="{Binding CanConfirmPayment}"/>
                            <Button Content="Hủy giao dịch"
                                    Margin="0,10,0,0"
                                    Background="Transparent"
                                    BorderThickness="0"
                                    Foreground="{StaticResource TextMutedBrush}"
                                    FontSize="13"
                                    Height="32"
                                    Cursor="Hand"
                                    Command="{Binding CancelCommand}"/>
                        </StackPanel>
                    </Border>
                </Grid>
            </Border>

            <!-- Loading overlay -->
            <Border Background="{StaticResource OverlayBrush}"
                    CornerRadius="12"
                    Width="520"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Center"
                    Visibility="{Binding IsLoading, Converter={StaticResource BoolToVis}}">
                <TextBlock Text="Đang xử lý..."
                           Foreground="White"
                           FontSize="16"
                           HorizontalAlignment="Center"
                           Padding="0,24"/>
            </Border>
        </Grid>

        <!-- Success panel -->
        <Grid>
            <Grid.Style>
                <Style TargetType="Grid">
                    <Setter Property="Visibility" Value="Collapsed"/>
                    <Style.Triggers>
                        <DataTrigger Binding="{Binding IsPaymentDone}" Value="True">
                            <Setter Property="Visibility" Value="Visible"/>
                        </DataTrigger>
                    </Style.Triggers>
                </Style>
            </Grid.Style>

            <Border Width="420"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Center"
                    Background="White"
                    CornerRadius="12"
                    Padding="48,40">
                <Border.Effect>
                    <DropShadowEffect BlurRadius="40" ShadowDepth="8" Opacity="0.35" Color="#000000"/>
                </Border.Effect>
                <StackPanel HorizontalAlignment="Center">
                    <Ellipse Width="80" Height="80"
                             Fill="#DCFCE7"
                             HorizontalAlignment="Center"
                             Margin="0,0,0,16"/>
                    <TextBlock Text="✓"
                               FontSize="40" Foreground="{StaticResource SuccessBrush}"
                               HorizontalAlignment="Center"
                               Margin="0,-68,0,24"/>
                    <TextBlock Text="Thanh toán thành công!"
                               FontSize="22" FontWeight="Bold"
                               Foreground="{StaticResource TextPrimaryBrush}"
                               HorizontalAlignment="Center"
                               Margin="0,0,0,8"/>
                    <TextBlock Text="Đơn hàng đã được xác nhận"
                               FontSize="14" Foreground="{StaticResource TextMutedBrush}"
                               HorizontalAlignment="Center"
                               Margin="0,0,0,32"/>
                    <Button Content="Quay lại bán hàng"
                            Style="{StaticResource ConfirmButton}"
                            Command="{Binding BackToSalesCommand}"
                            Width="220"/>
                    <Button Content="Xem hóa đơn"
                            Margin="0,10,0,0"
                            Background="Transparent"
                            BorderThickness="0"
                            Foreground="{StaticResource InfoBrush}"
                            FontSize="13"
                            Height="32"
                            Cursor="Hand"
                            Command="{Binding ShowInvoiceCommand}"/>
                </StackPanel>
            </Border>
        </Grid>
    </Grid>
</UserControl>
