<UserControl x:Class="SmartPOS.WPF.Views.PromotionDetailView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:SmartPOS.WPF.Views"
             xmlns:converters="clr-namespace:SmartPOS.WPF.Converters"
             xmlns:system="clr-namespace:System;assembly=mscorlib"
             mc:Ignorable="d" 
             Background="#121214"
             Foreground="#F3F4F6"
             d:DesignHeight="768" d:DesignWidth="1024">
    <UserControl.Resources>
        <converters:DateOnlyToDateTimeConverter x:Key="DateOnlyConverter" />
        <converters:BoolToVisibilityConverter x:Key="BoolToVis" />
        
        <Style TargetType="TextBox" x:Key="ModernTextBox">
            <Setter Property="Background" Value="#1E1E24"/>
            <Setter Property="Foreground" Value="#F3F4F6"/>
            <Setter Property="BorderBrush" Value="#374151"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="12,8"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TextBox">
                        <Border Background="{TemplateBinding Background}" 
                                BorderBrush="{TemplateBinding BorderBrush}" 
                                BorderThickness="{TemplateBinding BorderThickness}" 
                                CornerRadius="6">
                            <ScrollViewer x:Name="PART_ContentHost"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="ComboBox" x:Key="ModernComboBox">
            <Setter Property="Background" Value="#1E1E24"/>
            <Setter Property="Foreground" Value="#F3F4F6"/>
            <Setter Property="BorderBrush" Value="#374151"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="12,8"/>
            <Setter Property="FontSize" Value="14"/>
        </Style>

        <Style TargetType="Button" x:Key="BaseButton">
            <Setter Property="Padding" Value="16,10"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="6">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="Button" BasedOn="{StaticResource BaseButton}" x:Key="PrimaryButton">
            <Setter Property="Background" Value="#3B82F6"/>
        </Style>
        <Style TargetType="Button" BasedOn="{StaticResource BaseButton}" x:Key="DangerButton">
            <Setter Property="Background" Value="#EF4444"/>
        </Style>
        <Style TargetType="Button" BasedOn="{StaticResource BaseButton}" x:Key="SecondaryButton">
            <Setter Property="Background" Value="#4B5563"/>
        </Style>
    </UserControl.Resources>

    <Grid Margin="32">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" Text="CHI TIẾT KHUYẾN MÃI" FontSize="24" FontWeight="Bold" Margin="0,0,0,16"/>

        <StackPanel Grid.Row="1" Margin="0,0,0,12">
            <TextBlock Text="{Binding ErrorMessage}" Foreground="#EF4444" Visibility="Visible" TextWrapping="Wrap"/>
            <ProgressBar IsIndeterminate="True" Height="4" Margin="0,4,0,0" 
                         Visibility="{Binding IsLoading, Converter={StaticResource BoolToVis}}" 
                         Background="Transparent" Foreground="#3B82F6"/>
        </StackPanel>

        <ScrollViewer Grid.Row="2" VerticalScrollBarVisibility="Auto">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="32"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <!-- Left Column -->
                <!-- ID (Readonly) -->
                <StackPanel Grid.Row="0" Grid.Column="0" Margin="0,0,0,16">
                    <TextBlock Text="ID" Foreground="#9CA3AF" Margin="0,0,0,4"/>
                    <TextBox Text="{Binding Promotion.Id, Mode=OneWay}" IsReadOnly="True" Style="{StaticResource ModernTextBox}" Background="#2A2A35" Foreground="#6B7280"/>
                </StackPanel>

                <!-- Name -->
                <StackPanel Grid.Row="1" Grid.Column="0" Margin="0,0,0,16">
                    <TextBlock Text="Tên Khuyến Mãi" Foreground="#9CA3AF" Margin="0,0,0,4"/>
                    <TextBox Text="{Binding Promotion.Name}" Style="{StaticResource ModernTextBox}"/>
                </StackPanel>

                <!-- Type -->
                <StackPanel Grid.Row="2" Grid.Column="0" Margin="0,0,0,16">
                    <TextBlock Text="Loại" Foreground="#9CA3AF" Margin="0,0,0,4"/>
                    <ComboBox SelectedValue="{Binding Promotion.Type}" SelectedValuePath="Content" Style="{StaticResource ModernComboBox}">
                        <ComboBoxItem Content="Percentage" />
                        <ComboBoxItem Content="FixedAmount" />
                    </ComboBox>
                </StackPanel>

                <!-- Start Date -->
                <StackPanel Grid.Row="3" Grid.Column="0" Margin="0,0,0,16">
                    <TextBlock Text="Ngày Bắt Đầu" Foreground="#9CA3AF" Margin="0,0,0,4"/>
                    <DatePicker SelectedDate="{Binding Promotion.StartDate, Converter={StaticResource DateOnlyConverter}}" Height="38"/>
                </StackPanel>

                <!-- Min Order Amount -->
                <StackPanel Grid.Row="4" Grid.Column="0" Margin="0,0,0,16">
                    <TextBlock Text="Đơn Hàng Tối Thiểu (VNĐ)" Foreground="#9CA3AF" Margin="0,0,0,4"/>
                    <TextBox Text="{Binding Promotion.MinOrderAmount}" Style="{StaticResource ModernTextBox}"/>
                </StackPanel>

                <!-- Right Column -->
                <!-- Code -->
                <StackPanel Grid.Row="0" Grid.Column="2" Margin="0,0,0,16">
                    <TextBlock Text="Mã (Code)" Foreground="#9CA3AF" Margin="0,0,0,4"/>
                    <TextBox Text="{Binding Promotion.Code}" Style="{StaticResource ModernTextBox}"/>
                </StackPanel>

                <!-- Description -->
                <StackPanel Grid.Row="1" Grid.Column="2" Margin="0,0,0,16">
                    <TextBlock Text="Mô tả" Foreground="#9CA3AF" Margin="0,0,0,4"/>
                    <TextBox Text="{Binding Promotion.Description}" Style="{StaticResource ModernTextBox}"/>
                </StackPanel>

                <!-- Discount Value -->
                <StackPanel Grid.Row="2" Grid.Column="2" Margin="0,0,0,16">
                    <TextBlock Text="Giá Trị Giảm" Foreground="#9CA3AF" Margin="0,0,0,4"/>
                    <TextBox Text="{Binding Promotion.DiscountValue}" Style="{StaticResource ModernTextBox}"/>
                </StackPanel>

                <!-- End Date -->
                <StackPanel Grid.Row="3" Grid.Column="2" Margin="0,0,0,16">
                    <TextBlock Text="Ngày Kết Thúc" Foreground="#9CA3AF" Margin="0,0,0,4"/>
                    <DatePicker SelectedDate="{Binding Promotion.EndDate, Converter={StaticResource DateOnlyConverter}}" Height="38"/>
                </StackPanel>

                <!-- IsActive -->
                <StackPanel Grid.Row="4" Grid.Column="2" Margin="0,0,0,16" Orientation="Horizontal">
                    <CheckBox IsChecked="{Binding Promotion.IsActive}" VerticalAlignment="Center" Margin="0,0,8,0"/>
                    <TextBlock Text="Trạng thái kích hoạt (Active)" Foreground="#F3F4F6" VerticalAlignment="Center"/>
                </StackPanel>
            </Grid>
        </ScrollViewer>

        <!-- Action Buttons -->
        <Border Grid.Row="3" BorderBrush="#2D2D35" BorderThickness="0,1,0,0" Padding="0,16,0,0" Margin="0,16,0,0">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <Button Grid.Column="0" Content="← Trở Về" Style="{StaticResource SecondaryButton}" Command="{Binding ReturnCommand}"/>
                <Button Grid.Column="2" Content="Xóa" Style="{StaticResource DangerButton}" Margin="0,0,16,0" Command="{Binding DeleteCommand}"/>
                <Button Grid.Column="3" Content="Cập Nhật" Style="{StaticResource PrimaryButton}" Command="{Binding UpdateCommand}"/>
            </Grid>
        </Border>
    </Grid>
</UserControl>
