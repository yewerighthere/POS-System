<UserControl x:Class="SmartPOS.WPF.Views.PromotionView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:viewmodels="clr-namespace:SmartPOS.WPF.ViewModels"
             xmlns:converters="clr-namespace:SmartPOS.WPF.Converters"
             mc:Ignorable="d" 
             d:DataContext="{d:DesignInstance Type=viewmodels:PromotionViewModel}"
             Background="#F8FAFC">

    <UserControl.Resources>
        <converters:NullOrEmptyToVisibilityConverter x:Key="NullOrEmptyToVisibilityConverter"/>
        <BooleanToVisibilityConverter x:Key="BoolToVis"/>

        <Style x:Key="PrimaryBtn" TargetType="Button">
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="16,10"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="8" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="OutlineBtn" TargetType="Button">
            <Setter Property="Background" Value="White"/>
            <Setter Property="Foreground" Value="#00288E"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="BorderBrush" Value="#00288E"/>
            <Setter Property="Padding" Value="16,10"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}" CornerRadius="8" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </UserControl.Resources>

    <Grid Background="#F8FAFC">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Error & Success bar -->
        <StackPanel Grid.Row="0" Margin="24,12,24,0">
            <Border Background="#FEF2F2" BorderBrush="#FCA5A5" BorderThickness="1" CornerRadius="8" Padding="16,12" Margin="0,0,0,12"
                    Visibility="{Binding ErrorMessage, Converter={StaticResource NullOrEmptyToVisibilityConverter}, FallbackValue=Collapsed}">
                <TextBlock Text="{Binding ErrorMessage}" Foreground="#991B1B" FontSize="13" TextWrapping="Wrap"/>
            </Border>
            <Border Background="#F0FDF4" BorderBrush="#86EFAC" BorderThickness="1" CornerRadius="8" Padding="16,12" Margin="0,0,0,12"
                    Visibility="{Binding SuccessMessage, Converter={StaticResource NullOrEmptyToVisibilityConverter}, FallbackValue=Collapsed}">
                <TextBlock Text="{Binding SuccessMessage}" Foreground="#166534" FontSize="13" TextWrapping="Wrap"/>
            </Border>
        </StackPanel>

        <!-- Page header -->
        <Grid Grid.Row="1" Margin="24,8,24,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <StackPanel Grid.Column="0">
                <TextBlock Text="Promotions" FontSize="22" FontWeight="Bold" Foreground="#0F172A"/>
                <TextBlock Text="Quản lý mã giảm giá &amp; chương trình khuyến mãi" Foreground="#64748B" FontSize="12" Margin="0,4,0,0"/>
            </StackPanel>
            <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Bottom">
                <Button Content="↻  Tải lại" Command="{Binding LoadCommand}" Style="{StaticResource OutlineBtn}" Margin="0,0,10,0"/>
                <Button Content="＋  Thêm khuyến mãi" Command="{Binding ToggleAddPromotionCommand}" Style="{StaticResource PrimaryBtn}" Background="#00288E"/>
            </StackPanel>
        </Grid>

        <!-- Workspace -->
        <Grid Grid.Row="2" Margin="24,16,24,24">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- Add Promotion form (toggle) -->
            <Border Grid.Row="0" Background="White" BorderBrush="#E2E8F0" BorderThickness="1"
                    CornerRadius="12" Padding="20" Margin="0,0,0,12"
                    Visibility="{Binding IsAddPromotionVisible, Converter={StaticResource BoolToVis}}">
                <StackPanel>
                    <TextBlock Text="Tạo chương trình khuyến mãi mới" FontWeight="SemiBold" FontSize="14" Foreground="#0F172A" Margin="0,0,0,14"/>

                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="140"/>
                            <ColumnDefinition Width="200"/>
                            <ColumnDefinition Width="140"/>
                            <ColumnDefinition Width="140"/>
                            <ColumnDefinition Width="140"/>
                            <ColumnDefinition Width="140"/>
                            <ColumnDefinition Width="140"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        
                        <!-- Labels -->
                        <TextBlock Grid.Row="0" Grid.Column="0" Text="Mã (Code) *" FontSize="11" Foreground="#64748B" Margin="0,0,8,4"/>
                        <TextBlock Grid.Row="0" Grid.Column="1" Text="Tên chương trình *" FontSize="11" Foreground="#64748B" Margin="0,0,8,4"/>
                        <TextBlock Grid.Row="0" Grid.Column="2" Text="Loại" FontSize="11" Foreground="#64748B" Margin="0,0,8,4"/>
                        <TextBlock Grid.Row="0" Grid.Column="3" Text="Mức giảm *" FontSize="11" Foreground="#64748B" Margin="0,0,8,4"/>
                        <TextBlock Grid.Row="0" Grid.Column="4" Text="Đơn tối thiểu" FontSize="11" Foreground="#64748B" Margin="0,0,8,4"/>
                        <TextBlock Grid.Row="0" Grid.Column="5" Text="Từ ngày" FontSize="11" Foreground="#64748B" Margin="0,0,8,4"/>
                        <TextBlock Grid.Row="0" Grid.Column="6" Text="Đến ngày" FontSize="11" Foreground="#64748B" Margin="0,0,8,4"/>

                        <!-- Inputs -->
                        <TextBox Grid.Row="1" Grid.Column="0" Text="{Binding NewCode, UpdateSourceTrigger=PropertyChanged}" Padding="10,8" BorderBrush="#E2E8F0" BorderThickness="1" Margin="0,0,8,0" FontSize="13"/>
                        <TextBox Grid.Row="1" Grid.Column="1" Text="{Binding NewName, UpdateSourceTrigger=PropertyChanged}" Padding="10,8" BorderBrush="#E2E8F0" BorderThickness="1" Margin="0,0,8,0" FontSize="13"/>
                        <ComboBox Grid.Row="1" Grid.Column="2" SelectedValue="{Binding NewType, UpdateSourceTrigger=PropertyChanged}" SelectedValuePath="Content" Padding="10,8" BorderBrush="#E2E8F0" BorderThickness="1" Margin="0,0,8,0" FontSize="13">
                            <ComboBoxItem Content="Percentage"/>
                            <ComboBoxItem Content="FixedAmount"/>
                        </ComboBox>
                        <TextBox Grid.Row="1" Grid.Column="3" Text="{Binding NewDiscountValue, UpdateSourceTrigger=PropertyChanged}" Padding="10,8" BorderBrush="#E2E8F0" BorderThickness="1" Margin="0,0,8,0" FontSize="13"/>
                        <TextBox Grid.Row="1" Grid.Column="4" Text="{Binding NewMinOrderAmount, UpdateSourceTrigger=PropertyChanged}" Padding="10,8" BorderBrush="#E2E8F0" BorderThickness="1" Margin="0,0,8,0" FontSize="13"/>
                        <DatePicker Grid.Row="1" Grid.Column="5" SelectedDate="{Binding NewStartDate}" Padding="10,6" BorderBrush="#E2E8F0" BorderThickness="1" Margin="0,0,8,0" FontSize="13"/>
                        <DatePicker Grid.Row="1" Grid.Column="6" SelectedDate="{Binding NewEndDate}" Padding="10,6" BorderBrush="#E2E8F0" BorderThickness="1" Margin="0,0,8,0" FontSize="13"/>
                        
                        <!-- Submit button -->
                        <Button Grid.Row="1" Grid.Column="7" Content="Lưu" Command="{Binding AddPromotionCommand}" Style="{StaticResource PrimaryBtn}" Background="#2563EB" HorizontalAlignment="Right" Padding="24,8"/>
                    </Grid>
                </StackPanel>
            </Border>

            <!-- Filter bar -->
            <Border Grid.Row="1" Background="White" BorderBrush="#E2E8F0" BorderThickness="1" CornerRadius="12" Padding="16,12" Margin="0,0,0,12">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <Border Grid.Column="0" BorderBrush="#E2E8F0" BorderThickness="1" CornerRadius="8" Padding="10,0" Margin="0,0,12,0">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="🔍" FontSize="14" Foreground="#64748B" VerticalAlignment="Center" Margin="0,0,8,0"/>
                            <TextBox Grid.Column="1" Text="{Binding SearchQuery, UpdateSourceTrigger=PropertyChanged}" Background="Transparent" BorderThickness="0" FontSize="13" Foreground="#0F172A" VerticalAlignment="Center" Padding="0,8"/>
                        </Grid>
                    </Border>

                    <StackPanel Grid.Column="1" Margin="0,0,12,0">
                        <TextBlock Text="LOẠI (TYPE)" FontSize="10" FontWeight="Bold" Foreground="#64748B" Margin="0,0,0,4"/>
                        <ComboBox ItemsSource="{Binding TypeOptions}" SelectedItem="{Binding TypeFilter}" FontSize="13" MinWidth="160" Padding="8,6" BorderBrush="#E2E8F0"/>
                    </StackPanel>

                    <StackPanel Grid.Column="2" Margin="0,0,16,0">
                        <TextBlock Text="TRẠNG THÁI" FontSize="10" FontWeight="Bold" Foreground="#64748B" Margin="0,0,0,4"/>
                        <ComboBox ItemsSource="{Binding StatusOptions}" SelectedItem="{Binding StatusFilter}" FontSize="13" MinWidth="140" Padding="8,6" BorderBrush="#E2E8F0"/>
                    </StackPanel>

                    <TextBlock Grid.Column="3" VerticalAlignment="Bottom" Margin="0,0,0,6">
                        <Run Text="Hiển thị " Foreground="#64748B" FontSize="13"/>
                        <Run Text="{Binding FilteredCount, Mode=OneWay}" Foreground="#0F172A" FontWeight="Bold" FontSize="13"/>
                        <Run Text=" kết quả" Foreground="#64748B" FontSize="13"/>
                    </TextBlock>
                </Grid>
            </Border>

            <!-- Table -->
            <Border Grid.Row="2" Background="White" BorderBrush="#E2E8F0" BorderThickness="1" CornerRadius="12" ClipToBounds="True">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <!-- Table header -->
                    <Border Grid.Row="0" Background="#F4F2FC" BorderBrush="#E2E8F0" BorderThickness="0,0,0,1">
                        <Grid Margin="16,12">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="140"/>
                                <ColumnDefinition Width="2*"/>
                                <ColumnDefinition Width="100"/>
                                <ColumnDefinition Width="120"/>
                                <ColumnDefinition Width="120"/>
                                <ColumnDefinition Width="200"/>
                                <ColumnDefinition Width="100"/>
                                <ColumnDefinition Width="120"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="CODE" FontSize="11" FontWeight="Bold" Foreground="#64748B"/>
                            <TextBlock Grid.Column="1" Text="TÊN CHƯƠNG TRÌNH" FontSize="11" FontWeight="Bold" Foreground="#64748B"/>
                            <TextBlock Grid.Column="2" Text="LOẠI" FontSize="11" FontWeight="Bold" Foreground="#64748B"/>
                            <TextBlock Grid.Column="3" Text="MỨC GIẢM" FontSize="11" FontWeight="Bold" Foreground="#64748B" TextAlignment="Right" Margin="0,0,16,0"/>
                            <TextBlock Grid.Column="4" Text="ĐƠN TỐI THIỂU" FontSize="11" FontWeight="Bold" Foreground="#64748B" TextAlignment="Right" Margin="0,0,16,0"/>
                            <TextBlock Grid.Column="5" Text="THỜI GIAN" FontSize="11" FontWeight="Bold" Foreground="#64748B" Margin="12,0,0,0"/>
                            <TextBlock Grid.Column="6" Text="TRẠNG THÁI" FontSize="11" FontWeight="Bold" Foreground="#64748B"/>
                            <TextBlock Grid.Column="7" Text="THAO TÁC" FontSize="11" FontWeight="Bold" Foreground="#64748B" TextAlignment="Center"/>
                        </Grid>
                    </Border>

                    <!-- Table rows -->
                    <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                        <ItemsControl ItemsSource="{Binding FilteredPromotions}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border BorderBrush="#E2E8F0" BorderThickness="0,0,0,1">
                                        <Border.Style>
                                            <Style TargetType="Border">
                                                <Setter Property="Background" Value="White"/>
                                                <Style.Triggers>
                                                    <Trigger Property="IsMouseOver" Value="True">
                                                        <Setter Property="Background" Value="#F8FAFC"/>
                                                    </Trigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Border.Style>
                                        <Grid Margin="16,0" Height="56">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="140"/>
                                                <ColumnDefinition Width="2*"/>
                                                <ColumnDefinition Width="100"/>
                                                <ColumnDefinition Width="120"/>
                                                <ColumnDefinition Width="120"/>
                                                <ColumnDefinition Width="200"/>
                                                <ColumnDefinition Width="100"/>
                                                <ColumnDefinition Width="120"/>
                                            </Grid.ColumnDefinitions>

                                            <!-- Code -->
                                            <TextBlock Grid.Column="0" Text="{Binding Code}" FontWeight="Bold" FontSize="13" FontFamily="Consolas" Foreground="#00288E" VerticalAlignment="Center"/>
                                            
                                            <!-- Name -->
                                            <TextBlock Grid.Column="1" Text="{Binding Name}" FontSize="13" Foreground="#0F172A" VerticalAlignment="Center" TextWrapping="Wrap"/>

                                            <!-- Type -->
                                            <Border Grid.Column="2" VerticalAlignment="Center" HorizontalAlignment="Left" CornerRadius="4" Padding="6,2" Background="#F1F5F9">
                                                <TextBlock Text="{Binding Type}" FontSize="11" Foreground="#475569"/>
                                            </Border>

                                            <!-- Discount Value -->
                                            <TextBlock Grid.Column="3" Text="{Binding DiscountValue, StringFormat='{}{0:N0}'}" FontWeight="SemiBold" FontSize="13" Foreground="#0F172A" TextAlignment="Right" VerticalAlignment="Center" Margin="0,0,16,0"/>

                                            <!-- Min Order Amount -->
                                            <TextBlock Grid.Column="4" Text="{Binding MinOrderAmount, StringFormat='{}{0:N0}'}" FontSize="13" Foreground="#64748B" TextAlignment="Right" VerticalAlignment="Center" Margin="0,0,16,0"/>

                                            <!-- Dates -->
                                            <TextBlock Grid.Column="5" FontSize="12" Foreground="#475569" VerticalAlignment="Center" Margin="12,0,0,0">
                                                <Run Text="{Binding StartDate, StringFormat='{}{0:dd/MM/yyyy}'}"/>
                                                <Run Text=" - "/>
                                                <Run Text="{Binding EndDate, StringFormat='{}{0:dd/MM/yyyy}'}"/>
                                            </TextBlock>

                                            <!-- Status badge -->
                                            <Border Grid.Column="6" VerticalAlignment="Center" CornerRadius="12" Padding="8,3" HorizontalAlignment="Left">
                                                <Border.Style>
                                                    <Style TargetType="Border">
                                                        <Setter Property="Background" Value="#DCFCE7"/>
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding IsActive}" Value="False">
                                                                <Setter Property="Background" Value="#FEE2E2"/>
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </Border.Style>
                                                <TextBlock FontSize="10" FontWeight="Bold">
                                                    <TextBlock.Style>
                                                        <Style TargetType="TextBlock">
                                                            <Setter Property="Foreground" Value="#16A34A"/>
                                                            <Setter Property="Text" Value="Active"/>
                                                            <Style.Triggers>
                                                                <DataTrigger Binding="{Binding IsActive}" Value="False">
                                                                    <Setter Property="Foreground" Value="#DC2626"/>
                                                                    <Setter Property="Text" Value="Inactive"/>
                                                                </DataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </TextBlock.Style>
                                                </TextBlock>
                                            </Border>

                                            <!-- Actions -->
                                            <Grid Grid.Column="7" HorizontalAlignment="Center" VerticalAlignment="Center">
                                                <Button Content="Tạm dừng" Command="{Binding DataContext.DeactivatePromotionCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}" CommandParameter="{Binding Id}" Foreground="#DC2626" BorderBrush="#FCA5A5" Padding="12,4" FontSize="11">
                                                    <Button.Style>
                                                        <Style TargetType="Button" BasedOn="{StaticResource OutlineBtn}">
                                                            <Setter Property="Visibility" Value="Collapsed"/>
                                                            <Style.Triggers>
                                                                <DataTrigger Binding="{Binding IsActive}" Value="True">
                                                                    <Setter Property="Visibility" Value="Visible"/>
                                                                </DataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </Button.Style>
                                                </Button>
                                                <Button Content="Kích hoạt" Command="{Binding DataContext.ReactivatePromotionCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}" CommandParameter="{Binding Id}" Background="#16A34A" Padding="12,4" FontSize="11">
                                                    <Button.Style>
                                                        <Style TargetType="Button" BasedOn="{StaticResource PrimaryBtn}">
                                                            <Setter Property="Visibility" Value="Collapsed"/>
                                                            <Style.Triggers>
                                                                <DataTrigger Binding="{Binding IsActive}" Value="False">
                                                                    <Setter Property="Visibility" Value="Visible"/>
                                                                </DataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </Button.Style>
                                                </Button>
                                            </Grid>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ScrollViewer>
                </Grid>
            </Border>
        </Grid>
    </Grid>
</UserControl>
