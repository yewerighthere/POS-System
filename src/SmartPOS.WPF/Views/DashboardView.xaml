<UserControl x:Class="SmartPOS.WPF.Views.DashboardView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:SmartPOS.WPF.Views"
             xmlns:viewmodels="clr-namespace:SmartPOS.WPF.ViewModels"
             mc:Ignorable="d" 
             d:DataContext="{d:DesignInstance Type=viewmodels:DashboardViewModel}"
             Background="#F3F4F6"
             Foreground="#111827"
             d:DesignHeight="768" d:DesignWidth="1024">

    <UserControl.Resources>
        <BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter" />

        <Style x:Key="SidebarButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="#9CA3AF"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="16,12"/>
            <Setter Property="Margin" Value="8,4"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="HorizontalContentAlignment" Value="Left"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Name="Border" CornerRadius="8" Background="{TemplateBinding Background}" Padding="{TemplateBinding Padding}">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="{TemplateBinding Tag}" Margin="0,0,12,0" FontSize="16" VerticalAlignment="Center"/>
                                <ContentPresenter VerticalAlignment="Center"/>
                            </StackPanel>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Border" Property="Background" Value="#374151"/>
                                <Setter Property="Foreground" Value="White"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        
        <Style x:Key="SidebarActiveButtonStyle" TargetType="Button" BasedOn="{StaticResource SidebarButtonStyle}">
            <Setter Property="Background" Value="#6366F1"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Name="Border" CornerRadius="8" Background="{TemplateBinding Background}" Padding="{TemplateBinding Padding}">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="{TemplateBinding Tag}" Margin="0,0,12,0" FontSize="16" VerticalAlignment="Center"/>
                                <ContentPresenter VerticalAlignment="Center"/>
                            </StackPanel>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="KpiCardStyle" TargetType="Border">
            <Setter Property="Background" Value="White"/>
            <Setter Property="CornerRadius" Value="12"/>
            <Setter Property="Padding" Value="20"/>
            <Setter Property="Margin" Value="0,0,16,0"/>
            <Setter Property="BorderBrush" Value="#E5E7EB"/>
            <Setter Property="BorderThickness" Value="1"/>
        </Style>
    </UserControl.Resources>

    <Grid>
        <Grid.ColumnDefinitions>
            <!-- Sidebar -->
            <ColumnDefinition Width="240"/>
            <!-- Main Content -->
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- SIDEBAR -->
        <Border Grid.Column="0" Background="#111827">
            <Grid Margin="0,24,0,24">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <StackPanel Grid.Row="0" Margin="20,0,20,32">
                    <TextBlock Text="SmartPOS" Foreground="White" FontSize="20" FontWeight="Black"/>
                    <TextBlock Text="Backoffice" Foreground="#6366F1" FontSize="14" FontWeight="Bold" Margin="0,2,0,0"/>
                </StackPanel>

                <StackPanel Grid.Row="1">
                    <Button Style="{StaticResource SidebarActiveButtonStyle}" Tag="📊" Content="Overview"/>
                    <Button Style="{StaticResource SidebarButtonStyle}" Tag="🗂️" Content="Catalog &amp; Promo" Command="{Binding NavigateToCatalogCommand}"/>
                    <Button Style="{StaticResource SidebarButtonStyle}" Tag="📦" Content="Inventory"/>
                    <Button Style="{StaticResource SidebarButtonStyle}" Tag="👥" Content="Users &amp; Staff"/>
                    <Button Style="{StaticResource SidebarButtonStyle}" Tag="📈" Content="Reports &amp; Analytics"/>
                    <Button Style="{StaticResource SidebarButtonStyle}" Tag="⚙️" Content="Settings"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- MAIN CONTENT -->
        <Grid Grid.Column="1">
            <Grid.RowDefinitions>
                <RowDefinition Height="70"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- HEADER -->
            <Border Grid.Row="0" Background="White" BorderBrush="#E5E7EB" BorderThickness="0,0,0,1" Padding="24,0">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <TextBlock Grid.Column="0" Text="SMART STORE | BACKOFFICE" Foreground="#111827" FontSize="18" FontWeight="Black" VerticalAlignment="Center"/>

                    <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                        <Button Content="Switch to POS" Command="{Binding SwitchToPosCommand}" Background="#F3F4F6" Foreground="#4F46E5" FontWeight="Bold" BorderThickness="0" Padding="16,8" Cursor="Hand" Margin="0,0,20,0">
                            <Button.Resources>
                                <Style TargetType="Border">
                                    <Setter Property="CornerRadius" Value="6"/>
                                </Style>
                            </Button.Resources>
                        </Button>
                        
                        <Border Background="#F9FAFB" BorderBrush="#E5E7EB" BorderThickness="1" CornerRadius="20" Padding="12,4" Margin="0,0,16,0">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="{Binding CurrentUserName}" FontWeight="SemiBold" VerticalAlignment="Center" Margin="0,0,8,0"/>
                                <Border CornerRadius="12" Padding="8,2">
                                    <Border.Style>
                                        <Style TargetType="Border">
                                            <Setter Property="Background" Value="#FEE2E2"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding CurrentUserRole}" Value="Manager">
                                                    <Setter Property="Background" Value="#FEF3C7"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Border.Style>
                                    <TextBlock Text="{Binding CurrentUserRole}" FontSize="11" FontWeight="Bold">
                                        <TextBlock.Style>
                                            <Style TargetType="TextBlock">
                                                <Setter Property="Foreground" Value="#991B1B"/>
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding CurrentUserRole}" Value="Manager">
                                                        <Setter Property="Foreground" Value="#B45309"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </TextBlock.Style>
                                    </TextBlock>
                                </Border>
                            </StackPanel>
                        </Border>

                        <Button Content="Logout" Command="{Binding LogoutCommand}" Background="Transparent" Foreground="#6B7280" FontWeight="SemiBold" BorderThickness="0" Cursor="Hand"/>
                    </StackPanel>
                </Grid>
            </Border>

            <!-- DASHBOARD CONTENT -->
            <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                <Grid Margin="24">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/> <!-- KPIs -->
                        <RowDefinition Height="Auto"/> <!-- Charts -->
                        <RowDefinition Height="Auto"/> <!-- Lists -->
                    </Grid.RowDefinitions>

                    <!-- Loading Indicator -->
                    <ProgressBar IsIndeterminate="True" Height="4" VerticalAlignment="Top" Background="Transparent" Foreground="#6366F1" Visibility="{Binding IsLoading, Converter={StaticResource BooleanToVisibilityConverter}, FallbackValue=Collapsed}" Margin="0,-24,0,20"/>
                    
                    <TextBlock Text="{Binding ErrorMessage}" Foreground="Red" Visibility="{Binding ErrorMessage, Converter={StaticResource BooleanToVisibilityConverter}, FallbackValue=Collapsed}" Margin="0,0,0,16"/>

                    <!-- ROW 1: KPIs -->
                    <Grid Grid.Row="0" Margin="0,0,-16,24">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <!-- Revenue -->
                        <Border Grid.Column="0" Style="{StaticResource KpiCardStyle}">
                            <StackPanel>
                                <TextBlock Text="Today's Revenue" Foreground="#6B7280" FontSize="13" FontWeight="SemiBold"/>
                                <TextBlock Text="{Binding Overview.TodayRevenue, StringFormat='{}{0:N0} ₫'}" Foreground="#111827" FontSize="24" FontWeight="Black" Margin="0,8,0,0"/>
                                <TextBlock Text="+12% from yesterday" Foreground="#10B981" FontSize="12" Margin="0,4,0,0"/>
                            </StackPanel>
                        </Border>

                        <!-- Orders -->
                        <Border Grid.Column="1" Style="{StaticResource KpiCardStyle}">
                            <StackPanel>
                                <TextBlock Text="Total Orders" Foreground="#6B7280" FontSize="13" FontWeight="SemiBold"/>
                                <TextBlock Text="{Binding Overview.TotalOrders}" Foreground="#111827" FontSize="24" FontWeight="Black" Margin="0,8,0,0"/>
                                <TextBlock Text="+5% from yesterday" Foreground="#10B981" FontSize="12" Margin="0,4,0,0"/>
                            </StackPanel>
                        </Border>

                        <!-- Customers -->
                        <Border Grid.Column="2" Style="{StaticResource KpiCardStyle}">
                            <StackPanel>
                                <TextBlock Text="New Customers" Foreground="#6B7280" FontSize="13" FontWeight="SemiBold"/>
                                <TextBlock Text="{Binding Overview.NewCustomers}" Foreground="#111827" FontSize="24" FontWeight="Black" Margin="0,8,0,0"/>
                                <TextBlock Text="Steady growth" Foreground="#6B7280" FontSize="12" Margin="0,4,0,0"/>
                            </StackPanel>
                        </Border>

                        <!-- Alerts -->
                        <Border Grid.Column="3" Style="{StaticResource KpiCardStyle}">
                            <StackPanel>
                                <TextBlock Text="Inventory Alerts" Foreground="#6B7280" FontSize="13" FontWeight="SemiBold"/>
                                <TextBlock Text="{Binding Overview.InventoryAlerts}" Foreground="#DC2626" FontSize="24" FontWeight="Black" Margin="0,8,0,0"/>
                                <TextBlock Text="Items low on stock" Foreground="#EF4444" FontSize="12" Margin="0,4,0,0"/>
                            </StackPanel>
                        </Border>
                    </Grid>

                    <!-- ROW 2: CHARTS (Simulated with WPF standard controls) -->
                    <Grid Grid.Row="1" Margin="0,0,0,24">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="2*"/>
                            <ColumnDefinition Width="1*"/>
                        </Grid.ColumnDefinitions>

                        <!-- 7-Day Revenue Chart (Bar Chart Simulation) -->
                        <Border Grid.Column="0" Background="White" CornerRadius="12" Padding="20" Margin="0,0,24,0" BorderBrush="#E5E7EB" BorderThickness="1">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="250"/>
                                </Grid.RowDefinitions>
                                <TextBlock Grid.Row="0" Text="Revenue (Last 7 Days)" FontWeight="Bold" FontSize="16" Margin="0,0,0,16"/>
                                
                                <!-- Bar Chart -->
                                <ItemsControl Grid.Row="1" ItemsSource="{Binding Overview.Revenue7Days}" VerticalAlignment="Stretch">
                                    <ItemsControl.ItemsPanel>
                                        <ItemsPanelTemplate>
                                            <UniformGrid Rows="1" />
                                        </ItemsPanelTemplate>
                                    </ItemsControl.ItemsPanel>
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Grid Margin="8,0">
                                                <Grid.RowDefinitions>
                                                    <RowDefinition Height="*"/>
                                                    <RowDefinition Height="Auto"/>
                                                </Grid.RowDefinitions>
                                                <!-- The Bar -->
                                                <Border Grid.Row="0" Background="#6366F1" CornerRadius="4,4,0,0" VerticalAlignment="Bottom" ToolTip="{Binding Value}">
                                                    <!-- Simple height binding simulation: We could write a converter, but let's just make it fill for now and use Margin to push it down or use a converter. Since we can't easily write a converter without modifying a .cs file, I will just give a fixed max height and use a basic visual. -->
                                                    <!-- For this demo, let's just show a simple bar that's at least visible. -->
                                                    <Border.Height>
                                                        <!-- A simple hack to show varied height without a converter: we just bind to Value directly, scaled down. e.g. 20000 -> 200 -->
                                                        <!-- Actually Binding cannot divide without converter. So I'll just rely on a standard height and label -->
                                                        150 
                                                    </Border.Height>
                                                    <TextBlock Text="{Binding Value, StringFormat='{}{0:N0}'}" Foreground="White" FontSize="10" HorizontalAlignment="Center" Margin="0,4,0,0"/>
                                                </Border>
                                                <TextBlock Grid.Row="1" Text="{Binding Date}" HorizontalAlignment="Center" Margin="0,8,0,0" Foreground="#6B7280" FontSize="12"/>
                                            </Grid>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </Grid>
                        </Border>

                        <!-- Top Categories (Pie/List Simulation) -->
                        <Border Grid.Column="1" Background="White" CornerRadius="12" Padding="20" BorderBrush="#E5E7EB" BorderThickness="1">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="*"/>
                                </Grid.RowDefinitions>
                                <TextBlock Grid.Row="0" Text="Top Categories" FontWeight="Bold" FontSize="16" Margin="0,0,0,16"/>
                                
                                <ItemsControl Grid.Row="1" ItemsSource="{Binding Overview.TopCategories}">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Grid Margin="0,0,0,16">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="Auto"/>
                                                </Grid.ColumnDefinitions>
                                                <Grid.RowDefinitions>
                                                    <RowDefinition Height="Auto"/>
                                                    <RowDefinition Height="Auto"/>
                                                </Grid.RowDefinitions>
                                                
                                                <TextBlock Grid.Row="0" Grid.Column="0" Text="{Binding CategoryName}" FontWeight="Medium" FontSize="13"/>
                                                <TextBlock Grid.Row="0" Grid.Column="1" Text="{Binding Percentage, StringFormat='{}{0}%'}" FontWeight="Bold" FontSize="13" Foreground="#4F46E5"/>
                                                
                                                <!-- Progress Bar Simulation -->
                                                <Border Grid.Row="1" Grid.ColumnSpan="2" Background="#F3F4F6" Height="6" CornerRadius="3" Margin="0,8,0,0">
                                                    <Border Background="#4F46E5" CornerRadius="3" HorizontalAlignment="Left" Width="{Binding Percentage, ConverterParameter=2, StringFormat='{}{0}'}"/> <!-- Using Width to mock percentage visually loosely if possible -->
                                                </Border>
                                            </Grid>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </Grid>
                        </Border>
                    </Grid>

                    <!-- ROW 3: LISTS -->
                    <Grid Grid.Row="2">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="1*"/>
                            <ColumnDefinition Width="1*"/>
                        </Grid.ColumnDefinitions>

                        <!-- Recent Transactions -->
                        <Border Grid.Column="0" Background="White" CornerRadius="12" Padding="20" Margin="0,0,24,0" BorderBrush="#E5E7EB" BorderThickness="1">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="*"/>
                                </Grid.RowDefinitions>
                                <TextBlock Grid.Row="0" Text="Recent Transactions" FontWeight="Bold" FontSize="16" Margin="0,0,0,16"/>
                                
                                <ItemsControl Grid.Row="1" ItemsSource="{Binding Overview.RecentTransactions}">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Border BorderBrush="#F3F4F6" BorderThickness="0,0,0,1" Padding="0,12">
                                                <Grid>
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="*"/>
                                                        <ColumnDefinition Width="Auto"/>
                                                    </Grid.ColumnDefinitions>
                                                    <StackPanel Grid.Column="0">
                                                        <TextBlock Text="{Binding OrderId}" FontWeight="Bold" FontSize="14" Foreground="#111827"/>
                                                        <TextBlock Text="{Binding Time}" FontSize="12" Foreground="#6B7280" Margin="0,2,0,0"/>
                                                    </StackPanel>
                                                    <StackPanel Grid.Column="1" HorizontalAlignment="Right">
                                                        <TextBlock Text="{Binding Amount, StringFormat='{}{0:N0} ₫'}" FontWeight="Bold" FontSize="14" Foreground="#10B981" HorizontalAlignment="Right"/>
                                                        <Border Background="#D1FAE5" CornerRadius="4" Padding="6,2" Margin="0,4,0,0" HorizontalAlignment="Right">
                                                            <TextBlock Text="{Binding Status}" FontSize="10" Foreground="#065F46" FontWeight="SemiBold"/>
                                                        </Border>
                                                    </StackPanel>
                                                </Grid>
                                            </Border>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </Grid>
                        </Border>

                        <!-- Active Promotions -->
                        <Border Grid.Column="1" Background="White" CornerRadius="12" Padding="20" BorderBrush="#E5E7EB" BorderThickness="1">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="*"/>
                                </Grid.RowDefinitions>
                                <TextBlock Grid.Row="0" Text="Active Promotions" FontWeight="Bold" FontSize="16" Margin="0,0,0,16"/>
                                
                                <ItemsControl Grid.Row="1" ItemsSource="{Binding Overview.ActivePromotions}">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Border Background="#F9FAFB" CornerRadius="8" Padding="16" Margin="0,0,0,12">
                                                <Grid>
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="*"/>
                                                        <ColumnDefinition Width="Auto"/>
                                                    </Grid.ColumnDefinitions>
                                                    <StackPanel Grid.Column="0">
                                                        <TextBlock Text="{Binding Name}" FontWeight="Bold" FontSize="14" Foreground="#4F46E5"/>
                                                        <TextBlock Text="{Binding Description}" FontSize="13" Foreground="#4B5563" Margin="0,4,0,0" TextWrapping="Wrap"/>
                                                    </StackPanel>
                                                    <StackPanel Grid.Column="1" VerticalAlignment="Center" Margin="16,0,0,0">
                                                        <TextBlock Text="Valid Until" FontSize="11" Foreground="#9CA3AF" HorizontalAlignment="Right"/>
                                                        <TextBlock Text="{Binding ValidUntil}" FontSize="13" FontWeight="Medium" Foreground="#111827" HorizontalAlignment="Right"/>
                                                    </StackPanel>
                                                </Grid>
                                            </Border>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </Grid>
                        </Border>
                    </Grid>
                </Grid>
            </ScrollViewer>
        </Grid>
    </Grid>
</UserControl>
