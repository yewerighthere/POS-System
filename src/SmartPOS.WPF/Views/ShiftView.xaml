<UserControl x:Class="SmartPOS.WPF.Views.ShiftView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:conv="clr-namespace:SmartPOS.WPF.Converters">
    <UserControl.Resources>
        <conv:BoolToVisibilityConverter x:Key="BoolToVisibilityConverter"/>
        <conv:InverseBoolToVisibilityConverter x:Key="InverseBoolToVisibilityConverter"/>
        <conv:StringToVisibilityConverter x:Key="StringToVisibilityConverter"/>
        <conv:NullToVisibilityConverter x:Key="NullToVisibilityConverter"/>
    </UserControl.Resources>

    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" Text="Quản Lý Ca Làm Việc"
                   FontSize="22" FontWeight="SemiBold" Margin="0,0,0,16"/>

        <!-- Thông báo lỗi -->
        <Border Grid.Row="1" Background="#FFEBE9" BorderBrush="#C00000" BorderThickness="1"
                CornerRadius="4" Padding="10,6" Margin="0,0,0,8"
                Visibility="{Binding ErrorMessage, Converter={StaticResource StringToVisibilityConverter}}">
            <TextBlock Text="{Binding ErrorMessage}" Foreground="#C00000" TextWrapping="Wrap"/>
        </Border>

        <!-- Thông báo thành công -->
        <Border Grid.Row="2" Background="#E6F4EA" BorderBrush="#2E7D32" BorderThickness="1"
                CornerRadius="4" Padding="10,6" Margin="0,0,0,16"
                Visibility="{Binding StatusMessage, Converter={StaticResource StringToVisibilityConverter}}">
            <TextBlock Text="{Binding StatusMessage}" Foreground="#2E7D32" TextWrapping="Wrap"/>
        </Border>

        <Grid Grid.Row="3">
            <!-- Panel MỞ CA (khi chưa có ca) -->
            <Border Padding="24" MaxWidth="400" HorizontalAlignment="Left"
                    BorderBrush="#E0E0E0" BorderThickness="1" CornerRadius="8"
                    Visibility="{Binding HasOpenShift, Converter={StaticResource InverseBoolToVisibilityConverter}}">
                <StackPanel>
                    <TextBlock Text="Mở Ca Làm Việc" FontSize="16" FontWeight="SemiBold" Margin="0,0,0,16"/>

                    <TextBlock Text="Tiền đầu ca (VND)" Margin="0,0,0,4"/>
                    <TextBox Text="{Binding OpeningCash, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                             Margin="0,0,0,20" Height="36" Padding="8,0"/>

                    <Button Content="Mở Ca" Command="{Binding OpenShiftCommand}"
                            HorizontalAlignment="Stretch" Height="40"/>
                </StackPanel>
            </Border>

            <!-- Panel ĐÓNG CA (khi đang có ca mở) -->
            <StackPanel MaxWidth="480" HorizontalAlignment="Left"
                        Visibility="{Binding HasOpenShift, Converter={StaticResource BoolToVisibilityConverter}}">

                <!-- Thông tin ca hiện tại -->
                <Border Padding="16" BorderBrush="#1976D2" BorderThickness="1"
                        CornerRadius="8" Background="#E3F2FD" Margin="0,0,0,16">
                    <StackPanel>
                        <TextBlock Text="Ca Đang Mở" FontSize="14" FontWeight="SemiBold"
                                   Foreground="#1976D2" Margin="0,0,0,8"/>
                        <TextBlock Margin="0,2">
                            <Run Text="Giờ mở: "/>
                            <Run Text="{Binding CurrentShift.OpenedAt, StringFormat=HH:mm dd/MM/yyyy}"/>
                        </TextBlock>
                        <TextBlock Margin="0,2">
                            <Run Text="Tiền đầu ca: "/>
                            <Run Text="{Binding CurrentShift.OpeningCash, StringFormat={}{0:N0} VND}"/>
                        </TextBlock>
                    </StackPanel>
                </Border>

                <!-- Form đóng ca -->
                <Border Padding="24" BorderBrush="#E0E0E0" BorderThickness="1" CornerRadius="8" Margin="0,0,0,16">
                    <StackPanel>
                        <TextBlock Text="Đóng Ca Làm Việc" FontSize="16" FontWeight="SemiBold" Margin="0,0,0,16"/>

                        <TextBlock Text="Tiền cuối ca thực tế (VND)" Margin="0,0,0,4"/>
                        <TextBox Text="{Binding ClosingCash, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                 Margin="0,0,0,20" Height="36" Padding="8,0"/>

                        <Button Content="Đóng Ca" Command="{Binding CloseShiftCommand}"
                                HorizontalAlignment="Stretch" Height="40"/>
                    </StackPanel>
                </Border>

                <!-- Kết quả sau khi đóng ca -->
                <Border Padding="16" BorderBrush="#388E3C" BorderThickness="1"
                        CornerRadius="8" Background="#F1F8E9"
                        Visibility="{Binding LastSummary, Converter={StaticResource NullToVisibilityConverter}}">
                    <StackPanel>
                        <TextBlock Text="Kết Quả Ca" FontSize="14" FontWeight="SemiBold"
                                   Foreground="#388E3C" Margin="0,0,0,8"/>
                        <TextBlock Margin="0,2">
                            <Run Text="Tổng doanh thu: "/>
                            <Run Text="{Binding LastSummary.TotalSales, StringFormat={}{0:N0} VND}"/>
                        </TextBlock>
                        <TextBlock Margin="0,2">
                            <Run Text="Tiền mặt kỳ vọng: "/>
                            <Run Text="{Binding LastSummary.ExpectedCash, StringFormat={}{0:N0} VND}"/>
                        </TextBlock>
                    </StackPanel>
                </Border>
            </StackPanel>
        </Grid>
    </Grid>
</UserControl>
