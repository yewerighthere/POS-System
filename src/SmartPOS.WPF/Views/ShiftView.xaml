<UserControl x:Class="SmartPOS.WPF.Views.ShiftView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:conv="clr-namespace:SmartPOS.WPF.Converters">
    <UserControl.Resources>
        <SolidColorBrush x:Key="PrimaryBrush" Color="#00288E"/>
        <SolidColorBrush x:Key="PrimaryLightBrush" Color="#DBEAFE"/>
        <SolidColorBrush x:Key="BackgroundBrush" Color="#F8FAFC"/>
        <SolidColorBrush x:Key="SurfaceBrush" Color="#FFFFFF"/>
        <SolidColorBrush x:Key="TextPrimaryBrush" Color="#0F172A"/>
        <SolidColorBrush x:Key="TextSecondaryBrush" Color="#64748B"/>
        <SolidColorBrush x:Key="BorderBrush" Color="#E2E8F0"/>
        <SolidColorBrush x:Key="SurfaceContainerLowBrush" Color="#F4F2FC"/>
        <SolidColorBrush x:Key="SecondaryContainerBrush" Color="#DAE2FD"/>
        <SolidColorBrush x:Key="OnSecondaryContainerBrush" Color="#5C647A"/>
        <SolidColorBrush x:Key="SuccessBrush" Color="#16A34A"/>
        <SolidColorBrush x:Key="DangerBrush" Color="#DC2626"/>
        <SolidColorBrush x:Key="WarningBrush" Color="#D97706"/>

        <conv:BoolToVisibilityConverter x:Key="BoolToVisibilityConverter"/>
        <conv:InverseBoolToVisibilityConverter x:Key="InverseBoolToVisibilityConverter"/>
        <conv:StringToVisibilityConverter x:Key="StringToVisibilityConverter"/>
        <conv:NullToVisibilityConverter x:Key="NullToVisibilityConverter"/>

        <Style x:Key="QuickAmountButtonStyle" TargetType="Button">
            <Setter Property="Height" Value="36"/>
            <Setter Property="Background" Value="White"/>
            <Setter Property="Foreground" Value="{StaticResource TextSecondaryBrush}"/>
            <Setter Property="BorderBrush" Value="{StaticResource BorderBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="8">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="BorderBrush" Value="{StaticResource PrimaryBrush}"/>
                    <Setter Property="Foreground" Value="{StaticResource PrimaryBrush}"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="ActionButtonStyle" TargetType="Button">
            <Setter Property="Height" Value="52"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="FontSize" Value="16"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="8">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Opacity" Value="0.92"/>
                </Trigger>
                <Trigger Property="IsEnabled" Value="False">
                    <Setter Property="Opacity" Value="0.6"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="CashInputStyle" TargetType="TextBox">
            <Setter Property="Height" Value="52"/>
            <Setter Property="Padding" Value="40,0,14,0"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="Background" Value="{StaticResource BackgroundBrush}"/>
            <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}"/>
            <Setter Property="BorderBrush" Value="{StaticResource BorderBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="FontSize" Value="20"/>
            <Setter Property="FontFamily" Value="Consolas"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TextBox">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="8">
                            <ScrollViewer x:Name="PART_ContentHost"
                                          Margin="{TemplateBinding Padding}"
                                          VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsKeyboardFocused" Value="True">
                    <Setter Property="BorderBrush" Value="{StaticResource PrimaryBrush}"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="LinkButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Foreground" Value="{StaticResource TextSecondaryBrush}"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Foreground" Value="{StaticResource PrimaryBrush}"/>
                </Trigger>
            </Style.Triggers>
        </Style>
    </UserControl.Resources>

    <Grid Background="{StaticResource BackgroundBrush}">
        <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
            <Grid>

                <!-- ══════════════════════════════════════
                     OPEN SHIFT PANEL
                     ══════════════════════════════════════ -->
                <Border Visibility="{Binding HasOpenShift,
                            Converter={StaticResource InverseBoolToVisibilityConverter}}"
                        MaxWidth="560" Margin="24,32"
                        HorizontalAlignment="Center" VerticalAlignment="Top"
                        Background="{StaticResource SurfaceBrush}"
                        BorderBrush="{StaticResource BorderBrush}"
                        BorderThickness="1" CornerRadius="12">
                    <Border.Effect>
                        <DropShadowEffect Color="#000000" BlurRadius="20" ShadowDepth="4"
                                          Opacity="0.06" Direction="270"/>
                    </Border.Effect>
                    <StackPanel>
                        <!-- Accent bar -->
                        <Border Height="6" Background="{StaticResource PrimaryBrush}"
                                CornerRadius="12,12,0,0"/>

                        <!-- Body -->
                        <StackPanel Margin="32,32,32,28">

                            <!-- Icon + Title -->
                            <StackPanel HorizontalAlignment="Center" Margin="0,0,0,28">
                                <Border Width="64" Height="64" CornerRadius="32"
                                        Background="{StaticResource PrimaryLightBrush}"
                                        HorizontalAlignment="Center" Margin="0,0,0,16">
                                    <TextBlock Text="🖥" FontSize="30"
                                               HorizontalAlignment="Center"
                                               VerticalAlignment="Center"/>
                                </Border>
                                <TextBlock Text="Open New Shift" FontSize="24" FontWeight="Bold"
                                           Foreground="{StaticResource TextPrimaryBrush}"
                                           HorizontalAlignment="Center"/>
                                <TextBlock Text="Terminal #01 • SmartPOS Retail" FontSize="14"
                                           Foreground="{StaticResource TextSecondaryBrush}"
                                           HorizontalAlignment="Center" Margin="0,4,0,0"/>
                            </StackPanel>

                            <!-- Staff info card -->
                            <Border Background="{StaticResource SurfaceContainerLowBrush}"
                                    CornerRadius="8" Padding="16" Margin="0,0,0,20">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <Border Grid.Column="0" Width="40" Height="40" CornerRadius="20"
                                            Background="{StaticResource SecondaryContainerBrush}"
                                            Margin="0,0,12,0" VerticalAlignment="Center">
                                        <TextBlock Text="👤" FontSize="18"
                                                   HorizontalAlignment="Center"
                                                   VerticalAlignment="Center"/>
                                    </Border>
                                    <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                        <TextBlock Text="Staff Member" FontSize="12"
                                                   Foreground="{StaticResource TextSecondaryBrush}"/>
                                        <TextBlock Text="{Binding StaffName}" FontSize="14"
                                                   FontWeight="SemiBold"
                                                   Foreground="{StaticResource TextPrimaryBrush}"/>
                                    </StackPanel>
                                    <StackPanel Grid.Column="2" VerticalAlignment="Center"
                                                HorizontalAlignment="Right">
                                        <TextBlock Text="Role" FontSize="12"
                                                   Foreground="{StaticResource TextSecondaryBrush}"
                                                   HorizontalAlignment="Right"/>
                                        <Border Background="{StaticResource SecondaryContainerBrush}"
                                                CornerRadius="99" Padding="8,3"
                                                Margin="0,3,0,0" HorizontalAlignment="Right">
                                            <TextBlock Text="{Binding StaffRole}" FontSize="11"
                                                       FontWeight="Medium"
                                                       Foreground="{StaticResource OnSecondaryContainerBrush}"/>
                                        </Border>
                                    </StackPanel>
                                </Grid>
                            </Border>

                            <!-- Date/Time row -->
                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                <TextBlock Text="📅" FontSize="14" VerticalAlignment="Center"
                                           Foreground="{StaticResource TextSecondaryBrush}"/>
                                <TextBlock Text="{Binding CurrentDateDisplay}" FontSize="14"
                                           Foreground="{StaticResource TextSecondaryBrush}"
                                           VerticalAlignment="Center" Margin="6,0,0,0"/>
                                <TextBlock Text="|" FontSize="14" Opacity="0.3"
                                           Foreground="{StaticResource TextSecondaryBrush}"
                                           Margin="12,0" VerticalAlignment="Center"/>
                                <TextBlock Text="⏰" FontSize="14" VerticalAlignment="Center"
                                           Foreground="{StaticResource TextSecondaryBrush}"/>
                                <TextBlock Text="{Binding CurrentTimeDisplay}" FontSize="14"
                                           Foreground="{StaticResource TextSecondaryBrush}"
                                           VerticalAlignment="Center" Margin="6,0,0,0"/>
                            </StackPanel>

                            <!-- Divider -->
                            <Border Height="1" Background="{StaticResource BorderBrush}"
                                    Margin="0,16,0,24"/>

                            <!-- Opening Cash label -->
                            <TextBlock Text="OPENING CASH AMOUNT" FontSize="11" FontWeight="Medium"
                                       Foreground="{StaticResource TextSecondaryBrush}"
                                       Margin="0,0,0,8"/>

                            <!-- Input with ₫ prefix -->
                            <Grid Margin="0,0,0,12">
                                <TextBox Style="{StaticResource CashInputStyle}"
                                         Text="{Binding OpeningCash, Mode=TwoWay,
                                                UpdateSourceTrigger=PropertyChanged}"/>
                                <TextBlock Text="₫" FontFamily="Consolas" FontSize="16"
                                           Foreground="{StaticResource TextSecondaryBrush}"
                                           VerticalAlignment="Center" Margin="14,0,0,0"
                                           IsHitTestVisible="False"/>
                            </Grid>

                            <!-- Quick amount buttons -->
                            <UniformGrid Columns="4" Margin="0,0,0,28">
                                <Button Content="500,000"
                                        Style="{StaticResource QuickAmountButtonStyle}"
                                        Command="{Binding SetQuickAmountCommand}"
                                        CommandParameter="500000" Margin="0,0,4,0"/>
                                <Button Content="1,000,000"
                                        Style="{StaticResource QuickAmountButtonStyle}"
                                        Command="{Binding SetQuickAmountCommand}"
                                        CommandParameter="1000000" Margin="0,0,4,0"/>
                                <Button Content="2,000,000"
                                        Style="{StaticResource QuickAmountButtonStyle}"
                                        Command="{Binding SetQuickAmountCommand}"
                                        CommandParameter="2000000" Margin="0,0,4,0"/>
                                <Button Content="5,000,000"
                                        Style="{StaticResource QuickAmountButtonStyle}"
                                        Command="{Binding SetQuickAmountCommand}"
                                        CommandParameter="5000000"/>
                            </UniformGrid>

                            <!-- Error message -->
                            <Border Background="#FEF2F2" BorderBrush="#DC2626" BorderThickness="1"
                                    CornerRadius="8" Padding="12,8" Margin="0,0,0,12"
                                    Visibility="{Binding ErrorMessage,
                                        Converter={StaticResource StringToVisibilityConverter}}">
                                <TextBlock Text="{Binding ErrorMessage}" Foreground="#DC2626"
                                           FontSize="13" TextWrapping="Wrap"/>
                            </Border>

                            <!-- Green action button -->
                            <Button Background="{StaticResource SuccessBrush}"
                                    Style="{StaticResource ActionButtonStyle}"
                                    Command="{Binding OpenShiftCommand}"
                                    IsEnabled="{Binding IsNotLoading}"
                                    HorizontalAlignment="Stretch">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="▶" FontSize="16" VerticalAlignment="Center"
                                               Margin="0,0,8,0"/>
                                    <TextBlock Text="Open Shift &amp; Start Selling"
                                               FontSize="16" FontWeight="SemiBold"
                                               VerticalAlignment="Center"/>
                                </StackPanel>
                            </Button>

                            <!-- Back to Login -->
                            <Button Style="{StaticResource LinkButtonStyle}"
                                    Command="{Binding NavigateToLoginCommand}"
                                    HorizontalAlignment="Center" Margin="0,12,0,0">
                                <TextBlock Text="← Back to Login" FontSize="12"
                                           Foreground="{StaticResource TextSecondaryBrush}"/>
                            </Button>
                        </StackPanel>

                        <!-- Bottom hint -->
                        <Border Background="{StaticResource SurfaceContainerLowBrush}"
                                BorderBrush="{StaticResource BorderBrush}"
                                BorderThickness="0,1,0,0" Padding="32,16"
                                CornerRadius="0,0,12,12">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="⚠" FontSize="18"
                                           Foreground="{StaticResource WarningBrush}"
                                           VerticalAlignment="Top" Margin="0,0,12,0"/>
                                <TextBlock FontSize="12" TextWrapping="Wrap"
                                           Foreground="{StaticResource TextSecondaryBrush}">
                                    Ensure the opening cash matches the physical amount in the drawer. This will be used to calculate the variance at the end of the shift.
                                </TextBlock>
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </Border>

                <!-- ══════════════════════════════════════
                     CLOSE SHIFT PANEL
                     ══════════════════════════════════════ -->
                <Border Visibility="{Binding HasOpenShift,
                            Converter={StaticResource BoolToVisibilityConverter}}"
                        MaxWidth="560" Margin="24,32"
                        HorizontalAlignment="Center" VerticalAlignment="Top"
                        Background="{StaticResource SurfaceBrush}"
                        BorderBrush="{StaticResource BorderBrush}"
                        BorderThickness="1" CornerRadius="12">
                    <Border.Effect>
                        <DropShadowEffect Color="#000000" BlurRadius="20" ShadowDepth="4"
                                          Opacity="0.06" Direction="270"/>
                    </Border.Effect>
                    <StackPanel>
                        <!-- Accent bar -->
                        <Border Height="6" Background="{StaticResource DangerBrush}"
                                CornerRadius="12,12,0,0"/>

                        <!-- Body -->
                        <StackPanel Margin="32,32,32,28">

                            <!-- Icon + Title -->
                            <StackPanel HorizontalAlignment="Center" Margin="0,0,0,24">
                                <Border Width="64" Height="64" CornerRadius="32"
                                        Background="#FEE2E2"
                                        HorizontalAlignment="Center" Margin="0,0,0,16">
                                    <TextBlock Text="🔒" FontSize="28"
                                               HorizontalAlignment="Center"
                                               VerticalAlignment="Center"/>
                                </Border>
                                <TextBlock Text="Close Current Shift" FontSize="24" FontWeight="Bold"
                                           Foreground="{StaticResource TextPrimaryBrush}"
                                           HorizontalAlignment="Center"/>
                                <TextBlock Text="Terminal #01 • SmartPOS Retail" FontSize="14"
                                           Foreground="{StaticResource TextSecondaryBrush}"
                                           HorizontalAlignment="Center" Margin="0,4,0,0"/>
                            </StackPanel>

                            <!-- Staff info card -->
                            <Border Background="{StaticResource SurfaceContainerLowBrush}"
                                    CornerRadius="8" Padding="16" Margin="0,0,0,20">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <Border Grid.Column="0" Width="40" Height="40" CornerRadius="20"
                                            Background="{StaticResource SecondaryContainerBrush}"
                                            Margin="0,0,12,0" VerticalAlignment="Center">
                                        <TextBlock Text="👤" FontSize="18"
                                                   HorizontalAlignment="Center"
                                                   VerticalAlignment="Center"/>
                                    </Border>
                                    <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                        <TextBlock Text="Staff Member" FontSize="12"
                                                   Foreground="{StaticResource TextSecondaryBrush}"/>
                                        <TextBlock Text="{Binding StaffName}" FontSize="14"
                                                   FontWeight="SemiBold"
                                                   Foreground="{StaticResource TextPrimaryBrush}"/>
                                    </StackPanel>
                                    <StackPanel Grid.Column="2" VerticalAlignment="Center"
                                                HorizontalAlignment="Right">
                                        <TextBlock Text="Role" FontSize="12"
                                                   Foreground="{StaticResource TextSecondaryBrush}"
                                                   HorizontalAlignment="Right"/>
                                        <Border Background="{StaticResource SecondaryContainerBrush}"
                                                CornerRadius="99" Padding="8,3"
                                                Margin="0,3,0,0" HorizontalAlignment="Right">
                                            <TextBlock Text="{Binding StaffRole}" FontSize="11"
                                                       FontWeight="Medium"
                                                       Foreground="{StaticResource OnSecondaryContainerBrush}"/>
                                        </Border>
                                    </StackPanel>
                                </Grid>
                            </Border>

                            <!-- Date/Time row -->
                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                <TextBlock Text="📅" FontSize="14" VerticalAlignment="Center"
                                           Foreground="{StaticResource TextSecondaryBrush}"/>
                                <TextBlock Text="{Binding CurrentDateDisplay}" FontSize="14"
                                           Foreground="{StaticResource TextSecondaryBrush}"
                                           VerticalAlignment="Center" Margin="6,0,0,0"/>
                                <TextBlock Text="|" FontSize="14" Opacity="0.3"
                                           Foreground="{StaticResource TextSecondaryBrush}"
                                           Margin="12,0" VerticalAlignment="Center"/>
                                <TextBlock Text="⏰" FontSize="14" VerticalAlignment="Center"
                                           Foreground="{StaticResource TextSecondaryBrush}"/>
                                <TextBlock Text="{Binding CurrentTimeDisplay}" FontSize="14"
                                           Foreground="{StaticResource TextSecondaryBrush}"
                                           VerticalAlignment="Center" Margin="6,0,0,0"/>
                            </StackPanel>

                            <!-- Divider -->
                            <Border Height="1" Background="{StaticResource BorderBrush}"
                                    Margin="0,16,0,24"/>

                            <!-- Current shift info -->
                            <Border Background="{StaticResource SurfaceContainerLowBrush}"
                                    CornerRadius="8" Padding="16" Margin="0,0,0,24">
                                <StackPanel>
                                    <TextBlock Text="Ca Đang Mở" FontSize="12" FontWeight="Medium"
                                               Foreground="#1976D2" Margin="0,0,0,10"/>
                                    <Grid Margin="0,0,0,6">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Text="Giờ mở:" FontSize="13"
                                                   Foreground="{StaticResource TextSecondaryBrush}"/>
                                        <TextBlock Grid.Column="1" FontSize="13" FontWeight="Medium"
                                                   Foreground="{StaticResource TextPrimaryBrush}"
                                                   Text="{Binding ShiftOpenedAtDisplay}"/>
                                    </Grid>
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Text="Tiền đầu ca:" FontSize="13"
                                                   Foreground="{StaticResource TextSecondaryBrush}"/>
                                        <TextBlock Grid.Column="1" FontSize="13" FontWeight="Medium"
                                                   Foreground="{StaticResource TextPrimaryBrush}"
                                                   Text="{Binding CurrentShift.OpeningCash,
                                                          StringFormat={}{0:N0} ₫}"/>
                                    </Grid>
                                </StackPanel>
                            </Border>

                            <!-- Closing Cash label -->
                            <TextBlock Text="CLOSING CASH AMOUNT" FontSize="11" FontWeight="Medium"
                                       Foreground="{StaticResource TextSecondaryBrush}"
                                       Margin="0,0,0,8"/>

                            <!-- Input with ₫ prefix -->
                            <Grid Margin="0,0,0,24">
                                <TextBox Style="{StaticResource CashInputStyle}"
                                         Text="{Binding ClosingCash, Mode=TwoWay,
                                                UpdateSourceTrigger=PropertyChanged}"/>
                                <TextBlock Text="₫" FontFamily="Consolas" FontSize="16"
                                           Foreground="{StaticResource TextSecondaryBrush}"
                                           VerticalAlignment="Center" Margin="14,0,0,0"
                                           IsHitTestVisible="False"/>
                            </Grid>

                            <!-- Error message -->
                            <Border Background="#FEF2F2" BorderBrush="#DC2626" BorderThickness="1"
                                    CornerRadius="8" Padding="12,8" Margin="0,0,0,12"
                                    Visibility="{Binding ErrorMessage,
                                        Converter={StaticResource StringToVisibilityConverter}}">
                                <TextBlock Text="{Binding ErrorMessage}" Foreground="#DC2626"
                                           FontSize="13" TextWrapping="Wrap"/>
                            </Border>

                            <!-- Red close button -->
                            <Button Background="{StaticResource DangerBrush}"
                                    Style="{StaticResource ActionButtonStyle}"
                                    Command="{Binding CloseShiftCommand}"
                                    IsEnabled="{Binding IsNotLoading}"
                                    HorizontalAlignment="Stretch">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="🔒" FontSize="16" VerticalAlignment="Center"
                                               Margin="0,0,8,0"/>
                                    <TextBlock Text="Close Shift" FontSize="16" FontWeight="SemiBold"
                                               VerticalAlignment="Center"/>
                                </StackPanel>
                            </Button>

                            <!-- Shift result after close -->
                            <Border Background="#F0FDF4" BorderBrush="#16A34A" BorderThickness="1"
                                    CornerRadius="8" Padding="16" Margin="0,16,0,0"
                                    Visibility="{Binding LastSummary,
                                        Converter={StaticResource NullToVisibilityConverter}}">
                                <StackPanel>
                                    <TextBlock Text="✓ Kết Quả Ca" FontSize="14" FontWeight="SemiBold"
                                               Foreground="#16A34A" Margin="0,0,0,10"/>
                                    <Grid Margin="0,0,0,6">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Text="Tổng doanh thu:" FontSize="13"
                                                   Foreground="{StaticResource TextSecondaryBrush}"/>
                                        <TextBlock Grid.Column="1" FontSize="13" FontWeight="SemiBold"
                                                   Foreground="{StaticResource TextPrimaryBrush}"
                                                   Text="{Binding LastSummary.TotalSales,
                                                          StringFormat={}{0:N0} ₫}"/>
                                    </Grid>
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Text="Tiền mặt kỳ vọng:" FontSize="13"
                                                   Foreground="{StaticResource TextSecondaryBrush}"/>
                                        <TextBlock Grid.Column="1" FontSize="13" FontWeight="SemiBold"
                                                   Foreground="{StaticResource TextPrimaryBrush}"
                                                   Text="{Binding LastSummary.ExpectedCash,
                                                          StringFormat={}{0:N0} ₫}"/>
                                    </Grid>
                                </StackPanel>
                            </Border>

                            <!-- Status message -->
                            <Border Background="#F0FDF4" BorderBrush="#16A34A" BorderThickness="1"
                                    CornerRadius="8" Padding="12,8" Margin="0,12,0,0"
                                    Visibility="{Binding StatusMessage,
                                        Converter={StaticResource StringToVisibilityConverter}}">
                                <TextBlock Text="{Binding StatusMessage}" Foreground="#16A34A"
                                           FontSize="13" TextWrapping="Wrap"/>
                            </Border>
                        </StackPanel>

                        <!-- Bottom hint -->
                        <Border Background="{StaticResource SurfaceContainerLowBrush}"
                                BorderBrush="{StaticResource BorderBrush}"
                                BorderThickness="0,1,0,0" Padding="32,16"
                                CornerRadius="0,0,12,12">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="⚠" FontSize="18"
                                           Foreground="{StaticResource WarningBrush}"
                                           VerticalAlignment="Top" Margin="0,0,12,0"/>
                                <TextBlock FontSize="12" TextWrapping="Wrap"
                                           Foreground="{StaticResource TextSecondaryBrush}">
                                    Count the physical cash in the drawer before entering the closing amount. The system will calculate the variance automatically.
                                </TextBlock>
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </Border>

            </Grid>
        </ScrollViewer>
    </Grid>
</UserControl>
