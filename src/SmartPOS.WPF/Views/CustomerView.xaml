<UserControl x:Class="SmartPOS.WPF.Views.CustomerView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:SmartPOS.WPF.Views"
             xmlns:ui="http://schemas.modernwpf.com/2019"
             mc:Ignorable="d" 
             Background="#121214"
             Foreground="#F3F4F6"
             d:DesignHeight="768" d:DesignWidth="1024">
    <UserControl.Resources>
        <!-- Modern TextBox Style -->
        <Style x:Key="ModernTextBox" TargetType="TextBox">
            <Setter Property="Background" Value="#17171B"/>
            <Setter Property="Foreground" Value="#F3F4F6"/>
            <Setter Property="BorderBrush" Value="#2D2D35"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="12,10"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="CaretBrush" Value="#3B82F6"/>
            <Setter Property="SelectionBrush" Value="#3B82F6"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TextBox">
                        <Border Name="Border"
                                CornerRadius="6"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                Background="{TemplateBinding Background}">
                            <ScrollViewer x:Name="PART_ContentHost" Margin="0" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsFocused" Value="True">
                                <Setter TargetName="Border" Property="BorderBrush" Value="#3B82F6"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="Border" Property="Background" Value="#1E1E24"/>
                                <Setter Property="Foreground" Value="#6B7280"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Accent Button Style -->
        <Style x:Key="AccentButton" TargetType="Button">
            <Setter Property="Background" Value="#3B82F6"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="20,12"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Name="Border" 
                                CornerRadius="6" 
                                Background="{TemplateBinding Background}" 
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Border" Property="Background" Value="#2563EB"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Secondary Button Style -->
        <Style x:Key="SecondaryButton" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="#9CA3AF"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="BorderBrush" Value="#4B5563"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="20,12"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Name="Border" 
                                CornerRadius="6" 
                                Background="{TemplateBinding Background}" 
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Border" Property="Background" Value="#1F2937"/>
                                <Setter Property="Foreground" Value="White"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </UserControl.Resources>

    <Grid>
        <!-- Background Overlay -->
        <Grid Background="#0A0A0C" Opacity="0.5"/>

        <!-- Main Form Card -->
        <Border Background="#1E1E24" 
                BorderBrush="#2D2D35" 
                BorderThickness="1" 
                CornerRadius="12" 
                Width="480" 
                VerticalAlignment="Center" 
                HorizontalAlignment="Center"
                Padding="32">
            <Border.Effect>
                <DropShadowEffect Color="Black" Opacity="0.4" BlurRadius="30" ShadowDepth="10" Direction="270"/>
            </Border.Effect>

            <StackPanel>
                <!-- Header -->
                <TextBlock Text="Đăng Ký Khách Hàng Thành Viên" 
                           FontSize="22" 
                           FontWeight="Bold" 
                           Foreground="#F3F4F6" 
                           Margin="0,0,0,8"/>
                <TextBlock Text="Vui lòng điền thông tin để lưu lại lịch sử mua hàng và tích điểm." 
                           FontSize="13" 
                           Foreground="#9CA3AF" 
                           Margin="0,0,0,32" 
                           TextWrapping="Wrap"/>

                <!-- Phone (Readonly) -->
                <StackPanel Margin="0,0,0,20">
                    <TextBlock Text="Số điện thoại" FontSize="13" FontWeight="SemiBold" Foreground="#D1D5DB" Margin="0,0,0,8"/>
                    <TextBox Text="{Binding Phone}" 
                             Style="{StaticResource ModernTextBox}" 
                             IsEnabled="False" 
                             ToolTip="Số điện thoại không thể thay đổi ở đây"/>
                </StackPanel>

                <!-- Full Name (Required) -->
                <StackPanel Margin="0,0,0,20">
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                        <TextBlock Text="Họ và tên" FontSize="13" FontWeight="SemiBold" Foreground="#D1D5DB"/>
                        <TextBlock Text=" *" Foreground="#EF4444" FontSize="13" FontWeight="Bold"/>
                    </StackPanel>
                    <TextBox Text="{Binding FullName, UpdateSourceTrigger=PropertyChanged}" 
                             Style="{StaticResource ModernTextBox}" 
                             ui:ControlHelper.PlaceholderText="VD: Nguyễn Văn A"/>
                </StackPanel>

                <!-- Email (Optional) -->
                <StackPanel Margin="0,0,0,24">
                    <TextBlock Text="Email (Không bắt buộc)" FontSize="13" FontWeight="SemiBold" Foreground="#9CA3AF" Margin="0,0,0,8"/>
                    <TextBox Text="{Binding Email, UpdateSourceTrigger=PropertyChanged}" 
                             Style="{StaticResource ModernTextBox}" 
                             ui:ControlHelper.PlaceholderText="VD: email@example.com"/>
                </StackPanel>

                <!-- Error Message -->
                <TextBlock Text="{Binding ErrorMessage}" 
                           Foreground="#EF4444" 
                           FontSize="13" 
                           TextWrapping="Wrap" 
                           Margin="0,0,0,24" 
                           Visibility="Visible"/>

                <!-- Action Buttons -->
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="16"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    
                    <Button Grid.Column="0" 
                            Content="Hủy bỏ" 
                            Style="{StaticResource SecondaryButton}" 
                            Command="{Binding CancelCommand}"/>
                    
                    <Button Grid.Column="2" 
                            Content="Xác nhận tạo" 
                            Style="{StaticResource AccentButton}" 
                            Command="{Binding AcceptCommand}"/>
                </Grid>
            </StackPanel>
        </Border>
    </Grid>
</UserControl>
