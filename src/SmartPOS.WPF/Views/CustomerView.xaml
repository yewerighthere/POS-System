<UserControl x:Class="SmartPOS.WPF.Views.CustomerView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:converters="clr-namespace:SmartPOS.WPF.Converters"
             mc:Ignorable="d"
             d:DesignHeight="768" d:DesignWidth="1024"
             Background="#F8FAFC">

    <UserControl.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis"/>
        
        <!-- Vector Geometries -->
        <Geometry x:Key="IconPosData">M4 3h16a1 1 0 0 1 1 1v10a1 1 0 0 1-1 1H4a1 1 0 0 1-1-1V4a1 1 0 0 1 1-1zm0 13h16v2H4v-2zm7 3h2v2h-2v-2z</Geometry>
        <Geometry x:Key="IconInventoryData">M20 7l-8-4-8 4 8 4 8-4zm-16 3v8l8 4 8-4v-8l-8 4-8-4z</Geometry>
        <Geometry x:Key="IconCustomerData">M12 12c2.21 0 4-1.79 4-4s-1.79-4-4-4-4 1.79-4 4 1.79 4 4 4zm0 2c-2.67 0-8 1.34-8 4v2h16v-2c0-2.66-5.33-4-8-4z</Geometry>
        <Geometry x:Key="IconReturnData">M12 5V1L7 6l5 5V7c3.31 0 6 2.69 6 6s-2.69 6-6 6-6-2.69-6-6H4c0 4.42 3.58 8 8 8s8-3.58 8-8-3.58-8-8-8z</Geometry>
        <Geometry x:Key="IconCatalogData">M10 4H4c-1.1 0-1.99.9-1.99 2L2 18c0 1.1.9 2 2 2h16c1.1 0 2-.9 2-2V8c0-1.1-.9-2-2-2h-8l-2-2z</Geometry>
        <Geometry x:Key="IconReportData">M19 3H5c-1.1 0-2 .9-2 2v14c0 1.1.9 2 2 2h14c1.1 0 2-.9 2-2V5c0-1.1-.9-2-2-2zm-7 14h-2V9h2v8zm4 0h-2v-5h2v5zm-8 0H6v-3h2v3z</Geometry>
        <Geometry x:Key="IconSearchData">M15.5 14h-.79l-.28-.27C15.41 12.59 16 11.11 16 9.5 16 5.91 13.09 3 9.5 3S3 5.91 3 9.5 5.91 16 9.5 16c1.61 0 3.09-.59 4.23-1.57l.27.28v.79l5 4.99L20.49 19l-4.99-5zm-6 0C7.01 14 5 11.99 5 9.5S7.01 5 9.5 5 14 7.01 14 9.5 11.99 14 9.5 14z</Geometry>

        <Style x:Key="CardStyle" TargetType="Border">
            <Setter Property="Background" Value="White"/>
            <Setter Property="BorderBrush" Value="#E2E8F0"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="8"/>
            <Setter Property="Padding" Value="16"/>
        </Style>

        <Style x:Key="SearchTextBoxStyle" TargetType="TextBox">
            <Setter Property="Height" Value="38"/>
            <Setter Property="Background" Value="#F8FAFC"/>
            <Setter Property="Foreground" Value="#0F172A"/>
            <Setter Property="BorderBrush" Value="#E2E8F0"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="10,6"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TextBox">
                        <Border Name="Border" CornerRadius="6" Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="{TemplateBinding BorderThickness}">
                            <ScrollViewer x:Name="PART_ContentHost" Margin="0"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsFocused" Value="True">
                                <Setter TargetName="Border" Property="BorderBrush" Value="#2563EB"/>
                                <Setter TargetName="Border" Property="Background" Value="White"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="ComboBoxStyle" TargetType="ComboBox">
            <Setter Property="Height" Value="38"/>
            <Setter Property="Background" Value="White"/>
            <Setter Property="Foreground" Value="#0F172A"/>
            <Setter Property="BorderBrush" Value="#E2E8F0"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="8,4"/>
            <Setter Property="FontSize" Value="12"/>
        </Style>

        <Style x:Key="PrimaryButtonStyle" TargetType="Button">
            <Setter Property="Height" Value="38"/>
            <Setter Property="Background" Value="#2563EB"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Name="Border" CornerRadius="6" Background="{TemplateBinding Background}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Border" Property="Background" Value="#1D4ED8"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="EndShiftButton" TargetType="Button">
            <Setter Property="Background" Value="#EF4444"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="14,8"/>
            <Setter Property="Height" Value="36"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Name="Border" CornerRadius="6" Background="{TemplateBinding Background}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" Margin="12,0"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </UserControl.Resources>

    <Grid>
        <Grid.ColumnDefinitions>
            <!-- Sidebar Column -->
            <ColumnDefinition Width="220"/>
            <!-- Main Content Column -->
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- 1. LEFT SIDEBAR (Slate 900 #0F172A) -->
        <Border Grid.Column="0" Background="#0F172A" BorderThickness="0">
            <Grid Margin="0,20,0,16">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/> <!-- Brand Header -->
                    <RowDefinition Height="*"/>    <!-- Navigation Panel -->
                    <RowDefinition Height="Auto"/> <!-- Unified Sidebar Footer -->
                </Grid.RowDefinitions>

                <!-- Brand Header -->
                <StackPanel Grid.Row="0" Margin="20,0,20,16" VerticalAlignment="Center">
                    <TextBlock Text="SmartPOS" Foreground="#F8FAFC" FontSize="18" FontWeight="Black"/>
                    <TextBlock Text="Terminal #01" Foreground="#94A3B8" FontSize="11" Margin="0,2,0,0"/>
                </StackPanel>

                <!-- Scrollable Navigation Items -->
                <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                    <StackPanel Margin="10,0">

                        <!-- SECTION 1: OPERATIONS -->
                        <TextBlock Text="OPERATIONS" Foreground="#64748B" FontSize="10" FontWeight="Bold" Margin="10,4,10,6"/>

                        <!-- Point of Sale -->
                        <Button Style="{StaticResource SidebarNavButtonStyle}" Command="{Binding NavigateToSalesCommand}" VerticalAlignment="Center" Height="40" Margin="0,2">
                            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                <Path Data="{StaticResource IconPosData}" Fill="#94A3B8" Width="16" Height="16" Stretch="Uniform" Margin="0,0,12,0"/>
                                <TextBlock Text="Point of Sale" FontSize="13" VerticalAlignment="Center"/>
                            </StackPanel>
                        </Button>

                        <!-- Returns & Refunds -->
                        <Button Style="{StaticResource SidebarNavButtonStyle}" Command="{Binding NavigateToReturnCommand}" VerticalAlignment="Center" Height="40" Margin="0,2">
                            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                <Path Data="{StaticResource IconReturnData}" Fill="#94A3B8" Width="16" Height="16" Stretch="Uniform" Margin="0,0,12,0"/>
                                <TextBlock Text="Returns &amp; Refunds" FontSize="13" VerticalAlignment="Center"/>
                            </StackPanel>
                        </Button>

                        <!-- SECTION 2: MANAGEMENT -->
                        <TextBlock Text="MANAGEMENT" Foreground="#64748B" FontSize="10" FontWeight="Bold" Margin="10,14,10,6"/>

                        <!-- Inventory -->
                        <Button Style="{StaticResource SidebarNavButtonStyle}" Command="{Binding NavigateToSyncCommand}" VerticalAlignment="Center" Height="40" Margin="0,2">
                            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                <Path Data="{StaticResource IconInventoryData}" Fill="#94A3B8" Width="16" Height="16" Stretch="Uniform" Margin="0,0,12,0"/>
                                <TextBlock Text="Inventory" FontSize="13" VerticalAlignment="Center"/>
                            </StackPanel>
                        </Button>

                        <!-- Product Catalog -->
                        <Button Style="{StaticResource SidebarNavButtonStyle}" Command="{Binding NavigateToCatalogCommand}" VerticalAlignment="Center" Height="40" Margin="0,2">
                            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                <Path Data="{StaticResource IconCatalogData}" Fill="#94A3B8" Width="16" Height="16" Stretch="Uniform" Margin="0,0,12,0"/>
                                <TextBlock Text="Product Catalog" FontSize="13" VerticalAlignment="Center"/>
                            </StackPanel>
                        </Button>

                        <!-- ACTIVE: Customers (Royal Blue #2563EB) -->
                        <Border Background="#2563EB" CornerRadius="8" Margin="0,2" Padding="14,0" Height="40" VerticalAlignment="Center">
                            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                <Path Data="{StaticResource IconCustomerData}" Fill="White" Width="16" Height="16" Stretch="Uniform" Margin="0,0,12,0"/>
                                <TextBlock Text="Customers" Foreground="White" FontSize="13" FontWeight="SemiBold" VerticalAlignment="Center"/>
                            </StackPanel>
                        </Border>

                        <!-- SECTION 3: ANALYTICS -->
                        <TextBlock Text="ANALYTICS" Foreground="#64748B" FontSize="10" FontWeight="Bold" Margin="10,14,10,6"/>

                        <!-- Shift Reports -->
                        <Button Style="{StaticResource SidebarNavButtonStyle}" Command="{Binding NavigateToReportCommand}" VerticalAlignment="Center" Height="40" Margin="0,2">
                            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                <Path Data="{StaticResource IconReportData}" Fill="#94A3B8" Width="16" Height="16" Stretch="Uniform" Margin="0,0,12,0"/>
                                <TextBlock Text="Shift Reports" FontSize="13" VerticalAlignment="Center"/>
                            </StackPanel>
                        </Button>

                    </StackPanel>
                </ScrollViewer>

                <!-- UNIFIED SIDEBAR FOOTER (Stacked Info: Shift, Staff, Current Time) -->
                <StackPanel Grid.Row="2" Margin="10,12,10,0">
                    <Border Padding="12" CornerRadius="8" Background="#1E293B">
                        <StackPanel>
                            <!-- Shift info -->
                            <StackPanel Margin="0,0,0,8">
                                <TextBlock Text="SHIFT INFO" Foreground="#94A3B8" FontSize="10" FontWeight="Bold"/>
                                <TextBlock Text="{Binding ShiftCode}" Foreground="#F8FAFC" FontSize="12" FontWeight="SemiBold" Margin="0,2,0,0"/>
                            </StackPanel>

                            <!-- Staff info -->
                            <StackPanel Margin="0,0,0,8">
                                <TextBlock Text="STAFF / CASHIER" Foreground="#94A3B8" FontSize="10" FontWeight="Bold"/>
                                <TextBlock Text="{Binding StaffName}" Foreground="#F8FAFC" FontSize="12" FontWeight="SemiBold" Margin="0,2,0,0"/>
                            </StackPanel>

                            <!-- Current Time -->
                            <StackPanel>
                                <TextBlock Text="CURRENT TIME" Foreground="#94A3B8" FontSize="10" FontWeight="Bold"/>
                                <TextBlock Text="{Binding CurrentTimeDisplay}" Foreground="#F8FAFC" FontSize="11" Margin="0,2,0,0"/>
                            </StackPanel>
                        </StackPanel>
                    </Border>
                </StackPanel>
            </Grid>
        </Border>

        <!-- 2. MAIN CONTENT -->
        <Grid Grid.Column="1">
            <Grid.RowDefinitions>
                <RowDefinition Height="64"/> <!-- Top Header -->
                <RowDefinition Height="*"/>  <!-- Workspace -->
            </Grid.RowDefinitions>

            <!-- Top Header Bar -->
            <Border Grid.Row="0" Background="White" BorderBrush="#E2E8F0" BorderThickness="0,0,0,1" Padding="20,0">
                <Grid VerticalAlignment="Center">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <!-- Left: App Title -->
                    <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                        <TextBlock Text="CUSTOMER MANAGEMENT" Foreground="#0F172A" FontSize="16" FontWeight="Bold" VerticalAlignment="Center"/>
                    </StackPanel>

                    <!-- Right: End Shift button -->
                    <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                        <Button Content="Support" Background="Transparent" Foreground="#2563EB" FontSize="12" FontWeight="Bold" BorderThickness="0" Margin="0,0,16,0" Cursor="Hand"/>
                        <Button Content="End Shift" Style="{StaticResource EndShiftButton}"/>
                    </StackPanel>
                </Grid>
            </Border>

            <!-- Workspace Area -->
            <Grid Grid.Row="1" Margin="32">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <!-- Header -->
                <TextBlock Text="Customer Management" FontWeight="Bold" FontSize="22" Foreground="#0F172A" Margin="0,0,0,20" Grid.Row="0"/>

                <!-- Top Bar: Filters & Search -->
                <Border Grid.Row="1" Style="{StaticResource CardStyle}" Margin="0,0,0,20">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        
                        <TextBox Grid.Column="0" 
                                 Text="{Binding SearchTerm, UpdateSourceTrigger=PropertyChanged}" 
                                 Style="{StaticResource SearchTextBoxStyle}" 
                                 Margin="0,0,12,0"/>
                                 
                        <ComboBox Grid.Column="1" 
                                  ItemsSource="{Binding StatusFilters}" 
                                  SelectedItem="{Binding SelectedStatusFilter}"
                                  Style="{StaticResource ComboBoxStyle}"
                                  Width="90" Margin="0,0,12,0"/>

                        <ComboBox Grid.Column="2" 
                                  ItemsSource="{Binding OrderFilters}" 
                                  SelectedItem="{Binding SelectedOrderFilter}"
                                  Style="{StaticResource ComboBoxStyle}"
                                  Width="100" Margin="0,0,12,0"/>

                        <ComboBox Grid.Column="3" 
                                  ItemsSource="{Binding SortOptions}" 
                                  SelectedItem="{Binding SelectedSortOption}"
                                  Style="{StaticResource ComboBoxStyle}"
                                  Width="110" Margin="0,0,12,0"/>
                                  
                        <Button Grid.Column="4" 
                                Content="Search" 
                                Command="{Binding ExecuteSearchCommand}" 
                                Width="100"
                                Style="{StaticResource PrimaryButtonStyle}"/>
                    </Grid>
                </Border>

                <!-- Data Grid -->
                <Border Grid.Row="2" Style="{StaticResource CardStyle}">
                    <Grid>
                        <DataGrid ItemsSource="{Binding Customers}" 
                                  AutoGenerateColumns="False" 
                                  CanUserAddRows="False"
                                  IsReadOnly="True"
                                  HeadersVisibility="Column"
                                  Background="Transparent"
                                  BorderThickness="0"
                                  RowHeight="46"
                                  VerticalScrollBarVisibility="Auto">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="ID" Binding="{Binding Id}" Width="220"/>
                                <DataGridTextColumn Header="Tên (Name)" Binding="{Binding FullName}" Width="*"/>
                                <DataGridTextColumn Header="SĐT (Phone)" Binding="{Binding Phone}" Width="140"/>
                                <DataGridTextColumn Header="Tổng Đơn" Binding="{Binding OrderCount}" Width="90"/>
                                <DataGridTextColumn Header="Điểm (Points)" Binding="{Binding LoyaltyPoints}" Width="100"/>
                                
                                <DataGridTemplateColumn Header="Trạng thái" Width="100">
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate>
                                            <Border CornerRadius="4" Padding="6,2" HorizontalAlignment="Left" VerticalAlignment="Center">
                                                <Border.Style>
                                                    <Style TargetType="Border">
                                                        <Setter Property="Background" Value="#ECFDF5"/>
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding IsActive}" Value="False">
                                                                <Setter Property="Background" Value="#FEF2F2"/>
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </Border.Style>
                                                <TextBlock FontWeight="SemiBold" FontSize="11">
                                                    <TextBlock.Style>
                                                        <Style TargetType="TextBlock">
                                                            <Setter Property="Text" Value="Active"/>
                                                            <Setter Property="Foreground" Value="#059669"/>
                                                            <Style.Triggers>
                                                                <DataTrigger Binding="{Binding IsActive}" Value="False">
                                                                    <Setter Property="Text" Value="Banned"/>
                                                                    <Setter Property="Foreground" Value="#991B1B"/>
                                                                </DataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </TextBlock.Style>
                                                </TextBlock>
                                            </Border>
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>

                                <DataGridTemplateColumn Header="Actions" Width="170">
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate>
                                            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                                <!-- View Detail Button -->
                                                <Button Content="View Detail"
                                                        Command="{Binding DataContext.ViewDetailCommand, RelativeSource={RelativeSource AncestorType=DataGrid}}"
                                                        CommandParameter="{Binding Id}"
                                                        Padding="10,4" Background="#F1F5F9" Foreground="#0F172A" FontSize="12" FontWeight="Medium" BorderThickness="0" Margin="0,0,6,0">
                                                    <Button.Resources>
                                                        <Style TargetType="Border">
                                                            <Setter Property="CornerRadius" Value="4"/>
                                                        </Style>
                                                    </Button.Resources>
                                                </Button>
                                                
                                                <!-- Ban/Unban Button -->
                                                <Button Command="{Binding DataContext.ToggleStatusCommand, RelativeSource={RelativeSource AncestorType=DataGrid}}"
                                                        CommandParameter="{Binding Id}"
                                                        Padding="10,4" Foreground="White" FontSize="12" FontWeight="SemiBold" BorderThickness="0">
                                                    <Button.Style>
                                                        <Style TargetType="Button">
                                                            <Setter Property="Content" Value="Ban"/>
                                                            <Setter Property="Background" Value="#EF4444"/>
                                                            <Setter Property="Template">
                                                                <Setter.Value>
                                                                    <ControlTemplate TargetType="Button">
                                                                        <Border Background="{TemplateBinding Background}" CornerRadius="4">
                                                                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" Margin="{TemplateBinding Padding}"/>
                                                                        </Border>
                                                                    </ControlTemplate>
                                                                </Setter.Value>
                                                            </Setter>
                                                            <Style.Triggers>
                                                                <DataTrigger Binding="{Binding IsActive}" Value="False">
                                                                    <Setter Property="Content" Value="Unban"/>
                                                                    <Setter Property="Background" Value="#10B981"/>
                                                                </DataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </Button.Style>
                                                </Button>
                                            </StackPanel>
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>
                            </DataGrid.Columns>
                        </DataGrid>

                        <!-- Loading Overlay -->
                        <Border Background="#80FFFFFF" 
                                Visibility="{Binding IsLoading, Converter={StaticResource BoolToVis}}">
                            <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                                <TextBlock Text="Loading..." FontSize="16" FontWeight="Medium" Foreground="#475569"/>
                            </StackPanel>
                        </Border>
                    </Grid>
                </Border>
            </Grid>
        </Grid>

        <!-- CUSTOMER DETAIL POPUP -->
        <Border Grid.ColumnSpan="2" Background="#66000000" Visibility="{Binding IsCustomerDetailPopupOpen, Converter={StaticResource BoolToVis}}" Panel.ZIndex="100">
            <Border Background="White" CornerRadius="12" Width="780" Height="580" HorizontalAlignment="Center" VerticalAlignment="Center">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="56"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    
                    <!-- Header -->
                    <Border BorderBrush="#E2E8F0" BorderThickness="0,0,0,1" Padding="20,0">
                        <Grid>
                            <TextBlock Text="Thông tin khách hàng" FontWeight="Bold" FontSize="16" Foreground="#0F172A" VerticalAlignment="Center"/>
                            <Button HorizontalAlignment="Right" Content="✕" Width="28" Height="28" 
                                    Background="Transparent" BorderThickness="0" FontSize="14" Cursor="Hand" Foreground="#64748B"
                                    Command="{Binding CloseCustomerDetailPopupCommand}"/>
                        </Grid>
                    </Border>
                    
                    <!-- Content -->
                    <Grid Grid.Row="1" Margin="20">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="280"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        
                        <!-- Left side: Customer Info -->
                        <StackPanel Grid.Column="0" Margin="0,0,20,0">
                            <TextBlock Text="Tên khách hàng" FontWeight="SemiBold" FontSize="12" Foreground="#64748B" Margin="0,0,0,4"/>
                            <TextBox Text="{Binding EditingCustomerName}" Style="{StaticResource SearchTextBoxStyle}" Margin="0,0,0,14"/>
                            
                            <TextBlock Text="Số điện thoại" FontWeight="SemiBold" FontSize="12" Foreground="#64748B" Margin="0,0,0,4"/>
                            <TextBox Text="{Binding EditingCustomerPhone}" Style="{StaticResource SearchTextBoxStyle}" Margin="0,0,0,14"/>
                            
                            <TextBlock Text="Email" FontWeight="SemiBold" FontSize="12" Foreground="#64748B" Margin="0,0,0,4"/>
                            <TextBox Text="{Binding EditingCustomerEmail}" Style="{StaticResource SearchTextBoxStyle}" Margin="0,0,0,20"/>
                            
                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                                <Button Content="Ban / Unban" Command="{Binding ToggleCustomerStatusFromPopupCommand}"
                                        Background="#EF4444" Foreground="White" BorderThickness="0" Padding="14,6" FontSize="12" FontWeight="SemiBold" Margin="0,0,8,0">
                                    <Button.Resources>
                                        <Style TargetType="Border">
                                            <Setter Property="CornerRadius" Value="6"/>
                                        </Style>
                                    </Button.Resources>
                                </Button>
                                <Button Content="Cập nhật" Command="{Binding UpdateCustomerCommand}" 
                                        Background="#2563EB" Foreground="White" BorderThickness="0" Padding="14,6" FontSize="12" FontWeight="SemiBold">
                                    <Button.Resources>
                                        <Style TargetType="Border">
                                            <Setter Property="CornerRadius" Value="6"/>
                                        </Style>
                                    </Button.Resources>
                                </Button>
                            </StackPanel>
                        </StackPanel>
                        
                        <!-- Right side: Orders List -->
                        <Grid Grid.Column="1">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>
                            
                            <TextBlock Text="Lịch sử mua hàng" FontWeight="SemiBold" FontSize="14" Foreground="#0F172A" Margin="0,0,0,10"/>
                            
                            <DataGrid Grid.Row="1" ItemsSource="{Binding SelectedCustomerDetail.Orders}" 
                                      AutoGenerateColumns="False" CanUserAddRows="False" IsReadOnly="True"
                                      HeadersVisibility="Column" Background="Transparent" BorderBrush="#E2E8F0" BorderThickness="1"
                                      RowHeight="38" VerticalScrollBarVisibility="Auto">
                                <DataGrid.Columns>
                                    <DataGridTextColumn Header="Ngày tạo" Binding="{Binding CreatedAt, StringFormat=\{0:dd/MM/yyyy HH:mm\}}" Width="130"/>
                                    <DataGridTextColumn Header="Tổng tiền" Binding="{Binding TotalAmount, StringFormat=\{0:N0\} ₫}" Width="*"/>
                                    
                                    <DataGridTemplateColumn Header="" Width="90">
                                        <DataGridTemplateColumn.CellTemplate>
                                            <DataTemplate>
                                                <Button Content="View Detail" 
                                                        Command="{Binding DataContext.ViewOrderDetailCommand, RelativeSource={RelativeSource AncestorType=DataGrid}}"
                                                        CommandParameter="{Binding Id}"
                                                        Background="#F1F5F9" Foreground="#0F172A" FontSize="11" FontWeight="Medium" BorderThickness="0" Padding="6,3">
                                                    <Button.Resources>
                                                        <Style TargetType="Border">
                                                            <Setter Property="CornerRadius" Value="4"/>
                                                        </Style>
                                                    </Button.Resources>
                                                </Button>
                                            </DataTemplate>
                                        </DataGridTemplateColumn.CellTemplate>
                                    </DataGridTemplateColumn>
                                </DataGrid.Columns>
                            </DataGrid>
                        </Grid>
                    </Grid>
                </Grid>
            </Border>
        </Border>

        <!-- ORDER DETAIL POPUP -->
        <Border Grid.ColumnSpan="2" Background="#66000000" Visibility="{Binding IsOrderDetailPopupOpen, Converter={StaticResource BoolToVis}}" Panel.ZIndex="200">
            <Border Background="White" CornerRadius="12" Width="680" Height="600" HorizontalAlignment="Center" VerticalAlignment="Center">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="56"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>
                    
                    <!-- Header -->
                    <Border BorderBrush="#E2E8F0" BorderThickness="0,0,0,1" Padding="20,0">
                        <Grid>
                            <TextBlock Text="Chi tiết đơn hàng" FontWeight="Bold" FontSize="16" Foreground="#0F172A" VerticalAlignment="Center"/>
                            <Button HorizontalAlignment="Right" Content="✕" Width="28" Height="28" 
                                    Background="Transparent" BorderThickness="0" FontSize="14" Cursor="Hand" Foreground="#64748B"
                                    Command="{Binding CloseBothPopupsCommand}"/>
                        </Grid>
                    </Border>
                    
                    <!-- Content -->
                    <Grid Grid.Row="1" Margin="20">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="*"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <!-- Items Grid -->
                        <DataGrid Grid.Row="0" ItemsSource="{Binding SelectedOrderDetail.Items}" 
                                  AutoGenerateColumns="False" CanUserAddRows="False" IsReadOnly="True"
                                  HeadersVisibility="Column" Background="Transparent" BorderBrush="#E2E8F0" BorderThickness="1"
                                  RowHeight="36" Margin="0,0,0,14">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="Sản phẩm" Binding="{Binding ProductName}" Width="*"/>
                                <DataGridTextColumn Header="Đơn giá" Binding="{Binding UnitPrice, StringFormat=\{0:N0\} ₫}" Width="100"/>
                                <DataGridTextColumn Header="SL" Binding="{Binding Quantity}" Width="45"/>
                                <DataGridTextColumn Header="Giảm giá" Binding="{Binding DiscountAmount, StringFormat=\{0:N0\} ₫}" Width="90"/>
                                <DataGridTextColumn Header="Thành tiền" Binding="{Binding Subtotal, StringFormat=\{0:N0\} ₫}" Width="100"/>
                            </DataGrid.Columns>
                        </DataGrid>

                        <!-- Summary Info -->
                        <Grid Grid.Row="1" Margin="0,0,0,14">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            
                            <StackPanel Grid.Column="0">
                                <TextBlock Text="Tổng phụ:" FontWeight="SemiBold" FontSize="12" Foreground="#64748B" Margin="0,2"/>
                                <TextBlock Text="{Binding SelectedOrderDetail.Subtotal, StringFormat=\{0:N0\} ₫}" FontSize="12" Foreground="#0F172A" Margin="0,0,0,6"/>
                                
                                <TextBlock Text="Giảm giá:" FontWeight="SemiBold" FontSize="12" Foreground="#64748B" Margin="0,2"/>
                                <TextBlock Text="{Binding SelectedOrderDetail.DiscountAmount, StringFormat=\{0:N0\} ₫}" FontSize="12" Foreground="#0F172A" Margin="0,0,0,6"/>
                                
                                <TextBlock Text="Điểm dùng (quy ra tiền):" FontWeight="SemiBold" FontSize="12" Foreground="#64748B" Margin="0,2"/>
                                <TextBlock Text="{Binding SelectedOrderDetail.PointsDiscountAmount, StringFormat=\{0:N0\} ₫}" FontSize="12" Foreground="#0F172A" Margin="0,0,0,6"/>
                            </StackPanel>
                            
                            <StackPanel Grid.Column="1">
                                <TextBlock Text="Điểm tích được:" FontWeight="SemiBold" FontSize="12" Foreground="#64748B" Margin="0,2"/>
                                <TextBlock Text="{Binding SelectedOrderDetail.PointsEarned}" FontSize="12" Foreground="#0F172A" Margin="0,0,0,6"/>
                                
                                <TextBlock Text="Phương thức thanh toán:" FontWeight="SemiBold" FontSize="12" Foreground="#64748B" Margin="0,2"/>
                                <TextBlock Text="{Binding SelectedOrderDetail.PaymentMethod}" FontSize="12" Foreground="#0F172A" Margin="0,0,0,6"/>
                                
                                <TextBlock Text="Tiền khách đưa:" FontWeight="SemiBold" FontSize="12" Foreground="#64748B" Margin="0,2"/>
                                <TextBlock Text="{Binding SelectedOrderDetail.AmountReceived, StringFormat=\{0:N0\} ₫}" FontSize="12" Foreground="#0F172A" Margin="0,0,0,6"/>
                                
                                <TextBlock Text="Tiền thối:" FontWeight="SemiBold" FontSize="12" Foreground="#64748B" Margin="0,2"/>
                                <TextBlock Text="{Binding SelectedOrderDetail.ChangeAmount, StringFormat=\{0:N0\} ₫}" FontSize="12" Foreground="#0F172A" Margin="0,0,0,6"/>
                            </StackPanel>
                        </Grid>
                        
                        <Border Grid.Row="2" Background="#EFF6FF" Padding="14" CornerRadius="6">
                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                                <TextBlock Text="TỔNG CỘNG:" FontWeight="Bold" FontSize="16" Foreground="#0F172A" VerticalAlignment="Center" Margin="0,0,12,0"/>
                                <TextBlock Text="{Binding SelectedOrderDetail.TotalAmount, StringFormat=\{0:N0\} ₫}" FontWeight="Black" FontSize="22" Foreground="#2563EB"/>
                            </StackPanel>
                        </Border>
                    </Grid>
                    
                    <!-- Footer Buttons -->
                    <Border Grid.Row="2" Background="#F8FAFC" BorderBrush="#E2E8F0" BorderThickness="0,1,0,0" Padding="20,12" CornerRadius="0,0,12,12">
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                            <Button Content="Trở về" Command="{Binding CloseOrderDetailPopupCommand}"
                                    Background="White" BorderBrush="#E2E8F0" BorderThickness="1" Foreground="#0F172A" Padding="14,6" FontSize="12" FontWeight="SemiBold" Margin="0,0,10,0">
                                <Button.Resources>
                                    <Style TargetType="Border">
                                        <Setter Property="CornerRadius" Value="6"/>
                                    </Style>
                                </Button.Resources>
                            </Button>
                            <Button Content="Đóng" Command="{Binding CloseBothPopupsCommand}" 
                                    Background="#EF4444" Foreground="White" BorderThickness="0" Padding="14,6" FontSize="12" FontWeight="SemiBold">
                                <Button.Resources>
                                    <Style TargetType="Border">
                                        <Setter Property="CornerRadius" Value="6"/>
                                    </Style>
                                </Button.Resources>
                            </Button>
                        </StackPanel>
                    </Border>
                </Grid>
            </Border>
        </Border>
    </Grid>
</UserControl>
