<UserControl x:Class="SmartPOS.WPF.Views.AuditLogView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:local="clr-namespace:SmartPOS.WPF.Views"
             xmlns:viewmodels="clr-namespace:SmartPOS.WPF.ViewModels"
             xmlns:converters="clr-namespace:SmartPOS.WPF.Converters"
             mc:Ignorable="d"
             d:DataContext="{d:DesignInstance Type=viewmodels:AuditLogViewModel}"
             Background="#F3F4F6"
             Foreground="#111827"
             d:DesignHeight="768" d:DesignWidth="1024">

    <UserControl.Resources>
        <BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter" />
        <converters:RoleToVisibilityConverter x:Key="RoleToVisibilityConverter" />
        <converters:UtcToVietnamTimeConverter x:Key="UtcToVietnamTimeConverter" />

        <Style x:Key="SidebarButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="#9CA3AF"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="16,12"/>
            <Setter Property="Margin" Value="8,4"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="HorizontalContentAlignment" Value="Left"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Name="Border" CornerRadius="8" Background="{TemplateBinding Background}" Padding="{TemplateBinding Padding}">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="{TemplateBinding Tag}" Margin="0,0,12,0" FontSize="16" VerticalAlignment="Center"/>
                                <ContentPresenter VerticalAlignment="Center"/>
                            </StackPanel>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Border" Property="Background" Value="#374151"/>
                                <Setter Property="Foreground" Value="White"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="SidebarActiveButtonStyle" TargetType="Button" BasedOn="{StaticResource SidebarButtonStyle}">
            <Setter Property="Background" Value="#6366F1"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Name="Border" CornerRadius="8" Background="{TemplateBinding Background}" Padding="{TemplateBinding Padding}">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="{TemplateBinding Tag}" Margin="0,0,12,0" FontSize="16" VerticalAlignment="Center"/>
                                <ContentPresenter VerticalAlignment="Center"/>
                            </StackPanel>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </UserControl.Resources>

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="240"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- SIDEBAR -->
        <Border Grid.Column="0" Background="#111827">
            <Grid Margin="0,24,0,24">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <StackPanel Grid.Row="0" Margin="20,0,20,32">
                    <TextBlock Text="SmartPOS" Foreground="White" FontSize="20" FontWeight="Black"/>
                    <TextBlock Text="Backoffice" Foreground="#6366F1" FontSize="14" FontWeight="Bold" Margin="0,2,0,0"/>
                </StackPanel>

                <StackPanel Grid.Row="1">
                    <Button Style="{StaticResource SidebarButtonStyle}" Tag="📊" Content="Overview" Command="{Binding NavigateToOverviewCommand}" Visibility="{Binding CurrentUserRole, Converter={StaticResource RoleToVisibilityConverter}}"/>
                    <Button Style="{StaticResource SidebarButtonStyle}" Tag="🗂️" Content="Catalog &amp; Promo" Command="{Binding NavigateToCatalogPromoCommand}" Visibility="{Binding CurrentUserRole, Converter={StaticResource RoleToVisibilityConverter}}"/>
                    <Button Style="{StaticResource SidebarButtonStyle}" Tag="📦" Content="Inventory" Command="{Binding NavigateToInventoryCommand}" Visibility="{Binding CurrentUserRole, Converter={StaticResource RoleToVisibilityConverter}}"/>
                    <Button Style="{StaticResource SidebarButtonStyle}" Tag="👥" Content="Users &amp; Staff" Command="{Binding NavigateToUsersCommand}" Visibility="{Binding CurrentUserRole, Converter={StaticResource RoleToVisibilityConverter}}"/>
                    <Button Style="{StaticResource SidebarButtonStyle}" Tag="📈" Content="Reports &amp; Analytics" Command="{Binding NavigateToReportsCommand}" Visibility="{Binding CurrentUserRole, Converter={StaticResource RoleToVisibilityConverter}}"/>
                    <Button Style="{StaticResource SidebarActiveButtonStyle}" Tag="📋" Content="Audit Logs" Visibility="{Binding CurrentUserRole, Converter={StaticResource RoleToVisibilityConverter}}"/>
                    <Button Style="{StaticResource SidebarButtonStyle}" Tag="⚙️" Content="Settings" Visibility="{Binding CurrentUserRole, Converter={StaticResource RoleToVisibilityConverter}}"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- MAIN CONTENT -->
        <Grid Grid.Column="1">
            <Grid.RowDefinitions>
                <RowDefinition Height="70"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- HEADER -->
            <Border Grid.Row="0" Background="White" BorderBrush="#E5E7EB" BorderThickness="0,0,0,1" Padding="24,0">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <TextBlock Grid.Column="0" Text="SMART STORE | BACKOFFICE" Foreground="#111827" FontSize="18" FontWeight="Black" VerticalAlignment="Center"/>

                    <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                        <Button Content="Switch to POS" Command="{Binding SwitchToPosCommand}" Background="#F3F4F6" Foreground="#4F46E5" FontWeight="Bold" BorderThickness="0" Padding="16,8" Cursor="Hand" Margin="0,0,20,0">
                            <Button.Resources>
                                <Style TargetType="Border">
                                    <Setter Property="CornerRadius" Value="6"/>
                                </Style>
                            </Button.Resources>
                        </Button>
                        
                        <Border Background="#F9FAFB" BorderBrush="#E5E7EB" BorderThickness="1" CornerRadius="20" Padding="12,4" Margin="0,0,16,0">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="{Binding CurrentUserName}" FontWeight="SemiBold" VerticalAlignment="Center" Margin="0,0,8,0"/>
                                <Border CornerRadius="12" Padding="8,2">
                                    <Border.Style>
                                        <Style TargetType="Border">
                                            <Setter Property="Background" Value="#FEE2E2"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding CurrentUserRole}" Value="Manager">
                                                    <Setter Property="Background" Value="#FEF3C7"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Border.Style>
                                    <TextBlock Text="{Binding CurrentUserRole}" FontSize="11" FontWeight="Bold">
                                        <TextBlock.Style>
                                            <Style TargetType="TextBlock">
                                                <Setter Property="Foreground" Value="#991B1B"/>
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding CurrentUserRole}" Value="Manager">
                                                        <Setter Property="Foreground" Value="#B45309"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </TextBlock.Style>
                                    </TextBlock>
                                </Border>
                            </StackPanel>
                        </Border>

                        <Button Content="Logout" Command="{Binding LogoutCommand}" Background="Transparent" Foreground="#6B7280" FontWeight="SemiBold" BorderThickness="0" Cursor="Hand"/>
                    </StackPanel>
                </Grid>
            </Border>

            <!-- AUDIT LOG CONTENT -->
            <Grid Grid.Row="1" Margin="24">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <TextBlock Grid.Row="0" Text="System Audit Logs" FontSize="24" FontWeight="Bold" Foreground="#111827" Margin="0,0,0,16"/>

                <!-- Header: search and actions -->
                <StackPanel Orientation="Horizontal" Grid.Row="1" VerticalAlignment="Center" Margin="0,0,0,16">
                    <TextBox Width="320" Margin="0,0,8,0" Text="{Binding FilterQuery, UpdateSourceTrigger=PropertyChanged}" Padding="8,6" />
                    <Button Content="Tải lại" Command="{Binding RefreshAsyncCommand}" Margin="0,0,8,0" Padding="16,6" Background="#4F46E5" Foreground="White" BorderThickness="0"/>
                    <ProgressBar Width="120" Height="16" IsIndeterminate="True" Visibility="{Binding IsLoading, Converter={StaticResource BooleanToVisibilityConverter}}" />
                    <TextBlock Text="{Binding ErrorMessage}" Foreground="Red" Margin="12,0,0,0" VerticalAlignment="Center" />
                </StackPanel>

                <!-- Content -->
                <Grid Grid.Row="2">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="2*"/>
                        <ColumnDefinition Width="1*"/>
                    </Grid.ColumnDefinitions>

                    <DataGrid Grid.Column="0" ItemsSource="{Binding Logs}" AutoGenerateColumns="False" SelectionMode="Single" SelectedItem="{Binding SelectedLog, Mode=TwoWay}" CanUserAddRows="False" IsReadOnly="True" Background="White" BorderBrush="#E5E7EB" BorderThickness="1">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Ngày" Binding="{Binding CreatedAt, Converter={StaticResource UtcToVietnamTimeConverter}, StringFormat=dd/MM/yyyy}" Width="100"/>
                            <DataGridTextColumn Header="Giờ" Binding="{Binding CreatedAt, Converter={StaticResource UtcToVietnamTimeConverter}, StringFormat=HH:mm:ss}" Width="100"/>
                            <DataGridTextColumn Header="Người dùng" Binding="{Binding User.Username}" Width="*"/>
                            <DataGridTextColumn Header="Hành động" Binding="{Binding Action}" Width="180"/>
                            <DataGridTextColumn Header="Đối tượng" Binding="{Binding Entity}" Width="120"/>
                            <DataGridTextColumn Header="ID Đối tượng" Binding="{Binding EntityId}" Width="120"/>
                        </DataGrid.Columns>
                    </DataGrid>

                    <!-- Details Pane -->
                    <Border Grid.Column="1" Background="White" BorderBrush="#E5E7EB" BorderThickness="1" CornerRadius="8" Padding="16" Margin="16,0,0,0">
                        <StackPanel>
                            <TextBlock Text="Chi tiết thay đổi" FontWeight="Bold" FontSize="16" Margin="0,0,0,16" Foreground="#111827" />

                            <TextBlock Text="Hành động:" FontWeight="SemiBold" Foreground="#4B5563"/>
                            <TextBlock Text="{Binding SelectedLog.Action}" TextWrapping="Wrap" Margin="0,4,0,12" Foreground="#111827"/>

                            <TextBlock Text="Đối tượng bị tác động:" FontWeight="SemiBold" Foreground="#4B5563"/>
                            <TextBlock Text="{Binding SelectedLog.Entity}" TextWrapping="Wrap" Margin="0,4,0,12" Foreground="#111827"/>

                            <TextBlock Text="ID Đối tượng:" FontWeight="SemiBold" Foreground="#4B5563"/>
                            <TextBlock Text="{Binding SelectedLog.EntityId}" TextWrapping="Wrap" Margin="0,4,0,12" Foreground="#111827"/>

                            <TextBlock Text="Giá trị Cũ (Old Value):" FontWeight="SemiBold" Foreground="#4B5563"/>
                            <TextBox Text="{Binding SelectedLog.OldValue}" TextWrapping="Wrap" AcceptsReturn="True" Height="100" IsReadOnly="True" VerticalScrollBarVisibility="Auto" Margin="0,4,0,12" Background="#F9FAFB"/>

                            <TextBlock Text="Giá trị Mới (New Value):" FontWeight="SemiBold" Foreground="#4B5563"/>
                            <TextBox Text="{Binding SelectedLog.NewValue}" TextWrapping="Wrap" AcceptsReturn="True" Height="100" IsReadOnly="True" VerticalScrollBarVisibility="Auto" Background="#F9FAFB"/>
                        </StackPanel>
                    </Border>
                </Grid>
            </Grid>
        </Grid>
    </Grid>
</UserControl>
