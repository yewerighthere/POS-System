<UserControl x:Class="SmartPOS.WPF.Views.UserManagementView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:SmartPOS.WPF.Views"
             xmlns:viewmodels="clr-namespace:SmartPOS.WPF.ViewModels"
             mc:Ignorable="d" 
             d:DataContext="{d:DesignInstance Type=viewmodels:UserManagementViewModel}"
             d:DesignHeight="600" d:DesignWidth="800">

    <UserControl.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis"/>

        <Style x:Key="SearchTextBoxStyle" TargetType="TextBox">
            <Setter Property="Padding" Value="12,8"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Height" Value="40"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="BorderBrush" Value="#E2E8F0"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TextBox">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="8">
                            <ScrollViewer x:Name="PART_ContentHost" Margin="0"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="ComboBoxStyle" TargetType="ComboBox">
            <Setter Property="Height" Value="40"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="Padding" Value="12,8"/>
        </Style>

        <Style x:Key="PrimaryButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="#0062FF"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Height" Value="40"/>
            <Setter Property="Padding" Value="24,0"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="8">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#004ECB"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="SecondaryButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="#F1F5F9"/>
            <Setter Property="Foreground" Value="#1E293B"/>
            <Setter Property="Height" Value="40"/>
            <Setter Property="Padding" Value="24,0"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="BorderBrush" Value="#E2E8F0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="{TemplateBinding BorderThickness}" CornerRadius="8">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#E2E8F0"/>
                </Trigger>
            </Style.Triggers>
        </Style>
    </UserControl.Resources>

    <Grid Background="White" Margin="0">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/> <!-- Search & Actions Bar -->
            <RowDefinition Height="*"/>    <!-- DataGrid -->
        </Grid.RowDefinitions>

        <!-- TOP BAR: Filters & Add Action -->
        <Grid Grid.Row="0" Margin="24,24,24,16">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>      <!-- Search term -->
                <ColumnDefinition Width="Auto"/>   <!-- Role filter -->
                <ColumnDefinition Width="Auto"/>   <!-- Status filter -->
                <ColumnDefinition Width="Auto"/>   <!-- Search button -->
                <ColumnDefinition Width="Auto"/>   <!-- Add User button -->
            </Grid.ColumnDefinitions>

            <TextBox Grid.Column="0" 
                     Text="{Binding SearchTerm, UpdateSourceTrigger=PropertyChanged}" 
                     Style="{StaticResource SearchTextBoxStyle}" 
                     Margin="0,0,12,0"
                     Tag="Tìm kiếm theo Tên, SĐT, Email..."
                     VerticalAlignment="Center"/>

            <StackPanel Grid.Column="1" Orientation="Horizontal" Margin="0,0,12,0" VerticalAlignment="Center">
                <TextBlock Text="Vai trò:" VerticalAlignment="Center" Margin="0,0,8,0" FontSize="13" FontWeight="SemiBold" Foreground="#475569"/>
                <ComboBox ItemsSource="{Binding RoleFilters}" 
                          SelectedItem="{Binding SelectedRoleFilter}"
                          Style="{StaticResource ComboBoxStyle}"
                          Width="110"/>
            </StackPanel>

            <StackPanel Grid.Column="2" Orientation="Horizontal" Margin="0,0,12,0" VerticalAlignment="Center">
                <TextBlock Text="Trạng thái:" VerticalAlignment="Center" Margin="0,0,8,0" FontSize="13" FontWeight="SemiBold" Foreground="#475569"/>
                <ComboBox ItemsSource="{Binding StatusFilters}" 
                          SelectedItem="{Binding SelectedStatusFilter}"
                          Style="{StaticResource ComboBoxStyle}"
                          Width="110"/>
            </StackPanel>

            <Button Grid.Column="3" 
                    Content="Lọc" 
                    Command="{Binding ApplyFilterCommand}" 
                    Style="{StaticResource SecondaryButtonStyle}"
                    Width="80" Margin="0,0,12,0"
                    VerticalAlignment="Center"/>

            <Button Grid.Column="4" 
                    Content="+ Thêm nhân viên" 
                    Command="{Binding OpenAddPopupCommand}" 
                    Style="{StaticResource PrimaryButtonStyle}"
                    Width="160"
                    VerticalAlignment="Center"/>
        </Grid>

        <!-- GRID CONTAINER -->
        <Grid Grid.Row="1" Margin="24,0,24,24">
            <DataGrid ItemsSource="{Binding Users}" 
                      AutoGenerateColumns="False" 
                      CanUserAddRows="False"
                      IsReadOnly="True"
                      HeadersVisibility="Column"
                      Background="Transparent"
                      BorderThickness="1"
                      BorderBrush="#E5E7EB"
                      RowHeight="50"
                      VerticalScrollBarVisibility="Auto">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="Tên đăng nhập" Binding="{Binding Username}" Width="120" FontWeight="Bold"/>
                    <DataGridTextColumn Header="Họ và tên" Binding="{Binding FullName}" Width="*"/>
                    <DataGridTextColumn Header="Email" Binding="{Binding Email}" Width="180"/>
                    <DataGridTextColumn Header="Số điện thoại" Binding="{Binding PhoneNumber}" Width="110"/>
                    <DataGridTextColumn Header="Vai trò" Binding="{Binding Role}" Width="90"/>
                    
                    <DataGridTemplateColumn Header="Trạng thái" Width="100">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <Border CornerRadius="12" Padding="8,4" HorizontalAlignment="Left" VerticalAlignment="Center">
                                    <Border.Style>
                                        <Style TargetType="Border">
                                            <Setter Property="Background" Value="#DCFCE7"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding Status}" Value="Locked">
                                                    <Setter Property="Background" Value="#FEE2E2"/>
                                                </DataTrigger>
                                                <DataTrigger Binding="{Binding Status}" Value="Inactive">
                                                    <Setter Property="Background" Value="#F3F4F6"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Border.Style>
                                    <TextBlock FontWeight="Bold" FontSize="11">
                                        <TextBlock.Style>
                                            <Style TargetType="TextBlock">
                                                <Setter Property="Text" Value="Hoạt động"/>
                                                <Setter Property="Foreground" Value="#166534"/>
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding Status}" Value="Locked">
                                                        <Setter Property="Text" Value="Bị khóa"/>
                                                        <Setter Property="Foreground" Value="#991B1B"/>
                                                    </DataTrigger>
                                                    <DataTrigger Binding="{Binding Status}" Value="Inactive">
                                                        <Setter Property="Text" Value="Ngừng HĐ"/>
                                                        <Setter Property="Foreground" Value="#4B5563"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </TextBlock.Style>
                                    </TextBlock>
                                </Border>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>

                    <DataGridTemplateColumn Header="Thao tác" Width="260">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                    <!-- Edit Button -->
                                    <Button Content="Sửa"
                                            Command="{Binding DataContext.OpenEditPopupCommand, RelativeSource={RelativeSource AncestorType=DataGrid}}"
                                            CommandParameter="{Binding}"
                                            Background="#F1F5F9" Foreground="#1E293B" BorderThickness="0" Padding="10,6" Margin="0,0,6,0" Cursor="Hand">
                                        <Button.Resources>
                                            <Style TargetType="Border">
                                                <Setter Property="CornerRadius" Value="6"/>
                                            </Style>
                                        </Button.Resources>
                                    </Button>

                                    <!-- Lock/Unlock Button -->
                                    <Button Command="{Binding DataContext.ToggleUserStatusCommand, RelativeSource={RelativeSource AncestorType=DataGrid}}"
                                            CommandParameter="{Binding Id}"
                                            Padding="10,6" Foreground="White" BorderThickness="0" Margin="0,0,6,0" Cursor="Hand">
                                        <Button.Style>
                                            <Style TargetType="Button">
                                                <Setter Property="Content" Value="Khóa"/>
                                                <Setter Property="Background" Value="#EF4444"/>
                                                <Setter Property="Template">
                                                    <Setter.Value>
                                                        <ControlTemplate TargetType="Button">
                                                            <Border Background="{TemplateBinding Background}" CornerRadius="6">
                                                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" Margin="{TemplateBinding Padding}"/>
                                                            </Border>
                                                        </ControlTemplate>
                                                    </Setter.Value>
                                                </Setter>
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding Status}" Value="Locked">
                                                        <Setter Property="Content" Value="Mở khóa"/>
                                                        <Setter Property="Background" Value="#10B981"/>
                                                    </DataTrigger>
                                                    <Trigger Property="IsMouseOver" Value="True">
                                                        <Setter Property="Opacity" Value="0.9"/>
                                                    </Trigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Button.Style>
                                    </Button>

                                    <!-- Reset Password Button -->
                                    <Button Content="Đổi mật khẩu"
                                            Command="{Binding DataContext.OpenResetPasswordPopupCommand, RelativeSource={RelativeSource AncestorType=DataGrid}}"
                                            CommandParameter="{Binding}"
                                            Background="#0062FF" Foreground="White" BorderThickness="0" Padding="10,6" Cursor="Hand">
                                        <Button.Resources>
                                            <Style TargetType="Border">
                                                <Setter Property="CornerRadius" Value="6"/>
                                            </Style>
                                        </Button.Resources>
                                    </Button>
                                </StackPanel>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>
                </DataGrid.Columns>
            </DataGrid>

            <!-- Loading Overlay -->
            <Border Background="#80FFFFFF" Visibility="{Binding IsLoading, Converter={StaticResource BoolToVis}}">
                <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                    <TextBlock Text="Đang xử lý..." FontSize="16" FontWeight="SemiBold" Foreground="#475569"/>
                </StackPanel>
            </Border>
        </Grid>

        <!-- ADD USER POPUP -->
        <Border Grid.RowSpan="2" Background="#80000000" Visibility="{Binding IsAddPopupOpen, Converter={StaticResource BoolToVis}}" Panel.ZIndex="100">
            <Border Background="White" CornerRadius="12" Width="450" Height="Auto" VerticalAlignment="Center" HorizontalAlignment="Center" Padding="24">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <Grid Grid.Row="0" Margin="0,0,0,16">
                        <TextBlock Text="Thêm tài khoản nhân viên" FontSize="18" FontWeight="Bold" Foreground="#1E293B"/>
                        <Button Content="✕" Command="{Binding ClosePopupsCommand}" HorizontalAlignment="Right" Background="Transparent" BorderThickness="0" FontSize="16" Cursor="Hand"/>
                    </Grid>

                    <StackPanel Grid.Row="1">
                        <TextBlock Text="Tên đăng nhập *" FontWeight="SemiBold" Foreground="#475569" Margin="0,0,0,6"/>
                        <TextBox Text="{Binding InputUsername, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource SearchTextBoxStyle}" Margin="0,0,0,12"/>

                        <TextBlock Text="Mật khẩu *" FontWeight="SemiBold" Foreground="#475569" Margin="0,0,0,6"/>
                        <TextBox Text="{Binding InputPassword, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource SearchTextBoxStyle}" Margin="0,0,0,12"/>

                        <TextBlock Text="Họ và tên *" FontWeight="SemiBold" Foreground="#475569" Margin="0,0,0,6"/>
                        <TextBox Text="{Binding InputFullName, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource SearchTextBoxStyle}" Margin="0,0,0,12"/>

                        <TextBlock Text="Email" FontWeight="SemiBold" Foreground="#475569" Margin="0,0,0,6"/>
                        <TextBox Text="{Binding InputEmail, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource SearchTextBoxStyle}" Margin="0,0,0,12"/>

                        <TextBlock Text="Số điện thoại" FontWeight="SemiBold" Foreground="#475569" Margin="0,0,0,6"/>
                        <TextBox Text="{Binding InputPhone, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource SearchTextBoxStyle}" Margin="0,0,0,12"/>

                        <TextBlock Text="Vai trò *" FontWeight="SemiBold" Foreground="#475569" Margin="0,0,0,6"/>
                        <ComboBox ItemsSource="{Binding RoleOptions}" SelectedItem="{Binding InputRole}" Style="{StaticResource ComboBoxStyle}" Margin="0,0,0,24"/>

                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                            <Button Content="Hủy" Command="{Binding ClosePopupsCommand}" Style="{StaticResource SecondaryButtonStyle}" Margin="0,0,12,0"/>
                            <Button Content="Xác nhận tạo" Command="{Binding AddUserCommand}" Style="{StaticResource PrimaryButtonStyle}"/>
                        </StackPanel>
                    </StackPanel>
                </Grid>
            </Border>
        </Border>

        <!-- EDIT USER POPUP -->
        <Border Grid.RowSpan="2" Background="#80000000" Visibility="{Binding IsEditPopupOpen, Converter={StaticResource BoolToVis}}" Panel.ZIndex="100">
            <Border Background="White" CornerRadius="12" Width="450" Height="Auto" VerticalAlignment="Center" HorizontalAlignment="Center" Padding="24">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <Grid Grid.Row="0" Margin="0,0,0,16">
                        <StackPanel>
                            <TextBlock Text="Cập nhật tài khoản" FontSize="18" FontWeight="Bold" Foreground="#1E293B"/>
                            <TextBlock Text="{Binding SelectedUser.Username, StringFormat='Tài khoản: {0}'}" FontSize="12" Foreground="#64748B" Margin="0,2,0,0"/>
                        </StackPanel>
                        <Button Content="✕" Command="{Binding ClosePopupsCommand}" HorizontalAlignment="Right" Background="Transparent" BorderThickness="0" FontSize="16" Cursor="Hand" VerticalAlignment="Top"/>
                    </Grid>

                    <StackPanel Grid.Row="1">
                        <TextBlock Text="Họ và tên *" FontWeight="SemiBold" Foreground="#475569" Margin="0,0,0,6"/>
                        <TextBox Text="{Binding EditFullName, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource SearchTextBoxStyle}" Margin="0,0,0,12"/>

                        <TextBlock Text="Email" FontWeight="SemiBold" Foreground="#475569" Margin="0,0,0,6"/>
                        <TextBox Text="{Binding EditEmail, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource SearchTextBoxStyle}" Margin="0,0,0,12"/>

                        <TextBlock Text="Số điện thoại" FontWeight="SemiBold" Foreground="#475569" Margin="0,0,0,6"/>
                        <TextBox Text="{Binding EditPhone, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource SearchTextBoxStyle}" Margin="0,0,0,12"/>

                        <TextBlock Text="Vai trò *" FontWeight="SemiBold" Foreground="#475569" Margin="0,0,0,6"/>
                        <ComboBox ItemsSource="{Binding RoleOptions}" SelectedItem="{Binding EditRole}" Style="{StaticResource ComboBoxStyle}" Margin="0,0,0,24"/>

                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                            <Button Content="Hủy" Command="{Binding ClosePopupsCommand}" Style="{StaticResource SecondaryButtonStyle}" Margin="0,0,12,0"/>
                            <Button Content="Lưu thay đổi" Command="{Binding UpdateUserCommand}" Style="{StaticResource PrimaryButtonStyle}"/>
                        </StackPanel>
                    </StackPanel>
                </Grid>
            </Border>
        </Border>

        <!-- RESET PASSWORD POPUP -->
        <Border Grid.RowSpan="2" Background="#80000000" Visibility="{Binding IsResetPasswordPopupOpen, Converter={StaticResource BoolToVis}}" Panel.ZIndex="100">
            <Border Background="White" CornerRadius="12" Width="400" Height="Auto" VerticalAlignment="Center" HorizontalAlignment="Center" Padding="24">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <Grid Grid.Row="0" Margin="0,0,0,16">
                        <StackPanel>
                            <TextBlock Text="Đặt lại mật khẩu" FontSize="18" FontWeight="Bold" Foreground="#1E293B"/>
                            <TextBlock Text="{Binding SelectedUser.Username, StringFormat='Nhân viên: {0}'}" FontSize="12" Foreground="#64748B" Margin="0,2,0,0"/>
                        </StackPanel>
                        <Button Content="✕" Command="{Binding ClosePopupsCommand}" HorizontalAlignment="Right" Background="Transparent" BorderThickness="0" FontSize="16" Cursor="Hand" VerticalAlignment="Top"/>
                    </Grid>

                    <StackPanel Grid.Row="1">
                        <TextBlock Text="Mật khẩu mới *" FontWeight="SemiBold" Foreground="#475569" Margin="0,0,0,6"/>
                        <TextBox Text="{Binding NewPasswordInput, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource SearchTextBoxStyle}" Margin="0,0,0,24"/>

                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                            <Button Content="Hủy" Command="{Binding ClosePopupsCommand}" Style="{StaticResource SecondaryButtonStyle}" Margin="0,0,12,0"/>
                            <Button Content="Cập nhật mật khẩu" Command="{Binding ResetPasswordCommand}" Style="{StaticResource PrimaryButtonStyle}"/>
                        </StackPanel>
                    </StackPanel>
                </Grid>
            </Border>
        </Border>
    </Grid>
</UserControl>
