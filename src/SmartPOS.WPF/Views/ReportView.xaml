<UserControl x:Class="SmartPOS.WPF.Views.ReportView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:conv="clr-namespace:SmartPOS.WPF.Converters"
             Background="#F8FAFC"
             Loaded="UserControl_Loaded">
    <UserControl.Resources>
        <SolidColorBrush x:Key="PrimaryBrush"        Color="#00288E"/>
        <SolidColorBrush x:Key="TextPrimaryBrush"    Color="#0F172A"/>
        <SolidColorBrush x:Key="TextSecondaryBrush"  Color="#64748B"/>
        <SolidColorBrush x:Key="BorderBrush"         Color="#E2E8F0"/>
        <SolidColorBrush x:Key="SuccessBrush"        Color="#16A34A"/>
        <SolidColorBrush x:Key="DangerBrush"         Color="#DC2626"/>

        <conv:NullToVisibilityConverter           x:Key="NullToVisibilityConverter"/>
        <conv:StringToVisibilityConverter         x:Key="StringToVisibilityConverter"/>
        <conv:BoolToVisibilityConverter           x:Key="BoolToVisibilityConverter"/>
        <conv:InverseBoolToVisibilityConverter    x:Key="InverseBoolToVisibilityConverter"/>
        <conv:PercentToGridLengthConverter        x:Key="PercentToGridLengthConverter"/>

        <!-- Sidebar inactive button -->
        <Style x:Key="SidebarInactiveButton" TargetType="Button">
            <Setter Property="Background"             Value="Transparent"/>
            <Setter Property="Foreground"             Value="#94A3B8"/>
            <Setter Property="BorderThickness"        Value="0"/>
            <Setter Property="Padding"                Value="16,10"/>
            <Setter Property="Margin"                 Value="8,2"/>
            <Setter Property="Cursor"                 Value="Hand"/>
            <Setter Property="HorizontalContentAlignment" Value="Left"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Name="Border" CornerRadius="8"
                                Background="{TemplateBinding Background}"
                                Padding="{TemplateBinding Padding}">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="{TemplateBinding Tag}" Margin="0,0,12,0"
                                           FontSize="14" VerticalAlignment="Center"/>
                                <ContentPresenter VerticalAlignment="Center"/>
                            </StackPanel>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Border" Property="Background" Value="#2A2B35"/>
                                <Setter Property="Foreground" Value="White"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- End Shift button -->
        <Style x:Key="EndShiftButton" TargetType="Button">
            <Setter Property="Background"      Value="#DC2626"/>
            <Setter Property="Foreground"      Value="White"/>
            <Setter Property="FontWeight"      Value="Bold"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Height"          Value="36"/>
            <Setter Property="Padding"         Value="16,0"/>
            <Setter Property="Cursor"          Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Name="Border" CornerRadius="8"
                                Background="{TemplateBinding Background}"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Border" Property="Background" Value="#B91C1C"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Generate Report button -->
        <Style x:Key="GenerateButtonStyle" TargetType="Button">
            <Setter Property="Background"      Value="{StaticResource PrimaryBrush}"/>
            <Setter Property="Foreground"      Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding"         Value="20,10"/>
            <Setter Property="FontSize"        Value="14"/>
            <Setter Property="FontWeight"      Value="SemiBold"/>
            <Setter Property="Cursor"          Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="8"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Opacity" Value="0.9"/>
                </Trigger>
                <Trigger Property="IsEnabled" Value="False">
                    <Setter Property="Opacity" Value="0.6"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- Outline button (for filter dropdowns) -->
        <Style x:Key="OutlineButtonStyle" TargetType="Button">
            <Setter Property="Background"      Value="White"/>
            <Setter Property="Foreground"      Value="{StaticResource TextSecondaryBrush}"/>
            <Setter Property="BorderBrush"     Value="{StaticResource BorderBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding"         Value="12,8"/>
            <Setter Property="FontSize"        Value="13"/>
            <Setter Property="Cursor"          Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Name="Border" CornerRadius="8"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Border" Property="Background" Value="#F1F5F9"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Summary card -->
        <Style x:Key="CardStyle" TargetType="Border">
            <Setter Property="Background"      Value="White"/>
            <Setter Property="CornerRadius"    Value="12"/>
            <Setter Property="Padding"         Value="20,16"/>
            <Setter Property="BorderBrush"     Value="{StaticResource BorderBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
        </Style>

        <Style x:Key="SectionHeaderStyle" TargetType="TextBlock">
            <Setter Property="FontSize"   Value="16"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}"/>
            <Setter Property="Margin"     Value="0,0,0,4"/>
        </Style>

        <Style x:Key="TableHeaderStyle" TargetType="TextBlock">
            <Setter Property="FontSize"   Value="11"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="{StaticResource TextSecondaryBrush}"/>
        </Style>

        <Style x:Key="TableCellStyle" TargetType="TextBlock">
            <Setter Property="FontSize"          Value="13"/>
            <Setter Property="Foreground"        Value="{StaticResource TextPrimaryBrush}"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
        </Style>
    </UserControl.Resources>

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="220"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- ═══════ LEFT SIDEBAR ═══════ -->
        <Border Grid.Column="0" Background="#1A1B22">
            <Grid Margin="0,24,0,24">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <StackPanel Grid.Row="0" Margin="20,0,20,32">
                    <TextBlock Text="SmartPOS Admin" Foreground="#E2E8F0" FontSize="18" FontWeight="Black"/>
                    <TextBlock Text="Terminal #01" Foreground="#94A3B8" FontSize="12" Margin="0,4,0,0" Opacity="0.8"/>
                </StackPanel>

                <StackPanel Grid.Row="1">
                    <Button Style="{StaticResource SidebarInactiveButton}" Tag="🖥️" Content="Point of Sale"     Command="{Binding NavigateToSalesCommand}"/>
                    <Button Style="{StaticResource SidebarInactiveButton}" Tag="🧾" Content="Transactions"/>
                    <Button Style="{StaticResource SidebarInactiveButton}" Tag="📦" Content="Inventory"          Command="{Binding NavigateToSyncCommand}"/>
                    <Button Style="{StaticResource SidebarInactiveButton}" Tag="👤" Content="Customers"         Command="{Binding NavigateToCustomerCommand}"/>
                    <Button Style="{StaticResource SidebarInactiveButton}" Tag="🔄" Content="Returns &amp; Refunds"/>
                    <Button Style="{StaticResource SidebarInactiveButton}" Tag="🗂️" Content="Product Catalog"   Command="{Binding NavigateToCatalogCommand}"/>
                    <!-- ACTIVE -->
                    <Border Background="#00288E" CornerRadius="8" Margin="8,2" Padding="16,10">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="📊" Margin="0,0,12,0" FontSize="14" VerticalAlignment="Center"/>
                            <TextBlock Text="Shift Reports" Foreground="White" FontSize="13" FontWeight="SemiBold" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Border>
                    <Button Style="{StaticResource SidebarInactiveButton}" Tag="⚙️" Content="Settings"/>
                </StackPanel>

                <!-- User profile at bottom -->
                <Border Grid.Row="2" Margin="12,0" Padding="10,10" CornerRadius="8">
                    <StackPanel Orientation="Horizontal">
                        <Border Width="32" Height="32" CornerRadius="16" Background="#374151" Margin="0,0,10,0">
                            <TextBlock Text="👤" FontSize="14" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <StackPanel VerticalAlignment="Center">
                            <TextBlock Text="Staff" Foreground="White" FontSize="12" FontWeight="SemiBold"/>
                            <TextBlock Text="Cashier" Foreground="#94A3B8" FontSize="11"/>
                        </StackPanel>
                    </StackPanel>
                </Border>
            </Grid>
        </Border>

        <!-- ═══════ MAIN CONTENT ═══════ -->
        <Grid Grid.Column="1">
            <Grid.RowDefinitions>
                <RowDefinition Height="64"/>   <!-- Top header bar -->
                <RowDefinition Height="Auto"/> <!-- Page sub-header with filters -->
                <RowDefinition Height="Auto"/> <!-- Status bars -->
                <RowDefinition Height="*"/>    <!-- Scrollable content -->
            </Grid.RowDefinitions>

            <!-- TOP HEADER BAR -->
            <Border Grid.Row="0" Background="White" BorderBrush="{StaticResource BorderBrush}"
                    BorderThickness="0,0,0,1" Padding="20,0">
                <Grid VerticalAlignment="Center">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <!-- Brand -->
                    <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center" Margin="0,0,24,0">
                        <TextBlock Text="SmartPOS" Foreground="{StaticResource PrimaryBrush}"
                                   FontSize="18" FontWeight="Black" VerticalAlignment="Center"/>
                        <TextBlock Text=" Retail" Foreground="{StaticResource TextSecondaryBrush}"
                                   FontSize="18" FontWeight="Light" VerticalAlignment="Center"/>
                    </StackPanel>

                    <!-- Search bar -->
                    <Border Grid.Column="1" BorderBrush="{StaticResource BorderBrush}" BorderThickness="1"
                            CornerRadius="8" Padding="12,8" Background="#F8FAFC" MaxWidth="360">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="🔍" FontSize="13" VerticalAlignment="Center" Margin="0,0,8,0"
                                       Foreground="{StaticResource TextSecondaryBrush}"/>
                            <TextBlock Text="Search orders, products..." FontSize="13"
                                       Foreground="{StaticResource TextSecondaryBrush}" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Border>

                    <!-- Right actions -->
                    <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center" Margin="16,0,0,0">
                        <!-- Notification bell -->
                        <Border Width="36" Height="36" CornerRadius="8" Background="#F1F5F9"
                                Cursor="Hand" Margin="0,0,8,0">
                            <TextBlock Text="🔔" FontSize="14" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <!-- Help icon -->
                        <Border Width="36" Height="36" CornerRadius="8" Background="#F1F5F9"
                                Cursor="Hand" Margin="0,0,16,0">
                            <TextBlock Text="❓" FontSize="14" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <Button Content="Support" Background="Transparent" Foreground="{StaticResource PrimaryBrush}"
                                FontWeight="SemiBold" FontSize="13" BorderThickness="0" Margin="0,0,12,0" Cursor="Hand"/>
                        <Button Content="End Shift" Style="{StaticResource EndShiftButton}"
                                Command="{Binding NavigateToSalesCommand}"/>
                    </StackPanel>
                </Grid>
            </Border>

            <!-- PAGE SUB-HEADER: title left, filters+button right in one row -->
            <Border Grid.Row="1" Background="White" BorderBrush="{StaticResource BorderBrush}"
                    BorderThickness="0,0,0,1" Padding="24,16">
                <Grid VerticalAlignment="Center">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <!-- Left: Title + subtitle -->
                    <StackPanel Grid.Column="0" VerticalAlignment="Center">
                        <TextBlock Text="Shift Reports" FontSize="22" FontWeight="Bold"
                                   Foreground="{StaticResource TextPrimaryBrush}"/>
                        <TextBlock Text="Review operational data and register performance."
                                   FontSize="13" Foreground="{StaticResource TextSecondaryBrush}" Margin="0,2,0,0"/>
                    </StackPanel>

                    <!-- Right: date + shift + staff + Generate Report -->
                    <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center">
                        <!-- Date -->
                        <Border BorderBrush="{StaticResource BorderBrush}" BorderThickness="1"
                                CornerRadius="8" Padding="12,8" Margin="0,0,8,0" Background="White" Cursor="Hand">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="📅" FontSize="12" Margin="0,0,6,0" VerticalAlignment="Center"
                                           Foreground="{StaticResource TextSecondaryBrush}"/>
                                <TextBlock FontSize="13" Foreground="{StaticResource TextPrimaryBrush}" VerticalAlignment="Center"
                                           Text="{Binding TodayDisplay, StringFormat='Today: {0}'}"/>
                            </StackPanel>
                        </Border>
                        <!-- Shift selector -->
                        <Button Style="{StaticResource OutlineButtonStyle}" Margin="0,0,8,0">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="Morning Shift (06:00 - 14:00)" FontSize="13"
                                           Foreground="{StaticResource TextPrimaryBrush}"/>
                                <TextBlock Text=" ▾" FontSize="11" Foreground="{StaticResource TextSecondaryBrush}"
                                           VerticalAlignment="Center"/>
                            </StackPanel>
                        </Button>
                        <!-- Staff selector -->
                        <Button Style="{StaticResource OutlineButtonStyle}" Margin="0,0,12,0">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="👤" FontSize="12" Margin="0,0,6,0"
                                           Foreground="{StaticResource TextSecondaryBrush}" VerticalAlignment="Center"/>
                                <TextBlock Text="All Staff" FontSize="13"
                                           Foreground="{StaticResource TextPrimaryBrush}"/>
                                <TextBlock Text=" ▾" FontSize="11" Foreground="{StaticResource TextSecondaryBrush}"
                                           VerticalAlignment="Center"/>
                            </StackPanel>
                        </Button>
                        <!-- Generate Report button -->
                        <Button Content="📊  Generate Report"
                                Style="{StaticResource GenerateButtonStyle}"
                                Command="{Binding GenerateReportCommand}"/>
                    </StackPanel>
                </Grid>
            </Border>

            <!-- STATUS BARS -->
            <StackPanel Grid.Row="2">
                <Border Background="#EFF6FF" Padding="16,10"
                        Visibility="{Binding IsLoading, Converter={StaticResource BoolToVisibilityConverter}}">
                    <TextBlock Text="⏳  Đang tải báo cáo..." FontSize="13" Foreground="{StaticResource PrimaryBrush}"/>
                </Border>
                <Border Background="#FEE2E2" Padding="16,10"
                        Visibility="{Binding ErrorMessage, Converter={StaticResource StringToVisibilityConverter}}">
                    <TextBlock Text="{Binding ErrorMessage}" FontSize="13" Foreground="{StaticResource DangerBrush}"/>
                </Border>
            </StackPanel>

            <!-- SCROLLABLE CONTENT -->
            <ScrollViewer Grid.Row="3" VerticalScrollBarVisibility="Auto" Padding="24,20,24,24">
                <StackPanel>

                    <!-- Empty state: shown when no report yet -->
                    <Border Style="{StaticResource CardStyle}"
                            Visibility="{Binding ShiftReport, Converter={StaticResource NullToVisibilityConverter}, ConverterParameter=inverse}">
                        <StackPanel HorizontalAlignment="Center" Margin="0,48">
                            <TextBlock Text="📋" FontSize="52" HorizontalAlignment="Center" Margin="0,0,0,16"/>
                            <TextBlock Text="Chưa có báo cáo" FontSize="20" FontWeight="SemiBold"
                                       Foreground="{StaticResource TextPrimaryBrush}" HorizontalAlignment="Center"/>
                            <TextBlock Text="Bấm &quot;Generate Report&quot; để xem số liệu ca hiện tại"
                                       FontSize="13" Foreground="{StaticResource TextSecondaryBrush}"
                                       HorizontalAlignment="Center" Margin="0,8,0,0"/>
                        </StackPanel>
                    </Border>

                    <!-- ── 4 SUMMARY CARDS ── -->
                    <Grid Visibility="{Binding ShiftReport, Converter={StaticResource NullToVisibilityConverter}}"
                          Margin="0,0,0,20">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="12"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="12"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="12"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <!-- TOTAL REVENUE -->
                        <Border Grid.Column="0" Style="{StaticResource CardStyle}">
                            <StackPanel>
                                <TextBlock Text="TOTAL REVENUE" Style="{StaticResource TableHeaderStyle}" Margin="0,0,0,10"/>
                                <TextBlock FontSize="28" FontWeight="Bold" Foreground="{StaticResource PrimaryBrush}"
                                           Text="{Binding ShiftReport.TotalSales, StringFormat='{}{0:N0} ₫'}"/>
                                <StackPanel Orientation="Horizontal" Margin="0,8,0,0">
                                    <TextBlock Text="↑ " FontSize="12" Foreground="#16A34A"/>
                                    <TextBlock FontSize="12" Foreground="#16A34A" FontWeight="SemiBold"
                                               Text="{Binding ShiftReport.AverageTicket, StringFormat='Avg. ticket: {0:N0} ₫'}"/>
                                </StackPanel>
                            </StackPanel>
                        </Border>

                        <!-- TOTAL ORDERS -->
                        <Border Grid.Column="2" Style="{StaticResource CardStyle}">
                            <StackPanel>
                                <TextBlock Text="TOTAL ORDERS" Style="{StaticResource TableHeaderStyle}" Margin="0,0,0,10"/>
                                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                    <TextBlock FontSize="28" FontWeight="Bold" Foreground="{StaticResource PrimaryBrush}"
                                               Text="{Binding ShiftReport.TotalOrders}"/>
                                    <TextBlock Text=" transactions" FontSize="14" Foreground="{StaticResource TextSecondaryBrush}"
                                               VerticalAlignment="Bottom" Margin="4,0,0,4"/>
                                </StackPanel>
                                <TextBlock FontSize="12" Foreground="{StaticResource TextSecondaryBrush}" Margin="0,6,0,0"
                                           Text="{Binding ShiftReport.AverageTicket, StringFormat='Avg. ticket: {0:N0} ₫'}"/>
                            </StackPanel>
                        </Border>

                        <!-- CASH VS VNPAY — two-segment bar -->
                        <Border Grid.Column="4" Style="{StaticResource CardStyle}">
                            <StackPanel>
                                <TextBlock Text="CASH VS VNPAY" Style="{StaticResource TableHeaderStyle}" Margin="0,0,0,10"/>

                                <!-- Two-color segmented bar -->
                                <Grid Height="32" Margin="0,0,0,10">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="{Binding CashPercent, Converter={StaticResource PercentToGridLengthConverter}, Mode=OneWay}"/>
                                        <ColumnDefinition Width="{Binding VNPayPercent, Converter={StaticResource PercentToGridLengthConverter}, Mode=OneWay}"/>
                                    </Grid.ColumnDefinitions>
                                    <!-- Cash segment (left-rounded) -->
                                    <Border Grid.Column="0" Background="#00288E" CornerRadius="6,0,0,6">
                                        <TextBlock Text="{Binding CashPercent, StringFormat='{}{0:F0}%'}"
                                                   FontSize="12" FontWeight="Bold" Foreground="White"
                                                   HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    </Border>
                                    <!-- VNPay segment (right-rounded) -->
                                    <Border Grid.Column="1" Background="#93C5FD" CornerRadius="0,6,6,0">
                                        <TextBlock Text="{Binding VNPayPercent, StringFormat='{}{0:F0}%'}"
                                                   FontSize="12" FontWeight="Bold" Foreground="#1E3A8A"
                                                   HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    </Border>
                                </Grid>

                                <!-- Legend -->
                                <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                                    <Ellipse Width="8" Height="8" Fill="#00288E" Margin="0,0,6,0" VerticalAlignment="Center"/>
                                    <TextBlock Text="Cash" FontSize="12" Foreground="{StaticResource TextSecondaryBrush}" Margin="0,0,16,0"/>
                                    <Ellipse Width="8" Height="8" Fill="#93C5FD" Margin="0,0,6,0" VerticalAlignment="Center"/>
                                    <TextBlock Text="VNPay" FontSize="12" Foreground="{StaticResource TextSecondaryBrush}"/>
                                </StackPanel>

                                <!-- Amounts -->
                                <Grid>
                                    <TextBlock FontSize="12" Foreground="{StaticResource TextSecondaryBrush}"
                                               Text="{Binding ShiftReport.CashRevenue, StringFormat='{}{0:N0} ₫'}"/>
                                    <TextBlock HorizontalAlignment="Right" FontSize="12" Foreground="{StaticResource TextSecondaryBrush}"
                                               Text="{Binding ShiftReport.VNPayRevenue, StringFormat='{}{0:N0} ₫'}"/>
                                </Grid>
                            </StackPanel>
                        </Border>

                        <!-- CASH DIFFERENCE -->
                        <Border Grid.Column="6" Style="{StaticResource CardStyle}">
                            <StackPanel>
                                <TextBlock Text="CASH DIFFERENCE" Style="{StaticResource TableHeaderStyle}" Margin="0,0,0,10"/>
                                <TextBlock FontSize="28" FontWeight="Bold"
                                           Text="{Binding ShiftReport.CashDifference, StringFormat='{}{0:N0} ₫', TargetNullValue='—'}">
                                    <TextBlock.Style>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="Foreground" Value="#16A34A"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding ShiftReport.IsCashDifferenceNegative}" Value="True">
                                                    <Setter Property="Foreground" Value="#DC2626"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </TextBlock.Style>
                                </TextBlock>
                                <Border CornerRadius="4" Padding="8,4" Margin="0,8,0,0" HorizontalAlignment="Left">
                                    <Border.Style>
                                        <Style TargetType="Border">
                                            <Setter Property="Background" Value="#DCFCE7"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding ShiftReport.IsCashDifferenceNegative}" Value="True">
                                                    <Setter Property="Background" Value="#FEE2E2"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Border.Style>
                                    <TextBlock FontSize="11" FontWeight="SemiBold">
                                        <TextBlock.Style>
                                            <Style TargetType="TextBlock">
                                                <Setter Property="Text"       Value="✓ Within Margin"/>
                                                <Setter Property="Foreground" Value="#16A34A"/>
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding ShiftReport.IsCashDifferenceNegative}" Value="True">
                                                        <Setter Property="Text"       Value="⚠ Over Budget"/>
                                                        <Setter Property="Foreground" Value="#DC2626"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </TextBlock.Style>
                                    </TextBlock>
                                </Border>
                            </StackPanel>
                        </Border>
                    </Grid>

                    <!-- ── RECENT SHIFTS + TOP PRODUCTS ── -->
                    <Grid Margin="0,0,0,20"
                          Visibility="{Binding ShiftReport, Converter={StaticResource NullToVisibilityConverter}}">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="16"/>
                            <ColumnDefinition Width="300"/>
                        </Grid.ColumnDefinitions>

                        <!-- Recent Shifts -->
                        <Border Grid.Column="0" Style="{StaticResource CardStyle}">
                            <StackPanel>
                                <Grid Margin="0,0,0,12">
                                    <TextBlock Text="Recent Shifts" Style="{StaticResource SectionHeaderStyle}"/>
                                    <TextBlock Text="View All" HorizontalAlignment="Right" VerticalAlignment="Center"
                                               FontSize="13" Foreground="{StaticResource PrimaryBrush}" Cursor="Hand"/>
                                </Grid>
                                <!-- Header row -->
                                <Grid Margin="0,0,0,8">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="80*"/>
                                        <ColumnDefinition Width="110*"/>
                                        <ColumnDefinition Width="140*"/>
                                        <ColumnDefinition Width="70*"/>
                                        <ColumnDefinition Width="140*"/>
                                        <ColumnDefinition Width="80*"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0" Text="SHIFT #"      Style="{StaticResource TableHeaderStyle}"/>
                                    <TextBlock Grid.Column="1" Text="STAFF"        Style="{StaticResource TableHeaderStyle}"/>
                                    <TextBlock Grid.Column="2" Text="OPEN / CLOSE" Style="{StaticResource TableHeaderStyle}"/>
                                    <TextBlock Grid.Column="3" Text="ORDERS"       Style="{StaticResource TableHeaderStyle}"/>
                                    <TextBlock Grid.Column="4" Text="REVENUE"      Style="{StaticResource TableHeaderStyle}"/>
                                    <TextBlock Grid.Column="5" Text="STATUS"       Style="{StaticResource TableHeaderStyle}"/>
                                </Grid>
                                <Rectangle Height="1" Fill="{StaticResource BorderBrush}" Margin="0,0,0,8"/>
                                <ItemsControl ItemsSource="{Binding RecentShifts}">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <StackPanel>
                                            <Grid Margin="0,12,0,12">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="80*"/>
                                                    <ColumnDefinition Width="110*"/>
                                                    <ColumnDefinition Width="140*"/>
                                                    <ColumnDefinition Width="70*"/>
                                                    <ColumnDefinition Width="140*"/>
                                                    <ColumnDefinition Width="80*"/>
                                                </Grid.ColumnDefinitions>
                                                <TextBlock Grid.Column="0" FontSize="13" FontWeight="SemiBold"
                                                           Foreground="{StaticResource PrimaryBrush}" VerticalAlignment="Center"
                                                           Text="{Binding DisplayId}"/>
                                                <TextBlock Grid.Column="1" Style="{StaticResource TableCellStyle}" FontSize="13"
                                                           Text="{Binding StaffName}" TextTrimming="CharacterEllipsis" VerticalAlignment="Center"/>
                                                <StackPanel Grid.Column="2" VerticalAlignment="Center">
                                                    <TextBlock FontSize="13" Foreground="{StaticResource TextPrimaryBrush}"
                                                               Text="{Binding OpenedAt, StringFormat='{}{0:dd/MM/yyyy HH:mm}'}"/>
                                                    <TextBlock FontSize="12" Foreground="{StaticResource TextSecondaryBrush}"
                                                               Text="{Binding ClosedAt, StringFormat='{}{0:dd/MM/yyyy HH:mm}', TargetNullValue='—'}"/>
                                                </StackPanel>
                                                <TextBlock Grid.Column="3" Style="{StaticResource TableCellStyle}"
                                                           Text="{Binding TotalOrders}"/>
                                                <TextBlock Grid.Column="4" Style="{StaticResource TableCellStyle}" FontWeight="SemiBold"
                                                           Text="{Binding TotalRevenue, StringFormat='{}{0:N0} ₫'}"/>
                                                <Border Grid.Column="5" CornerRadius="12" Padding="10,4" HorizontalAlignment="Left" VerticalAlignment="Center">
                                                    <Border.Style>
                                                        <Style TargetType="Border">
                                                            <Setter Property="Background" Value="#F1F5F9"/>
                                                            <Style.Triggers>
                                                                <DataTrigger Binding="{Binding Status}" Value="Open">
                                                                    <Setter Property="Background" Value="#1E3A8A"/>
                                                                </DataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </Border.Style>
                                                    <TextBlock FontSize="11" FontWeight="Bold">
                                                        <TextBlock.Style>
                                                            <Style TargetType="TextBlock">
                                                                <Setter Property="Foreground" Value="#64748B"/>
                                                                <Setter Property="Text"       Value="CLOSED"/>
                                                                <Style.Triggers>
                                                                    <DataTrigger Binding="{Binding Status}" Value="Open">
                                                                        <Setter Property="Foreground" Value="White"/>
                                                                        <Setter Property="Text"       Value="ACTIVE"/>
                                                                    </DataTrigger>
                                                                </Style.Triggers>
                                                            </Style>
                                                        </TextBlock.Style>
                                                    </TextBlock>
                                                </Border>
                                            </Grid>
                                            <Rectangle Height="1" Fill="{StaticResource BorderBrush}"/>
                                            </StackPanel>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </StackPanel>
                        </Border>

                        <!-- Top Products -->
                        <Border Grid.Column="2" Style="{StaticResource CardStyle}">
                            <StackPanel>
                                <TextBlock Text="Top Products" Style="{StaticResource SectionHeaderStyle}"/>
                                <TextBlock Text="Items with highest volume" FontSize="12"
                                           Foreground="{StaticResource TextSecondaryBrush}" Margin="0,0,0,16"/>
                                <ItemsControl ItemsSource="{Binding TopProducts}">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <StackPanel Margin="0,0,0,16">
                                                <Grid Margin="0,0,0,6">
                                                    <TextBlock Text="{Binding ProductName}" FontSize="13"
                                                               Foreground="{StaticResource TextPrimaryBrush}" FontWeight="Medium"/>
                                                    <TextBlock HorizontalAlignment="Right" FontSize="13" FontWeight="Bold"
                                                               Foreground="{StaticResource PrimaryBrush}"
                                                               Text="{Binding TotalSold, StringFormat='{}{0} Sold'}"/>
                                                </Grid>
                                                <ProgressBar Height="8"
                                                             Maximum="{Binding DataContext.MaxTopSold, RelativeSource={RelativeSource AncestorType=UserControl}, Mode=OneWay}"
                                                             Value="{Binding TotalSold, Mode=OneWay}"
                                                             Background="#E2E8F0"
                                                             Foreground="#00288E"
                                                             BorderThickness="0"/>
                                            </StackPanel>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                                <Border BorderBrush="{StaticResource BorderBrush}" BorderThickness="1"
                                        CornerRadius="8" Margin="0,8,0,0" Padding="12,8" Cursor="Hand">
                                    <TextBlock Text="Detailed Inventory Report" TextAlignment="Center"
                                               FontSize="13" Foreground="{StaticResource PrimaryBrush}" FontWeight="SemiBold"/>
                                </Border>
                            </StackPanel>
                        </Border>
                    </Grid>

                    <!-- ── DETAILED ORDER LOG ── -->
                    <Border Style="{StaticResource CardStyle}" Margin="0,0,0,24"
                            Visibility="{Binding ShiftReport, Converter={StaticResource NullToVisibilityConverter}}">
                        <StackPanel>
                            <!-- Log header -->
                            <Grid Margin="0,0,0,16">
                                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                    <TextBlock Text="Detailed Order Log" Style="{StaticResource SectionHeaderStyle}" Margin="0"/>
                                    <Border Background="#DCFCE7" CornerRadius="4" Padding="6,2" Margin="10,0,0,0" VerticalAlignment="Center">
                                        <TextBlock Text="LIVE" FontSize="10" FontWeight="Bold" Foreground="#16A34A"/>
                                    </Border>
                                </StackPanel>
                                <StackPanel HorizontalAlignment="Right" Orientation="Horizontal">
                                    <Border BorderBrush="{StaticResource BorderBrush}" BorderThickness="1"
                                            CornerRadius="6" Padding="10,6" Margin="0,0,8,0" Cursor="Hand">
                                        <TextBlock Text="All Payment Methods ▾" FontSize="12"
                                                   Foreground="{StaticResource TextSecondaryBrush}"/>
                                    </Border>
                                    <Border BorderBrush="{StaticResource BorderBrush}" BorderThickness="1"
                                            CornerRadius="6" Padding="10,6" Cursor="Hand">
                                        <TextBlock Text="⬇ Export" FontSize="12" Foreground="{StaticResource TextSecondaryBrush}"/>
                                    </Border>
                                </StackPanel>
                            </Grid>

                            <!-- Column headers -->
                            <Grid Margin="0,0,0,8">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="90*"/>
                                    <ColumnDefinition Width="55*"/>
                                    <ColumnDefinition Width="110*"/>
                                    <ColumnDefinition Width="120*"/>
                                    <ColumnDefinition Width="130*"/>
                                    <ColumnDefinition Width="140*"/>
                                    <ColumnDefinition Width="100*"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Text="ORDER #"       Style="{StaticResource TableHeaderStyle}"/>
                                <TextBlock Grid.Column="1" Text="TIME"          Style="{StaticResource TableHeaderStyle}"/>
                                <TextBlock Grid.Column="2" Text="STAFF"         Style="{StaticResource TableHeaderStyle}"/>
                                <TextBlock Grid.Column="3" Text="ITEMS SUMMARY" Style="{StaticResource TableHeaderStyle}"/>
                                <TextBlock Grid.Column="4" Text="PAYMENT"       Style="{StaticResource TableHeaderStyle}"/>
                                <TextBlock Grid.Column="5" Text="AMOUNT"        Style="{StaticResource TableHeaderStyle}" TextAlignment="Right" Margin="0,0,16,0"/>
                                <TextBlock Grid.Column="6" Text="STATUS"        Style="{StaticResource TableHeaderStyle}" Margin="8,0,0,0"/>
                            </Grid>
                            <Rectangle Height="1" Fill="{StaticResource BorderBrush}" Margin="0,0,0,8"/>

                            <!-- Rows -->
                            <ItemsControl ItemsSource="{Binding OrderLog}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <StackPanel>
                                        <Grid Margin="0,14,0,14">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="90*"/>
                                                <ColumnDefinition Width="55*"/>
                                                <ColumnDefinition Width="110*"/>
                                                <ColumnDefinition Width="120*"/>
                                                <ColumnDefinition Width="130*"/>
                                                <ColumnDefinition Width="140*"/>
                                                <ColumnDefinition Width="100*"/>
                                            </Grid.ColumnDefinitions>
                                            <!-- ORDER# -->
                                            <TextBlock Grid.Column="0" FontSize="13" FontWeight="SemiBold"
                                                       Foreground="{StaticResource PrimaryBrush}" VerticalAlignment="Center"
                                                       Text="{Binding DisplayId}"/>
                                            <!-- TIME -->
                                            <TextBlock Grid.Column="1" Style="{StaticResource TableCellStyle}" FontSize="13"
                                                       Text="{Binding CreatedAt, StringFormat='{}{0:HH:mm}'}"/>
                                            <!-- STAFF -->
                                            <TextBlock Grid.Column="2" Style="{StaticResource TableCellStyle}" FontSize="13"
                                                       Text="{Binding StaffName}" TextTrimming="CharacterEllipsis"/>
                                            <!-- ITEMS SUMMARY -->
                                            <TextBlock Grid.Column="3" FontSize="13" VerticalAlignment="Center"
                                                       Foreground="{StaticResource TextSecondaryBrush}"
                                                       Text="{Binding ItemsSummary}"
                                                       TextTrimming="CharacterEllipsis" ToolTip="{Binding ItemsSummary}"/>
                                            <!-- PAYMENT -->
                                            <TextBlock Grid.Column="4" Style="{StaticResource TableCellStyle}" FontSize="13"
                                                       Text="{Binding PaymentMethod}"/>
                                            <!-- AMOUNT (right-aligned with right margin) -->
                                            <TextBlock Grid.Column="5" FontSize="13" FontWeight="SemiBold"
                                                       Foreground="{StaticResource TextPrimaryBrush}" VerticalAlignment="Center"
                                                       TextAlignment="Right" Margin="0,0,16,0"
                                                       Text="{Binding TotalAmount, StringFormat='{}{0:N0} ₫'}"/>
                                            <!-- STATUS badge -->
                                            <Border Grid.Column="6" CornerRadius="6" Padding="10,4"
                                                    HorizontalAlignment="Left" VerticalAlignment="Center" Margin="8,0,0,0">
                                                <Border.Style>
                                                    <Style TargetType="Border">
                                                        <Setter Property="Background" Value="#DCFCE7"/>
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding PaymentStatus}" Value="Pending">
                                                                <Setter Property="Background" Value="#FEF9C3"/>
                                                            </DataTrigger>
                                                            <DataTrigger Binding="{Binding PaymentStatus}" Value="Failed">
                                                                <Setter Property="Background" Value="#FEE2E2"/>
                                                            </DataTrigger>
                                                            <DataTrigger Binding="{Binding PaymentStatus}" Value="Timeout">
                                                                <Setter Property="Background" Value="#FEE2E2"/>
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </Border.Style>
                                                <TextBlock FontSize="11" FontWeight="Bold">
                                                    <TextBlock.Style>
                                                        <Style TargetType="TextBlock">
                                                            <Setter Property="Foreground" Value="#16A34A"/>
                                                            <Setter Property="Text"       Value="PAID"/>
                                                            <Style.Triggers>
                                                                <DataTrigger Binding="{Binding PaymentStatus}" Value="Pending">
                                                                    <Setter Property="Foreground" Value="#92400E"/>
                                                                    <Setter Property="Text"       Value="PENDING"/>
                                                                </DataTrigger>
                                                                <DataTrigger Binding="{Binding PaymentStatus}" Value="Failed">
                                                                    <Setter Property="Foreground" Value="#DC2626"/>
                                                                    <Setter Property="Text"       Value="FAILED"/>
                                                                </DataTrigger>
                                                                <DataTrigger Binding="{Binding PaymentStatus}" Value="Timeout">
                                                                    <Setter Property="Foreground" Value="#DC2626"/>
                                                                    <Setter Property="Text"       Value="TIMEOUT"/>
                                                                </DataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </TextBlock.Style>
                                                </TextBlock>
                                            </Border>
                                        </Grid>
                                        <Rectangle Height="1" Fill="{StaticResource BorderBrush}"/>
                                        </StackPanel>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </StackPanel>
                    </Border>

                </StackPanel>
            </ScrollViewer>
        </Grid>
    </Grid>
</UserControl>
