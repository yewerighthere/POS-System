<UserControl x:Class="SmartPOS.WPF.Views.ReportView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:viewmodels="clr-namespace:SmartPOS.WPF.ViewModels"
             xmlns:converters="clr-namespace:SmartPOS.WPF.Converters"
             mc:Ignorable="d"
             d:DataContext="{d:DesignInstance Type=viewmodels:ReportViewModel}"
             Background="#F8FAFC"
             Foreground="{StaticResource TextPrimaryBrush}"
             d:DesignHeight="768" d:DesignWidth="1024">

    <UserControl.Resources>
        <!-- Converters -->
        <converters:PercentToGridLengthConverter     x:Key="PercentToGridLengthConverter"/>
        <converters:NullToVisibilityConverter        x:Key="NullToVisibilityConverter"/>
        <converters:StringToVisibilityConverter      x:Key="StringToVisibilityConverter"/>
        <BooleanToVisibilityConverter                x:Key="BoolToVisibilityConverter"/>

        <!-- Vector Geometries -->
        <Geometry x:Key="IconPosData">M4 3h16a1 1 0 0 1 1 1v10a1 1 0 0 1-1 1H4a1 1 0 0 1-1-1V4a1 1 0 0 1 1-1zm0 13h16v2H4v-2zm7 3h2v2h-2v-2z</Geometry>
        <Geometry x:Key="IconInventoryData">M20 7l-8-4-8 4 8 4 8-4zm-16 3v8l8 4 8-4v-8l-8 4-8-4z</Geometry>
        <Geometry x:Key="IconCustomerData">M12 12c2.21 0 4-1.79 4-4s-1.79-4-4-4-4 1.79-4 4 1.79 4 4 4zm0 2c-2.67 0-8 1.34-8 4v2h16v-2c0-2.66-5.33-4-8-4z</Geometry>
        <Geometry x:Key="IconReturnData">M12 5V1L7 6l5 5V7c3.31 0 6 2.69 6 6s-2.69 6-6 6-6-2.69-6-6H4c0 4.42 3.58 8 8 8s8-3.58 8-8-3.58-8-8-8z</Geometry>
        <Geometry x:Key="IconCatalogData">M10 4H4c-1.1 0-1.99.9-1.99 2L2 18c0 1.1.9 2 2 2h16c1.1 0 2-.9 2-2V8c0-1.1-.9-2-2-2h-8l-2-2z</Geometry>
        <Geometry x:Key="IconReportData">M19 3H5c-1.1 0-2 .9-2 2v14c0 1.1.9 2 2 2h14c1.1 0 2-.9 2-2V5c0-1.1-.9-2-2-2zm-7 14h-2V9h2v8zm4 0h-2v-5h2v5zm-8 0H6v-3h2v3z</Geometry>
        <Geometry x:Key="IconSearchData">M15.5 14h-.79l-.28-.27C15.41 12.59 16 11.11 16 9.5 16 5.91 13.09 3 9.5 3S3 5.91 3 9.5 5.91 16 9.5 16c1.61 0 3.09-.59 4.23-1.57l.27.28v.79l5 4.99L20.49 19l-4.99-5zm-6 0C7.01 14 5 11.99 5 9.5S7.01 5 9.5 5 14 7.01 14 9.5 11.99 14 9.5 14z</Geometry>

        <!-- Generate Report button style -->
        <Style x:Key="GenerateButtonStyle" TargetType="Button">
            <Setter Property="Background"      Value="#2563EB"/>
            <Setter Property="Foreground"      Value="White"/>
            <Setter Property="FontWeight"      Value="SemiBold"/>
            <Setter Property="FontSize"        Value="13"/>
            <Setter Property="Padding"         Value="16,8"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor"          Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd" Background="{TemplateBinding Background}"
                                CornerRadius="6" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#1D4ED8"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="EndShiftButton" TargetType="Button">
            <Setter Property="Background"      Value="#EF4444"/>
            <Setter Property="Foreground"      Value="White"/>
            <Setter Property="FontWeight"      Value="SemiBold"/>
            <Setter Property="FontSize"        Value="12"/>
            <Setter Property="Padding"         Value="12,6"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor"          Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd" Background="{TemplateBinding Background}" CornerRadius="6" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="OutlineButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="White"/>
            <Setter Property="Foreground" Value="#0F172A"/>
            <Setter Property="BorderBrush" Value="#E2E8F0"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="12,6"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Name="Border" CornerRadius="6"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Border" Property="Background" Value="#F8FAFC"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Summary card style -->
        <Style x:Key="CardStyle" TargetType="Border">
            <Setter Property="Background" Value="White"/>
            <Setter Property="CornerRadius" Value="8"/>
            <Setter Property="Padding" Value="18,14"/>
            <Setter Property="BorderBrush" Value="#E2E8F0"/>
            <Setter Property="BorderThickness" Value="1"/>
        </Style>

        <Style x:Key="SectionHeaderStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="15"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Foreground" Value="#0F172A"/>
            <Setter Property="Margin" Value="0,0,0,4"/>
        </Style>

        <Style x:Key="TableHeaderStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Foreground" Value="#64748B"/>
        </Style>

        <Style x:Key="TableCellStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Foreground" Value="#0F172A"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
        </Style>
    </UserControl.Resources>

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="220"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- ═══════ LEFT SIDEBAR (Slate 900 #0F172A) ═══════ -->
        <Border Grid.Column="0" Background="#0F172A" BorderThickness="0">
            <Grid Margin="0,20,0,20">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/> <!-- Brand Header -->
                    <RowDefinition Height="*"/>    <!-- Navigation Panel -->
                    <RowDefinition Height="Auto"/> <!-- User profile footer -->
                </Grid.RowDefinitions>

                <!-- Brand Header -->
                <StackPanel Grid.Row="0" Margin="20,0,20,16" VerticalAlignment="Center">
                    <TextBlock Text="SmartPOS" Foreground="#F8FAFC" FontSize="18" FontWeight="Black"/>
                    <TextBlock Text="Terminal #01" Foreground="#94A3B8" FontSize="11" Margin="0,2,0,0"/>
                </StackPanel>

                <!-- Scrollable Navigation Items -->
                <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                    <StackPanel Margin="10,0">

                        <!-- SECTION 1: OPERATIONS -->
                        <TextBlock Text="OPERATIONS" Foreground="#64748B" FontSize="10" FontWeight="Bold" Margin="10,4,10,6"/>

                        <!-- Point of Sale -->
                        <Button Style="{StaticResource SidebarNavButtonStyle}" Command="{Binding NavigateToSalesCommand}" VerticalAlignment="Center" Height="40" Margin="0,2">
                            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                <Path Data="{StaticResource IconPosData}" Fill="#94A3B8" Width="16" Height="16" Stretch="Uniform" Margin="0,0,12,0"/>
                                <TextBlock Text="Point of Sale" FontSize="13" VerticalAlignment="Center"/>
                            </StackPanel>
                        </Button>

                        <!-- Returns & Refunds -->
                        <Button Style="{StaticResource SidebarNavButtonStyle}" Command="{Binding NavigateToReturnCommand}" VerticalAlignment="Center" Height="40" Margin="0,2">
                            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                <Path Data="{StaticResource IconReturnData}" Fill="#94A3B8" Width="16" Height="16" Stretch="Uniform" Margin="0,0,12,0"/>
                                <TextBlock Text="Returns &amp; Refunds" FontSize="13" VerticalAlignment="Center"/>
                            </StackPanel>
                        </Button>

                        <!-- SECTION 2: MANAGEMENT -->
                        <TextBlock Text="MANAGEMENT" Foreground="#64748B" FontSize="10" FontWeight="Bold" Margin="10,14,10,6"/>

                        <!-- Inventory -->
                        <Button Style="{StaticResource SidebarNavButtonStyle}" Command="{Binding NavigateToSyncCommand}" VerticalAlignment="Center" Height="40" Margin="0,2">
                            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                <Path Data="{StaticResource IconInventoryData}" Fill="#94A3B8" Width="16" Height="16" Stretch="Uniform" Margin="0,0,12,0"/>
                                <TextBlock Text="Inventory" FontSize="13" VerticalAlignment="Center"/>
                            </StackPanel>
                        </Button>

                        <!-- Product Catalog -->
                        <Button Style="{StaticResource SidebarNavButtonStyle}" Command="{Binding NavigateToCatalogCommand}" VerticalAlignment="Center" Height="40" Margin="0,2">
                            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                <Path Data="{StaticResource IconCatalogData}" Fill="#94A3B8" Width="16" Height="16" Stretch="Uniform" Margin="0,0,12,0"/>
                                <TextBlock Text="Product Catalog" FontSize="13" VerticalAlignment="Center"/>
                            </StackPanel>
                        </Button>

                        <!-- Customers -->
                        <Button Style="{StaticResource SidebarNavButtonStyle}" Command="{Binding NavigateToCustomerCommand}" VerticalAlignment="Center" Height="40" Margin="0,2">
                            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                <Path Data="{StaticResource IconCustomerData}" Fill="#94A3B8" Width="16" Height="16" Stretch="Uniform" Margin="0,0,12,0"/>
                                <TextBlock Text="Customers" FontSize="13" VerticalAlignment="Center"/>
                            </StackPanel>
                        </Button>

                        <!-- SECTION 3: ANALYTICS -->
                        <TextBlock Text="ANALYTICS" Foreground="#64748B" FontSize="10" FontWeight="Bold" Margin="10,14,10,6"/>

                        <!-- ACTIVE: Shift Reports (Royal Blue #2563EB) -->
                        <Border Background="#2563EB" CornerRadius="8" Margin="0,2" Padding="14,0" Height="40" VerticalAlignment="Center">
                            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                <Path Data="{StaticResource IconReportData}" Fill="White" Width="16" Height="16" Stretch="Uniform" Margin="0,0,12,0"/>
                                <TextBlock Text="Shift Reports" Foreground="White" FontSize="13" FontWeight="SemiBold" VerticalAlignment="Center"/>
                            </StackPanel>
                        </Border>

                    </StackPanel>
                </ScrollViewer>

                <!-- UNIFIED SIDEBAR FOOTER (Stacked Info: Shift, Staff, Current Time) -->
                <StackPanel Grid.Row="2" Margin="10,12,10,0">
                    <Border Padding="12" CornerRadius="8" Background="#1E293B">
                        <StackPanel>
                            <!-- Shift info -->
                            <StackPanel Margin="0,0,0,8">
                                <TextBlock Text="SHIFT INFO" Foreground="#94A3B8" FontSize="10" FontWeight="Bold"/>
                                <TextBlock Text="Shift #0042" Foreground="#F8FAFC" FontSize="12" FontWeight="SemiBold" Margin="0,2,0,0"/>
                            </StackPanel>

                            <!-- Staff info -->
                            <StackPanel Margin="0,0,0,8">
                                <TextBlock Text="STAFF / CASHIER" Foreground="#94A3B8" FontSize="10" FontWeight="Bold"/>
                                <TextBlock Text="Nguyen Van A" Foreground="#F8FAFC" FontSize="12" FontWeight="SemiBold" Margin="0,2,0,0"/>
                            </StackPanel>

                            <!-- Current Time -->
                            <StackPanel>
                                <TextBlock Text="CURRENT TIME" Foreground="#94A3B8" FontSize="10" FontWeight="Bold"/>
                                <TextBlock Text="Jun 7 - 2026, 12:22 AM" Foreground="#F8FAFC" FontSize="11" Margin="0,2,0,0"/>
                            </StackPanel>
                        </StackPanel>
                    </Border>
                </StackPanel>
            </Grid>
        </Border>

        <!-- ═══════ MAIN CONTENT ═══════ -->
        <Grid Grid.Column="1">
            <Grid.RowDefinitions>
                <RowDefinition Height="64"/>   <!-- Top header bar -->
                <RowDefinition Height="Auto"/> <!-- Page sub-header with filters -->
                <RowDefinition Height="Auto"/> <!-- Status bars -->
                <RowDefinition Height="*"/>    <!-- Scrollable content -->
            </Grid.RowDefinitions>

            <!-- TOP HEADER BAR -->
            <Border Grid.Row="0" Background="White" BorderBrush="#E2E8F0"
                    BorderThickness="0,0,0,1" Padding="20,0">
                <Grid VerticalAlignment="Center">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <!-- Brand -->
                    <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center" Margin="0,0,24,0">
                        <TextBlock Text="SmartPOS" Foreground="#2563EB"
                                   FontSize="18" FontWeight="Black" VerticalAlignment="Center"/>
                        <TextBlock Text=" Retail" Foreground="#64748B"
                                   FontSize="18" FontWeight="Light" VerticalAlignment="Center"/>
                    </StackPanel>

                    <!-- Search bar -->
                    <Border Grid.Column="1" BorderBrush="#E2E8F0" BorderThickness="1"
                            CornerRadius="6" Padding="10,6" Background="#F8FAFC" MaxWidth="360">
                        <StackPanel Orientation="Horizontal">
                            <Path Data="{StaticResource IconSearchData}" Fill="#94A3B8" Width="14" Height="14" Stretch="Uniform" VerticalAlignment="Center" Margin="0,0,8,0"/>
                            <TextBlock Text="Search orders, products..." FontSize="12"
                                       Foreground="#94A3B8" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Border>

                    <!-- Right actions -->
                    <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center" Margin="16,0,0,0">
                        <Button Content="Support" Background="Transparent" Foreground="#2563EB"
                                FontWeight="Bold" FontSize="12" BorderThickness="0" Margin="0,0,12,0" Cursor="Hand"/>
                        <Button Content="End Shift" Style="{StaticResource EndShiftButton}"
                                Command="{Binding NavigateToSalesCommand}"/>
                    </StackPanel>
                </Grid>
            </Border>

            <!-- PAGE SUB-HEADER: title left, filters+button right in one row -->
            <Border Grid.Row="1" Background="White" BorderBrush="#E2E8F0"
                    BorderThickness="0,0,0,1" Padding="24,14">
                <Grid VerticalAlignment="Center">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <!-- Left: Title + subtitle -->
                    <StackPanel Grid.Column="0" VerticalAlignment="Center">
                        <TextBlock Text="Shift Reports" FontSize="20" FontWeight="Bold" Foreground="#0F172A"/>
                        <TextBlock Text="Review operational data and register performance."
                                   FontSize="12" Foreground="#64748B" Margin="0,2,0,0"/>
                    </StackPanel>

                    <!-- Right: date + shift + staff + Generate Report -->
                    <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center">
                        <!-- Date -->
                        <Border BorderBrush="#E2E8F0" BorderThickness="1"
                                CornerRadius="6" Padding="10,6" Margin="0,0,8,0" Background="White">
                            <TextBlock FontSize="12" Foreground="#0F172A" VerticalAlignment="Center"
                                       Text="{Binding TodayDisplay, StringFormat='Today: {0}'}"/>
                        </Border>

                        <!-- Shift selector -->
                        <Button Style="{StaticResource OutlineButtonStyle}" Margin="0,0,8,0">
                            <TextBlock Text="Morning Shift (06:00 - 14:00)" FontSize="12" Foreground="#0F172A"/>
                        </Button>

                        <!-- Staff selector -->
                        <Button Style="{StaticResource OutlineButtonStyle}" Margin="0,0,10,0">
                            <TextBlock Text="All Staff" FontSize="12" Foreground="#0F172A"/>
                        </Button>

                        <!-- Generate Report button -->
                        <Button Content="Generate Report"
                                Style="{StaticResource GenerateButtonStyle}"
                                Command="{Binding GenerateReportCommand}"/>
                    </StackPanel>
                </Grid>
            </Border>

            <!-- STATUS BARS -->
            <StackPanel Grid.Row="2">
                <Border Background="#EFF6FF" Padding="16,8"
                        Visibility="{Binding IsLoading, Converter={StaticResource BoolToVisibilityConverter}}">
                    <TextBlock Text="Đang tải báo cáo..." FontSize="12" Foreground="#2563EB" FontWeight="Medium"/>
                </Border>
                <Border Background="#FEF2F2" Padding="16,8"
                        Visibility="{Binding ErrorMessage, Converter={StaticResource StringToVisibilityConverter}}">
                    <TextBlock Text="{Binding ErrorMessage}" FontSize="12" Foreground="#EF4444" FontWeight="Medium"/>
                </Border>
            </StackPanel>

            <!-- SCROLLABLE CONTENT -->
            <ScrollViewer Grid.Row="3" VerticalScrollBarVisibility="Auto" Padding="24,20">
                <StackPanel>

                    <!-- Empty state: shown when no report yet -->
                    <Border Style="{StaticResource CardStyle}"
                            Visibility="{Binding ShiftReport, Converter={StaticResource NullToVisibilityConverter}, ConverterParameter=inverse}">
                        <StackPanel HorizontalAlignment="Center" Margin="0,40">
                            <Path Data="{StaticResource IconReportData}" Fill="#94A3B8" Width="48" Height="48" Stretch="Uniform" HorizontalAlignment="Center" Margin="0,0,0,14"/>
                            <TextBlock Text="Chưa có báo cáo" FontSize="18" FontWeight="SemiBold"
                                       Foreground="#0F172A" HorizontalAlignment="Center"/>
                            <TextBlock Text="Bấm &quot;Generate Report&quot; để xem số liệu ca hiện tại"
                                       FontSize="12" Foreground="#64748B"
                                       HorizontalAlignment="Center" Margin="0,6,0,0"/>
                        </StackPanel>
                    </Border>

                    <!-- ── 4 SUMMARY CARDS ── -->
                    <Grid Visibility="{Binding ShiftReport, Converter={StaticResource NullToVisibilityConverter}}"
                          Margin="0,0,0,18">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="12"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="12"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="12"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <!-- TOTAL REVENUE -->
                        <Border Grid.Column="0" Style="{StaticResource CardStyle}">
                            <StackPanel>
                                <TextBlock Text="TOTAL REVENUE" Style="{StaticResource TableHeaderStyle}" Margin="0,0,0,8"/>
                                <TextBlock FontSize="24" FontWeight="Black" Foreground="#2563EB"
                                           Text="{Binding ShiftReport.TotalSales, StringFormat='{}{0:N0} ₫'}"/>
                                <StackPanel Orientation="Horizontal" Margin="0,6,0,0">
                                    <TextBlock FontSize="11" Foreground="#059669" FontWeight="SemiBold"
                                               Text="{Binding ShiftReport.AverageTicket, StringFormat='Avg. ticket: {0:N0} ₫'}"/>
                                </StackPanel>
                            </StackPanel>
                        </Border>

                        <!-- TOTAL ORDERS -->
                        <Border Grid.Column="2" Style="{StaticResource CardStyle}">
                            <StackPanel>
                                <TextBlock Text="TOTAL ORDERS" Style="{StaticResource TableHeaderStyle}" Margin="0,0,0,8"/>
                                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                    <TextBlock FontSize="24" FontWeight="Black" Foreground="#0F172A"
                                               Text="{Binding ShiftReport.TotalOrders}"/>
                                    <TextBlock Text=" orders" FontSize="12" Foreground="#64748B"
                                               VerticalAlignment="Bottom" Margin="4,0,0,3"/>
                                </StackPanel>
                                <TextBlock FontSize="11" Foreground="#64748B" Margin="0,6,0,0"
                                           Text="{Binding ShiftReport.AverageTicket, StringFormat='Avg. ticket: {0:N0} ₫'}"/>
                            </StackPanel>
                        </Border>

                        <!-- CASH VS VNPAY — two-segment bar -->
                        <Border Grid.Column="4" Style="{StaticResource CardStyle}">
                            <StackPanel>
                                <TextBlock Text="CASH VS VNPAY" Style="{StaticResource TableHeaderStyle}" Margin="0,0,0,8"/>

                                <!-- Two-color segmented bar -->
                                <Grid Height="28" Margin="0,0,0,8">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="{Binding CashPercent, Converter={StaticResource PercentToGridLengthConverter}, Mode=OneWay}"/>
                                        <ColumnDefinition Width="{Binding VNPayPercent, Converter={StaticResource PercentToGridLengthConverter}, Mode=OneWay}"/>
                                    </Grid.ColumnDefinitions>
                                    <!-- Cash segment (left-rounded) -->
                                    <Border Grid.Column="0" Background="#2563EB" CornerRadius="4,0,0,4">
                                        <TextBlock Text="{Binding CashPercent, StringFormat='{}{0:F0}%'}"
                                                   FontSize="11" FontWeight="Bold" Foreground="White"
                                                   HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    </Border>
                                    <!-- VNPay segment (right-rounded) -->
                                    <Border Grid.Column="1" Background="#93C5FD" CornerRadius="0,4,4,0">
                                        <TextBlock Text="{Binding VNPayPercent, StringFormat='{}{0:F0}%'}"
                                                   FontSize="11" FontWeight="Bold" Foreground="#1E3A8A"
                                                   HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    </Border>
                                </Grid>

                                <!-- Legend -->
                                <StackPanel Orientation="Horizontal" Margin="0,0,0,6">
                                    <Ellipse Width="8" Height="8" Fill="#2563EB" Margin="0,0,6,0" VerticalAlignment="Center"/>
                                    <TextBlock Text="Cash" FontSize="11" Foreground="#64748B" Margin="0,0,14,0"/>
                                    <Ellipse Width="8" Height="8" Fill="#93C5FD" Margin="0,0,6,0" VerticalAlignment="Center"/>
                                    <TextBlock Text="VNPay" FontSize="11" Foreground="#64748B"/>
                                </StackPanel>

                                <!-- Amounts -->
                                <Grid>
                                    <TextBlock FontSize="11" Foreground="#64748B"
                                               Text="{Binding ShiftReport.CashRevenue, StringFormat='{}{0:N0} ₫'}"/>
                                    <TextBlock HorizontalAlignment="Right" FontSize="11" Foreground="#64748B"
                                               Text="{Binding ShiftReport.VNPayRevenue, StringFormat='{}{0:N0} ₫'}"/>
                                </Grid>
                            </StackPanel>
                        </Border>

                        <!-- CASH DIFFERENCE -->
                        <Border Grid.Column="6" Style="{StaticResource CardStyle}">
                            <StackPanel>
                                <TextBlock Text="CASH DIFFERENCE" Style="{StaticResource TableHeaderStyle}" Margin="0,0,0,8"/>
                                <TextBlock FontSize="24" FontWeight="Black"
                                           Text="{Binding ShiftReport.CashDifference, StringFormat='{}{0:N0} ₫', TargetNullValue='—'}">
                                    <TextBlock.Style>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="Foreground" Value="#10B981"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding ShiftReport.IsCashDifferenceNegative}" Value="True">
                                                    <Setter Property="Foreground" Value="#EF4444"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </TextBlock.Style>
                                </TextBlock>
                                <Border CornerRadius="4" Padding="6,3" Margin="0,6,0,0" HorizontalAlignment="Left">
                                    <Border.Style>
                                        <Style TargetType="Border">
                                            <Setter Property="Background" Value="#ECFDF5"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding ShiftReport.IsCashDifferenceNegative}" Value="True">
                                                    <Setter Property="Background" Value="#FEF2F2"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Border.Style>
                                    <TextBlock FontSize="10" FontWeight="Bold">
                                        <TextBlock.Style>
                                            <Style TargetType="TextBlock">
                                                <Setter Property="Text" Value="Within Margin"/>
                                                <Setter Property="Foreground" Value="#059669"/>
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding ShiftReport.IsCashDifferenceNegative}" Value="True">
                                                        <Setter Property="Text" Value="Over Budget"/>
                                                        <Setter Property="Foreground" Value="#991B1B"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </TextBlock.Style>
                                    </TextBlock>
                                </Border>
                            </StackPanel>
                        </Border>
                    </Grid>

                    <!-- ── RECENT SHIFTS + TOP PRODUCTS ── -->
                    <Grid Margin="0,0,0,18"
                          Visibility="{Binding ShiftReport, Converter={StaticResource NullToVisibilityConverter}}">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="14"/>
                            <ColumnDefinition Width="280"/>
                        </Grid.ColumnDefinitions>

                        <!-- Recent Shifts -->
                        <Border Grid.Column="0" Style="{StaticResource CardStyle}">
                            <StackPanel>
                                <Grid Margin="0,0,0,10">
                                    <TextBlock Text="Recent Shifts" Style="{StaticResource SectionHeaderStyle}"/>
                                </Grid>
                                <!-- Header row -->
                                <Grid Margin="0,0,0,6">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="80*"/>
                                        <ColumnDefinition Width="110*"/>
                                        <ColumnDefinition Width="140*"/>
                                        <ColumnDefinition Width="70*"/>
                                        <ColumnDefinition Width="140*"/>
                                        <ColumnDefinition Width="80*"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0" Text="SHIFT #" Style="{StaticResource TableHeaderStyle}"/>
                                    <TextBlock Grid.Column="1" Text="STAFF" Style="{StaticResource TableHeaderStyle}"/>
                                    <TextBlock Grid.Column="2" Text="OPEN / CLOSE" Style="{StaticResource TableHeaderStyle}"/>
                                    <TextBlock Grid.Column="3" Text="ORDERS" Style="{StaticResource TableHeaderStyle}"/>
                                    <TextBlock Grid.Column="4" Text="REVENUE" Style="{StaticResource TableHeaderStyle}"/>
                                    <TextBlock Grid.Column="5" Text="STATUS" Style="{StaticResource TableHeaderStyle}"/>
                                </Grid>
                                <Rectangle Height="1" Fill="#E2E8F0" Margin="0,0,0,6"/>
                                <ItemsControl ItemsSource="{Binding RecentShifts}">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <StackPanel>
                                                <Grid Margin="0,10,0,10">
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="80*"/>
                                                        <ColumnDefinition Width="110*"/>
                                                        <ColumnDefinition Width="140*"/>
                                                        <ColumnDefinition Width="70*"/>
                                                        <ColumnDefinition Width="140*"/>
                                                        <ColumnDefinition Width="80*"/>
                                                    </Grid.ColumnDefinitions>
                                                    <TextBlock Grid.Column="0" FontSize="12" FontWeight="SemiBold"
                                                               Foreground="#2563EB" VerticalAlignment="Center"
                                                               Text="{Binding DisplayId}"/>
                                                    <TextBlock Grid.Column="1" Style="{StaticResource TableCellStyle}" FontSize="12"
                                                               Text="{Binding StaffName}" TextTrimming="CharacterEllipsis" VerticalAlignment="Center"/>
                                                    <StackPanel Grid.Column="2" VerticalAlignment="Center">
                                                        <TextBlock FontSize="12" Foreground="#0F172A"
                                                                   Text="{Binding OpenedAt, StringFormat='{}{0:dd/MM/yyyy HH:mm}'}"/>
                                                        <TextBlock FontSize="11" Foreground="#64748B"
                                                                   Text="{Binding ClosedAt, StringFormat='{}{0:dd/MM/yyyy HH:mm}', TargetNullValue='—'}"/>
                                                    </StackPanel>
                                                    <TextBlock Grid.Column="3" Style="{StaticResource TableCellStyle}"
                                                               Text="{Binding TotalOrders}"/>
                                                    <TextBlock Grid.Column="4" Style="{StaticResource TableCellStyle}" FontWeight="SemiBold"
                                                               Text="{Binding TotalRevenue, StringFormat='{}{0:N0} ₫'}"/>
                                                    <Border Grid.Column="5" CornerRadius="10" Padding="8,3" HorizontalAlignment="Left" VerticalAlignment="Center">
                                                        <Border.Style>
                                                            <Style TargetType="Border">
                                                                <Setter Property="Background" Value="#F1F5F9"/>
                                                                <Style.Triggers>
                                                                    <DataTrigger Binding="{Binding Status}" Value="Open">
                                                                        <Setter Property="Background" Value="#EFF6FF"/>
                                                                    </DataTrigger>
                                                                </Style.Triggers>
                                                            </Style>
                                                        </Border.Style>
                                                        <TextBlock FontSize="10" FontWeight="Bold">
                                                            <TextBlock.Style>
                                                                <Style TargetType="TextBlock">
                                                                    <Setter Property="Foreground" Value="#64748B"/>
                                                                    <Setter Property="Text" Value="CLOSED"/>
                                                                    <Style.Triggers>
                                                                        <DataTrigger Binding="{Binding Status}" Value="Open">
                                                                            <Setter Property="Foreground" Value="#2563EB"/>
                                                                            <Setter Property="Text" Value="ACTIVE"/>
                                                                        </DataTrigger>
                                                                    </Style.Triggers>
                                                                </Style>
                                                            </TextBlock.Style>
                                                        </TextBlock>
                                                    </Border>
                                                </Grid>
                                                <Rectangle Height="1" Fill="#E2E8F0"/>
                                            </StackPanel>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </StackPanel>
                        </Border>

                        <!-- Top Products -->
                        <Border Grid.Column="2" Style="{StaticResource CardStyle}">
                            <StackPanel>
                                <TextBlock Text="Top Products" Style="{StaticResource SectionHeaderStyle}"/>
                                <TextBlock Text="Items with highest volume" FontSize="11"
                                           Foreground="#64748B" Margin="0,0,0,12"/>
                                <ItemsControl ItemsSource="{Binding TopProducts}">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <StackPanel Margin="0,0,0,12">
                                                <Grid Margin="0,0,0,4">
                                                    <TextBlock Text="{Binding ProductName}" FontSize="12"
                                                               Foreground="#0F172A" FontWeight="Medium"/>
                                                    <TextBlock HorizontalAlignment="Right" FontSize="12" FontWeight="Bold"
                                                               Foreground="#2563EB"
                                                               Text="{Binding TotalSold, StringFormat='{}{0} Sold'}"/>
                                                </Grid>
                                                <ProgressBar Height="6"
                                                             Maximum="{Binding DataContext.MaxTopSold, RelativeSource={RelativeSource AncestorType=UserControl}, Mode=OneWay}"
                                                             Value="{Binding TotalSold, Mode=OneWay}"
                                                             Background="#E2E8F0"
                                                             Foreground="#2563EB"
                                                             BorderThickness="0"/>
                                            </StackPanel>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                                <Border BorderBrush="#E2E8F0" BorderThickness="1"
                                        CornerRadius="6" Margin="0,6,0,0" Padding="10,6" Cursor="Hand">
                                    <Border.InputBindings>
                                         <MouseBinding MouseAction="LeftClick" Command="{Binding NavigateToCatalogCommand}"/>
                                     </Border.InputBindings>
                                     <TextBlock Text="Detailed Inventory Report" TextAlignment="Center"
                                               FontSize="12" Foreground="#2563EB" FontWeight="SemiBold"/>
                                </Border>
                            </StackPanel>
                        </Border>
                    </Grid>

                    <!-- ── DETAILED ORDER LOG ── -->
                    <Border Style="{StaticResource CardStyle}" Margin="0,0,0,20"
                            Visibility="{Binding ShiftReport, Converter={StaticResource NullToVisibilityConverter}}">
                        <StackPanel>
                            <!-- Log header -->
                            <Grid Margin="0,0,0,14">
                                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                    <TextBlock Text="Detailed Order Log" Style="{StaticResource SectionHeaderStyle}" Margin="0"/>
                                    <Border Background="#ECFDF5" CornerRadius="4" Padding="6,2" Margin="8,0,0,0" VerticalAlignment="Center">
                                        <TextBlock Text="LIVE" FontSize="10" FontWeight="Bold" Foreground="#059669"/>
                                    </Border>
                                </StackPanel>
                            </Grid>

                            <!-- Column headers -->
                            <Grid Margin="0,0,0,6">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="90*"/>
                                    <ColumnDefinition Width="55*"/>
                                    <ColumnDefinition Width="110*"/>
                                    <ColumnDefinition Width="120*"/>
                                    <ColumnDefinition Width="130*"/>
                                    <ColumnDefinition Width="140*"/>
                                    <ColumnDefinition Width="100*"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Text="ORDER #" Style="{StaticResource TableHeaderStyle}"/>
                                <TextBlock Grid.Column="1" Text="TIME" Style="{StaticResource TableHeaderStyle}"/>
                                <TextBlock Grid.Column="2" Text="STAFF" Style="{StaticResource TableHeaderStyle}"/>
                                <TextBlock Grid.Column="3" Text="ITEMS SUMMARY" Style="{StaticResource TableHeaderStyle}"/>
                                <TextBlock Grid.Column="4" Text="PAYMENT" Style="{StaticResource TableHeaderStyle}"/>
                                <TextBlock Grid.Column="5" Text="AMOUNT" Style="{StaticResource TableHeaderStyle}" TextAlignment="Right" Margin="0,0,14,0"/>
                                <TextBlock Grid.Column="6" Text="STATUS" Style="{StaticResource TableHeaderStyle}" Margin="6,0,0,0"/>
                            </Grid>
                            <Rectangle Height="1" Fill="#E2E8F0" Margin="0,0,0,6"/>

                            <!-- Rows -->
                            <ItemsControl ItemsSource="{Binding OrderLog}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <StackPanel>
                                            <Grid Margin="0,10,0,10">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="90*"/>
                                                    <ColumnDefinition Width="55*"/>
                                                    <ColumnDefinition Width="110*"/>
                                                    <ColumnDefinition Width="120*"/>
                                                    <ColumnDefinition Width="130*"/>
                                                    <ColumnDefinition Width="140*"/>
                                                    <ColumnDefinition Width="100*"/>
                                                </Grid.ColumnDefinitions>
                                                <!-- ORDER# -->
                                                <TextBlock Grid.Column="0" FontSize="12" FontWeight="SemiBold"
                                                           Foreground="#2563EB" VerticalAlignment="Center"
                                                           Text="{Binding DisplayId}"/>
                                                <!-- TIME -->
                                                <TextBlock Grid.Column="1" Style="{StaticResource TableCellStyle}" FontSize="12"
                                                           Text="{Binding CreatedAt, StringFormat='{}{0:HH:mm}'}"/>
                                                <!-- STAFF -->
                                                <TextBlock Grid.Column="2" Style="{StaticResource TableCellStyle}" FontSize="12"
                                                           Text="{Binding StaffName}" TextTrimming="CharacterEllipsis"/>
                                                <!-- ITEMS SUMMARY -->
                                                <TextBlock Grid.Column="3" FontSize="12" VerticalAlignment="Center"
                                                           Foreground="#64748B"
                                                           Text="{Binding ItemsSummary}"
                                                           TextTrimming="CharacterEllipsis" ToolTip="{Binding ItemsSummary}"/>
                                                <!-- PAYMENT -->
                                                <TextBlock Grid.Column="4" Style="{StaticResource TableCellStyle}" FontSize="12"
                                                           Text="{Binding PaymentMethod}"/>
                                                <!-- AMOUNT -->
                                                <TextBlock Grid.Column="5" FontSize="12" FontWeight="SemiBold"
                                                           Foreground="#0F172A" VerticalAlignment="Center"
                                                           TextAlignment="Right" Margin="0,0,14,0"
                                                           Text="{Binding TotalAmount, StringFormat='{}{0:N0} ₫'}"/>
                                                <!-- STATUS badge -->
                                                <Border Grid.Column="6" CornerRadius="4" Padding="6,2"
                                                        HorizontalAlignment="Left" VerticalAlignment="Center" Margin="6,0,0,0">
                                                    <Border.Style>
                                                        <Style TargetType="Border">
                                                            <Setter Property="Background" Value="#ECFDF5"/>
                                                            <Style.Triggers>
                                                                <DataTrigger Binding="{Binding PaymentStatus}" Value="Pending">
                                                                    <Setter Property="Background" Value="#FEF9C3"/>
                                                                </DataTrigger>
                                                                <DataTrigger Binding="{Binding PaymentStatus}" Value="Failed">
                                                                    <Setter Property="Background" Value="#FEF2F2"/>
                                                                </DataTrigger>
                                                                <DataTrigger Binding="{Binding PaymentStatus}" Value="Timeout">
                                                                    <Setter Property="Background" Value="#FEF2F2"/>
                                                                </DataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </Border.Style>
                                                    <TextBlock FontSize="10" FontWeight="Bold">
                                                        <TextBlock.Style>
                                                            <Style TargetType="TextBlock">
                                                                <Setter Property="Foreground" Value="#059669"/>
                                                                <Setter Property="Text" Value="PAID"/>
                                                                <Style.Triggers>
                                                                    <DataTrigger Binding="{Binding PaymentStatus}" Value="Pending">
                                                                        <Setter Property="Foreground" Value="#92400E"/>
                                                                        <Setter Property="Text" Value="PENDING"/>
                                                                    </DataTrigger>
                                                                    <DataTrigger Binding="{Binding PaymentStatus}" Value="Failed">
                                                                        <Setter Property="Foreground" Value="#EF4444"/>
                                                                        <Setter Property="Text" Value="FAILED"/>
                                                                    </DataTrigger>
                                                                    <DataTrigger Binding="{Binding PaymentStatus}" Value="Timeout">
                                                                        <Setter Property="Foreground" Value="#EF4444"/>
                                                                        <Setter Property="Text" Value="TIMEOUT"/>
                                                                    </DataTrigger>
                                                                </Style.Triggers>
                                                            </Style>
                                                        </TextBlock.Style>
                                                    </TextBlock>
                                                </Border>
                                            </Grid>
                                            <Rectangle Height="1" Fill="#E2E8F0"/>
                                        </StackPanel>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </StackPanel>
                    </Border>

                </StackPanel>
            </ScrollViewer>
        </Grid>
    </Grid>
</UserControl>
