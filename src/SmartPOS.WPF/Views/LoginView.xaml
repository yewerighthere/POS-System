<UserControl x:Class="SmartPOS.WPF.Views.LoginView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d"
             d:DesignHeight="720"
             d:DesignWidth="1180"
             MinWidth="860"
             MinHeight="560">
    <UserControl.Resources>
        <Color x:Key="PrimaryColor">#00288E</Color>
        <Color x:Key="PrimaryHoverColor">#1E40AF</Color>
        <Color x:Key="BackgroundColor">#F8FAFC</Color>
        <Color x:Key="SurfaceColor">#FFFFFF</Color>
        <Color x:Key="TextPrimaryColor">#0F172A</Color>
        <Color x:Key="TextSecondaryColor">#64748B</Color>
        <Color x:Key="BorderColor">#E2E8F0</Color>
        <Color x:Key="SuccessColor">#16A34A</Color>
        <SolidColorBrush x:Key="PrimaryBrush" Color="{StaticResource PrimaryColor}" />
        <SolidColorBrush x:Key="PrimaryHoverBrush" Color="{StaticResource PrimaryHoverColor}" />
        <SolidColorBrush x:Key="BackgroundBrush" Color="{StaticResource BackgroundColor}" />
        <SolidColorBrush x:Key="SurfaceBrush" Color="{StaticResource SurfaceColor}" />
        <SolidColorBrush x:Key="TextPrimaryBrush" Color="{StaticResource TextPrimaryColor}" />
        <SolidColorBrush x:Key="TextSecondaryBrush" Color="{StaticResource TextSecondaryColor}" />
        <SolidColorBrush x:Key="BorderBrush" Color="{StaticResource BorderColor}" />
        <SolidColorBrush x:Key="SuccessBrush" Color="{StaticResource SuccessColor}" />

        <Style x:Key="FieldLabelStyle" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}" />
            <Setter Property="FontSize" Value="12" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Margin" Value="0,0,0,6" />
        </Style>

        <Style x:Key="InputTextBoxStyle" TargetType="TextBox">
            <Setter Property="Height" Value="42" />
            <Setter Property="Padding" Value="38,0,14,0" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
            <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}" />
            <Setter Property="Background" Value="{StaticResource SurfaceBrush}" />
            <Setter Property="BorderBrush" Value="{StaticResource BorderBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="FontSize" Value="14" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TextBox">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="8">
                            <ScrollViewer x:Name="PART_ContentHost" />
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsKeyboardFocused" Value="True">
                    <Setter Property="BorderBrush" Value="{StaticResource PrimaryBrush}" />
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="InputPasswordBoxStyle" TargetType="PasswordBox">
            <Setter Property="Height" Value="42" />
            <Setter Property="Padding" Value="38,0,44,0" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
            <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}" />
            <Setter Property="Background" Value="{StaticResource SurfaceBrush}" />
            <Setter Property="BorderBrush" Value="{StaticResource BorderBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="FontSize" Value="14" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="PasswordBox">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="8">
                            <ScrollViewer x:Name="PART_ContentHost" />
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsKeyboardFocused" Value="True">
                    <Setter Property="BorderBrush" Value="{StaticResource PrimaryBrush}" />
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="PrimaryButtonStyle" TargetType="Button">
            <Setter Property="Height" Value="48" />
            <Setter Property="Foreground" Value="White" />
            <Setter Property="Background" Value="{StaticResource PrimaryBrush}" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="FontSize" Value="16" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="8">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="{StaticResource PrimaryHoverBrush}" />
                </Trigger>
                <Trigger Property="IsEnabled" Value="False">
                    <Setter Property="Opacity" Value="0.68" />
                </Trigger>
            </Style.Triggers>
        </Style>
    </UserControl.Resources>

    <Grid Background="{StaticResource BackgroundBrush}">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>

        <Grid Grid.Column="0" ClipToBounds="True">
            <Grid.Background>
                <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                    <GradientStop Color="#111827" Offset="0" />
                    <GradientStop Color="#1A1B22" Offset="0.55" />
                    <GradientStop Color="#0F172A" Offset="1" />
                </LinearGradientBrush>
            </Grid.Background>

            <Canvas Opacity="0.16" IsHitTestVisible="False">
                <Ellipse Width="420" Height="420" Fill="#1E40AF" Canvas.Left="-120" Canvas.Top="-130" />
                <Ellipse Width="260" Height="260" Fill="#872D00" Canvas.Right="-70" Canvas.Bottom="-80" />
            </Canvas>

            <Grid Margin="32">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <StackPanel Grid.Row="0">
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                        <Border Width="42" Height="42" Background="{StaticResource PrimaryBrush}" CornerRadius="8">
                            <TextBlock Text="▣"
                                       Foreground="White"
                                       FontSize="20"
                                       HorizontalAlignment="Center"
                                       VerticalAlignment="Center" />
                        </Border>
                        <TextBlock Text="SmartPOS"
                                   Foreground="White"
                                   FontSize="26"
                                   FontWeight="Bold"
                                   Margin="10,0,0,0"
                                   VerticalAlignment="Center" />
                    </StackPanel>

                    <TextBlock Text="Retail Management System"
                               Foreground="#E5E7EB"
                               FontSize="18"
                               FontWeight="SemiBold"
                               Margin="0,28,0,0" />
                    <TextBlock Text="SWD392 - FPT University"
                               Foreground="#94A3B8"
                               FontSize="14"
                               Margin="0,5,0,0" />
                </StackPanel>

                <Border Grid.Row="1"
                        MaxWidth="430"
                        Height="245"
                        HorizontalAlignment="Center"
                        VerticalAlignment="Center"
                        Background="#332F3037"
                        BorderBrush="#22FFFFFF"
                        BorderThickness="1"
                        CornerRadius="12">
                    <Grid Margin="24">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="*" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>

                        <StackPanel VerticalAlignment="Center">
                            <TextBlock Text="POS"
                                       Foreground="#B8C4FF"
                                       FontSize="14"
                                       FontWeight="SemiBold"
                                       Margin="0,0,0,8" />
                            <TextBlock Text="Secure terminal access for retail operations"
                                       Foreground="White"
                                       FontSize="24"
                                       FontWeight="Bold"
                                       TextWrapping="Wrap"
                                       LineHeight="31" />
                            <TextBlock Text="Inventory, shifts, orders, reports, and payment workflows start here."
                                       Foreground="#CBD5E1"
                                       FontSize="14"
                                       TextWrapping="Wrap"
                                       Margin="0,12,0,0" />
                        </StackPanel>

                        <StackPanel Grid.Row="1" Orientation="Horizontal" VerticalAlignment="Bottom">
                            <TextBlock Text="✓"
                                       Foreground="#B8C4FF"
                                       FontSize="18"
                                       FontWeight="Bold"
                                       VerticalAlignment="Center" />
                            <TextBlock Text="Enterprise Secured"
                                       Foreground="White"
                                       FontSize="12"
                                       FontWeight="SemiBold"
                                       Margin="8,0,0,0"
                                       VerticalAlignment="Center" />
                        </StackPanel>
                    </Grid>
                </Border>

                <StackPanel Grid.Row="2" Orientation="Horizontal">
                    <Ellipse Width="8" Height="8" Fill="{StaticResource SuccessBrush}" VerticalAlignment="Center" />
                    <TextBlock Text="System Operations Online"
                               Foreground="#94A3B8"
                               FontSize="12"
                               Margin="10,0,0,0"
                               VerticalAlignment="Center" />
                </StackPanel>
            </Grid>
        </Grid>

        <Grid Grid.Column="1" Margin="36">
            <Grid.RowDefinitions>
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <Border Grid.Row="0"
                    Width="480"
                    Padding="32"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Center"
                    Background="{StaticResource SurfaceBrush}"
                    BorderBrush="{StaticResource BorderBrush}"
                    BorderThickness="1"
                    CornerRadius="12">
                <Border.Effect>
                    <DropShadowEffect Color="#22000000" BlurRadius="28" ShadowDepth="8" Opacity="0.18" />
                </Border.Effect>

                <StackPanel>
                    <TextBlock Text="Welcome back"
                               Foreground="{StaticResource TextPrimaryBrush}"
                               FontSize="26"
                               FontWeight="Bold" />
                    <TextBlock Text="Sign in to your account"
                               Foreground="{StaticResource TextSecondaryBrush}"
                               FontSize="14"
                               Margin="0,4,0,30" />

                    <TextBlock Text="Username" Style="{StaticResource FieldLabelStyle}" />
                    <Grid Margin="0,0,0,18">
                        <TextBlock Text="👤"
                                   Foreground="{StaticResource TextSecondaryBrush}"
                                   FontSize="15"
                                   Margin="13,0,0,0"
                                   VerticalAlignment="Center"
                                   IsHitTestVisible="False" />
                        <TextBox Style="{StaticResource InputTextBoxStyle}"
                                 Text="{Binding Username, UpdateSourceTrigger=PropertyChanged}"
                                 ToolTip="Enter your username" />
                    </Grid>

                    <TextBlock Text="Password" Style="{StaticResource FieldLabelStyle}" />
                    <Grid Margin="0,0,0,24">
                        <TextBlock Text="🔒"
                                   Foreground="{StaticResource TextSecondaryBrush}"
                                   FontSize="15"
                                   Margin="13,0,0,0"
                                   VerticalAlignment="Center"
                                   IsHitTestVisible="False" />
                        <PasswordBox x:Name="PasswordInput"
                                     Style="{StaticResource InputPasswordBoxStyle}"
                                     PasswordChanged="PasswordInput_OnPasswordChanged" />
                        <TextBox x:Name="VisiblePasswordInput"
                                 Style="{StaticResource InputTextBoxStyle}"
                                 Padding="38,0,44,0"
                                 Visibility="Collapsed"
                                 TextChanged="VisiblePasswordInput_OnTextChanged" />
                        <ToggleButton x:Name="TogglePasswordButton"
                                      Width="34"
                                      Height="34"
                                      HorizontalAlignment="Right"
                                      VerticalAlignment="Center"
                                      Margin="0,0,6,0"
                                      Background="Transparent"
                                      BorderThickness="0"
                                      Checked="TogglePasswordButton_OnToggled"
                                      Unchecked="TogglePasswordButton_OnToggled"
                                      ToolTip="Show or hide password">
                            <TextBlock x:Name="PasswordToggleIcon"
                                       Text="👁"
                                       Foreground="{StaticResource TextSecondaryBrush}"
                                       HorizontalAlignment="Center"
                                       VerticalAlignment="Center" />
                        </ToggleButton>
                    </Grid>

                    <Button Command="{Binding LoginCommand}" Style="{StaticResource PrimaryButtonStyle}">
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                            <TextBlock Text="Sign In" VerticalAlignment="Center" />
                            <TextBlock Text="→" FontSize="20" Margin="10,-1,0,0" VerticalAlignment="Center" />
                        </StackPanel>
                    </Button>

                    <TextBlock Text="{Binding ErrorMessage}"
                               Foreground="#DC2626"
                               FontSize="13"
                               TextWrapping="Wrap"
                               Margin="0,14,0,0" />

                    <Border BorderBrush="{StaticResource BorderBrush}"
                            BorderThickness="0,1,0,0"
                            Margin="0,26,0,0"
                            Padding="0,20,0,0">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="ⓘ"
                                       Foreground="{StaticResource TextSecondaryBrush}"
                                       FontSize="16"
                                       Margin="0,0,10,0"
                                       VerticalAlignment="Top" />
                            <TextBlock Text="Contact your manager if you cannot log in. Technical support is available via the internal portal for all terminal sessions."
                                       Foreground="{StaticResource TextSecondaryBrush}"
                                       FontSize="12"
                                       TextWrapping="Wrap"
                                       Width="360"
                                       LineHeight="17" />
                        </StackPanel>
                    </Border>
                </StackPanel>
            </Border>

            <Grid Grid.Row="1" Margin="0,24,0,0">
                <TextBlock Text="v1.0.0"
                           HorizontalAlignment="Left"
                           Foreground="{StaticResource TextSecondaryBrush}"
                           FontFamily="Consolas"
                           FontSize="12"
                           Opacity="0.7" />
                <TextBlock Text="SmartPOS Retail"
                           HorizontalAlignment="Right"
                           Foreground="{StaticResource TextSecondaryBrush}"
                           FontSize="12"
                           FontWeight="Bold"
                           Opacity="0.7" />
            </Grid>
        </Grid>
    </Grid>
</UserControl>
