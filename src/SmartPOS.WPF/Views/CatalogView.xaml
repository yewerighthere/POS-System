<UserControl x:Class="SmartPOS.WPF.Views.CatalogView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:viewmodels="clr-namespace:SmartPOS.WPF.ViewModels"
             xmlns:converters="clr-namespace:SmartPOS.WPF.Converters"
             mc:Ignorable="d" 
             d:DataContext="{d:DesignInstance Type=viewmodels:CatalogViewModel}"
             Background="#F8FAFC"
             Foreground="{StaticResource TextPrimaryBrush}"
             d:DesignHeight="768" d:DesignWidth="1024">

    <UserControl.Resources>
        <!-- Value Converters -->
        <converters:NullOrEmptyToVisibilityConverter x:Key="NullOrEmptyToVisibilityConverter" />
        <converters:NullToVisibilityConverter        x:Key="NullToVisibilityConverter" />
        <converters:LocalImagePathConverter          x:Key="LocalImagePathConverter" />
        <converters:ImagePathToVisibilityConverter   x:Key="ImagePathToVis" />
        <converters:StockBackgroundConverter         x:Key="StockBgConverter" />
        <converters:StockTextConverter               x:Key="StockTextConverter" />
        <converters:StockForegroundConverter         x:Key="StockFgConverter" />
        <BooleanToVisibilityConverter                x:Key="BoolToVis"/>
        <converters:InverseBoolConverter             x:Key="BoolInverter"/>

        <!-- Vector Geometries -->
        <Geometry x:Key="IconPosData">M4 3h16a1 1 0 0 1 1 1v10a1 1 0 0 1-1 1H4a1 1 0 0 1-1-1V4a1 1 0 0 1 1-1zm0 13h16v2H4v-2zm7 3h2v2h-2v-2z</Geometry>
        <Geometry x:Key="IconInventoryData">M20 7l-8-4-8 4 8 4 8-4zm-16 3v8l8 4 8-4v-8l-8 4-8-4z</Geometry>
        <Geometry x:Key="IconCustomerData">M12 12c2.21 0 4-1.79 4-4s-1.79-4-4-4-4 1.79-4 4 1.79 4 4 4zm0 2c-2.67 0-8 1.34-8 4v2h16v-2c0-2.66-5.33-4-8-4z</Geometry>
        <Geometry x:Key="IconReturnData">M12 5V1L7 6l5 5V7c3.31 0 6 2.69 6 6s-2.69 6-6 6-6-2.69-6-6H4c0 4.42 3.58 8 8 8s8-3.58 8-8-3.58-8-8-8z</Geometry>
        <Geometry x:Key="IconCatalogData">M10 4H4c-1.1 0-1.99.9-1.99 2L2 18c0 1.1.9 2 2 2h16c1.1 0 2-.9 2-2V8c0-1.1-.9-2-2-2h-8l-2-2z</Geometry>
        <Geometry x:Key="IconReportData">M19 3H5c-1.1 0-2 .9-2 2v14c0 1.1.9 2 2 2h14c1.1 0 2-.9 2-2V5c0-1.1-.9-2-2-2zm-7 14h-2V9h2v8zm4 0h-2v-5h2v5zm-8 0H6v-3h2v3z</Geometry>
        <Geometry x:Key="IconSearchData">M15.5 14h-.79l-.28-.27C15.41 12.59 16 11.11 16 9.5 16 5.91 13.09 3 9.5 3S3 5.91 3 9.5 5.91 16 9.5 16c1.61 0 3.09-.59 4.23-1.57l.27.28v.79l5 4.99L20.49 19l-4.99-5zm-6 0C7.01 14 5 11.99 5 9.5S7.01 5 9.5 5 14 7.01 14 9.5 11.99 14 9.5 14z</Geometry>
        <Geometry x:Key="IconTrashData">M6 19c0 1.1.9 2 2 2h8c1.1 0 2-.9 2-2V7H6v12zM19 4h-3.5l-1-1h-5l-1 1H5v2h14V4z</Geometry>

        <Style x:Key="PrimaryBtn" TargetType="Button">
            <Setter Property="Background" Value="#2563EB"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Name="Border" CornerRadius="6" Background="{TemplateBinding Background}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" Margin="{TemplateBinding Padding}"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Border" Property="Background" Value="#1D4ED8"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="OutlineBtn" TargetType="Button">
            <Setter Property="Background" Value="White"/>
            <Setter Property="Foreground" Value="#0F172A"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="BorderBrush" Value="#E2E8F0"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Name="Border" CornerRadius="6" Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="{TemplateBinding BorderThickness}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" Margin="{TemplateBinding Padding}"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Border" Property="Background" Value="#F8FAFC"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="RowIconBtn" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="#64748B"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Width" Value="28"/>
            <Setter Property="Height" Value="28"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Name="Border" CornerRadius="4" Background="{TemplateBinding Background}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Border" Property="Background" Value="#F1F5F9"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </UserControl.Resources>

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="Auto"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- LEFT SIDEBAR (Slate 900 #0F172A) -->
        <Border Grid.Column="0" Width="220" Background="#0F172A" BorderThickness="0"
                Visibility="{Binding ShowNavigation, Converter={StaticResource BoolToVis}}">
            <Grid Margin="0,20,0,16">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/> <!-- Brand Header -->
                    <RowDefinition Height="*"/>    <!-- Navigation Panel -->
                    <RowDefinition Height="Auto"/> <!-- Unified Sidebar Footer -->
                </Grid.RowDefinitions>

                <!-- Brand Header -->
                <StackPanel Grid.Row="0" Margin="20,0,20,16" VerticalAlignment="Center">
                    <TextBlock Text="SmartPOS" Foreground="#F8FAFC" FontSize="18" FontWeight="Black"/>
                    <TextBlock Text="Terminal #01" Foreground="#94A3B8" FontSize="11" Margin="0,2,0,0"/>
                </StackPanel>

                <!-- Scrollable Navigation Items -->
                <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                    <StackPanel Margin="10,0">

                        <!-- SECTION 1: OPERATIONS -->
                        <TextBlock Text="OPERATIONS" Foreground="#64748B" FontSize="10" FontWeight="Bold" Margin="10,4,10,6"/>

                        <!-- Point of Sale -->
                        <Button Style="{StaticResource SidebarNavButtonStyle}" Command="{Binding NavigateToSalesCommand}" VerticalAlignment="Center" Height="40" Margin="0,2">
                            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                <Path Data="{StaticResource IconPosData}" Fill="#94A3B8" Width="16" Height="16" Stretch="Uniform" Margin="0,0,12,0"/>
                                <TextBlock Text="Point of Sale" FontSize="13" VerticalAlignment="Center"/>
                            </StackPanel>
                        </Button>

                        <!-- Returns & Refunds -->
                        <Button Style="{StaticResource SidebarNavButtonStyle}" Command="{Binding NavigateToReturnCommand}" VerticalAlignment="Center" Height="40" Margin="0,2">
                            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                <Path Data="{StaticResource IconReturnData}" Fill="#94A3B8" Width="16" Height="16" Stretch="Uniform" Margin="0,0,12,0"/>
                                <TextBlock Text="Returns &amp; Refunds" FontSize="13" VerticalAlignment="Center"/>
                            </StackPanel>
                        </Button>

                        <!-- SECTION 2: MANAGEMENT -->
                        <TextBlock Text="MANAGEMENT" Foreground="#64748B" FontSize="10" FontWeight="Bold" Margin="10,14,10,6"/>

                        <!-- Inventory -->
                        <Button Style="{StaticResource SidebarNavButtonStyle}" Command="{Binding NavigateToSyncCommand}" VerticalAlignment="Center" Height="40" Margin="0,2">
                            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                <Path Data="{StaticResource IconInventoryData}" Fill="#94A3B8" Width="16" Height="16" Stretch="Uniform" Margin="0,0,12,0"/>
                                <TextBlock Text="Inventory" FontSize="13" VerticalAlignment="Center"/>
                            </StackPanel>
                        </Button>

                        <!-- ACTIVE: Product Catalog (Royal Blue #2563EB) -->
                        <Border Background="#2563EB" CornerRadius="8" Margin="0,2" Padding="14,0" Height="40" VerticalAlignment="Center">
                            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                <Path Data="{StaticResource IconCatalogData}" Fill="White" Width="16" Height="16" Stretch="Uniform" Margin="0,0,12,0"/>
                                <TextBlock Text="Product Catalog" Foreground="White" FontSize="13" FontWeight="SemiBold" VerticalAlignment="Center"/>
                            </StackPanel>
                        </Border>

                        <!-- Customers -->
                        <Button Style="{StaticResource SidebarNavButtonStyle}" Command="{Binding NavigateToCustomerCommand}" VerticalAlignment="Center" Height="40" Margin="0,2">
                            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                <Path Data="{StaticResource IconCustomerData}" Fill="#94A3B8" Width="16" Height="16" Stretch="Uniform" Margin="0,0,12,0"/>
                                <TextBlock Text="Customers" FontSize="13" VerticalAlignment="Center"/>
                            </StackPanel>
                        </Button>

                        <!-- SECTION 3: ANALYTICS -->
                        <TextBlock Text="ANALYTICS" Foreground="#64748B" FontSize="10" FontWeight="Bold" Margin="10,14,10,6"/>

                        <!-- Shift Reports -->
                        <Button Style="{StaticResource SidebarNavButtonStyle}" Command="{Binding NavigateToReportCommand}" VerticalAlignment="Center" Height="40" Margin="0,2">
                            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                <Path Data="{StaticResource IconReportData}" Fill="#94A3B8" Width="16" Height="16" Stretch="Uniform" Margin="0,0,12,0"/>
                                <TextBlock Text="Shift Reports" FontSize="13" VerticalAlignment="Center"/>
                            </StackPanel>
                        </Button>

                    </StackPanel>
                </ScrollViewer>

                <!-- UNIFIED SIDEBAR FOOTER (Stacked Info: Shift, Staff, Current Time) -->
                <StackPanel Grid.Row="2" Margin="10,12,10,0">
                    <Border Padding="12" CornerRadius="8" Background="#1E293B">
                        <StackPanel>
                            <!-- Shift info -->
                            <StackPanel Margin="0,0,0,8">
                                <TextBlock Text="SHIFT INFO" Foreground="#94A3B8" FontSize="10" FontWeight="Bold"/>
                                <TextBlock Text="{Binding ShiftCode}" Foreground="#F8FAFC" FontSize="12" FontWeight="SemiBold" Margin="0,2,0,0"/>
                            </StackPanel>

                            <!-- Staff info -->
                            <StackPanel Margin="0,0,0,8">
                                <TextBlock Text="STAFF / CASHIER" Foreground="#94A3B8" FontSize="10" FontWeight="Bold"/>
                                <TextBlock Text="{Binding StaffName}" Foreground="#F8FAFC" FontSize="12" FontWeight="SemiBold" Margin="0,2,0,0"/>
                            </StackPanel>

                            <!-- Current Time -->
                            <StackPanel>
                                <TextBlock Text="CURRENT TIME" Foreground="#94A3B8" FontSize="10" FontWeight="Bold"/>
                                <TextBlock Text="{Binding CurrentTimeDisplay}" Foreground="#F8FAFC" FontSize="11" Margin="0,2,0,0"/>
                            </StackPanel>
                        </StackPanel>
                    </Border>
                </StackPanel>
            </Grid>
        </Border>

        <!-- MAIN CONTENT -->
        <Grid Grid.Column="1" Background="#F8FAFC">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- Top header bar -->
            <Border Grid.Row="0" Background="White" BorderBrush="#E2E8F0" BorderThickness="0,0,0,1" Padding="20,0" Height="64">
                <Grid VerticalAlignment="Center">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0" Text="SmartPOS Retail" Foreground="#2563EB"
                               FontSize="18" FontWeight="Black" VerticalAlignment="Center"/>
                    <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                        <Button Content="Support" Background="Transparent" Foreground="#2563EB"
                                FontSize="12" FontWeight="Bold" BorderThickness="0" Margin="0,0,16,0" Cursor="Hand"/>
                        <Button Content="End Shift" Command="{Binding NavigateToSalesCommand}"
                                Style="{StaticResource PrimaryBtn}" Background="#EF4444" Padding="14,6" FontSize="12"/>
                    </StackPanel>
                </Grid>
            </Border>

            <!-- Error bar -->
            <Grid Grid.Row="1" Margin="24,12,24,0"
                  Visibility="{Binding ErrorMessage, Converter={StaticResource NullOrEmptyToVisibilityConverter}, FallbackValue=Collapsed}">
                <Border Background="#FEF2F2" BorderBrush="#FCA5A5" BorderThickness="1" CornerRadius="6" Padding="14,10">
                    <TextBlock Text="{Binding ErrorMessage}" Foreground="#991B1B" FontSize="12" TextWrapping="Wrap" FontWeight="Medium"/>
                </Border>
            </Grid>

            <!-- Sync status bar -->
            <Grid Grid.Row="1" Margin="24,12,24,0"
                  Visibility="{Binding SyncStatus, Converter={StaticResource NullOrEmptyToVisibilityConverter}, FallbackValue=Collapsed}">
                <Border Background="#ECFDF5" BorderBrush="#6EE7B7" BorderThickness="1" CornerRadius="6" Padding="14,10">
                    <TextBlock Text="{Binding SyncStatus}" Foreground="#065F46" FontSize="12" TextWrapping="Wrap" FontWeight="Medium"/>
                </Border>
            </Grid>

            <!-- Page header -->
            <Grid Grid.Row="2" Margin="24,16,24,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <StackPanel Grid.Column="0">
                    <TextBlock Text="Product Catalog" FontSize="22" FontWeight="Bold" Foreground="#0F172A"/>
                    <TextBlock Text="{Binding LastSyncedText}" Foreground="#64748B" FontSize="12" Margin="0,4,0,0"/>
                </StackPanel>
                <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Bottom">
                    <Button Command="{Binding SyncFromInventoryCommand}"
                            IsEnabled="{Binding IsSyncing, Converter={StaticResource BoolInverter}}"
                            Style="{StaticResource OutlineBtn}" Margin="0,0,10,0" Height="38" Padding="14,0">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="↻" FontSize="14" Margin="0,0,6,0" VerticalAlignment="Center"/>
                            <TextBlock VerticalAlignment="Center" FontSize="12">
                                <TextBlock.Style>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="Text" Value="Update from Inventory"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding IsSyncing}" Value="True">
                                                <Setter Property="Text" Value="Đang đồng bộ..."/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBlock.Style>
                            </TextBlock>
                        </StackPanel>
                    </Button>
                    <Button Content="＋ Add Product" Command="{Binding ToggleAddProductCommand}"
                            Style="{StaticResource PrimaryBtn}" Background="#2563EB" Height="38" Padding="16,0" FontSize="13"/>
                </StackPanel>
            </Grid>

            <!-- Workspace -->
            <Grid Grid.Row="3" Margin="24,16,24,24">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <!-- Add Product form (toggle) -->
                <Border Grid.Row="0" Background="White" BorderBrush="#E2E8F0" BorderThickness="1"
                        CornerRadius="8" Padding="18" Margin="0,0,0,12"
                        Visibility="{Binding IsAddProductVisible, Converter={StaticResource BoolToVis}}">
                    <StackPanel>
                        <TextBlock Text="Thêm sản phẩm mới" FontWeight="SemiBold" FontSize="15"
                                   Foreground="#0F172A" Margin="0,0,0,12"/>

                        <!-- Main layout: image on left, fields on right -->
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>

                            <!-- Image Upload Panel -->
                            <StackPanel Grid.Column="0" Margin="0,0,16,0" VerticalAlignment="Top">
                                <Border Width="110" Height="110" CornerRadius="8"
                                        BorderBrush="#E2E8F0" BorderThickness="1"
                                        Background="#F8FAFC" ClipToBounds="True">
                                    <Grid>
                                        <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center"
                                                    Visibility="{Binding NewProductImagePath,
                                                        Converter={StaticResource ImagePathToVis},
                                                        ConverterParameter=inverse}">
                                            <Path Data="{StaticResource IconCatalogData}" Fill="#94A3B8" Width="24" Height="24" Stretch="Uniform" HorizontalAlignment="Center"/>
                                            <TextBlock Text="Chọn ảnh" FontSize="11"
                                                       Foreground="#94A3B8" HorizontalAlignment="Center"
                                                       Margin="0,4,0,0"/>
                                        </StackPanel>
                                        <Image Source="{Binding NewProductImagePath, Converter={StaticResource LocalImagePathConverter}}"
                                               Stretch="UniformToFill"
                                               Visibility="{Binding NewProductImagePath, Converter={StaticResource ImagePathToVis}}"/>
                                    </Grid>
                                </Border>

                                <Button Command="{Binding BrowseImageCommand}"
                                        Margin="0,6,0,0" Padding="8,5" FontSize="12"
                                        Background="#2563EB" Foreground="White"
                                        BorderThickness="0" Cursor="Hand">
                                    <Button.Template>
                                        <ControlTemplate TargetType="Button">
                                            <Border Background="{TemplateBinding Background}" CornerRadius="6" Padding="{TemplateBinding Padding}">
                                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                            </Border>
                                            <ControlTemplate.Triggers>
                                                <Trigger Property="IsMouseOver" Value="True">
                                                    <Setter Property="Background" Value="#1D4ED8"/>
                                                </Trigger>
                                            </ControlTemplate.Triggers>
                                        </ControlTemplate>
                                    </Button.Template>
                                    Chọn ảnh
                                </Button>

                                <Button Command="{Binding ClearImageCommand}"
                                        Visibility="{Binding NewProductImagePath, Converter={StaticResource ImagePathToVis}}"
                                        Margin="0,4,0,0" Padding="8,4" FontSize="11"
                                        Background="Transparent" Foreground="#EF4444"
                                        BorderThickness="1" BorderBrush="#FCA5A5" Cursor="Hand">
                                    <Button.Template>
                                        <ControlTemplate TargetType="Button">
                                            <Border Background="{TemplateBinding Background}"
                                                    BorderBrush="{TemplateBinding BorderBrush}"
                                                    BorderThickness="{TemplateBinding BorderThickness}"
                                                    CornerRadius="6" Padding="{TemplateBinding Padding}">
                                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                            </Border>
                                            <ControlTemplate.Triggers>
                                                <Trigger Property="IsMouseOver" Value="True">
                                                    <Setter Property="Background" Value="#FEF2F2"/>
                                                </Trigger>
                                            </ControlTemplate.Triggers>
                                        </ControlTemplate>
                                    </Button.Template>
                                    Xóa ảnh
                                </Button>
                            </StackPanel>

                            <!-- Input Fields -->
                            <StackPanel Grid.Column="1">
                                <!-- Fields row -->
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="160"/>
                                        <ColumnDefinition Width="130"/>
                                        <ColumnDefinition Width="140"/>
                                        <ColumnDefinition Width="120"/>
                                        <ColumnDefinition Width="90"/>
                                    </Grid.ColumnDefinitions>
                                    <ComboBox Grid.Column="0" ItemsSource="{Binding Categories}"
                                              SelectedItem="{Binding SelectedCategory}" DisplayMemberPath="Name"
                                              Margin="0,0,8,0" Padding="10,8" FontSize="13" BorderBrush="#E2E8F0"/>
                                    <TextBox Grid.Column="1" Text="{Binding NewProductName, UpdateSourceTrigger=PropertyChanged}"
                                             Padding="10,8" BorderBrush="#E2E8F0" BorderThickness="1" Margin="0,0,8,0" FontSize="13"/>
                                    <TextBox Grid.Column="2" Text="{Binding NewProductSku, UpdateSourceTrigger=PropertyChanged}"
                                             Padding="10,8" BorderBrush="#E2E8F0" BorderThickness="1" Margin="0,0,8,0" FontSize="13"/>
                                    <TextBox Grid.Column="3" Text="{Binding NewProductBarcode, UpdateSourceTrigger=PropertyChanged}"
                                             Padding="10,8" BorderBrush="#E2E8F0" BorderThickness="1" Margin="0,0,8,0" FontSize="13"/>
                                    <TextBox Grid.Column="4" Text="{Binding NewProductPrice, UpdateSourceTrigger=PropertyChanged}"
                                             Padding="10,8" BorderBrush="#E2E8F0" BorderThickness="1" Margin="0,0,8,0" FontSize="13"/>
                                    <TextBox Grid.Column="5" Text="{Binding NewProductStock, UpdateSourceTrigger=PropertyChanged}"
                                             Padding="10,8" BorderBrush="#E2E8F0" BorderThickness="1" FontSize="13"/>
                                </Grid>
                                <!-- Labels row -->
                                <Grid Margin="0,4,0,10">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="160"/>
                                        <ColumnDefinition Width="130"/>
                                        <ColumnDefinition Width="140"/>
                                        <ColumnDefinition Width="120"/>
                                        <ColumnDefinition Width="90"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0" Text="Danh mục *" FontSize="11" Foreground="#64748B"/>
                                    <TextBlock Grid.Column="1" Text="Tên sản phẩm *" FontSize="11" Foreground="#64748B" Margin="0,0,8,0"/>
                                    <TextBlock Grid.Column="2" Text="SKU" FontSize="11" Foreground="#64748B" Margin="0,0,8,0"/>
                                    <TextBlock Grid.Column="3" Text="Barcode" FontSize="11" Foreground="#64748B" Margin="0,0,8,0"/>
                                    <TextBlock Grid.Column="4" Text="Giá (VNĐ) *" FontSize="11" Foreground="#64748B" Margin="0,0,8,0"/>
                                    <TextBlock Grid.Column="5" Text="Tồn kho" FontSize="11" Foreground="#64748B"/>
                                </Grid>
                                <!-- Submit button -->
                                <Button Content="＋ Thêm sản phẩm" Command="{Binding AddProductCommand}"
                                        HorizontalAlignment="Right"
                                        Style="{StaticResource PrimaryBtn}" Background="#2563EB" Padding="20,10" FontSize="13"/>
                            </StackPanel>
                        </Grid>
                    </StackPanel>
                </Border>

                <!-- Selected product edit bar -->
                <Border Grid.Row="1" Background="#EFF6FF" BorderBrush="#BFDBFE" BorderThickness="1"
                        CornerRadius="8" Padding="14" Margin="0,0,0,12"
                        Visibility="{Binding SelectedProduct, Converter={StaticResource NullToVisibilityConverter}}">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0" VerticalAlignment="Center">
                            <TextBlock FontWeight="SemiBold" FontSize="14" Foreground="#0F172A">
                                <Run Text="Đang chọn: "/><Run Text="{Binding SelectedProduct.Name}"/>
                            </TextBlock>
                        </StackPanel>
                        <StackPanel Grid.Column="1" Orientation="Horizontal" Margin="12,0" VerticalAlignment="Center">
                            <TextBlock Text="Giá mới:" VerticalAlignment="Center" Margin="0,0,6,0" Foreground="#0F172A" FontSize="13"/>
                            <TextBox Text="{Binding UpdatedPrice, UpdateSourceTrigger=PropertyChanged}"
                                     Width="110" Padding="8,6" BorderBrush="#E2E8F0" BorderThickness="1" FontSize="13"/>
                            <TextBlock Text="Tồn kho:" VerticalAlignment="Center" Margin="14,0,6,0" Foreground="#0F172A" FontSize="13"/>
                            <TextBox Text="{Binding UpdatedStock, UpdateSourceTrigger=PropertyChanged}"
                                     Width="70" Padding="8,6" BorderBrush="#E2E8F0" BorderThickness="1" FontSize="13"/>
                        </StackPanel>
                        <Button Grid.Column="2" Content="Đổi ảnh" Command="{Binding UpdateImageCommand}"
                                Style="{StaticResource OutlineBtn}" Margin="0,0,8,0" Height="36" FontSize="12" Padding="12,0"/>
                        <Button Grid.Column="3" Content="Cập nhật" Command="{Binding UpdateProductInfoCommand}"
                                Style="{StaticResource PrimaryBtn}" Background="#2563EB" Margin="0,0,8,0" Height="36" FontSize="12" Padding="14,0"/>
                        <Grid Grid.Column="4">
                            <Button Content="Ngừng KD" Command="{Binding DeactivateProductCommand}"
                                    Background="#EF4444" Height="36" FontSize="12" Padding="14,0">
                                <Button.Style>
                                    <Style TargetType="Button" BasedOn="{StaticResource PrimaryBtn}">
                                        <Setter Property="Visibility" Value="Collapsed"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding SelectedProduct.IsActive}" Value="True">
                                                <Setter Property="Visibility" Value="Visible"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Button.Style>
                            </Button>
                            <Button Content="Kinh doanh lại" Command="{Binding ReactivateProductCommand}"
                                    Background="#10B981" Height="36" FontSize="12" Padding="14,0">
                                <Button.Style>
                                    <Style TargetType="Button" BasedOn="{StaticResource PrimaryBtn}">
                                        <Setter Property="Visibility" Value="Collapsed"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding SelectedProduct.IsActive}" Value="False">
                                                <Setter Property="Visibility" Value="Visible"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Button.Style>
                            </Button>
                        </Grid>
                    </Grid>
                </Border>

                <!-- Filter bar -->
                <Border Grid.Row="2" Background="White" BorderBrush="#E2E8F0" BorderThickness="1"
                        CornerRadius="8" Padding="14,10" Margin="0,0,0,12" Height="58">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <!-- Search bar -->
                        <Border Grid.Column="0" BorderBrush="#E2E8F0" BorderThickness="1" CornerRadius="6"
                                Padding="10,0" Margin="0,0,14,0" Background="#F8FAFC">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <Path Grid.Column="0" Data="{StaticResource IconSearchData}" Fill="#94A3B8" Width="14" Height="14" Stretch="Uniform" VerticalAlignment="Center" Margin="2,0,6,0"/>
                                <TextBox Grid.Column="1" Text="{Binding SearchQuery, UpdateSourceTrigger=PropertyChanged}"
                                         Background="Transparent" BorderThickness="0" FontSize="13" VerticalContentAlignment="Center"
                                         Foreground="#0F172A" VerticalAlignment="Center" Padding="0,6"/>
                            </Grid>
                        </Border>

                        <StackPanel Grid.Column="1" Orientation="Horizontal" Margin="0,0,14,0" VerticalAlignment="Center">
                            <TextBlock Text="Category:" FontSize="12" FontWeight="SemiBold" Foreground="#64748B" VerticalAlignment="Center" Margin="0,0,6,0"/>
                            <ComboBox ItemsSource="{Binding CategoryFilterOptions}"
                                      SelectedItem="{Binding CategoryFilter}"
                                      FontSize="12" MinWidth="130" Padding="8,6" Height="36" BorderBrush="#E2E8F0"/>
                        </StackPanel>

                        <StackPanel Grid.Column="2" Orientation="Horizontal" Margin="0,0,20,0" VerticalAlignment="Center">
                            <TextBlock Text="Status:" FontSize="12" FontWeight="SemiBold" Foreground="#64748B" VerticalAlignment="Center" Margin="0,0,6,0"/>
                            <ComboBox ItemsSource="{Binding StatusOptions}" SelectedItem="{Binding StatusFilter}"
                                      FontSize="12" MinWidth="120" Padding="8,6" Height="36" BorderBrush="#E2E8F0"/>
                        </StackPanel>

                        <TextBlock Grid.Column="3" VerticalAlignment="Center" FontSize="12" Foreground="#64748B">
                            <Run Text="Hiển thị "/>
                            <Run Text="{Binding FilteredCount, Mode=OneWay}" Foreground="#0F172A" FontWeight="Bold"/>
                            <Run Text="/"/>
                            <Run Text="{Binding AllCount, Mode=OneWay}" Foreground="#0F172A" FontWeight="Bold"/>
                            <Run Text=" sản phẩm"/>
                        </TextBlock>
                    </Grid>
                </Border>

                <!-- Product table -->
                <Border Grid.Row="3" Background="White" BorderBrush="#E2E8F0" BorderThickness="1"
                        CornerRadius="8" ClipToBounds="True">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>

                        <!-- Table header -->
                        <Border Grid.Row="0" Background="#F8FAFC" BorderBrush="#E2E8F0" BorderThickness="0,0,0,1">
                            <Grid Margin="14,10">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="36"/>
                                    <ColumnDefinition Width="54"/>
                                    <ColumnDefinition Width="3*"/>
                                    <ColumnDefinition Width="120"/>
                                    <ColumnDefinition Width="130"/>
                                    <ColumnDefinition Width="100"/>
                                    <ColumnDefinition Width="140"/>
                                    <ColumnDefinition Width="130"/>
                                    <ColumnDefinition Width="100"/>
                                </Grid.ColumnDefinitions>
                                <CheckBox Grid.Column="0" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                <TextBlock Grid.Column="1" Text="IMAGE" FontSize="11" FontWeight="Bold" Foreground="#64748B"/>
                                <TextBlock Grid.Column="2" Text="PRODUCT" FontSize="11" FontWeight="Bold" Foreground="#64748B"/>
                                <TextBlock Grid.Column="3" Text="CATEGORY" FontSize="11" FontWeight="Bold" Foreground="#64748B"/>
                                <TextBlock Grid.Column="4" Text="BARCODE" FontSize="11" FontWeight="Bold" Foreground="#64748B"/>
                                <TextBlock Grid.Column="5" Text="PRICE (₫)" FontSize="11" FontWeight="Bold" Foreground="#64748B" TextAlignment="Right" Margin="0,0,14,0"/>
                                <TextBlock Grid.Column="6" Text="STOCK" FontSize="11" FontWeight="Bold" Foreground="#64748B"/>
                                <TextBlock Grid.Column="7" Text="STATUS" FontSize="11" FontWeight="Bold" Foreground="#64748B"/>
                                <TextBlock Grid.Column="8" Text="ACTIONS" FontSize="11" FontWeight="Bold" Foreground="#64748B" TextAlignment="Center"/>
                            </Grid>
                        </Border>

                        <!-- Table rows -->
                        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                            <ItemsControl ItemsSource="{Binding FilteredProducts}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Border BorderBrush="#E2E8F0" BorderThickness="0,0,0,1">
                                            <Border.Style>
                                                <Style TargetType="Border">
                                                    <Setter Property="Background" Value="White"/>
                                                    <Style.Triggers>
                                                        <Trigger Property="IsMouseOver" Value="True">
                                                            <Setter Property="Background" Value="#F8FAFC"/>
                                                        </Trigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </Border.Style>
                                            <Grid Margin="14,0" Height="64">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="36"/>
                                                    <ColumnDefinition Width="54"/>
                                                    <ColumnDefinition Width="3*"/>
                                                    <ColumnDefinition Width="120"/>
                                                    <ColumnDefinition Width="130"/>
                                                    <ColumnDefinition Width="100"/>
                                                    <ColumnDefinition Width="140"/>
                                                    <ColumnDefinition Width="130"/>
                                                    <ColumnDefinition Width="100"/>
                                                </Grid.ColumnDefinitions>

                                                <!-- Checkbox -->
                                                <CheckBox Grid.Column="0" HorizontalAlignment="Center" VerticalAlignment="Center"/>

                                                <!-- Image -->
                                                <Border Grid.Column="1" Width="40" Height="40"
                                                        CornerRadius="6" VerticalAlignment="Center"
                                                        ClipToBounds="True" Background="#F1F5F9">
                                                    <Grid>
                                                        <Border Background="#F1F5F9" CornerRadius="6"
                                                                Visibility="{Binding ImagePath, Converter={StaticResource ImagePathToVis}, ConverterParameter=inverse}">
                                                            <Path Data="{StaticResource IconCatalogData}" Fill="#94A3B8" Width="16" Height="16" Stretch="Uniform" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                        </Border>
                                                        <Image Source="{Binding ImagePath, Converter={StaticResource LocalImagePathConverter}}"
                                                               Stretch="UniformToFill"
                                                               Visibility="{Binding ImagePath, Converter={StaticResource ImagePathToVis}}"/>
                                                    </Grid>
                                                </Border>

                                                <!-- Product Name & SKU -->
                                                <StackPanel Grid.Column="2" VerticalAlignment="Center">
                                                    <TextBlock Text="{Binding Name}" FontWeight="Bold" FontSize="13" Foreground="#0F172A"/>
                                                    <TextBlock Text="{Binding Sku}" FontSize="11" Foreground="#94A3B8"
                                                               FontFamily="Consolas" Margin="0,2,0,0"/>
                                                </StackPanel>

                                                <!-- Category -->
                                                <TextBlock Grid.Column="3" Text="{Binding CategoryName}"
                                                           FontSize="12" Foreground="#64748B" VerticalAlignment="Center"/>

                                                <!-- Barcode -->
                                                <TextBlock Grid.Column="4" Text="{Binding Barcode}"
                                                           FontSize="12" FontFamily="Consolas" Foreground="#64748B"
                                                           VerticalAlignment="Center"/>

                                                <!-- Price -->
                                                <TextBlock Grid.Column="5"
                                                           Text="{Binding UnitPrice, StringFormat='{}{0:N0} ₫'}"
                                                           FontWeight="Bold" FontSize="13" Foreground="#0F172A"
                                                           TextAlignment="Right" VerticalAlignment="Center" Margin="0,0,14,0"/>

                                                <!-- Stock pill -->
                                                <Border Grid.Column="6" VerticalAlignment="Center"
                                                        Background="{Binding LocalStockQuantity, Converter={StaticResource StockBgConverter}}"
                                                        CornerRadius="10" Padding="8,3" HorizontalAlignment="Left">
                                                    <TextBlock Text="{Binding LocalStockQuantity, Converter={StaticResource StockTextConverter}}"
                                                               Foreground="{Binding LocalStockQuantity, Converter={StaticResource StockFgConverter}}"
                                                               FontSize="11" FontWeight="Bold"/>
                                                </Border>

                                                <!-- Status tag -->
                                                <Border Grid.Column="7" VerticalAlignment="Center"
                                                        CornerRadius="10" Padding="8,3" HorizontalAlignment="Left">
                                                    <Border.Style>
                                                        <Style TargetType="Border">
                                                            <Setter Property="Background" Value="#ECFDF5"/>
                                                            <Style.Triggers>
                                                                <DataTrigger Binding="{Binding IsActive}" Value="False">
                                                                    <Setter Property="Background" Value="#F1F5F9"/>
                                                                </DataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </Border.Style>
                                                    <TextBlock FontSize="11" FontWeight="Bold">
                                                        <TextBlock.Style>
                                                            <Style TargetType="TextBlock">
                                                                <Setter Property="Text" Value="Active"/>
                                                                <Setter Property="Foreground" Value="#10B981"/>
                                                                <Style.Triggers>
                                                                    <DataTrigger Binding="{Binding IsActive}" Value="False">
                                                                        <Setter Property="Text" Value="Inactive"/>
                                                                        <Setter Property="Foreground" Value="#64748B"/>
                                                                    </DataTrigger>
                                                                </Style.Triggers>
                                                            </Style>
                                                        </TextBlock.Style>
                                                    </TextBlock>
                                                </Border>

                                                <!-- Actions -->
                                                <StackPanel Grid.Column="8" Orientation="Horizontal"
                                                            VerticalAlignment="Center" HorizontalAlignment="Center">
                                                    <Button ToolTip="Chỉnh sửa" Content="✏" FontSize="12"
                                                            Style="{StaticResource RowIconBtn}"
                                                            Command="{Binding DataContext.SelectProductCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                                            CommandParameter="{Binding}"/>
                                                    <Button ToolTip="Xóa" Content="🗑" FontSize="12"
                                                            Margin="4,0,0,0" Foreground="#EF4444"
                                                            Style="{StaticResource RowIconBtn}"
                                                            Command="{Binding DataContext.DeleteProductCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                                            CommandParameter="{Binding}"/>
                                                </StackPanel>
                                            </Grid>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </ScrollViewer>
                    </Grid>
                </Border>
            </Grid>
        </Grid>
    </Grid>
</UserControl>
