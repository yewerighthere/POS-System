<UserControl x:Class="SmartPOS.WPF.Views.CatalogView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:viewmodels="clr-namespace:SmartPOS.WPF.ViewModels"
             xmlns:converters="clr-namespace:SmartPOS.WPF.Converters"
             mc:Ignorable="d"
             d:DataContext="{d:DesignInstance Type=viewmodels:CatalogViewModel}"
             Background="{StaticResource BackgroundBrush}">

    <UserControl.Resources>
        <converters:NullOrEmptyToVisibilityConverter x:Key="NullOrEmptyToVisibilityConverter"/>
        <converters:NullToVisibilityConverter x:Key="NullToVisibilityConverter"/>
        <BooleanToVisibilityConverter x:Key="BoolToVis"/>
        <converters:InverseBoolConverter x:Key="BoolInverter"/>
        <converters:LocalImagePathConverter x:Key="LocalImagePathConverter"/>
        <converters:ImagePathToVisibilityConverter x:Key="ImagePathToVis"/>

        <Style x:Key="PrimaryBtn" TargetType="Button">
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="16,10"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="8" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="OutlineBtn" TargetType="Button">
            <Setter Property="Background" Value="White"/>
            <Setter Property="Foreground" Value="#00288E"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="BorderBrush" Value="#00288E"/>
            <Setter Property="Padding" Value="16,10"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}" CornerRadius="8" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="RowIconBtn" TargetType="Button">
            <Setter Property="Width" Value="32"/>
            <Setter Property="Height" Value="32"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Foreground" Value="#64748B"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd" Background="{TemplateBinding Background}" CornerRadius="6">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#EFF6FF"/>
                                <Setter Property="Foreground" Value="#00288E"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </UserControl.Resources>

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="Auto"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- LEFT SIDEBAR -->
        <Border Grid.Column="0" Width="220" Background="#1A1B22"
                Visibility="{Binding ShowNavigation, Converter={StaticResource BoolToVis}}">
            <Grid Margin="0,24,0,24">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>
                <StackPanel Grid.Row="0" Margin="20,0,20,32">
                    <TextBlock Text="SmartPOS Admin" Foreground="#E2E8F0" FontSize="18" FontWeight="Black"/>
                    <TextBlock Text="Terminal #01" Foreground="{StaticResource SidebarTextBrush}" FontSize="12" Margin="0,4,0,0" Opacity="0.8"/>
                </StackPanel>
                <StackPanel Grid.Row="1">
                    <Button Style="{StaticResource SidebarNavButtonStyle}" Tag="🖥️" Content="Point of Sale"      Command="{Binding NavigateToSalesCommand}"/>
                    <Button Style="{StaticResource SidebarNavButtonStyle}" Tag="🧾" Content="Transactions"/>
                    <Button Style="{StaticResource SidebarNavButtonStyle}" Tag="📦" Content="Inventory"           Command="{Binding NavigateToSyncCommand}"/>
                    <Button Style="{StaticResource SidebarNavButtonStyle}" Tag="👤" Content="Customers"           Command="{Binding NavigateToCustomerCommand}"/>
                    <Button Style="{StaticResource SidebarNavButtonStyle}" Tag="🔄" Content="Returns &amp; Refunds"/>
                    <!-- ACTIVE: Product Catalog -->
                    <Border Background="#00288E" CornerRadius="8" Margin="8,2" Padding="16,10">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="🗂️" Margin="0,0,12,0" FontSize="14" VerticalAlignment="Center"/>
                            <TextBlock Text="Product Catalog" Foreground="White" FontSize="13" FontWeight="SemiBold" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Border>
                    <Button Style="{StaticResource SidebarNavButtonStyle}" Tag="📊" Content="Shift Reports"       Command="{Binding NavigateToReportCommand}"/>
                    <Button Style="{StaticResource SidebarNavButtonStyle}" Tag="⚙️" Content="Settings"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- MAIN CONTENT -->
        <Grid Grid.Column="1" Background="#F8FAFC">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- Top header bar -->
            <Border Grid.Row="0" Background="White" BorderBrush="{StaticResource BorderMediumBrush}" BorderThickness="0,0,0,1" Padding="24,0">
                <Grid VerticalAlignment="Center">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0" Text="SmartPOS Retail" Foreground="#00288E"
                               FontSize="20" FontWeight="Black" VerticalAlignment="Center"/>
                    <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                        <Button Content="Support" Background="Transparent" Foreground="#00288E"
                                FontWeight="Bold" BorderThickness="0" Margin="0,0,16,0" Cursor="Hand"/>
                        <Button Content="End Shift" Command="{Binding NavigateToSalesCommand}"
                                Style="{StaticResource PrimaryBtn}" Background="#00288E" Padding="16,8"/>
                    </StackPanel>
                </Grid>
            </Border>

            <!-- Error bar -->
            <Grid Grid.Row="1" Margin="24,12,24,0"
                  Visibility="{Binding ErrorMessage, Converter={StaticResource NullOrEmptyToVisibilityConverter}, FallbackValue=Collapsed}">
                <Border Background="#FEF2F2" BorderBrush="#FCA5A5" BorderThickness="1" CornerRadius="8" Padding="16,12">
                    <TextBlock Text="{Binding ErrorMessage}" Foreground="#991B1B" FontSize="13" TextWrapping="Wrap"/>
                </Border>
            </Grid>

            <!-- Sync status bar -->
            <Grid Grid.Row="1" Margin="24,12,24,0"
                  Visibility="{Binding SyncStatus, Converter={StaticResource NullOrEmptyToVisibilityConverter}, FallbackValue=Collapsed}">
                <Border Background="#F0FDF4" BorderBrush="#86EFAC" BorderThickness="1" CornerRadius="8" Padding="16,12">
                    <TextBlock Text="{Binding SyncStatus}" Foreground="#166534" FontSize="13" TextWrapping="Wrap"/>
                </Border>
            </Grid>

            <!-- Page header -->
            <Grid Grid.Row="2" Margin="24,20,24,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <StackPanel Grid.Column="0">
                    <TextBlock Text="Product Catalog" FontSize="24" FontWeight="Bold" Foreground="{StaticResource TextPrimaryBrush}"/>
                    <TextBlock Text="{Binding LastSyncedText}" Foreground="{StaticResource TextMutedBrush}" FontSize="13" Margin="0,4,0,0"/>
                </StackPanel>
                <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Bottom">
                    <Button Command="{Binding SyncFromInventoryCommand}"
                            IsEnabled="{Binding IsSyncing, Converter={StaticResource BoolInverter}}"
                            Style="{StaticResource OutlineBtn}" Margin="0,0,10,0" Height="42" Padding="16,0">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="↻" FontSize="15" Margin="0,0,6,0" VerticalAlignment="Center"/>
                            <TextBlock VerticalAlignment="Center">
                                <TextBlock.Style>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="Text" Value="Update from Inventory"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding IsSyncing}" Value="True">
                                                <Setter Property="Text" Value="Đang đồng bộ..."/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBlock.Style>
                            </TextBlock>
                        </StackPanel>
                    </Button>
                    <Button Content="＋  Add Product" Command="{Binding ToggleAddProductCommand}"
                            Style="{StaticResource PrimaryBtn}" Background="#2563EB" Height="42" Padding="20,0" FontSize="14"/>
                </StackPanel>
            </Grid>

            <!-- Workspace -->
            <Grid Grid.Row="3" Margin="24,16,24,24">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <!-- Add Product form (toggle) -->
                <Border Grid.Row="0" Background="White" BorderBrush="{StaticResource BorderMediumBrush}" BorderThickness="1"
                        CornerRadius="12" Padding="20" Margin="0,0,0,12"
                        Visibility="{Binding IsAddProductVisible, Converter={StaticResource BoolToVis}}">
                    <StackPanel>
                        <TextBlock Text="Thêm sản phẩm mới" FontWeight="SemiBold" FontSize="16"
                                   Foreground="{StaticResource TextPrimaryBrush}" Margin="0,0,0,14"/>

                        <!-- Main layout: image on left, fields on right -->
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>

                            <!-- Image Upload Panel -->
                            <StackPanel Grid.Column="0" Margin="0,0,16,0" VerticalAlignment="Top">
                                <Border Width="120" Height="120" CornerRadius="10"
                                        BorderBrush="{StaticResource BorderMediumBrush}" BorderThickness="2"
                                        Background="{StaticResource BackgroundBrush}" ClipToBounds="True">
                                    <Grid>
                                        <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center"
                                                    Visibility="{Binding NewProductImagePath,
                                                        Converter={StaticResource ImagePathToVis},
                                                        ConverterParameter=inverse}">
                                            <TextBlock Text="📷" FontSize="36" HorizontalAlignment="Center"/>
                                            <TextBlock Text="Chọn ảnh" FontSize="12"
                                                       Foreground="{StaticResource SidebarTextBrush}" HorizontalAlignment="Center"
                                                       Margin="0,4,0,0"/>
                                        </StackPanel>
                                        <Image Source="{Binding NewProductImagePath, Converter={StaticResource LocalImagePathConverter}}"
                                               Stretch="UniformToFill"
                                               Visibility="{Binding NewProductImagePath, Converter={StaticResource ImagePathToVis}}"/>
                                    </Grid>
                                </Border>

                                <Button Command="{Binding BrowseImageCommand}"
                                        Margin="0,8,0,0" Padding="8,6" FontSize="13"
                                        Background="#2563EB" Foreground="White"
                                        BorderThickness="0" Cursor="Hand">
                                    <Button.Template>
                                        <ControlTemplate TargetType="Button">
                                            <Border Background="{TemplateBinding Background}" CornerRadius="7" Padding="{TemplateBinding Padding}">
                                                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                                    <TextBlock Text="📂" FontSize="13" Margin="0,0,5,0" VerticalAlignment="Center"/>
                                                    <ContentPresenter VerticalAlignment="Center"/>
                                                </StackPanel>
                                            </Border>
                                            <ControlTemplate.Triggers>
                                                <Trigger Property="IsMouseOver" Value="True">
                                                    <Setter Property="Background" Value="#1D4ED8"/>
                                                </Trigger>
                                            </ControlTemplate.Triggers>
                                        </ControlTemplate>
                                    </Button.Template>
                                    Chọn ảnh
                                </Button>

                                <Button Command="{Binding ClearImageCommand}"
                                        Visibility="{Binding NewProductImagePath, Converter={StaticResource ImagePathToVis}}"
                                        Margin="0,4,0,0" Padding="8,5" FontSize="12"
                                        Background="Transparent" Foreground="{StaticResource DangerBrush}"
                                        BorderThickness="1" BorderBrush="#FCA5A5" Cursor="Hand">
                                    <Button.Template>
                                        <ControlTemplate TargetType="Button">
                                            <Border Background="{TemplateBinding Background}"
                                                    BorderBrush="{TemplateBinding BorderBrush}"
                                                    BorderThickness="{TemplateBinding BorderThickness}"
                                                    CornerRadius="7" Padding="{TemplateBinding Padding}">
                                                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                                    <TextBlock Text="✕" FontSize="11" Margin="0,0,4,0"
                                                               Foreground="{StaticResource DangerBrush}" VerticalAlignment="Center"/>
                                                    <ContentPresenter VerticalAlignment="Center"/>
                                                </StackPanel>
                                            </Border>
                                            <ControlTemplate.Triggers>
                                                <Trigger Property="IsMouseOver" Value="True">
                                                    <Setter Property="Background" Value="#FEF2F2"/>
                                                </Trigger>
                                            </ControlTemplate.Triggers>
                                        </ControlTemplate>
                                    </Button.Template>
                                    Xóa ảnh
                                </Button>
                            </StackPanel>

                            <!-- Input Fields -->
                            <StackPanel Grid.Column="1">
                                <!-- Fields row -->
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="180"/>
                                        <ColumnDefinition Width="140"/>
                                        <ColumnDefinition Width="150"/>
                                        <ColumnDefinition Width="130"/>
                                        <ColumnDefinition Width="100"/>
                                    </Grid.ColumnDefinitions>
                                    <ComboBox Grid.Column="0" ItemsSource="{Binding Categories}"
                                              SelectedItem="{Binding SelectedCategory}" DisplayMemberPath="Name"
                                              Margin="0,0,8,0" Padding="12,10" FontSize="14" BorderBrush="{StaticResource BorderMediumBrush}"/>
                                    <TextBox Grid.Column="1" Text="{Binding NewProductName, UpdateSourceTrigger=PropertyChanged}"
                                             Padding="12,10" BorderBrush="{StaticResource BorderMediumBrush}" BorderThickness="1" Margin="0,0,8,0" FontSize="14"/>
                                    <TextBox Grid.Column="2" Text="{Binding NewProductSku, UpdateSourceTrigger=PropertyChanged}"
                                             Padding="12,10" BorderBrush="{StaticResource BorderMediumBrush}" BorderThickness="1" Margin="0,0,8,0" FontSize="14"/>
                                    <TextBox Grid.Column="3" Text="{Binding NewProductBarcode, UpdateSourceTrigger=PropertyChanged}"
                                             Padding="12,10" BorderBrush="{StaticResource BorderMediumBrush}" BorderThickness="1" Margin="0,0,8,0" FontSize="14"/>
                                    <TextBox Grid.Column="4" Text="{Binding NewProductPrice, UpdateSourceTrigger=PropertyChanged}"
                                             Padding="12,10" BorderBrush="{StaticResource BorderMediumBrush}" BorderThickness="1" Margin="0,0,8,0" FontSize="14"/>
                                    <TextBox Grid.Column="5" Text="{Binding NewProductStock, UpdateSourceTrigger=PropertyChanged}"
                                             Padding="12,10" BorderBrush="{StaticResource BorderMediumBrush}" BorderThickness="1" FontSize="14"/>
                                </Grid>
                                <!-- Labels row -->
                                <Grid Margin="0,4,0,12">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="180"/>
                                        <ColumnDefinition Width="140"/>
                                        <ColumnDefinition Width="150"/>
                                        <ColumnDefinition Width="130"/>
                                        <ColumnDefinition Width="100"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0" Text="Danh mục *" FontSize="12" Foreground="{StaticResource TextMutedBrush}"/>
                                    <TextBlock Grid.Column="1" Text="Tên sản phẩm *" FontSize="12" Foreground="{StaticResource TextMutedBrush}" Margin="0,0,8,0"/>
                                    <TextBlock Grid.Column="2" Text="SKU" FontSize="12" Foreground="{StaticResource TextMutedBrush}" Margin="0,0,8,0"/>
                                    <TextBlock Grid.Column="3" Text="Barcode" FontSize="12" Foreground="{StaticResource TextMutedBrush}" Margin="0,0,8,0"/>
                                    <TextBlock Grid.Column="4" Text="Giá (VNĐ) *" FontSize="12" Foreground="{StaticResource TextMutedBrush}" Margin="0,0,8,0"/>
                                    <TextBlock Grid.Column="5" Text="Tồn kho" FontSize="12" Foreground="{StaticResource TextMutedBrush}"/>
                                </Grid>
                                <!-- Submit button -->
                                <Button Content="＋  Thêm sản phẩm" Command="{Binding AddProductCommand}"
                                        HorizontalAlignment="Right"
                                        Style="{StaticResource PrimaryBtn}" Background="#2563EB" Padding="24,12" FontSize="14"/>
                            </StackPanel>
                        </Grid>
                    </StackPanel>
                </Border>

                <!-- Selected product edit bar -->
                <Border Grid.Row="1" Background="#EFF6FF" BorderBrush="#2563EB" BorderThickness="1"
                        CornerRadius="12" Padding="16" Margin="0,0,0,12"
                        Visibility="{Binding SelectedProduct, Converter={StaticResource NullToVisibilityConverter}}">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0" VerticalAlignment="Center">
                            <TextBlock FontWeight="SemiBold" FontSize="15" Foreground="{StaticResource TextPrimaryBrush}">
                                <Run Text="Đang chọn: "/><Run Text="{Binding SelectedProduct.Name}"/>
                            </TextBlock>
                        </StackPanel>
                        <StackPanel Grid.Column="1" Orientation="Horizontal" Margin="12,0" VerticalAlignment="Center">
                            <TextBlock Text="Giá mới:" VerticalAlignment="Center" Margin="0,0,8,0" Foreground="{StaticResource TextPrimaryBrush}" FontSize="14"/>
                            <TextBox Text="{Binding UpdatedPrice, UpdateSourceTrigger=PropertyChanged}"
                                     Width="120" Padding="10,8" BorderBrush="{StaticResource BorderMediumBrush}" BorderThickness="1" FontSize="14"/>
                            <TextBlock Text="Tồn kho:" VerticalAlignment="Center" Margin="16,0,8,0" Foreground="{StaticResource TextPrimaryBrush}" FontSize="14"/>
                            <TextBox Text="{Binding UpdatedStock, UpdateSourceTrigger=PropertyChanged}"
                                     Width="80" Padding="10,8" BorderBrush="{StaticResource BorderMediumBrush}" BorderThickness="1" FontSize="14"/>
                        </StackPanel>
                        <Button Grid.Column="2" Content="📷 Đổi ảnh" Command="{Binding UpdateImageCommand}"
                                Style="{StaticResource OutlineBtn}" Margin="0,0,8,0" Height="40" FontSize="13"/>
                        <Button Grid.Column="3" Content="✏ Cập nhật" Command="{Binding UpdateProductInfoCommand}"
                                Style="{StaticResource PrimaryBtn}" Background="#2563EB" Margin="0,0,8,0" Height="40" FontSize="13"/>
                        <Grid Grid.Column="4">
                            <Button Content="✕ Ngừng KD" Command="{Binding DeactivateProductCommand}"
                                    Background="#DC2626" Height="40" FontSize="13">
                                <Button.Style>
                                    <Style TargetType="Button" BasedOn="{StaticResource PrimaryBtn}">
                                        <Setter Property="Visibility" Value="Collapsed"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding SelectedProduct.IsActive}" Value="True">
                                                <Setter Property="Visibility" Value="Visible"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Button.Style>
                            </Button>
                            <Button Content="✓ Kinh doanh lại" Command="{Binding ReactivateProductCommand}"
                                    Background="#16A34A" Height="40" FontSize="13">
                                <Button.Style>
                                    <Style TargetType="Button" BasedOn="{StaticResource PrimaryBtn}">
                                        <Setter Property="Visibility" Value="Collapsed"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding SelectedProduct.IsActive}" Value="False">
                                                <Setter Property="Visibility" Value="Visible"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Button.Style>
                            </Button>
                        </Grid>
                    </Grid>
                </Border>

                <!-- Filter bar -->
                <Border Grid.Row="2" Background="White" BorderBrush="{StaticResource BorderMediumBrush}" BorderThickness="1"
                        CornerRadius="20" Padding="16,12" Margin="0,0,0,12" Height="68">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <!-- Search bar -->
                        <Border Grid.Column="0" BorderBrush="{StaticResource BorderMediumBrush}" BorderThickness="1" CornerRadius="20"
                                Padding="14,0" Margin="0,0,16,0" Background="#F8FAFC">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Text="🔍" FontSize="16" Foreground="{StaticResource TextMutedBrush}"
                                           VerticalAlignment="Center" Margin="4,0,8,0"/>
                                <TextBox Grid.Column="1" Text="{Binding SearchQuery, UpdateSourceTrigger=PropertyChanged}"
                                         Background="Transparent" BorderThickness="0" FontSize="14" VerticalContentAlignment="Center"
                                         Foreground="{StaticResource TextPrimaryBrush}" VerticalAlignment="Center" Padding="0,8"
                                         Tag="Tìm kiếm sản phẩm, SKU hoặc Barcode"/>
                            </Grid>
                        </Border>

                        <StackPanel Grid.Column="1" Orientation="Horizontal" Margin="0,0,16,0" VerticalAlignment="Center">
                            <TextBlock Text="Category:" FontSize="14" FontWeight="SemiBold" Foreground="{StaticResource TextMutedBrush}" VerticalAlignment="Center" Margin="0,0,8,0"/>
                            <ComboBox ItemsSource="{Binding CategoryFilterOptions}"
                                      SelectedItem="{Binding CategoryFilter}"
                                      FontSize="14" MinWidth="140" Padding="10,8" Height="42" BorderBrush="{StaticResource BorderMediumBrush}">
                                <ComboBox.Resources>
                                    <Style TargetType="Border">
                                        <Setter Property="CornerRadius" Value="8"/>
                                    </Style>
                                </ComboBox.Resources>
                            </ComboBox>
                        </StackPanel>

                        <StackPanel Grid.Column="2" Orientation="Horizontal" Margin="0,0,24,0" VerticalAlignment="Center">
                            <TextBlock Text="Status:" FontSize="14" FontWeight="SemiBold" Foreground="{StaticResource TextMutedBrush}" VerticalAlignment="Center" Margin="0,0,8,0"/>
                            <ComboBox ItemsSource="{Binding StatusOptions}" SelectedItem="{Binding StatusFilter}"
                                      FontSize="14" MinWidth="130" Padding="10,8" Height="42" BorderBrush="{StaticResource BorderMediumBrush}">
                                <ComboBox.Resources>
                                    <Style TargetType="Border">
                                        <Setter Property="CornerRadius" Value="8"/>
                                    </Style>
                                </ComboBox.Resources>
                            </ComboBox>
                        </StackPanel>

                        <TextBlock Grid.Column="3" VerticalAlignment="Center" FontSize="14" Foreground="{StaticResource TextMutedBrush}">
                            <Run Text="Hiển thị "/>
                            <Run Text="{Binding FilteredCount, Mode=OneWay}" Foreground="{StaticResource TextPrimaryBrush}" FontWeight="Bold"/>
                            <Run Text="/"/>
                            <Run Text="{Binding AllCount, Mode=OneWay}" Foreground="{StaticResource TextPrimaryBrush}" FontWeight="Bold"/>
                            <Run Text=" sản phẩm"/>
                        </TextBlock>
                    </Grid>
                </Border>

                <!-- Product table -->
                <Border Grid.Row="3" Background="White" BorderBrush="{StaticResource BorderMediumBrush}" BorderThickness="1"
                        CornerRadius="12" ClipToBounds="True">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>

                        <!-- Table header -->
                        <Border Grid.Row="0" Background="#F4F2FC" BorderBrush="{StaticResource BorderMediumBrush}" BorderThickness="0,0,0,1">
                            <Grid Margin="16,12">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="40"/>
                                    <ColumnDefinition Width="60"/>
                                    <ColumnDefinition Width="3*"/>
                                    <ColumnDefinition Width="130"/>
                                    <ColumnDefinition Width="140"/>
                                    <ColumnDefinition Width="110"/>
                                    <ColumnDefinition Width="150"/>
                                    <ColumnDefinition Width="140"/>
                                    <ColumnDefinition Width="110"/>
                                </Grid.ColumnDefinitions>
                                <CheckBox Grid.Column="0" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                <TextBlock Grid.Column="1" Text="IMAGE"    FontSize="13" FontWeight="Bold" Foreground="{StaticResource TextMutedBrush}"/>
                                <TextBlock Grid.Column="2" Text="PRODUCT"  FontSize="13" FontWeight="Bold" Foreground="{StaticResource TextMutedBrush}"/>
                                <TextBlock Grid.Column="3" Text="CATEGORY" FontSize="13" FontWeight="Bold" Foreground="{StaticResource TextMutedBrush}"/>
                                <TextBlock Grid.Column="4" Text="BARCODE"  FontSize="13" FontWeight="Bold" Foreground="{StaticResource TextMutedBrush}"/>
                                <TextBlock Grid.Column="5" Text="PRICE (đ)" FontSize="13" FontWeight="Bold" Foreground="{StaticResource TextMutedBrush}" TextAlignment="Right" Margin="0,0,16,0"/>
                                <TextBlock Grid.Column="6" Text="STOCK"    FontSize="13" FontWeight="Bold" Foreground="{StaticResource TextMutedBrush}"/>
                                <TextBlock Grid.Column="7" Text="STATUS"   FontSize="13" FontWeight="Bold" Foreground="{StaticResource TextMutedBrush}"/>
                                <TextBlock Grid.Column="8" Text="ACTIONS"  FontSize="13" FontWeight="Bold" Foreground="{StaticResource TextMutedBrush}" TextAlignment="Center"/>
                            </Grid>
                        </Border>

                        <!-- Table rows -->
                        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                            <ItemsControl ItemsSource="{Binding FilteredProducts}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Border BorderBrush="{StaticResource BorderMediumBrush}" BorderThickness="0,0,0,1">
                                            <Border.Style>
                                                <Style TargetType="Border">
                                                    <Setter Property="Background" Value="White"/>
                                                    <Style.Triggers>
                                                        <Trigger Property="IsMouseOver" Value="True">
                                                            <Setter Property="Background" Value="#F8FAFC"/>
                                                        </Trigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </Border.Style>
                                            <Grid Margin="16,0" Height="72">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="40"/>
                                                    <ColumnDefinition Width="60"/>
                                                    <ColumnDefinition Width="3*"/>
                                                    <ColumnDefinition Width="130"/>
                                                    <ColumnDefinition Width="140"/>
                                                    <ColumnDefinition Width="110"/>
                                                    <ColumnDefinition Width="150"/>
                                                    <ColumnDefinition Width="140"/>
                                                    <ColumnDefinition Width="110"/>
                                                </Grid.ColumnDefinitions>

                                                <!-- Checkbox -->
                                                <CheckBox Grid.Column="0" HorizontalAlignment="Center" VerticalAlignment="Center"/>

                                                <!-- Image -->
                                                <Border Grid.Column="1" Width="44" Height="44"
                                                        CornerRadius="8" VerticalAlignment="Center"
                                                        ClipToBounds="True" Background="#F1F5F9">
                                                    <Grid>
                                                        <Border Background="#EEF2FF" CornerRadius="8"
                                                                Visibility="{Binding ImagePath, Converter={StaticResource ImagePathToVis}, ConverterParameter=inverse}">
                                                            <TextBlock Text="📦" FontSize="20"
                                                                       HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                        </Border>
                                                        <Image Source="{Binding ImagePath, Converter={StaticResource LocalImagePathConverter}}"
                                                               Stretch="UniformToFill"
                                                               Visibility="{Binding ImagePath, Converter={StaticResource ImagePathToVis}}"/>
                                                    </Grid>
                                                </Border>

                                                <!-- Product Name & SKU -->
                                                <StackPanel Grid.Column="2" VerticalAlignment="Center">
                                                    <TextBlock Text="{Binding Name}" FontWeight="Bold" FontSize="15" Foreground="{StaticResource TextPrimaryBrush}"/>
                                                    <TextBlock Text="{Binding Sku}" FontSize="12" Foreground="{StaticResource TextMutedBrush}"
                                                               FontFamily="Consolas" Margin="0,2,0,0"/>
                                                </StackPanel>

                                                <!-- Category -->
                                                <TextBlock Grid.Column="3" Text="{Binding CategoryName}"
                                                           FontSize="14" Foreground="{StaticResource TextMutedBrush}" VerticalAlignment="Center"/>

                                                <!-- Barcode -->
                                                <TextBlock Grid.Column="4" Text="{Binding Barcode}"
                                                           FontSize="13" FontFamily="Consolas" Foreground="{StaticResource TextMutedBrush}"
                                                           VerticalAlignment="Center"/>

                                                <!-- Price -->
                                                <TextBlock Grid.Column="5"
                                                           Text="{Binding UnitPrice, StringFormat='{}{0:N0} đ'}"
                                                           FontWeight="Bold" FontSize="15" Foreground="{StaticResource TextPrimaryBrush}"
                                                           TextAlignment="Right" VerticalAlignment="Center" Margin="0,0,16,0"/>

                                                <!-- Stock pill -->
                                                <Border Grid.Column="6" VerticalAlignment="Center"
                                                        Background="{Binding LocalStockQuantity, Converter={StaticResource StockBgConverter}}"
                                                        CornerRadius="12" Padding="10,4" HorizontalAlignment="Left">
                                                    <TextBlock Text="{Binding LocalStockQuantity, Converter={StaticResource StockTextConverter}}"
                                                               Foreground="{Binding LocalStockQuantity, Converter={StaticResource StockFgConverter}}"
                                                               FontSize="12" FontWeight="Bold"/>
                                                </Border>

                                                <!-- Status tag -->
                                                <Border Grid.Column="7" VerticalAlignment="Center"
                                                        CornerRadius="12" Padding="10,4" HorizontalAlignment="Left">
                                                    <Border.Style>
                                                        <Style TargetType="Border">
                                                            <Setter Property="Background" Value="#ECFDF5"/>
                                                            <Style.Triggers>
                                                                <DataTrigger Binding="{Binding IsActive}" Value="False">
                                                                    <Setter Property="Background" Value="#F1F5F9"/>
                                                                </DataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </Border.Style>
                                                    <TextBlock FontSize="12" FontWeight="Bold">
                                                        <TextBlock.Style>
                                                            <Style TargetType="TextBlock">
                                                                <Setter Property="Text" Value="Đang bán (Active)"/>
                                                                <Setter Property="Foreground" Value="#10B981"/>
                                                                <Style.Triggers>
                                                                    <DataTrigger Binding="{Binding IsActive}" Value="False">
                                                                        <Setter Property="Text" Value="Ngừng bán (Inactive)"/>
                                                                        <Setter Property="Foreground" Value="#64748B"/>
                                                                    </DataTrigger>
                                                                </Style.Triggers>
                                                            </Style>
                                                        </TextBlock.Style>
                                                    </TextBlock>
                                                </Border>

                                                <!-- Actions -->
                                                <StackPanel Grid.Column="8" Orientation="Horizontal"
                                                            VerticalAlignment="Center" HorizontalAlignment="Center">
                                                    <Button Content="⋮" ToolTip="Tác vụ khác" FontSize="14" FontWeight="Bold"
                                                            Style="{StaticResource RowIconBtn}" Margin="0,0,4,0">
                                                        <Button.ContextMenu>
                                                            <ContextMenu>
                                                                <MenuItem Header="View Details"
                                                                          Command="{Binding DataContext.SelectProductCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                                                          CommandParameter="{Binding}"/>
                                                                <MenuItem Header="Quick Edit Stock"
                                                                          Command="{Binding DataContext.SelectProductCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                                                          CommandParameter="{Binding}"/>
                                                                <MenuItem Header="Deactivate"
                                                                          Command="{Binding DataContext.DeactivateProductCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                                                          CommandParameter="{Binding}"/>
                                                            </ContextMenu>
                                                        </Button.ContextMenu>
                                                    </Button>
                                                    <Button ToolTip="Chỉnh sửa" Content="✏" FontSize="13"
                                                            Style="{StaticResource RowIconBtn}"
                                                            Command="{Binding DataContext.SelectProductCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                                            CommandParameter="{Binding}"/>
                                                    <Button ToolTip="Xóa" Content="🗑️" FontSize="13"
                                                            Margin="4,0,0,0" Foreground="#EF4444"
                                                            Style="{StaticResource RowIconBtn}"
                                                            Command="{Binding DataContext.DeleteProductCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                                            CommandParameter="{Binding}"/>
                                                </StackPanel>
                                            </Grid>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </ScrollViewer>
                    </Grid>
                </Border>
            </Grid>
        </Grid>
    </Grid>
</UserControl>
