<UserControl x:Class="SmartPOS.WPF.Views.CatalogView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:conv="clr-namespace:SmartPOS.WPF.Converters"
             mc:Ignorable="d">

    <UserControl.Resources>
        <conv:NullToVisibilityConverter x:Key="NullToVisible"/>

        <SolidColorBrush x:Key="PrimaryBlue"  Color="#2563EB"/>
        <SolidColorBrush x:Key="DangerRed"    Color="#DC2626"/>
        <SolidColorBrush x:Key="DarkText"     Color="#0F172A"/>
        <SolidColorBrush x:Key="MutedText"    Color="#64748B"/>
        <SolidColorBrush x:Key="PageBg"       Color="#F8FAFC"/>
        <SolidColorBrush x:Key="CardBg"       Color="#FFFFFF"/>
        <SolidColorBrush x:Key="BorderColor"  Color="#E2E8F0"/>

        <Style x:Key="SidebarButton" TargetType="RadioButton">
            <Setter Property="Padding"    Value="14,10"/>
            <Setter Property="Margin"     Value="0,0,0,6"/>
            <Setter Property="Foreground" Value="{StaticResource DarkText}"/>
            <Setter Property="FontSize"   Value="14"/>
            <Setter Property="Cursor"     Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="RadioButton">
                        <Border x:Name="Bd" CornerRadius="8" Padding="{TemplateBinding Padding}"
                                Background="Transparent">
                            <ContentPresenter VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="{StaticResource PrimaryBlue}"/>
                                <Setter Property="Foreground" Value="White"/>
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#EFF6FF"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="PrimaryButton" TargetType="Button">
            <Setter Property="Background"       Value="{StaticResource PrimaryBlue}"/>
            <Setter Property="Foreground"       Value="White"/>
            <Setter Property="Padding"          Value="16,9"/>
            <Setter Property="BorderThickness"  Value="0"/>
            <Setter Property="FontWeight"       Value="SemiBold"/>
            <Setter Property="Cursor"           Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="8"
                                Padding="{TemplateBinding Padding}" Opacity="{TemplateBinding Opacity}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Opacity" Value="0.5"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="DangerButton" TargetType="Button" BasedOn="{StaticResource PrimaryButton}">
            <Setter Property="Background" Value="{StaticResource DangerRed}"/>
        </Style>

        <Style x:Key="FieldBox" TargetType="TextBox">
            <Setter Property="Padding"         Value="10,8"/>
            <Setter Property="BorderBrush"     Value="{StaticResource BorderColor}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Background"      Value="White"/>
            <Setter Property="FontSize"        Value="13"/>
        </Style>

        <!-- Product card được chọn thì highlight border -->
        <Style x:Key="ProductCardItem" TargetType="ListBoxItem">
            <Setter Property="Padding"    Value="0"/>
            <Setter Property="Margin"     Value="0,0,16,16"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ListBoxItem">
                        <Border x:Name="CardBorder" Background="{StaticResource CardBg}"
                                CornerRadius="12" Width="220" Padding="14"
                                BorderBrush="{StaticResource BorderColor}" BorderThickness="1">
                            <ContentPresenter/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="CardBorder" Property="BorderBrush" Value="{StaticResource PrimaryBlue}"/>
                                <Setter TargetName="CardBorder" Property="BorderThickness" Value="2"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </UserControl.Resources>

    <Grid Background="{StaticResource PageBg}">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="220"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- ═══ Sidebar danh mục ═══ -->
        <Border Grid.Column="0" Background="White"
                BorderBrush="{StaticResource BorderColor}" BorderThickness="0,0,1,0">
            <DockPanel Margin="16">
                <TextBlock DockPanel.Dock="Top" Text="Danh mục" FontWeight="Bold" FontSize="16"
                           Foreground="{StaticResource DarkText}" Margin="4,0,0,12"/>

                <StackPanel DockPanel.Dock="Bottom" Margin="0,16,0,0">
                    <TextBox Style="{StaticResource FieldBox}"
                             Text="{Binding NewCategoryName, UpdateSourceTrigger=PropertyChanged}"
                             Tag="Tên danh mục mới"/>
                    <Button Content="+ Thêm danh mục" Style="{StaticResource PrimaryButton}"
                            Margin="0,8,0,0" Command="{Binding AddCategoryCommand}"/>
                </StackPanel>

                <ListBox ItemsSource="{Binding Categories}"
                         SelectedItem="{Binding SelectedCategory}"
                         BorderThickness="0" Background="Transparent">
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <RadioButton Content="{Binding Name}" Style="{StaticResource SidebarButton}"
                                         GroupName="Categories"
                                         IsChecked="{Binding IsSelected, RelativeSource={RelativeSource AncestorType=ListBoxItem}, Mode=OneWay}"
                                         HorizontalAlignment="Stretch"/>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                    <ListBox.ItemContainerStyle>
                        <Style TargetType="ListBoxItem">
                            <Setter Property="Padding"     Value="0"/>
                            <Setter Property="Background"  Value="Transparent"/>
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="ListBoxItem">
                                        <ContentPresenter/>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                        </Style>
                    </ListBox.ItemContainerStyle>
                </ListBox>
            </DockPanel>
        </Border>

        <!-- ═══ Nội dung chính ═══ -->
        <DockPanel Grid.Column="1" Margin="24">

            <!-- Header -->
            <Grid DockPanel.Dock="Top" Margin="0,0,0,16">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <StackPanel>
                    <TextBlock Text="Quản lý sản phẩm" FontSize="22" FontWeight="Bold"
                               Foreground="{StaticResource DarkText}"/>
                    <TextBlock Text="Thêm, chỉnh sửa danh mục và sản phẩm trong hệ thống"
                               Foreground="{StaticResource MutedText}" Margin="0,4,0,0"/>
                </StackPanel>
                <!-- FIX: đổi ExecuteCommand → LoadAsyncCommand -->
                <Button Grid.Column="1" Content="↻ Tải lại" Style="{StaticResource PrimaryButton}"
                        Command="{Binding LoadAsyncCommand}" VerticalAlignment="Top"/>
            </Grid>

            <!-- Form thêm sản phẩm mới -->
            <Border DockPanel.Dock="Top" Background="White" CornerRadius="12" Padding="16"
                    BorderBrush="{StaticResource BorderColor}" BorderThickness="1" Margin="0,0,0,12">
                <StackPanel>
                    <TextBlock Text="Thêm sản phẩm mới" FontWeight="SemiBold" Margin="0,0,0,10"/>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="2*"/>
                            <ColumnDefinition Width="110"/>
                            <ColumnDefinition Width="130"/>
                            <ColumnDefinition Width="130"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <!-- Tên -->
                        <TextBox Grid.Column="0" Style="{StaticResource FieldBox}" Margin="0,0,8,0"
                                 Text="{Binding NewProductName, UpdateSourceTrigger=PropertyChanged}"/>
                        <!-- SKU -->
                        <TextBox Grid.Column="1" Style="{StaticResource FieldBox}" Margin="0,0,8,0"
                                 Text="{Binding NewProductSku, UpdateSourceTrigger=PropertyChanged}"/>
                        <!-- Barcode (FIX: thêm mới) -->
                        <TextBox Grid.Column="2" Style="{StaticResource FieldBox}" Margin="0,0,8,0"
                                 Text="{Binding NewProductBarcode, UpdateSourceTrigger=PropertyChanged}"/>
                        <!-- Giá -->
                        <TextBox Grid.Column="3" Style="{StaticResource FieldBox}" Margin="0,0,8,0"
                                 Text="{Binding NewProductPrice, UpdateSourceTrigger=PropertyChanged}"/>
                        <Button Grid.Column="4" Content="+ Thêm" Style="{StaticResource PrimaryButton}"
                                Command="{Binding AddProductCommand}"/>
                    </Grid>
                    <!-- Label hướng dẫn -->
                    <Grid Margin="0,4,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="2*"/>
                            <ColumnDefinition Width="110"/>
                            <ColumnDefinition Width="130"/>
                            <ColumnDefinition Width="130"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="Tên sản phẩm *"   FontSize="11" Foreground="{StaticResource MutedText}"/>
                        <TextBlock Grid.Column="1" Text="SKU"              FontSize="11" Foreground="{StaticResource MutedText}" Margin="0,0,8,0"/>
                        <TextBlock Grid.Column="2" Text="Barcode"          FontSize="11" Foreground="{StaticResource MutedText}" Margin="0,0,8,0"/>
                        <TextBlock Grid.Column="3" Text="Giá (VNĐ) *"      FontSize="11" Foreground="{StaticResource MutedText}" Margin="0,0,8,0"/>
                    </Grid>
                    <TextBlock Text="{Binding ErrorMessage}" Foreground="{StaticResource DangerRed}" Margin="0,8,0,0"
                               Visibility="{Binding ErrorMessage, Converter={StaticResource NullToVisible}}"/>
                </StackPanel>
            </Border>

            <!-- Panel thao tác sản phẩm đang chọn (chỉ hiện khi có SelectedProduct) -->
            <Border DockPanel.Dock="Top" Background="#EFF6FF" CornerRadius="12" Padding="16"
                    BorderBrush="{StaticResource PrimaryBlue}" BorderThickness="1" Margin="0,0,0,12"
                    Visibility="{Binding SelectedProduct, Converter={StaticResource NullToVisible}}">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <!-- Thông tin sản phẩm đang chọn -->
                    <StackPanel Grid.Column="0" VerticalAlignment="Center">
                        <TextBlock FontWeight="SemiBold" Foreground="{StaticResource DarkText}">
                            <Run Text="Đang chọn: "/>
                            <Run Text="{Binding SelectedProduct.Name}"/>
                        </TextBlock>
                        <TextBlock Foreground="{StaticResource MutedText}" FontSize="12" Margin="0,2,0,0">
                            <Run Text="Giá hiện tại: "/>
                            <Run Text="{Binding SelectedProduct.UnitPrice, StringFormat='{}{0:N0} đ'}"/>
                        </TextBlock>
                    </StackPanel>

                    <!-- Nhập giá mới -->
                    <StackPanel Grid.Column="1" Orientation="Horizontal" Margin="12,0" VerticalAlignment="Center">
                        <TextBlock Text="Giá mới:" VerticalAlignment="Center" Margin="0,0,8,0"
                                   Foreground="{StaticResource DarkText}"/>
                        <TextBox Style="{StaticResource FieldBox}" Width="120"
                                 Text="{Binding UpdatedPrice, UpdateSourceTrigger=PropertyChanged}"/>
                    </StackPanel>

                    <!-- Nút cập nhật giá -->
                    <Button Grid.Column="2" Content="✏ Cập nhật giá" Style="{StaticResource PrimaryButton}"
                            Margin="0,0,8,0" Command="{Binding UpdatePriceCommand}"/>

                    <!-- Nút ngừng kinh doanh -->
                    <Button Grid.Column="3" Content="✕ Ngừng KD" Style="{StaticResource DangerButton}"
                            Command="{Binding DeactivateProductCommand}"/>
                </Grid>
            </Border>

            <!-- Danh sách sản phẩm (ListBox để hỗ trợ selection) -->
            <ScrollViewer VerticalScrollBarVisibility="Auto">
                <ListBox ItemsSource="{Binding Products}"
                         SelectedItem="{Binding SelectedProduct}"
                         Background="Transparent" BorderThickness="0"
                         ItemContainerStyle="{StaticResource ProductCardItem}">
                    <ListBox.ItemsPanel>
                        <ItemsPanelTemplate>
                            <WrapPanel Orientation="Horizontal"/>
                        </ItemsPanelTemplate>
                    </ListBox.ItemsPanel>
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <StackPanel>
                                <Border Height="100" Background="#EFF6FF" CornerRadius="8" Margin="0,0,0,10">
                                    <TextBlock Text="📦" FontSize="32"
                                               HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                                <TextBlock Text="{Binding Name}" FontWeight="SemiBold" FontSize="14"
                                           Foreground="{StaticResource DarkText}" TextWrapping="Wrap"/>
                                <TextBlock Text="{Binding Sku, StringFormat='SKU: {0}'}" FontSize="11"
                                           Foreground="{StaticResource MutedText}" Margin="0,2,0,8"/>
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0"
                                               Text="{Binding UnitPrice, StringFormat='{}{0:N0} đ'}"
                                               FontWeight="Bold" Foreground="{StaticResource PrimaryBlue}" FontSize="15"/>
                                    <Border Grid.Column="1" Background="#ECFDF5" CornerRadius="4" Padding="6,2">
                                        <TextBlock Text="{Binding LocalStockQuantity, StringFormat='Tồn: {0}'}"
                                                   FontSize="10" Foreground="#16A34A"/>
                                    </Border>
                                </Grid>
                            </StackPanel>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>
            </ScrollViewer>
        </DockPanel>
    </Grid>
</UserControl>
