<UserControl x:Class="SmartPOS.WPF.Views.CatalogView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:viewmodels="clr-namespace:SmartPOS.WPF.ViewModels"
             xmlns:converters="clr-namespace:SmartPOS.WPF.Converters"
             mc:Ignorable="d"
             d:DataContext="{d:DesignInstance Type=viewmodels:CatalogViewModel}"
             Background="{StaticResource BackgroundBrush}">

    <UserControl.Resources>
        <converters:NullOrEmptyToVisibilityConverter x:Key="NullOrEmptyToVisibilityConverter"/>
        <converters:NullToVisibilityConverter x:Key="NullToVisibilityConverter"/>
        <BooleanToVisibilityConverter x:Key="BoolToVis"/>
        <converters:InverseBoolConverter x:Key="BoolInverter"/>
        <converters:LocalImagePathConverter x:Key="LocalImagePathConverter"/>
        <converters:ImagePathToVisibilityConverter x:Key="ImagePathToVis"/>

        

        <Style x:Key="PrimaryBtn" TargetType="Button">
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="16,10"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="8" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="OutlineBtn" TargetType="Button">
            <Setter Property="Background" Value="White"/>
            <Setter Property="Foreground" Value="#00288E"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="BorderBrush" Value="#00288E"/>
            <Setter Property="Padding" Value="16,10"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}" CornerRadius="8" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="RowIconBtn" TargetType="Button">
            <Setter Property="Width" Value="32"/>
            <Setter Property="Height" Value="32"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Foreground" Value="#64748B"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd" Background="{TemplateBinding Background}" CornerRadius="6">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#EFF6FF"/>
                                <Setter Property="Foreground" Value="#00288E"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </UserControl.Resources>

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="220"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- LEFT SIDEBAR (dark, same as SalesView) -->
        <Border Grid.Column="0" Background="#1A1B22">
            <Grid Margin="0,24,0,16">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <StackPanel Grid.Row="0" Margin="20,0,20,32">
                    <TextBlock Text="SmartPOS Admin" Foreground="#E2E8F0" FontSize="18" FontWeight="Black"/>
                    <TextBlock Text="Terminal #01" Foreground="{StaticResource SidebarTextBrush}" FontSize="12" Margin="0,4,0,0" Opacity="0.8"/>
                </StackPanel>

                <StackPanel Grid.Row="1">
                    <Button Style="{StaticResource SidebarNavButtonStyle}" Tag="🖥️" Content="Point of Sale"
                            Command="{Binding NavigateToSalesCommand}" FontSize="13"/>
                    <Button Style="{StaticResource SidebarNavButtonStyle}" Tag="🧾" Content="Transactions" FontSize="13"/>
                    <Button Style="{StaticResource SidebarNavButtonStyle}" Tag="📦" Content="Inventory" FontSize="13"/>
                    <Button Style="{StaticResource SidebarNavButtonStyle}" Tag="👤" Content="Customers" FontSize="13"/>
                    <Button Style="{StaticResource SidebarNavButtonStyle}" Tag="🔄" Content="Returns &amp; Refunds" FontSize="13"/>
                    <Border Background="#00288E" CornerRadius="8" Margin="8,2" Padding="12,10">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="🗂️" Margin="0,0,12,0" FontSize="14" VerticalAlignment="Center"/>
                            <TextBlock Text="Product Catalog" Foreground="White" FontSize="13" FontWeight="SemiBold" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Border>
                    <Button Style="{StaticResource SidebarNavButtonStyle}" Tag="📊" Content="Shift Reports" FontSize="13"/>
                    <Button Style="{StaticResource SidebarNavButtonStyle}" Tag="⚙️" Content="Settings" FontSize="13"/>
                </StackPanel>

                <Button Grid.Row="2" Content="+ New Transaction" Margin="12,0"
                        Command="{Binding NavigateToSalesCommand}"
                        Style="{StaticResource PrimaryBtn}" Background="#B8C4FF" Foreground="#001453"/>
            </Grid>
        </Border>

        <!-- MAIN CONTENT -->
        <Grid Grid.Column="1">
            <Grid.RowDefinitions>
                <RowDefinition Height="64"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- Top header bar -->
            <Border Grid.Row="0" Background="White" BorderBrush="{StaticResource BorderMediumBrush}" BorderThickness="0,0,0,1" Padding="24,0">
                <Grid VerticalAlignment="Center">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0" Text="SmartPOS Retail" Foreground="#00288E"
                               FontSize="20" FontWeight="Black" VerticalAlignment="Center"/>
                    <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                        <Button Content="Support" Background="Transparent" Foreground="#00288E"
                                FontWeight="Bold" BorderThickness="0" Margin="0,0,16,0" Cursor="Hand"/>
                        <Button Content="End Shift" Command="{Binding NavigateToSalesCommand}"
                                Style="{StaticResource PrimaryBtn}" Background="#00288E" Padding="16,8"/>
                    </StackPanel>
                </Grid>
            </Border>

            <!-- Error bar -->
            <Grid Grid.Row="1" Margin="24,12,24,0"
                  Visibility="{Binding ErrorMessage, Converter={StaticResource NullOrEmptyToVisibilityConverter}, FallbackValue=Collapsed}">
                <Border Background="#FEF2F2" BorderBrush="#FCA5A5" BorderThickness="1" CornerRadius="8" Padding="16,12">
                    <TextBlock Text="{Binding ErrorMessage}" Foreground="#991B1B" FontSize="13" TextWrapping="Wrap"/>
                </Border>
            </Grid>

            <!-- Sync status bar -->
            <Grid Grid.Row="1" Margin="24,12,24,0"
                  Visibility="{Binding SyncStatus, Converter={StaticResource NullOrEmptyToVisibilityConverter}, FallbackValue=Collapsed}">
                <Border Background="#F0FDF4" BorderBrush="#86EFAC" BorderThickness="1" CornerRadius="8" Padding="16,12">
                    <TextBlock Text="{Binding SyncStatus}" Foreground="#166534" FontSize="13" TextWrapping="Wrap"/>
                </Border>
            </Grid>

            <!-- Page header -->
            <Grid Grid.Row="2" Margin="24,20,24,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <StackPanel Grid.Column="0">
                    <TextBlock Text="Product Catalog" FontSize="22" FontWeight="Bold" Foreground="{StaticResource TextPrimaryBrush}"/>
                    <TextBlock Text="Quản lý sản phẩm &amp; danh mục trong hệ thống"
                               Foreground="{StaticResource TextMutedBrush}" FontSize="12" Margin="0,4,0,0"/>
                </StackPanel>
                <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Bottom">
                    <Button Command="{Binding SyncFromInventoryCommand}"
                            IsEnabled="{Binding IsSyncing, Converter={StaticResource BoolInverter}}"
                            Style="{StaticResource OutlineBtn}" Margin="0,0,10,0">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="↻" FontSize="14" Margin="0,0,6,0"/>
                            <TextBlock>
                                <TextBlock.Style>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="Text" Value="Sync from Inventory"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding IsSyncing}" Value="True">
                                                <Setter Property="Text" Value="Đang đồng bộ..."/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBlock.Style>
                            </TextBlock>
                        </StackPanel>
                    </Button>
                    <Button Content="＋  Add Product" Command="{Binding ToggleAddProductCommand}"
                            Style="{StaticResource PrimaryBtn}" Background="#00288E"/>
                </StackPanel>
            </Grid>

            <!-- Workspace -->
            <Grid Grid.Row="3" Margin="24,16,24,24">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <!-- Add Product form (toggle) -->
                <Border Grid.Row="0" Background="White" BorderBrush="{StaticResource BorderMediumBrush}" BorderThickness="1"
                        CornerRadius="12" Padding="20" Margin="0,0,0,12"
                        Visibility="{Binding IsAddProductVisible, Converter={StaticResource BoolToVis}}">
                    <StackPanel>
                        <TextBlock Text="Thêm sản phẩm mới" FontWeight="SemiBold" FontSize="14"
                                   Foreground="{StaticResource TextPrimaryBrush}" Margin="0,0,0,14"/>

                        <!-- Main layout: image on left, fields on right -->
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>

                            <!-- ── Image Upload Panel ── -->
                            <StackPanel Grid.Column="0" Margin="0,0,16,0" VerticalAlignment="Top">
                                <!-- Image preview / placeholder -->
                                <Border Width="110" Height="110" CornerRadius="10"
                                        BorderBrush="{StaticResource BorderMediumBrush}" BorderThickness="2"
                                        Background="{StaticResource BackgroundBrush}" ClipToBounds="True">
                                    <!-- Placeholder (camera icon) when no image -->
                                    <Grid>
                                        <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center"
                                                    Visibility="{Binding NewProductImagePath,
                                                        Converter={StaticResource ImagePathToVis},
                                                        ConverterParameter=inverse}">
                                            <TextBlock Text="📷" FontSize="32"
                                                       HorizontalAlignment="Center"/>
                                            <TextBlock Text="Chọn ảnh" FontSize="10"
                                                       Foreground="{StaticResource SidebarTextBrush}" HorizontalAlignment="Center"
                                                       Margin="0,4,0,0"/>
                                        </StackPanel>
                                        <!-- Actual image preview -->
                                        <Image Source="{Binding NewProductImagePath,
                                                   Converter={StaticResource LocalImagePathConverter}}"
                                               Stretch="UniformToFill"
                                               Visibility="{Binding NewProductImagePath,
                                                   Converter={StaticResource ImagePathToVis}}"/>
                                    </Grid>
                                </Border>

                                <!-- Browse button -->
                                <Button Command="{Binding BrowseImageCommand}"
                                        Margin="0,8,0,0" Padding="8,6" FontSize="12"
                                        Background="#2563EB" Foreground="White"
                                        BorderThickness="0" Cursor="Hand">
                                    <Button.Template>
                                        <ControlTemplate TargetType="Button">
                                            <Border Background="{TemplateBinding Background}"
                                                    CornerRadius="7" Padding="{TemplateBinding Padding}">
                                                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                                    <TextBlock Text="📂" FontSize="12" Margin="0,0,5,0"
                                                               VerticalAlignment="Center"/>
                                                    <ContentPresenter VerticalAlignment="Center"/>
                                                </StackPanel>
                                            </Border>
                                            <ControlTemplate.Triggers>
                                                <Trigger Property="IsMouseOver" Value="True">
                                                    <Setter Property="Background" Value="#1D4ED8"/>
                                                </Trigger>
                                            </ControlTemplate.Triggers>
                                        </ControlTemplate>
                                    </Button.Template>
                                    Chọn ảnh
                                </Button>

                                <!-- Clear image button (only visible when image selected) -->
                                <Button Command="{Binding ClearImageCommand}"
                                        Visibility="{Binding NewProductImagePath,
                                            Converter={StaticResource ImagePathToVis}}"
                                        Margin="0,4,0,0" Padding="8,5" FontSize="11"
                                        Background="Transparent" Foreground="{StaticResource DangerBrush}"
                                        BorderThickness="1" BorderBrush="#FCA5A5" Cursor="Hand">
                                    <Button.Template>
                                        <ControlTemplate TargetType="Button">
                                            <Border Background="{TemplateBinding Background}"
                                                    BorderBrush="{TemplateBinding BorderBrush}"
                                                    BorderThickness="{TemplateBinding BorderThickness}"
                                                    CornerRadius="7" Padding="{TemplateBinding Padding}">
                                                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                                    <TextBlock Text="✕" FontSize="10" Margin="0,0,4,0"
                                                               Foreground="{StaticResource DangerBrush}" VerticalAlignment="Center"/>
                                                    <ContentPresenter VerticalAlignment="Center"/>
                                                </StackPanel>
                                            </Border>
                                            <ControlTemplate.Triggers>
                                                <Trigger Property="IsMouseOver" Value="True">
                                                    <Setter Property="Background" Value="#FEF2F2"/>
                                                </Trigger>
                                            </ControlTemplate.Triggers>
                                        </ControlTemplate>
                                    </Button.Template>
                                    Xóa ảnh
                                </Button>
                            </StackPanel>

                            <!-- ── Input Fields ── -->
                            <StackPanel Grid.Column="1">
                                <!-- Row 1: fields -->
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="160"/>
                                        <ColumnDefinition Width="120"/>
                                        <ColumnDefinition Width="140"/>
                                        <ColumnDefinition Width="110"/>
                                        <ColumnDefinition Width="90"/>
                                    </Grid.ColumnDefinitions>
                                    <ComboBox Grid.Column="0" ItemsSource="{Binding Categories}"
                                              SelectedItem="{Binding SelectedCategory}" DisplayMemberPath="Name"
                                              Margin="0,0,8,0" Padding="10,8" FontSize="13" BorderBrush="{StaticResource BorderMediumBrush}"/>
                                    <TextBox Grid.Column="1" Text="{Binding NewProductName, UpdateSourceTrigger=PropertyChanged}"
                                             Padding="10,8" BorderBrush="{StaticResource BorderMediumBrush}" BorderThickness="1" Margin="0,0,8,0" FontSize="13"/>
                                    <TextBox Grid.Column="2" Text="{Binding NewProductSku, UpdateSourceTrigger=PropertyChanged}"
                                             Padding="10,8" BorderBrush="{StaticResource BorderMediumBrush}" BorderThickness="1" Margin="0,0,8,0" FontSize="13"/>
                                    <TextBox Grid.Column="3" Text="{Binding NewProductBarcode, UpdateSourceTrigger=PropertyChanged}"
                                             Padding="10,8" BorderBrush="{StaticResource BorderMediumBrush}" BorderThickness="1" Margin="0,0,8,0" FontSize="13"/>
                                    <TextBox Grid.Column="4" Text="{Binding NewProductPrice, UpdateSourceTrigger=PropertyChanged}"
                                             Padding="10,8" BorderBrush="{StaticResource BorderMediumBrush}" BorderThickness="1" Margin="0,0,8,0" FontSize="13"/>
                                    <TextBox Grid.Column="5" Text="{Binding NewProductStock, UpdateSourceTrigger=PropertyChanged}"
                                             Padding="10,8" BorderBrush="{StaticResource BorderMediumBrush}" BorderThickness="1" FontSize="13"/>
                                </Grid>
                                <!-- Labels row -->
                                <Grid Margin="0,4,0,12">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="160"/>
                                        <ColumnDefinition Width="120"/>
                                        <ColumnDefinition Width="140"/>
                                        <ColumnDefinition Width="110"/>
                                        <ColumnDefinition Width="90"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0" Text="Danh mục *" FontSize="11" Foreground="{StaticResource TextMutedBrush}"/>
                                    <TextBlock Grid.Column="1" Text="Tên sản phẩm *" FontSize="11" Foreground="{StaticResource TextMutedBrush}" Margin="0,0,8,0"/>
                                    <TextBlock Grid.Column="2" Text="SKU" FontSize="11" Foreground="{StaticResource TextMutedBrush}" Margin="0,0,8,0"/>
                                    <TextBlock Grid.Column="3" Text="Barcode" FontSize="11" Foreground="{StaticResource TextMutedBrush}" Margin="0,0,8,0"/>
                                    <TextBlock Grid.Column="4" Text="Giá (VNĐ) *" FontSize="11" Foreground="{StaticResource TextMutedBrush}" Margin="0,0,8,0"/>
                                    <TextBlock Grid.Column="5" Text="Tồn kho" FontSize="11" Foreground="{StaticResource TextMutedBrush}"/>
                                </Grid>
                                <!-- Submit button -->
                                <Button Content="＋  Thêm sản phẩm" Command="{Binding AddProductCommand}"
                                        HorizontalAlignment="Right"
                                        Style="{StaticResource PrimaryBtn}" Background="#2563EB" Padding="20,10"/>
                            </StackPanel>
                        </Grid>
                    </StackPanel>
                </Border>

                <!-- Selected product edit bar -->
                <Border Grid.Row="1" Background="#EFF6FF" BorderBrush="#2563EB" BorderThickness="1"
                        CornerRadius="12" Padding="16" Margin="0,0,0,12"
                        Visibility="{Binding SelectedProduct, Converter={StaticResource NullToVisibilityConverter}}">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0" VerticalAlignment="Center">
                            <TextBlock FontWeight="SemiBold" Foreground="{StaticResource TextPrimaryBrush}">
                                <Run Text="Đang chọn: "/><Run Text="{Binding SelectedProduct.Name}"/>
                            </TextBlock>
                            <TextBlock Foreground="{StaticResource TextMutedBrush}" FontSize="12" Margin="0,2,0,0">
                                <Run Text="Giá hiện tại: "/>
                                <Run Text="{Binding SelectedProduct.UnitPrice, StringFormat='{}{0:N0} đ', Mode=OneWay}"/>
                            </TextBlock>
                        </StackPanel>
                        <StackPanel Grid.Column="1" Orientation="Horizontal" Margin="12,0" VerticalAlignment="Center">
                            <TextBlock Text="Giá mới:" VerticalAlignment="Center" Margin="0,0,8,0" Foreground="{StaticResource TextPrimaryBrush}" FontSize="13"/>
                            <TextBox Text="{Binding UpdatedPrice, UpdateSourceTrigger=PropertyChanged}"
                                     Width="120" Padding="10,8" BorderBrush="{StaticResource BorderMediumBrush}" BorderThickness="1" FontSize="13"/>
                        </StackPanel>
                        
                        <Button Grid.Column="2" Content="📷 Đổi ảnh" Command="{Binding UpdateImageCommand}"
                                Style="{StaticResource OutlineBtn}" Margin="0,0,8,0"/>
                                
                        <Button Grid.Column="3" Content="✏ Cập nhật giá" Command="{Binding UpdatePriceCommand}"
                                Style="{StaticResource PrimaryBtn}" Background="#2563EB" Margin="0,0,8,0"/>
                                
                        <Grid Grid.Column="4">
                            <Button Content="✕ Ngừng KD" Command="{Binding DeactivateProductCommand}"
                                    Background="#DC2626">
                                <Button.Style>
                                    <Style TargetType="Button" BasedOn="{StaticResource PrimaryBtn}">
                                        <Setter Property="Visibility" Value="Collapsed"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding SelectedProduct.IsActive}" Value="True">
                                                <Setter Property="Visibility" Value="Visible"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Button.Style>
                            </Button>
                            <Button Content="✓ Kinh doanh lại" Command="{Binding ReactivateProductCommand}"
                                    Background="#16A34A">
                                <Button.Style>
                                    <Style TargetType="Button" BasedOn="{StaticResource PrimaryBtn}">
                                        <Setter Property="Visibility" Value="Collapsed"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding SelectedProduct.IsActive}" Value="False">
                                                <Setter Property="Visibility" Value="Visible"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Button.Style>
                            </Button>
                        </Grid>
                    </Grid>
                </Border>

                <!-- Filter bar -->
                <Border Grid.Row="2" Background="White" BorderBrush="{StaticResource BorderMediumBrush}" BorderThickness="1"
                        CornerRadius="12" Padding="16,12" Margin="0,0,0,12">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <Border Grid.Column="0" BorderBrush="{StaticResource BorderMediumBrush}" BorderThickness="1" CornerRadius="8"
                                Padding="10,0" Margin="0,0,12,0">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Text="🔍" FontSize="14" Foreground="{StaticResource TextMutedBrush}"
                                           VerticalAlignment="Center" Margin="0,0,8,0"/>
                                <TextBox Grid.Column="1" Text="{Binding SearchQuery, UpdateSourceTrigger=PropertyChanged}"
                                         Background="Transparent" BorderThickness="0" FontSize="13"
                                         Foreground="{StaticResource TextPrimaryBrush}" VerticalAlignment="Center" Padding="0,8"/>
                            </Grid>
                        </Border>

                        <StackPanel Grid.Column="1" Margin="0,0,12,0">
                            <TextBlock Text="CATEGORY" FontSize="10" FontWeight="Bold" Foreground="{StaticResource TextMutedBrush}" Margin="0,0,0,4"/>
                            <ComboBox ItemsSource="{Binding CategoryFilterOptions}"
                                      SelectedItem="{Binding CategoryFilter}"
                                      FontSize="13" MinWidth="160" Padding="8,6" BorderBrush="{StaticResource BorderMediumBrush}"/>
                        </StackPanel>

                        <StackPanel Grid.Column="2" Margin="0,0,16,0">
                            <TextBlock Text="STATUS" FontSize="10" FontWeight="Bold" Foreground="{StaticResource TextMutedBrush}" Margin="0,0,0,4"/>
                            <ComboBox ItemsSource="{Binding StatusOptions}" SelectedItem="{Binding StatusFilter}"
                                      FontSize="13" MinWidth="140" Padding="8,6" BorderBrush="{StaticResource BorderMediumBrush}"/>
                        </StackPanel>

                        <TextBlock Grid.Column="3" VerticalAlignment="Bottom" Margin="0,0,0,6">
                            <Run Text="Hiển thị " Foreground="{StaticResource TextMutedBrush}" FontSize="13"/>
                            <Run Text="{Binding FilteredCount, Mode=OneWay}" Foreground="{StaticResource TextPrimaryBrush}" FontWeight="Bold" FontSize="13"/>
                            <Run Text=" sản phẩm" Foreground="{StaticResource TextMutedBrush}" FontSize="13"/>
                        </TextBlock>
                    </Grid>
                </Border>

                <!-- Product table -->
                <Border Grid.Row="3" Background="White" BorderBrush="{StaticResource BorderMediumBrush}" BorderThickness="1"
                        CornerRadius="12" ClipToBounds="True">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>

                        <!-- Table header -->
                        <Border Grid.Row="0" Background="#F4F2FC" BorderBrush="{StaticResource BorderMediumBrush}" BorderThickness="0,0,0,1">
                            <Grid Margin="16,12">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="52"/>
                                    <ColumnDefinition Width="2*"/>
                                    <ColumnDefinition Width="130"/>
                                    <ColumnDefinition Width="140"/>
                                    <ColumnDefinition Width="90"/>
                                    <ColumnDefinition Width="120"/>
                                    <ColumnDefinition Width="90"/>
                                    <ColumnDefinition Width="90"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Text="IMAGE" FontSize="11" FontWeight="Bold" Foreground="{StaticResource TextMutedBrush}"/>
                                <TextBlock Grid.Column="1" Text="PRODUCT NAME &amp; SKU" FontSize="11" FontWeight="Bold" Foreground="{StaticResource TextMutedBrush}"/>
                                <TextBlock Grid.Column="2" Text="CATEGORY" FontSize="11" FontWeight="Bold" Foreground="{StaticResource TextMutedBrush}"/>
                                <TextBlock Grid.Column="3" Text="BARCODE" FontSize="11" FontWeight="Bold" Foreground="{StaticResource TextMutedBrush}"/>
                                <TextBlock Grid.Column="4" Text="PRICE (đ)" FontSize="11" FontWeight="Bold" Foreground="{StaticResource TextMutedBrush}" TextAlignment="Right" Margin="0,0,16,0"/>
                                <TextBlock Grid.Column="5" Text="STOCK" FontSize="11" FontWeight="Bold" Foreground="{StaticResource TextMutedBrush}" Margin="12,0,0,0"/>
                                <TextBlock Grid.Column="6" Text="STATUS" FontSize="11" FontWeight="Bold" Foreground="{StaticResource TextMutedBrush}"/>
                                <TextBlock Grid.Column="7" Text="ACTIONS" FontSize="11" FontWeight="Bold" Foreground="{StaticResource TextMutedBrush}" TextAlignment="Center"/>
                            </Grid>
                        </Border>

                        <!-- Table rows -->
                        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                            <ItemsControl ItemsSource="{Binding FilteredProducts}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Border BorderBrush="{StaticResource BorderMediumBrush}" BorderThickness="0,0,0,1">
                                            <Border.Style>
                                                <Style TargetType="Border">
                                                    <Setter Property="Background" Value="White"/>
                                                    <Style.Triggers>
                                                        <Trigger Property="IsMouseOver" Value="True">
                                                            <Setter Property="Background" Value="#F8FAFC"/>
                                                        </Trigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </Border.Style>
                                            <Grid Margin="16,0" Height="64">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="52"/>
                                                    <ColumnDefinition Width="2*"/>
                                                    <ColumnDefinition Width="130"/>
                                                    <ColumnDefinition Width="140"/>
                                                    <ColumnDefinition Width="90"/>
                                                    <ColumnDefinition Width="120"/>
                                                    <ColumnDefinition Width="90"/>
                                                    <ColumnDefinition Width="90"/>
                                                </Grid.ColumnDefinitions>

                                                <!-- Image (real photo or placeholder) -->
                                                <Border Grid.Column="0" Width="40" Height="40"
                                                        CornerRadius="8" VerticalAlignment="Center"
                                                        ClipToBounds="True">
                                                    <Grid>
                                                        <!-- Placeholder shown when no image -->
                                                        <Border Background="#EEF2FF" CornerRadius="8"
                                                                Visibility="{Binding ImagePath,
                                                                    Converter={StaticResource ImagePathToVis},
                                                                    ConverterParameter=inverse}">
                                                            <TextBlock Text="📦" FontSize="18"
                                                                       HorizontalAlignment="Center"
                                                                       VerticalAlignment="Center"/>
                                                        </Border>
                                                        <!-- Actual product image -->
                                                        <Image Source="{Binding ImagePath,
                                                                   Converter={StaticResource LocalImagePathConverter}}"
                                                               Stretch="UniformToFill"
                                                               Visibility="{Binding ImagePath,
                                                                   Converter={StaticResource ImagePathToVis}}"/>
                                                    </Grid>
                                                </Border>

                                                <!-- Name + SKU -->
                                                <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                                    <TextBlock Text="{Binding Name}" FontWeight="Bold" FontSize="13" Foreground="{StaticResource TextPrimaryBrush}"/>
                                                    <TextBlock Text="{Binding Sku}" FontSize="11" Foreground="{StaticResource TextMutedBrush}"
                                                               FontFamily="Consolas" Margin="0,2,0,0"/>
                                                </StackPanel>

                                                <!-- Category -->
                                                <TextBlock Grid.Column="2" Text="{Binding CategoryName}"
                                                           FontSize="13" Foreground="{StaticResource TextMutedBrush}" VerticalAlignment="Center"/>

                                                <!-- Barcode -->
                                                <TextBlock Grid.Column="3" Text="{Binding Barcode}"
                                                           FontSize="12" FontFamily="Consolas" Foreground="{StaticResource TextMutedBrush}"
                                                           VerticalAlignment="Center"/>

                                                <!-- Price -->
                                                <TextBlock Grid.Column="4"
                                                           Text="{Binding UnitPrice, StringFormat='{}{0:N0}'}"
                                                           FontWeight="Bold" FontSize="13" Foreground="{StaticResource TextPrimaryBrush}"
                                                           TextAlignment="Right" VerticalAlignment="Center"
                                                           Margin="0,0,16,0"/>

                                                <!-- Stock badge -->
                                                <Border Grid.Column="5" VerticalAlignment="Center"
                                                        CornerRadius="12" Padding="8,3" HorizontalAlignment="Left"
                                                        Margin="12,0,0,0">
                                                    <Border.Style>
                                                        <Style TargetType="Border">
                                                            <Setter Property="Background" Value="#DCFCE7"/>
                                                            <Style.Triggers>
                                                                <DataTrigger Binding="{Binding LocalStockQuantity}" Value="0">
                                                                    <Setter Property="Background" Value="#FEE2E2"/>
                                                                </DataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </Border.Style>
                                                    <TextBlock FontSize="10" FontWeight="Bold">
                                                        <TextBlock.Style>
                                                            <Style TargetType="TextBlock">
                                                                <Setter Property="Foreground" Value="#16A34A"/>
                                                                <Style.Triggers>
                                                                    <DataTrigger Binding="{Binding LocalStockQuantity}" Value="0">
                                                                        <Setter Property="Foreground" Value="#DC2626"/>
                                                                    </DataTrigger>
                                                                </Style.Triggers>
                                                            </Style>
                                                        </TextBlock.Style>
                                                        <Run Text="{Binding LocalStockQuantity, Mode=OneWay}"/>
                                                        <Run Text=" In Stock"/>
                                                    </TextBlock>
                                                </Border>

                                                <!-- Status badge -->
                                                <Border Grid.Column="6" VerticalAlignment="Center"
                                                        CornerRadius="12" Padding="8,3" HorizontalAlignment="Left">
                                                    <Border.Style>
                                                        <Style TargetType="Border">
                                                            <Setter Property="Background" Value="#DBEAFE"/>
                                                            <Style.Triggers>
                                                                <DataTrigger Binding="{Binding IsActive}" Value="False">
                                                                    <Setter Property="Background" Value="#F1F0FA"/>
                                                                </DataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </Border.Style>
                                                    <TextBlock FontSize="10" FontWeight="Bold">
                                                        <TextBlock.Style>
                                                            <Style TargetType="TextBlock">
                                                                <Setter Property="Text" Value="ACTIVE"/>
                                                                <Setter Property="Foreground" Value="#00288E"/>
                                                                <Style.Triggers>
                                                                    <DataTrigger Binding="{Binding IsActive}" Value="False">
                                                                        <Setter Property="Text" Value="INACTIVE"/>
                                                                        <Setter Property="Foreground" Value="#757684"/>
                                                                    </DataTrigger>
                                                                </Style.Triggers>
                                                            </Style>
                                                        </TextBlock.Style>
                                                    </TextBlock>
                                                </Border>

                                                <!-- Actions -->
                                                <StackPanel Grid.Column="7" Orientation="Horizontal"
                                                            VerticalAlignment="Center" HorizontalAlignment="Center">
                                                    <Button ToolTip="Chỉnh sửa" Content="✏" FontSize="13"
                                                            Style="{StaticResource RowIconBtn}"
                                                            Command="{Binding DataContext.SelectProductCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                                            CommandParameter="{Binding}"/>
                                                    <Button ToolTip="Ngừng kinh doanh" Content="✕" FontSize="13"
                                                            Margin="4,0,0,0" Foreground="{StaticResource TextMutedBrush}"
                                                            Style="{StaticResource RowIconBtn}"
                                                            Command="{Binding DataContext.DeactivateProductCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                                            CommandParameter="{Binding}"/>
                                                </StackPanel>
                                            </Grid>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </ScrollViewer>
                    </Grid>
                </Border>
            </Grid>
        </Grid>
    </Grid>
</UserControl>
