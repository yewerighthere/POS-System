<UserControl x:Class="SmartPOS.WPF.Views.SyncView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:conv="clr-namespace:SmartPOS.WPF.Converters"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             mc:Ignorable="d">

    <UserControl.Resources>
        <conv:BoolToVisibilityConverter          x:Key="BoolToVisible"/>
        <conv:NullOrEmptyToVisibilityConverter   x:Key="NotEmptyToVisible"/>

        

        <Style x:Key="ActionButton" TargetType="Button">
            <Setter Property="Foreground"      Value="White"/>
            <Setter Property="Padding"         Value="20,10"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="FontWeight"      Value="SemiBold"/>
            <Setter Property="FontSize"        Value="14"/>
            <Setter Property="Cursor"          Value="Hand"/>
            <Setter Property="Background"      Value="#7C3AED"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd" Background="{TemplateBinding Background}"
                                CornerRadius="8" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="Bd" Property="Opacity" Value="0.5"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="PrimaryActionButton" TargetType="Button" BasedOn="{StaticResource ActionButton}">
            <Setter Property="Background" Value="{StaticResource PrimaryBrush}"/>
        </Style>

        <Style x:Key="SidebarInactiveButton" TargetType="Button">
            <Setter Property="Background"                 Value="Transparent"/>
            <Setter Property="Foreground"                 Value="#94A3B8"/>
            <Setter Property="BorderThickness"            Value="0"/>
            <Setter Property="Padding"                    Value="16,10"/>
            <Setter Property="Margin"                     Value="8,2"/>
            <Setter Property="Cursor"                     Value="Hand"/>
            <Setter Property="HorizontalContentAlignment" Value="Left"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd" CornerRadius="8" Background="{TemplateBinding Background}" Padding="{TemplateBinding Padding}">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="{TemplateBinding Tag}" Margin="0,0,12,0" FontSize="14" VerticalAlignment="Center"/>
                                <ContentPresenter VerticalAlignment="Center"/>
                            </StackPanel>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#374151"/>
                                <Setter Property="Foreground" Value="White"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </UserControl.Resources>

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="220"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- LEFT SIDEBAR -->
        <Border Grid.Column="0" Background="{StaticResource SidebarBackgroundBrush}">
            <Grid Margin="0,24,0,24">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>
                <StackPanel Grid.Row="0" Margin="20,0,20,32">
                    <TextBlock Text="SmartPOS Admin" Foreground="#E2E8F0" FontSize="18" FontWeight="Black"/>
                    <TextBlock Text="Terminal #01" Foreground="{StaticResource SidebarTextBrush}" FontSize="12" Margin="0,4,0,0" Opacity="0.8"/>
                </StackPanel>
                <StackPanel Grid.Row="1">
                    <Button Style="{StaticResource SidebarNavButtonStyle}" Tag="🖥️" Content="Point of Sale"      Command="{Binding NavigateToSalesCommand}"/>
                    <!-- ACTIVE: Inventory -->
                    <Border Background="#00288E" CornerRadius="8" Margin="8,2" Padding="16,10">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="📦" Margin="0,0,12,0" FontSize="14" VerticalAlignment="Center"/>
                            <TextBlock Text="Inventory" Foreground="White" FontSize="13" FontWeight="SemiBold" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Border>
                    <Button Style="{StaticResource SidebarNavButtonStyle}" Tag="👤" Content="Customers"           Command="{Binding NavigateToCustomerCommand}"/>
                    <Button Style="{StaticResource SidebarNavButtonStyle}" Tag="🔄" Content="Returns &amp; Refunds" Command="{Binding NavigateToReturnCommand}"/>
                    <Button Style="{StaticResource SidebarNavButtonStyle}" Tag="🗂️" Content="Product Catalog"    Command="{Binding NavigateToCatalogCommand}"/>
                    <Button Style="{StaticResource SidebarNavButtonStyle}" Tag="📊" Content="Shift Reports"       Command="{Binding NavigateToReportCommand}"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- MAIN CONTENT -->
        <Grid Grid.Column="1" Background="{StaticResource BackgroundBrush}">
        <ScrollViewer VerticalScrollBarVisibility="Auto">
            <StackPanel Margin="32" MaxWidth="780">

                <!-- ═══ Header ═══ -->
                <StackPanel Margin="0,0,0,28">
                    <TextBlock Text="Đồng Bộ Kho Hàng" FontSize="26" FontWeight="Bold"
                               Foreground="{StaticResource TextPrimaryBrush}"/>
                    <TextBlock Margin="0,6,0,0" Foreground="{StaticResource TextMutedBrush}" FontSize="14"
                               TextWrapping="Wrap"
                               Text="Đồng bộ danh mục và tồn kho từ Inventory Manager về POS. Chạy Sync Catalog trước khi Sync Tồn Kho."/>
                </StackPanel>

                <!-- ═══ Nút Sync Tất Cả ═══ -->
                <Border Background="#EFF6FF" CornerRadius="16" Padding="28,20"
                        BorderBrush="{StaticResource PrimaryBrush}" BorderThickness="1"
                        Margin="0,0,0,20">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel VerticalAlignment="Center">
                            <TextBlock Text="⚡  Đồng Bộ Toàn Bộ" FontSize="17" FontWeight="Bold"
                                       Foreground="{StaticResource PrimaryBrush}"/>
                            <TextBlock Margin="0,4,0,0" Foreground="{StaticResource TextMutedBrush}" FontSize="13"
                                       Text="Chạy Sync Catalog rồi Sync Tồn Kho tuần tự."/>
                        </StackPanel>
                        <Button Grid.Column="1" Content="⚡ Sync Tất Cả"
                                Style="{StaticResource PrimaryActionButton}"
                                Command="{Binding SyncAllCommand}"
                                VerticalAlignment="Center"/>
                    </Grid>
                </Border>

                <!-- ═══ Loading ═══ -->
                <Border Background="#FFFBEB" CornerRadius="10" Padding="16,12" Margin="0,0,0,12"
                        BorderBrush="#F59E0B" BorderThickness="1"
                        Visibility="{Binding IsLoading, Converter={StaticResource BoolToVisible}}">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="⏳" FontSize="16" Margin="0,0,10,0"/>
                        <TextBlock Text="Đang xử lý, vui lòng chờ..." Foreground="#92400E" FontSize="13"/>
                    </StackPanel>
                </Border>

                <!-- ═══ Lỗi tổng ═══ -->
                <Border Background="#FEF2F2" CornerRadius="10" Padding="16,12" Margin="0,0,0,12"
                        BorderBrush="{StaticResource DangerBrush}" BorderThickness="1"
                        Visibility="{Binding StatusMessage, Converter={StaticResource NotEmptyToVisible}}">
                    <TextBlock Text="{Binding StatusMessage}" Foreground="{StaticResource DangerBrush}"
                               FontSize="13" TextWrapping="Wrap"/>
                </Border>

                <!-- ═══ Card: Sync Catalog ═══ -->
                <Border Background="{StaticResource SurfaceBrush}" CornerRadius="16" Padding="28"
                        BorderBrush="{StaticResource BorderMediumBrush}" BorderThickness="1"
                        Margin="0,0,0,16">
                    <StackPanel>
                        <Grid Margin="0,0,0,14">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel>
                                <TextBlock Text="📦  Đồng Bộ Catalog" FontSize="16" FontWeight="Bold"
                                           Foreground="{StaticResource TextPrimaryBrush}"/>
                                <TextBlock Margin="0,4,0,0" Foreground="{StaticResource TextMutedBrush}" FontSize="13"
                                           Text="Kéo danh mục và thông tin sản phẩm từ Inventory Manager về POS."/>
                            </StackPanel>
                            <Button Grid.Column="1" Content="Sync Catalog"
                                    Style="{StaticResource ActionButton}"
                                    Command="{Binding SyncCatalogCommand}"
                                    VerticalAlignment="Top"/>
                        </Grid>

                        <!-- Kết quả Catalog -->
                        <Border CornerRadius="8" Padding="14,10"
                                Visibility="{Binding CatalogStatus, Converter={StaticResource NotEmptyToVisible}}">
                            <Border.Style>
                                <Style TargetType="Border">
                                    <Setter Property="Background"      Value="#F0FDF4"/>
                                    <Setter Property="BorderBrush"     Value="{StaticResource SuccessBrush}"/>
                                    <Setter Property="BorderThickness" Value="1"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding CatalogSuccess}" Value="False">
                                            <Setter Property="Background"  Value="#FEF2F2"/>
                                            <Setter Property="BorderBrush" Value="{StaticResource DangerBrush}"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Border.Style>
                            <TextBlock Text="{Binding CatalogStatus}" FontSize="13" TextWrapping="Wrap">
                                <TextBlock.Style>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="Foreground" Value="{StaticResource SuccessBrush}"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding CatalogSuccess}" Value="False">
                                                <Setter Property="Foreground" Value="{StaticResource DangerBrush}"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBlock.Style>
                            </TextBlock>
                        </Border>
                    </StackPanel>
                </Border>

                <!-- ═══ Card: Sync Stock ═══ -->
                <Border Background="{StaticResource SurfaceBrush}" CornerRadius="16" Padding="28"
                        BorderBrush="{StaticResource BorderMediumBrush}" BorderThickness="1">
                    <StackPanel>
                        <Grid Margin="0,0,0,14">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel>
                                <TextBlock Text="📊  Đồng Bộ Tồn Kho" FontSize="16" FontWeight="Bold"
                                           Foreground="{StaticResource TextPrimaryBrush}"/>
                                <TextBlock Margin="0,4,0,0" Foreground="{StaticResource TextMutedBrush}" FontSize="13"
                                           Text="Cập nhật số lượng tồn kho từ Inventory Manager vào POS."/>
                            </StackPanel>
                            <Button Grid.Column="1" Content="Sync Tồn Kho"
                                    Style="{StaticResource ActionButton}"
                                    Command="{Binding SyncStockCommand}"
                                    VerticalAlignment="Top"/>
                        </Grid>

                        <!-- Kết quả Stock -->
                        <Border CornerRadius="8" Padding="14,10"
                                Visibility="{Binding StockStatus, Converter={StaticResource NotEmptyToVisible}}">
                            <Border.Style>
                                <Style TargetType="Border">
                                    <Setter Property="Background"      Value="#F0FDF4"/>
                                    <Setter Property="BorderBrush"     Value="{StaticResource SuccessBrush}"/>
                                    <Setter Property="BorderThickness" Value="1"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding StockSuccess}" Value="False">
                                            <Setter Property="Background"  Value="#FEF2F2"/>
                                            <Setter Property="BorderBrush" Value="{StaticResource DangerBrush}"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Border.Style>
                            <TextBlock Text="{Binding StockStatus}" FontSize="13" TextWrapping="Wrap">
                                <TextBlock.Style>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="Foreground" Value="{StaticResource SuccessBrush}"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding StockSuccess}" Value="False">
                                                <Setter Property="Foreground" Value="{StaticResource DangerBrush}"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBlock.Style>
                            </TextBlock>
                        </Border>
                    </StackPanel>
                </Border>

            </StackPanel>
        </ScrollViewer>
        </Grid>
    </Grid>
</UserControl>
