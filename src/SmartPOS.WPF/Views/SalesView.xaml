<UserControl x:Class="SmartPOS.WPF.Views.SalesView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:SmartPOS.WPF.Views"
             xmlns:viewmodels="clr-namespace:SmartPOS.WPF.ViewModels"
             xmlns:converters="clr-namespace:SmartPOS.WPF.Converters"
             mc:Ignorable="d" 
             d:DataContext="{d:DesignInstance Type=viewmodels:SalesViewModel}"
             Background="{StaticResource BackgroundBrush}"
             Foreground="{StaticResource TextPrimaryBrush}"
             d:DesignHeight="768" d:DesignWidth="1024">
             
     <UserControl.Resources>
         <converters:NullOrEmptyToVisibilityConverter x:Key="NullOrEmptyToVisibilityConverter" />
         <converters:DecimalToVisibilityConverter x:Key="DecimalToVisibilityConverter" />
         <converters:ProductImageConverter x:Key="ProductImageConverter" />
        <converters:LocalImagePathConverter x:Key="LocalImagePathConverter" />
        <converters:ImagePathToVisibilityConverter x:Key="ImagePathToVis" />
         <BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter" />
         
         <!-- Modern ScrollViewer style for clean UI -->
         <Style x:Key="ModernScrollViewer" TargetType="{x:Type ScrollViewer}">
             <Setter Property="VerticalScrollBarVisibility" Value="Auto"/>
             <Setter Property="HorizontalScrollBarVisibility" Value="Disabled"/>
             <Setter Property="Template">
                 <Setter.Value>
                     <ControlTemplate TargetType="{x:Type ScrollViewer}">
                         <Grid>
                             <ScrollContentPresenter x:Name="PART_ScrollContentPresenter" SnapsToDevicePixels="{TemplateBinding SnapsToDevicePixels}"/>
                             <ScrollBar x:Name="PART_VerticalScrollBar" 
                                        Value="{TemplateBinding VerticalOffset}" 
                                        Maximum="{TemplateBinding ScrollableHeight}" 
                                        ViewportSize="{TemplateBinding ViewportHeight}" 
                                        Visibility="{TemplateBinding ComputedVerticalScrollBarVisibility}" 
                                        HorizontalAlignment="Right" 
                                        Width="8"/>
                         </Grid>
                     </ControlTemplate>
                 </Setter.Value>
             </Setter>
         </Style>

         

          <!-- New Transaction Button Style -->
          <Style x:Key="NewTransactionButton" TargetType="Button">
              <Setter Property="Background" Value="{StaticResource PrimaryBrush}"/>
              <Setter Property="Foreground" Value="White"/>
              <Setter Property="FontWeight" Value="SemiBold"/>
              <Setter Property="BorderThickness" Value="0"/>
              <Setter Property="Height" Value="40"/>
              <Setter Property="Cursor" Value="Hand"/>
              <Setter Property="Template">
                  <Setter.Value>
                      <ControlTemplate TargetType="Button">
                          <Border Name="Border" CornerRadius="8" Background="{TemplateBinding Background}" RenderTransformOrigin="0.5,0.5">
                              <Border.RenderTransform>
                                  <ScaleTransform ScaleX="1" ScaleY="1"/>
                              </Border.RenderTransform>
                              <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                          </Border>
                          <ControlTemplate.Triggers>
                              <Trigger Property="IsMouseOver" Value="True">
                                  <Setter TargetName="Border" Property="Background" Value="{StaticResource PrimaryHoverBrush}"/>
                              </Trigger>
                              <Trigger Property="IsPressed" Value="True">
                                  <Setter TargetName="Border" Property="RenderTransform">
                                      <Setter.Value>
                                          <ScaleTransform ScaleX="0.97" ScaleY="0.97"/>
                                      </Setter.Value>
                                  </Setter>
                              </Trigger>
                          </ControlTemplate.Triggers>
                      </ControlTemplate>
                  </Setter.Value>
              </Setter>
          </Style>

          <!-- End Shift Button Style -->
          <Style x:Key="EndShiftButton" TargetType="Button">
              <Setter Property="Background" Value="#DC2626"/>
              <Setter Property="Foreground" Value="White"/>
              <Setter Property="FontWeight" Value="Bold"/>
              <Setter Property="BorderThickness" Value="0"/>
              <Setter Property="Padding" Value="16,8"/>
              <Setter Property="Height" Value="36"/>
              <Setter Property="Cursor" Value="Hand"/>
              <Setter Property="Template">
                  <Setter.Value>
                      <ControlTemplate TargetType="Button">
                          <Border Name="Border" CornerRadius="8" Background="{TemplateBinding Background}" RenderTransformOrigin="0.5,0.5">
                              <Border.RenderTransform>
                                  <ScaleTransform ScaleX="1" ScaleY="1"/>
                              </Border.RenderTransform>
                              <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" Margin="12,0"/>
                          </Border>
                          <ControlTemplate.Triggers>
                              <Trigger Property="IsMouseOver" Value="True">
                                  <Setter TargetName="Border" Property="Background" Value="#B91C1C"/>
                              </Trigger>
                              <Trigger Property="IsPressed" Value="True">
                                  <Setter TargetName="Border" Property="RenderTransform">
                                      <Setter.Value>
                                          <ScaleTransform ScaleX="0.97" ScaleY="0.97"/>
                                      </Setter.Value>
                                  </Setter>
                              </Trigger>
                          </ControlTemplate.Triggers>
                      </ControlTemplate>
                  </Setter.Value>
              </Setter>
          </Style>

          <!-- Search Button Style -->
          <Style x:Key="SearchButton" TargetType="Button">
              <Setter Property="Background" Value="{StaticResource PrimaryBrush}"/>
              <Setter Property="Foreground" Value="White"/>
              <Setter Property="FontWeight" Value="SemiBold"/>
              <Setter Property="BorderThickness" Value="0"/>
              <Setter Property="Height" Value="42"/>
              <Setter Property="Cursor" Value="Hand"/>
              <Setter Property="Template">
                  <Setter.Value>
                      <ControlTemplate TargetType="Button">
                          <Border Name="Border" CornerRadius="8" Background="{TemplateBinding Background}" RenderTransformOrigin="0.5,0.5">
                              <Border.RenderTransform>
                                  <ScaleTransform ScaleX="1" ScaleY="1"/>
                              </Border.RenderTransform>
                              <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                          </Border>
                          <ControlTemplate.Triggers>
                              <Trigger Property="IsMouseOver" Value="True">
                                  <Setter TargetName="Border" Property="Background" Value="{StaticResource PrimaryHoverBrush}"/>
                              </Trigger>
                              <Trigger Property="IsPressed" Value="True">
                                  <Setter TargetName="Border" Property="RenderTransform">
                                      <Setter.Value>
                                          <ScaleTransform ScaleX="0.97" ScaleY="0.97"/>
                                      </Setter.Value>
                                  </Setter>
                              </Trigger>
                          </ControlTemplate.Triggers>
                      </ControlTemplate>
                  </Setter.Value>
              </Setter>
          </Style>

          <!-- Category Filter Button Style -->
          <Style x:Key="CategoryFilterButton" TargetType="RadioButton">
              <Setter Property="Background" Value="White"/>
              <Setter Property="Foreground" Value="#64748B"/>
              <Setter Property="BorderBrush" Value="#E2E8F0"/>
              <Setter Property="BorderThickness" Value="1"/>
              <Setter Property="Padding" Value="18,8"/>
              <Setter Property="Margin" Value="0,0,8,0"/>
              <Setter Property="Height" Value="36"/>
              <Setter Property="Cursor" Value="Hand"/>
              <Setter Property="Template">
                  <Setter.Value>
                      <ControlTemplate TargetType="RadioButton">
                          <Border Name="Border" CornerRadius="18" Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="{TemplateBinding BorderThickness}" Padding="{TemplateBinding Padding}">
                              <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                          </Border>
                          <ControlTemplate.Triggers>
                              <Trigger Property="IsChecked" Value="True">
                                  <Setter TargetName="Border" Property="Background" Value="{StaticResource PrimaryBrush}"/>
                                  <Setter TargetName="Border" Property="BorderThickness" Value="0"/>
                                  <Setter Property="Foreground" Value="White"/>
                              </Trigger>
                              <Trigger Property="IsMouseOver" Value="True">
                                  <Setter TargetName="Border" Property="BorderBrush" Value="{StaticResource PrimaryBrush}"/>
                              </Trigger>
                           </ControlTemplate.Triggers>
                      </ControlTemplate>
                  </Setter.Value>
              </Setter>
          </Style>

          <!-- Add Product Button Style -->
          <Style x:Key="AddProductButton" TargetType="Button">
              <Setter Property="Background" Value="{StaticResource PrimaryLightBrush}"/>
              <Setter Property="Foreground" Value="{StaticResource PrimaryBrush}"/>
              <Setter Property="FontWeight" Value="Bold"/>
              <Setter Property="FontSize" Value="16"/>
              <Setter Property="Width" Value="36"/>
              <Setter Property="Height" Value="36"/>
              <Setter Property="BorderThickness" Value="0"/>
              <Setter Property="Cursor" Value="Hand"/>
              <Setter Property="Template">
                  <Setter.Value>
                      <ControlTemplate TargetType="Button">
                          <Border Name="Border" CornerRadius="8" Background="{TemplateBinding Background}" RenderTransformOrigin="0.5,0.5">
                              <Border.RenderTransform>
                                  <ScaleTransform ScaleX="1" ScaleY="1"/>
                              </Border.RenderTransform>
                              <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" Margin="0,-2,0,0"/>
                          </Border>
                          <ControlTemplate.Triggers>
                              <Trigger Property="IsMouseOver" Value="True">
                                  <Setter TargetName="Border" Property="Background" Value="{StaticResource PrimaryBrush}"/>
                                  <Setter Property="Foreground" Value="White"/>
                              </Trigger>
                              <Trigger Property="IsPressed" Value="True">
                                  <Setter TargetName="Border" Property="RenderTransform">
                                      <Setter.Value>
                                          <ScaleTransform ScaleX="0.95" ScaleY="0.95"/>
                                      </Setter.Value>
                                  </Setter>
                              </Trigger>
                          </ControlTemplate.Triggers>
                      </ControlTemplate>
                  </Setter.Value>
              </Setter>
          </Style>

          <!-- Qty Adjust Button Style -->
          <Style x:Key="QtyAdjustButton" TargetType="Button">
              <Setter Property="Background" Value="#F8FAFC"/>
              <Setter Property="Foreground" Value="#64748B"/>
              <Setter Property="BorderBrush" Value="#E2E8F0"/>
              <Setter Property="BorderThickness" Value="1"/>
              <Setter Property="Width" Value="24"/>
              <Setter Property="Height" Value="24"/>
              <Setter Property="FontWeight" Value="Bold"/>
              <Setter Property="Cursor" Value="Hand"/>
              <Setter Property="Template">
                  <Setter.Value>
                      <ControlTemplate TargetType="Button">
                          <Border Name="Border" CornerRadius="6" Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="{TemplateBinding BorderThickness}" RenderTransformOrigin="0.5,0.5">
                              <Border.RenderTransform>
                                  <ScaleTransform ScaleX="1" ScaleY="1"/>
                              </Border.RenderTransform>
                              <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" Margin="0,-1,0,0"/>
                          </Border>
                          <ControlTemplate.Triggers>
                              <Trigger Property="IsMouseOver" Value="True">
                                  <Setter TargetName="Border" Property="BorderBrush" Value="{StaticResource PrimaryBrush}"/>
                                  <Setter Property="Foreground" Value="{StaticResource PrimaryBrush}"/>
                              </Trigger>
                              <Trigger Property="IsPressed" Value="True">
                                  <Setter TargetName="Border" Property="RenderTransform">
                                      <Setter.Value>
                                          <ScaleTransform ScaleX="0.92" ScaleY="0.92"/>
                                      </Setter.Value>
                                  </Setter>
                              </Trigger>
                          </ControlTemplate.Triggers>
                      </ControlTemplate>
                  </Setter.Value>
              </Setter>
          </Style>

          <!-- Remove Cart Item Button Style -->
          <Style x:Key="RemoveCartItemButton" TargetType="Button">
              <Setter Property="Background" Value="Transparent"/>
              <Setter Property="Foreground" Value="#94A3B8"/>
              <Setter Property="BorderThickness" Value="0"/>
              <Setter Property="Width" Value="24"/>
              <Setter Property="Height" Value="24"/>
              <Setter Property="Cursor" Value="Hand"/>
              <Setter Property="Margin" Value="8,0,0,0"/>
              <Setter Property="Template">
                  <Setter.Value>
                      <ControlTemplate TargetType="Button">
                          <Border Name="Border" Background="{TemplateBinding Background}">
                              <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                          </Border>
                          <ControlTemplate.Triggers>
                              <Trigger Property="IsMouseOver" Value="True">
                                  <Setter Property="Foreground" Value="#DC2626"/>
                              </Trigger>
                          </ControlTemplate.Triggers>
                      </ControlTemplate>
                  </Setter.Value>
              </Setter>
          </Style>

          <!-- Promo Code TextBox Style -->
          <Style x:Key="PromoTextBox" TargetType="TextBox">
              <Setter Property="Background" Value="#F8FAFC"/>
              <Setter Property="Foreground" Value="#0F172A"/>
              <Setter Property="BorderBrush" Value="#E2E8F0"/>
              <Setter Property="BorderThickness" Value="1"/>
              <Setter Property="Padding" Value="12,8"/>
              <Setter Property="Height" Value="40"/>
              <Setter Property="VerticalContentAlignment" Value="Center"/>
              <Setter Property="CaretBrush" Value="{StaticResource PrimaryBrush}"/>
              <Setter Property="Template">
                  <Setter.Value>
                      <ControlTemplate TargetType="TextBox">
                          <Border Name="Border" CornerRadius="8" Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="{TemplateBinding BorderThickness}">
                              <ScrollViewer x:Name="PART_ContentHost" Margin="0"/>
                          </Border>
                          <ControlTemplate.Triggers>
                              <Trigger Property="IsFocused" Value="True">
                                  <Setter TargetName="Border" Property="BorderBrush" Value="{StaticResource PrimaryBrush}"/>
                                  <Setter TargetName="Border" Property="Background" Value="White"/>
                              </Trigger>
                          </ControlTemplate.Triggers>
                      </ControlTemplate>
                  </Setter.Value>
              </Setter>
          </Style>

          <!-- Apply Promo Button Style -->
          <Style x:Key="ApplyPromoButton" TargetType="Button">
              <Setter Property="Background" Value="#F1F5F9"/>
              <Setter Property="Foreground" Value="{StaticResource PrimaryBrush}"/>
              <Setter Property="FontWeight" Value="Bold"/>
              <Setter Property="BorderThickness" Value="0"/>
              <Setter Property="Padding" Value="16,0"/>
              <Setter Property="Height" Value="40"/>
              <Setter Property="Cursor" Value="Hand"/>
              <Setter Property="Template">
                  <Setter.Value>
                      <ControlTemplate TargetType="Button">
                          <Border Name="Border" CornerRadius="8" Background="{TemplateBinding Background}" RenderTransformOrigin="0.5,0.5">
                              <Border.RenderTransform>
                                  <ScaleTransform ScaleX="1" ScaleY="1"/>
                              </Border.RenderTransform>
                              <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" Margin="{TemplateBinding Padding}"/>
                          </Border>
                          <ControlTemplate.Triggers>
                              <Trigger Property="IsMouseOver" Value="True">
                                  <Setter TargetName="Border" Property="Background" Value="#E2E8F0"/>
                              </Trigger>
                              <Trigger Property="IsPressed" Value="True">
                                  <Setter TargetName="Border" Property="RenderTransform">
                                      <Setter.Value>
                                          <ScaleTransform ScaleX="0.97" ScaleY="0.97"/>
                                      </Setter.Value>
                                  </Setter>
                              </Trigger>
                          </ControlTemplate.Triggers>
                      </ControlTemplate>
                  </Setter.Value>
              </Setter>
          </Style>

          <!-- Cancel Order Button Style -->
          <Style x:Key="CancelOrderButton" TargetType="Button">
              <Setter Property="Background" Value="Transparent"/>
              <Setter Property="Foreground" Value="#64748B"/>
              <Setter Property="BorderThickness" Value="0"/>
              <Setter Property="Height" Value="45"/>
              <Setter Property="FontWeight" Value="SemiBold"/>
              <Setter Property="Cursor" Value="Hand"/>
              <Setter Property="Template">
                  <Setter.Value>
                      <ControlTemplate TargetType="Button">
                          <Border Name="Border" CornerRadius="12" Background="{TemplateBinding Background}" RenderTransformOrigin="0.5,0.5">
                              <Border.RenderTransform>
                                  <ScaleTransform ScaleX="1" ScaleY="1"/>
                              </Border.RenderTransform>
                              <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                          </Border>
                          <ControlTemplate.Triggers>
                              <Trigger Property="IsMouseOver" Value="True">
                                  <Setter Property="Foreground" Value="#DC2626"/>
                                  <Setter TargetName="Border" Property="Background" Value="#FEF2F2"/>
                              </Trigger>
                              <Trigger Property="IsPressed" Value="True">
                                  <Setter TargetName="Border" Property="RenderTransform">
                                      <Setter.Value>
                                          <ScaleTransform ScaleX="0.97" ScaleY="0.97"/>
                                      </Setter.Value>
                                  </Setter>
                              </Trigger>
                          </ControlTemplate.Triggers>
                      </ControlTemplate>
                  </Setter.Value>
              </Setter>
          </Style>

          <!-- Checkout Button Style -->
          <Style x:Key="CheckoutButton" TargetType="Button">
              <Setter Property="Background" Value="{StaticResource PrimaryBrush}"/>
              <Setter Property="Foreground" Value="White"/>
              <Setter Property="FontWeight" Value="Bold"/>
              <Setter Property="BorderThickness" Value="0"/>
              <Setter Property="Height" Value="45"/>
              <Setter Property="Cursor" Value="Hand"/>
              <Setter Property="Template">
                  <Setter.Value>
                      <ControlTemplate TargetType="Button">
                          <Border Name="Border" CornerRadius="12" Background="{TemplateBinding Background}" RenderTransformOrigin="0.5,0.5">
                              <Border.RenderTransform>
                                  <ScaleTransform ScaleX="1" ScaleY="1"/>
                              </Border.RenderTransform>
                              <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                          </Border>
                          <ControlTemplate.Triggers>
                              <Trigger Property="IsMouseOver" Value="True">
                                  <Setter TargetName="Border" Property="Background" Value="{StaticResource PrimaryHoverBrush}"/>
                              </Trigger>
                              <Trigger Property="IsPressed" Value="True">
                                  <Setter TargetName="Border" Property="RenderTransform">
                                      <Setter.Value>
                                          <ScaleTransform ScaleX="0.97" ScaleY="0.97"/>
                                      </Setter.Value>
                                  </Setter>
                              </Trigger>
                              <Trigger Property="IsEnabled" Value="False">
                                  <Setter TargetName="Border" Property="Background" Value="#E2E8F0"/>
                                  <Setter Property="Foreground" Value="#94A3B8"/>
                              </Trigger>
                          </ControlTemplate.Triggers>
                      </ControlTemplate>
                  </Setter.Value>
              </Setter>
          </Style>
     </UserControl.Resources>

     <Grid Background="{StaticResource BackgroundBrush}">
         <Grid.ColumnDefinitions>
             <!-- Sidebar Column -->
             <ColumnDefinition Width="220"/>
             <!-- Main Content Column -->
             <ColumnDefinition Width="*"/>
         </Grid.ColumnDefinitions>

         <!-- 1. LEFT SIDEBAR -->
         <Border Grid.Column="0" Background="#1A1B22" BorderThickness="0">
             <Grid Margin="0,24,0,24">
                 <Grid.RowDefinitions>
                     <RowDefinition Height="Auto"/> <!-- Title/Terminal -->
                     <RowDefinition Height="*"/>    <!-- Navigation items -->
                     <RowDefinition Height="Auto"/> <!-- New Transaction Button -->
                 </Grid.RowDefinitions>

                 <!-- Brand Header -->
                 <StackPanel Grid.Row="0" Margin="20,0,20,32">
                     <TextBlock Text="SmartPOS Admin" Foreground="#E2E8F0" FontSize="18" FontWeight="Black"/>
                     <TextBlock Text="Terminal #01" Foreground="{StaticResource SidebarTextBrush}" FontSize="12" Margin="0,4,0,0" Opacity="0.8"/>
                 </StackPanel>

                 <!-- Navigation Links -->
                 <StackPanel Grid.Row="1">
                     <!-- Point of Sale (Active button) -->
                     <Border Background="#00288E" CornerRadius="8" Margin="8,2" Padding="16,10">
                         <StackPanel Orientation="Horizontal">
                             <TextBlock Text="🖥️" Margin="0,0,12,0" FontSize="14" VerticalAlignment="Center"/>
                             <TextBlock Text="Point of Sale" Foreground="White" FontSize="13" FontWeight="SemiBold" VerticalAlignment="Center"/>
                         </StackPanel>
                     </Border>
                     <!-- Inactive buttons -->
                     <Button Style="{StaticResource SidebarNavButtonStyle}" Tag="📦" Content="Inventory" Command="{Binding NavigateToSyncCommand}"/>
                     <Button Style="{StaticResource SidebarNavButtonStyle}" Tag="👤" Content="Customers" Command="{Binding NavigateToCustomerCommand}"/>
                     <Button Style="{StaticResource SidebarNavButtonStyle}" Tag="🔄" Content="Returns &amp; Refunds" Command="{Binding NavigateToReturnCommand}"/>
                     <Button Style="{StaticResource SidebarNavButtonStyle}" Tag="🗂️" Content="Product Catalog" Command="{Binding NavigateToCatalogCommand}"/>
                     <Button Style="{StaticResource SidebarNavButtonStyle}" Tag="📊" Content="Shift Reports" Command="{Binding NavigateToReportCommand}"/>
                 </StackPanel>

                 <!-- New Transaction Button -->
                 <Button Grid.Row="2" Style="{StaticResource NewTransactionButton}" Content="+ New Transaction" Margin="12,0"/>
             </Grid>
         </Border>

         <!-- 2. MAIN CONTENT -->
         <Grid Grid.Column="1">
             <Grid.RowDefinitions>
                 <RowDefinition Height="64"/> <!-- Top Header -->
                 <RowDefinition Height="Auto"/> <!-- Error Messages -->
                 <RowDefinition Height="*"/>  <!-- Workspace -->
             </Grid.RowDefinitions>

             <!-- Top Header Bar -->
             <Border Grid.Row="0" Background="White" BorderBrush="{StaticResource BorderMediumBrush}" BorderThickness="0,0,0,1" Padding="20,0">
                 <Grid VerticalAlignment="Center">
                     <Grid.ColumnDefinitions>
                         <ColumnDefinition Width="*"/>
                         <ColumnDefinition Width="Auto"/>
                     </Grid.ColumnDefinitions>

                     <!-- Left: App Title and Info -->
                     <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                         <TextBlock Text="SMART STORE" Foreground="#00288E" FontSize="20" FontWeight="Black" VerticalAlignment="Center" Margin="0,0,24,0"/>
                         <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                             <!-- Shift info -->
                             <StackPanel Margin="0,0,16,0">
                                 <TextBlock Text="SHIFT INFO" Foreground="{StaticResource TextMutedBrush}" FontSize="10" FontWeight="Bold"/>
                                 <TextBlock Text="Shift #0042" Foreground="{StaticResource TextPrimaryBrush}" FontSize="13" FontWeight="SemiBold" Margin="0,2,0,0"/>
                             </StackPanel>
                             <Border Width="1" Height="24" Background="{StaticResource BorderMediumBrush}" Margin="0,0,16,0"/>
                             <!-- Staff info -->
                             <StackPanel Margin="0,0,16,0">
                                 <TextBlock Text="STAFF" Foreground="{StaticResource TextMutedBrush}" FontSize="10" FontWeight="Bold"/>
                                 <TextBlock Text="Nguyen Van A" Foreground="{StaticResource TextPrimaryBrush}" FontSize="13" FontWeight="SemiBold" Margin="0,2,0,0"/>
                             </StackPanel>
                             <Border Width="1" Height="24" Background="{StaticResource BorderMediumBrush}" Margin="0,0,16,0"/>
                             <!-- Current Time -->
                             <StackPanel>
                                 <TextBlock Text="CURRENT TIME" Foreground="{StaticResource TextMutedBrush}" FontSize="10" FontWeight="Bold"/>
                                 <TextBlock Text="Jun 7 - 2026, 12:22 AM" Foreground="{StaticResource TextPrimaryBrush}" FontSize="13" FontFamily="Segoe UI" Margin="0,2,0,0"/>
                             </StackPanel>
                         </StackPanel>
                     </StackPanel>

                     <!-- Right: End Shift button -->
                     <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                         <Button Content="Support" Background="Transparent" Foreground="#00288E" FontWeight="Bold" BorderThickness="0" Margin="0,0,16,0" Cursor="Hand"/>
                         <Button Content="End Shift" Command="{Binding NavigateToShiftCommand}" Style="{StaticResource EndShiftButton}"/>
                     </StackPanel>
                 </Grid>
             </Border>

             <!-- Notification / Error Messages -->
             <Grid Grid.Row="1" Margin="20,12,20,0" Visibility="{Binding ErrorMessage, Converter={StaticResource NullOrEmptyToVisibilityConverter}, FallbackValue=Collapsed}">
                 <Border Background="#FEF2F2" BorderBrush="#FCA5A5" BorderThickness="1" CornerRadius="8" Padding="16,12">
                     <Grid>
                         <Grid.ColumnDefinitions>
                             <ColumnDefinition Width="*"/>
                             <ColumnDefinition Width="Auto"/>
                         </Grid.ColumnDefinitions>
                         <TextBlock Text="{Binding ErrorMessage}" Foreground="#991B1B" FontSize="13" FontWeight="Medium" VerticalAlignment="Center" TextWrapping="Wrap"/>
                         <Button Grid.Column="1" Content="✕" Foreground="#EF4444" Background="Transparent" BorderThickness="0" Command="{Binding ClearErrorMessageCommand}" VerticalAlignment="Center" Margin="12,0,0,0" Cursor="Hand" FontWeight="Bold"/>
                     </Grid>
                 </Border>
             </Grid>

             <!-- Workspace Area -->
             <Grid Grid.Row="2">
                 <Grid.ColumnDefinitions>
                     <ColumnDefinition Width="*"/> <!-- Product Catalog -->
                     <ColumnDefinition Width="420"/> <!-- Cart / Sidebar -->
                 </Grid.ColumnDefinitions>

                 <!-- LEFT: Products Selection -->
                 <Grid Grid.Column="0" Margin="20">
                     <Grid.RowDefinitions>
                         <RowDefinition Height="Auto"/> <!-- Barcode & Search Bar -->
                         <RowDefinition Height="Auto"/> <!-- Category Filters -->
                         <RowDefinition Height="*"/>    <!-- Products Grid -->
                     </Grid.RowDefinitions>

                     <!-- Barcode & Search Bar row -->
                     <Grid Grid.Row="0" Margin="0,0,0,12">
                         <Grid.ColumnDefinitions>
                             <ColumnDefinition Width="*"/>
                             <ColumnDefinition Width="Auto"/>
                         </Grid.ColumnDefinitions>

                         <!-- Search/Barcode box -->
                         <Border Grid.Column="0" Background="White" BorderBrush="{StaticResource BorderMediumBrush}" BorderThickness="1" CornerRadius="12" Padding="12,4">
                             <Grid>
                                 <Grid.ColumnDefinitions>
                                     <ColumnDefinition Width="Auto"/>
                                     <ColumnDefinition Width="*"/>
                                 </Grid.ColumnDefinitions>
                                 <TextBlock Text="🔍" FontSize="16" Foreground="{StaticResource TextMutedBrush}" VerticalAlignment="Center" Margin="4,0,8,0"/>
                                 <TextBox Grid.Column="1" 
                                          Background="Transparent" 
                                          BorderThickness="0" 
                                          Foreground="{StaticResource TextPrimaryBrush}" 
                                          FontSize="14" 
                                          VerticalAlignment="Center"
                                          Text="{Binding SearchQuery, UpdateSourceTrigger=PropertyChanged}"
                                          Padding="0,8"
                                          x:Name="SearchBox">
                                     <TextBox.InputBindings>
                                         <KeyBinding Key="Enter" Command="{Binding SearchProductsCommand}"/>
                                     </TextBox.InputBindings>
                                 </TextBox>
                                 <!-- Placeholder -->
                                 <TextBlock Grid.Column="1" 
                                            Text="Scan barcode or search product name..." 
                                            Foreground="{StaticResource SidebarTextBrush}" 
                                            FontSize="14" 
                                            VerticalAlignment="Center"
                                            IsHitTestVisible="False" 
                                            Margin="2,0,0,0">
                                     <TextBlock.Style>
                                         <Style TargetType="TextBlock">
                                             <Setter Property="Visibility" Value="Collapsed"/>
                                             <Style.Triggers>
                                                 <DataTrigger Binding="{Binding Text, ElementName=SearchBox}" Value="">
                                                     <Setter Property="Visibility" Value="Visible"/>
                                                 </DataTrigger>
                                             </Style.Triggers>
                                         </Style>
                                     </TextBlock.Style>
                                 </TextBlock>
                             </Grid>
                         </Border>

                         <!-- Search Button -->
                         <Button Grid.Column="1" 
                                 Content="Tìm kiếm" 
                                 Command="{Binding SearchProductsCommand}" 
                                 Style="{StaticResource SearchButton}" 
                                 Margin="8,0,0,0" 
                                 Width="100"/>
                     </Grid>

                     <!-- Category Filters Row -->
                     <ScrollViewer Grid.Row="1" HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Disabled" Margin="0,0,0,16">
                         <ListBox ItemsSource="{Binding CategoriesList}" SelectedItem="{Binding SelectedCategoryName, Mode=TwoWay}" BorderThickness="0" Background="Transparent" ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                             <ListBox.ItemsPanel>
                                 <ItemsPanelTemplate>
                                     <StackPanel Orientation="Horizontal"/>
                                 </ItemsPanelTemplate>
                             </ListBox.ItemsPanel>
                             <ListBox.ItemContainerStyle>
                                 <Style TargetType="ListBoxItem">
                                     <Setter Property="Template">
                                         <Setter.Value>
                                             <ControlTemplate TargetType="ListBoxItem">
                                                 <RadioButton Content="{Binding}" IsChecked="{Binding IsSelected, RelativeSource={RelativeSource TemplatedParent}, Mode=TwoWay}" Style="{StaticResource CategoryFilterButton}"/>
                                             </ControlTemplate>
                                         </Setter.Value>
                                     </Setter>
                                 </Style>
                             </ListBox.ItemContainerStyle>
                         </ListBox>
                     </ScrollViewer>

                     <!-- Products Grid -->
                     <Grid Grid.Row="2">
                         <!-- Loader overlay -->
                         <ProgressBar IsIndeterminate="True" Height="3" VerticalAlignment="Top" Background="Transparent" Foreground="#00288E" Visibility="{Binding IsLoading, Converter={StaticResource BooleanToVisibilityConverter}, FallbackValue=Collapsed}" Panel.ZIndex="10"/>

                         <ScrollViewer Style="{StaticResource ModernScrollViewer}">
                             <ItemsControl ItemsSource="{Binding SearchResults}">
                                 <ItemsControl.ItemsPanel>
                                     <ItemsPanelTemplate>
                                         <WrapPanel Orientation="Horizontal" Margin="-6"/>
                                     </ItemsPanelTemplate>
                                 </ItemsControl.ItemsPanel>
                                 <ItemsControl.ItemTemplate>
                                     <DataTemplate>
                                         <Border Width="220" Height="265" Background="White" BorderBrush="{StaticResource BorderMediumBrush}" BorderThickness="1" CornerRadius="12" Margin="6" Padding="12">
                                             <Grid>
                                                 <Grid.RowDefinitions>
                                                     <RowDefinition Height="130"/> <!-- Image area -->
                                                     <RowDefinition Height="Auto"/> <!-- Title -->
                                                     <RowDefinition Height="Auto"/> <!-- SKU -->
                                                     <RowDefinition Height="*"/>    <!-- Price & Add -->
                                                 </Grid.RowDefinitions>

                                                 <Grid Grid.Row="0">
                                                     <Border CornerRadius="8" Background="{StaticResource BorderLightBrush}" ClipToBounds="True">
                                                         <Grid>
                                                             <Border Background="#EEF2FF"
                                                                     Visibility="{Binding ImagePath, Converter={StaticResource ImagePathToVis}, ConverterParameter=inverse}">
                                                                 <TextBlock Text="📦" FontSize="36" HorizontalAlignment="Center" VerticalAlignment="Center" Foreground="{StaticResource SidebarTextBrush}"/>
                                                             </Border>
                                                             <Image Source="{Binding ImagePath, Converter={StaticResource LocalImagePathConverter}}" 
                                                                    Stretch="UniformToFill" RenderOptions.BitmapScalingMode="HighQuality"
                                                                    Visibility="{Binding ImagePath, Converter={StaticResource ImagePathToVis}}"/>
                                                         </Grid>
                                                     </Border>
                                                 </Grid>

                                                 <!-- IN STOCK Badge -->
                                                 <Border HorizontalAlignment="Right" VerticalAlignment="Top" Margin="8" Background="#ECFDF5" CornerRadius="8" Padding="6,3">
                                                     <StackPanel Orientation="Horizontal">
                                                         <Ellipse Width="6" Height="6" Fill="#16A34A" VerticalAlignment="Center" Margin="0,0,4,0"/>
                                                         <TextBlock Text="IN STOCK" FontSize="9" FontWeight="Bold" Foreground="{StaticResource SuccessBrush}" VerticalAlignment="Center"/>
                                                     </StackPanel>
                                                 </Border>

                                                 <!-- Product Title -->
                                                 <TextBlock Grid.Row="1" Text="{Binding Name}" FontWeight="Bold" FontSize="13" Foreground="{StaticResource TextPrimaryBrush}" Margin="0,8,0,0" TextTrimming="CharacterEllipsis"/>

                                                 <!-- SKU code -->
                                                 <TextBlock Grid.Row="2" Text="{Binding Sku, StringFormat='SKU: {0}'}" FontSize="11" Foreground="{StaticResource TextMutedBrush}" Margin="0,2,0,0" FontFamily="Consolas"/>

                                                 <!-- Price and Add button -->
                                                 <Grid Grid.Row="3" VerticalAlignment="Bottom" Margin="0,0,0,2">
                                                     <Grid.ColumnDefinitions>
                                                         <ColumnDefinition Width="*"/>
                                                         <ColumnDefinition Width="Auto"/>
                                                     </Grid.ColumnDefinitions>
                                                     <!-- Price -->
                                                     <TextBlock Grid.Column="0" Text="{Binding UnitPrice, StringFormat='{}{0:N0} ₫'}" FontSize="16" FontWeight="Black" Foreground="#00288E" VerticalAlignment="Center"/>
                                                     <!-- Add Button -->
                                                     <Button Grid.Column="1" 
                                                             Content="+" 
                                                             Style="{StaticResource AddProductButton}" 
                                                             Command="{Binding DataContext.AddToCartCommand, RelativeSource={RelativeSource AncestorType=UserControl}}" 
                                                             CommandParameter="{Binding}"/>
                                                 </Grid>
                                             </Grid>
                                         </Border>
                                     </DataTemplate>
                                 </ItemsControl.ItemTemplate>
                             </ItemsControl>
                         </ScrollViewer>
                     </Grid>
                 </Grid>

                 <!-- RIGHT: Cart Sidebar -->
                 <Border Grid.Column="1" Background="White" BorderBrush="{StaticResource BorderMediumBrush}" BorderThickness="1,0,0,0">
                     <Grid>
                         <Grid.RowDefinitions>
                             <RowDefinition Height="Auto"/> <!-- Header (Current Order) -->
                             <RowDefinition Height="*"/>    <!-- Cart Items ScrollView -->
                             <RowDefinition Height="Auto"/> <!-- Footer Calculations & Actions -->
                         </Grid.RowDefinitions>

                         <!-- Cart Header -->
                         <Border Grid.Row="0" BorderBrush="{StaticResource BorderMediumBrush}" BorderThickness="0,0,0,1" Padding="20,16">
                             <Grid>
                                 <StackPanel>
                                     <TextBlock Text="Current Order" FontSize="15" FontWeight="Bold" Foreground="{StaticResource TextPrimaryBrush}"/>
                                     <TextBlock Text="#ORD-20260606-0089" FontSize="12" Foreground="{StaticResource TextMutedBrush}" Margin="0,2,0,0" FontFamily="Consolas"/>
                                 </StackPanel>
                                 <!-- Clear all -->
                                 <Button HorizontalAlignment="Right" Background="Transparent" BorderThickness="0" Command="{Binding ClearCartCommand}" Padding="4" ToolTip="Xóa tất cả">
                                     <TextBlock Text="🗑️" FontSize="18" Foreground="{StaticResource TextMutedBrush}"/>
                                 </Button>
                             </Grid>
                         </Border>

                         <!-- Cart Items List -->
                         <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                             <ItemsControl ItemsSource="{Binding Cart.Items}">
                                 <ItemsControl.ItemTemplate>
                                     <DataTemplate>
                                         <Border BorderBrush="{StaticResource BorderLightBrush}" BorderThickness="0,0,0,1" Padding="16,12">
                                             <Grid>
                                                 <Grid.ColumnDefinitions>
                                                     <ColumnDefinition Width="Auto"/> <!-- Thumbnail image -->
                                                     <ColumnDefinition Width="*"/>    <!-- Name / Unit Price -->
                                                     <ColumnDefinition Width="Auto"/> <!-- Qty adjuster -->
                                                     <ColumnDefinition Width="80"/>   <!-- Subtotal -->
                                                     <ColumnDefinition Width="Auto"/> <!-- Delete button -->
                                                 </Grid.ColumnDefinitions>

                                                 <!-- Thumbnail image -->
                                                 <Border Grid.Column="0" Width="44" Height="44" CornerRadius="6" Background="{StaticResource BorderLightBrush}" ClipToBounds="True" Margin="0,0,10,0">
                                                     <Grid>
                                                         <Border Background="#EEF2FF"
                                                                 Visibility="{Binding ProductImagePath, Converter={StaticResource ImagePathToVis}, ConverterParameter=inverse}">
                                                             <TextBlock Text="📦" FontSize="18" HorizontalAlignment="Center" VerticalAlignment="Center" Foreground="{StaticResource SidebarTextBrush}"/>
                                                         </Border>
                                                         <Image Source="{Binding ProductImagePath, Converter={StaticResource LocalImagePathConverter}}" 
                                                                Stretch="UniformToFill"
                                                                Visibility="{Binding ProductImagePath, Converter={StaticResource ImagePathToVis}}"/>
                                                     </Grid>
                                                 </Border>

                                                 <!-- Product details -->
                                                 <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                                     <TextBlock Text="{Binding ProductName}" FontWeight="Bold" FontSize="13" Foreground="{StaticResource TextPrimaryBrush}" TextTrimming="CharacterEllipsis"/>
                                                     <TextBlock Text="{Binding UnitPrice, StringFormat='{}{0:N0} ₫'}" FontSize="11" Foreground="{StaticResource TextMutedBrush}" Margin="0,2,0,0"/>
                                                 </StackPanel>

                                                 <!-- Quantity adjustments -->
                                                 <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center" Margin="8,0">
                                                     <Button Content="-" 
                                                             Style="{StaticResource QtyAdjustButton}"
                                                             Command="{Binding DataContext.DecreaseQuantityCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                             CommandParameter="{Binding}"/>
                                                     <TextBlock Text="{Binding Quantity}" 
                                                                VerticalAlignment="Center" 
                                                                HorizontalAlignment="Center" 
                                                                Width="28" 
                                                                TextAlignment="Center" 
                                                                FontWeight="Bold" 
                                                                Foreground="{StaticResource TextPrimaryBrush}"
                                                                FontSize="12"/>
                                                     <Button Content="+" 
                                                             Style="{StaticResource QtyAdjustButton}"
                                                             Command="{Binding DataContext.IncreaseQuantityCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                             CommandParameter="{Binding}"/>
                                                 </StackPanel>

                                                 <!-- Subtotal -->
                                                 <TextBlock Grid.Column="3" 
                                                            Text="{Binding Subtotal, StringFormat='{}{0:N0} ₫'}" 
                                                            FontWeight="Bold" 
                                                            Foreground="{StaticResource TextPrimaryBrush}" 
                                                            FontSize="13" 
                                                            HorizontalAlignment="Right" 
                                                            VerticalAlignment="Center"/>

                                                 <!-- Remove item button -->
                                                 <Button Grid.Column="4" 
                                                         Content="✕" 
                                                         Style="{StaticResource RemoveCartItemButton}"
                                                         Command="{Binding DataContext.RemoveItemCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                         CommandParameter="{Binding}"/>
                                             </Grid>
                                         </Border>
                                     </DataTemplate>
                                 </ItemsControl.ItemTemplate>
                             </ItemsControl>
                         </ScrollViewer>

                         <!-- Cart Footer calculations & checkout -->
                         <Border Grid.Row="2" BorderBrush="{StaticResource BorderMediumBrush}" BorderThickness="0,1,0,0" Background="#FFFFFF" Padding="20,16">
                             <StackPanel>
                                 <!-- Customer Info Row -->
                                 <Border Background="{StaticResource BackgroundBrush}" CornerRadius="8" Padding="12,8" Margin="0,0,0,12">
                                     <StackPanel>
                                         <Grid>
                                             <!-- Selected Customer Info -->
                                             <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                                 <StackPanel.Style>
                                                     <Style TargetType="StackPanel">
                                                         <Setter Property="Visibility" Value="Visible"/>
                                                         <Style.Triggers>
                                                             <DataTrigger Binding="{Binding Cart.Customer}" Value="{x:Null}">
                                                                 <Setter Property="Visibility" Value="Collapsed"/>
                                                             </DataTrigger>
                                                         </Style.Triggers>
                                                     </Style>
                                                 </StackPanel.Style>
                                                 <TextBlock Text="👤" FontSize="14" Margin="0,0,8,0"/>
                                                 <TextBlock Text="{Binding CustomerInfo}" FontWeight="Medium" Foreground="{StaticResource TextPrimaryBrush}" FontSize="12"/>
                                                 <Button Content="✕" Command="{Binding RemoveCustomerCommand}" Background="Transparent" Foreground="{StaticResource DangerBrush}" BorderThickness="0" FontSize="10" Margin="8,0,0,0" Cursor="Hand" ToolTip="Xóa khách hàng"/>
                                             </StackPanel>
                                             
                                             <!-- Customer Search Input -->
                                             <Grid>
                                                 <Grid.Style>
                                                     <Style TargetType="Grid">
                                                         <Setter Property="Visibility" Value="Collapsed"/>
                                                         <Style.Triggers>
                                                             <DataTrigger Binding="{Binding Cart.Customer}" Value="{x:Null}">
                                                                 <Setter Property="Visibility" Value="Visible"/>
                                                             </DataTrigger>
                                                         </Style.Triggers>
                                                     </Style>
                                                 </Grid.Style>
                                                 <Grid.ColumnDefinitions>
                                                     <ColumnDefinition Width="*"/>
                                                     <ColumnDefinition Width="Auto"/>
                                                 </Grid.ColumnDefinitions>
                                                 
                                                 <Grid Grid.Column="0">
                                                     <TextBox Style="{StaticResource PromoTextBox}" 
                                                              Text="{Binding BarcodeQuery, UpdateSourceTrigger=PropertyChanged}" 
                                                              x:Name="CustomerPhoneInput">
                                                         <TextBox.InputBindings>
                                                             <KeyBinding Key="Enter" Command="{Binding ScanBarcodeCommand}"/>
                                                         </TextBox.InputBindings>
                                                     </TextBox>
                                                     <!-- Placeholder -->
                                                     <TextBlock Text="👤 Nhập SĐT khách hàng..." 
                                                                Foreground="#94A3B8" 
                                                                FontSize="13" 
                                                                VerticalAlignment="Center" 
                                                                IsHitTestVisible="False" 
                                                                Margin="10,0,0,0">
                                                         <TextBlock.Style>
                                                             <Style TargetType="TextBlock">
                                                                 <Setter Property="Visibility" Value="Collapsed"/>
                                                                 <Style.Triggers>
                                                                     <DataTrigger Binding="{Binding Text, ElementName=CustomerPhoneInput}" Value="">
                                                                         <Setter Property="Visibility" Value="Visible"/>
                                                                     </DataTrigger>
                                                                 </Style.Triggers>
                                                             </Style>
                                                         </TextBlock.Style>
                                                     </TextBlock>
                                                 </Grid>

                                                 <Button Grid.Column="1" 
                                                         Content="Tìm khách" 
                                                         Command="{Binding ScanBarcodeCommand}" 
                                                         Style="{StaticResource ApplyPromoButton}" 
                                                         Margin="8,0,0,0"/>
                                             </Grid>
                                         </Grid>
                                         
                                         <!-- Điểm tích lũy -->
                                         <Grid Margin="0,8,0,0" Visibility="{Binding Cart.Customer, Converter={StaticResource NullOrEmptyToVisibilityConverter}, FallbackValue=Collapsed}">
                                             <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                                 <TextBlock Text="🌟 Điểm hiện tại: " Foreground="{StaticResource TextMutedBrush}" FontSize="12"/>
                                                 <TextBlock Text="{Binding Cart.Customer.LoyaltyPoints, StringFormat='{}{0:N0}'}" FontWeight="Bold" Foreground="{StaticResource SuccessBrush}" FontSize="12"/>
                                             </StackPanel>
                                             <Button Content="Sử dụng/Hủy điểm" Command="{Binding ToggleUsePointsCommand}" Background="Transparent" Foreground="{StaticResource SuccessBrush}" FontWeight="Bold" FontSize="12" BorderThickness="0" HorizontalAlignment="Right" Cursor="Hand"/>
                                         </Grid>
                                     </StackPanel>
                                 </Border>

                                 <!-- Promo Button -->
                                 <Grid Margin="0,0,0,16">
                                     <Button Content="🏷️ Áp dụng Khuyến mãi" 
                                             Command="{Binding OpenPromoPopupCommand}" 
                                             Background="{StaticResource BorderLightBrush}" Foreground="{StaticResource TextPrimaryBrush}" FontWeight="SemiBold" 
                                             BorderThickness="1" BorderBrush="{StaticResource BorderMediumBrush}" Height="44" Cursor="Hand">
                                         <Button.Template>
                                             <ControlTemplate TargetType="Button">
                                                 <Border Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="{TemplateBinding BorderThickness}" CornerRadius="8">
                                                     <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                 </Border>
                                             </ControlTemplate>
                                         </Button.Template>
                                     </Button>
                                 </Grid>

                                 <!-- Calculations list -->
                                 <StackPanel Margin="0,0,0,16">
                                     <!-- Subtotal -->
                                     <Grid Margin="0,2">
                                         <TextBlock Text="Subtotal" Foreground="{StaticResource TextMutedBrush}" FontSize="13"/>
                                         <TextBlock Text="{Binding Cart.Subtotal, StringFormat='{}{0:N0} ₫'}" Foreground="{StaticResource TextMutedBrush}" FontSize="13" HorizontalAlignment="Right"/>
                                     </Grid>
                                     <!-- Discount -->
                                     <Grid Margin="0,2" Visibility="{Binding Cart.DiscountAmount, Converter={StaticResource DecimalToVisibilityConverter}, FallbackValue=Collapsed}">
                                         <Grid.ColumnDefinitions>
                                             <ColumnDefinition Width="Auto"/>
                                             <ColumnDefinition Width="*"/>
                                             <ColumnDefinition Width="Auto"/>
                                         </Grid.ColumnDefinitions>
                                         <TextBlock Grid.Column="0" Text="Khuyến mãi: " Foreground="{StaticResource TextMutedBrush}" FontSize="13"/>
                                         <TextBlock Grid.Column="1" Text="{Binding PromotionInfo}" Foreground="{StaticResource SuccessBrush}" FontSize="13" FontWeight="SemiBold"/>
                                         <Button Grid.Column="2" Content="✕" Command="{Binding RemovePromoCommand}" Background="Transparent" Foreground="{StaticResource DangerBrush}" BorderThickness="0" FontSize="12" Cursor="Hand" ToolTip="Gỡ khuyến mãi" Margin="8,0,0,0"/>
                                     </Grid>
                                     <!-- Tax -->
                                     <Grid Margin="0,2">
                                         <TextBlock Text="Tax (10%)" Foreground="{StaticResource TextMutedBrush}" FontSize="13"/>
                                         <TextBlock Text="{Binding Cart.TaxAmount, StringFormat='{}{0:N0} ₫'}" Foreground="{StaticResource TextMutedBrush}" FontSize="13" HorizontalAlignment="Right"/>
                                     </Grid>
                                     <!-- Sử dụng điểm -->
                                     <Grid Margin="0,2" Visibility="{Binding Cart.PointsDiscountAmount, Converter={StaticResource DecimalToVisibilityConverter}, FallbackValue=Collapsed}">
                                         <TextBlock Text="Sử dụng điểm" Foreground="{StaticResource TextMutedBrush}" FontSize="13"/>
                                         <TextBlock Text="{Binding Cart.PointsDiscountAmount, StringFormat='-{0:N0} ₫'}" Foreground="{StaticResource SuccessBrush}" FontSize="13" HorizontalAlignment="Right"/>
                                     </Grid>
                                     <!-- Điểm được cộng -->
                                     <Grid Margin="0,2">
                                         <TextBlock Text="Điểm được tích" Foreground="{StaticResource TextMutedBrush}" FontSize="13"/>
                                         <TextBlock Text="{Binding Cart.PointsEarned, StringFormat='+{0:N0} điểm'}" Foreground="{StaticResource SuccessBrush}" FontSize="13" HorizontalAlignment="Right"/>
                                     </Grid>
                                     <!-- Total -->
                                     <Border Height="1" Background="{StaticResource BorderMediumBrush}" Margin="0,8"/>
                                     <Grid>
                                         <TextBlock Text="Total" FontSize="18" FontWeight="Bold" Foreground="{StaticResource TextPrimaryBrush}" VerticalAlignment="Center"/>
                                         <TextBlock Text="{Binding Cart.TotalAmount, StringFormat='{}{0:N0} ₫'}" FontSize="24" FontWeight="Black" Foreground="#00288E" HorizontalAlignment="Right" VerticalAlignment="Center"/>
                                     </Grid>
                                 </StackPanel>

                                 <!-- Actions -->
                                 <Grid>
                                     <Grid.ColumnDefinitions>
                                         <ColumnDefinition Width="*"/>
                                         <ColumnDefinition Width="*"/>
                                     </Grid.ColumnDefinitions>
                                     <Button Grid.Column="0" 
                                             Content="Cancel Order" 
                                             Command="{Binding CancelOrderCommand}" 
                                             Style="{StaticResource CancelOrderButton}" 
                                             Margin="0,0,6,0"/>
                                     <Button Grid.Column="1" 
                                             Content="Checkout" 
                                             Command="{Binding CheckoutCommand}" 
                                             Style="{StaticResource CheckoutButton}" 
                                             Margin="6,0,0,0"/>
                                 </Grid>
                             </StackPanel>
                         </Border>
                     </Grid>
                 </Border>
             </Grid>
     </Grid>
         
         <!-- Popup: Customer Not Found -->
         <Grid Background="#66000000" Panel.ZIndex="100" Grid.ColumnSpan="2" Visibility="{Binding IsCustomerNotFoundPopupOpen, Converter={StaticResource BooleanToVisibilityConverter}}">
             <Border Background="White" CornerRadius="12" Width="400" HorizontalAlignment="Center" VerticalAlignment="Center" Padding="24">
                 <StackPanel>
                     <TextBlock Text="Khách hàng chưa tồn tại" FontSize="18" FontWeight="Bold" Foreground="{StaticResource TextPrimaryBrush}" Margin="0,0,0,16"/>
                     <TextBlock Text="Không tìm thấy thông tin khách hàng với số điện thoại này. Quý khách có muốn tạo mới tài khoản không?" FontSize="14" Foreground="{StaticResource TextMutedBrush}" TextWrapping="Wrap" Margin="0,0,0,24"/>
                     <Grid>
                         <Grid.ColumnDefinitions>
                             <ColumnDefinition Width="*"/>
                             <ColumnDefinition Width="*"/>
                         </Grid.ColumnDefinitions>
                         <Button Grid.Column="0" Content="Bỏ qua" Command="{Binding CloseCustomerPopupsCommand}" Background="Transparent" Foreground="{StaticResource TextMutedBrush}" BorderThickness="0" FontWeight="SemiBold" Margin="0,0,8,0" Height="40" Cursor="Hand"/>
                         <Button Grid.Column="1" Content="Tạo mới" Command="{Binding ShowCreateCustomerFormCommand}" Style="{StaticResource CheckoutButton}" Height="40"/>
                     </Grid>
                 </StackPanel>
             </Border>
         </Grid>

         <!-- Popup: Create Customer Form -->
         <Grid Background="#66000000" Panel.ZIndex="100" Grid.ColumnSpan="2" Visibility="{Binding IsCreateCustomerPopupOpen, Converter={StaticResource BooleanToVisibilityConverter}}">
             <Border Background="White" CornerRadius="12" Width="400" HorizontalAlignment="Center" VerticalAlignment="Center" Padding="24">
                 <StackPanel>
                     <TextBlock Text="Tạo tài khoản thành viên" FontSize="18" FontWeight="Bold" Foreground="{StaticResource TextPrimaryBrush}" Margin="0,0,0,16"/>
                     
                     <TextBlock Text="Số điện thoại" FontSize="12" FontWeight="SemiBold" Foreground="{StaticResource TextMutedBrush}" Margin="0,0,0,4"/>
                     <TextBox Text="{Binding NewCustomerPhone}" IsReadOnly="True" Style="{StaticResource PromoTextBox}" Background="{StaticResource BorderLightBrush}" Foreground="{StaticResource TextMutedBrush}" Margin="0,0,0,16"/>
                     
                     <TextBlock Text="Tên khách hàng (*)" FontSize="12" FontWeight="SemiBold" Foreground="{StaticResource TextMutedBrush}" Margin="0,0,0,4"/>
                     <TextBox Text="{Binding NewCustomerName, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource PromoTextBox}" Margin="0,0,0,16"/>
                     
                     <TextBlock Text="Email (Không bắt buộc)" FontSize="12" FontWeight="SemiBold" Foreground="{StaticResource TextMutedBrush}" Margin="0,0,0,4"/>
                     <TextBox Text="{Binding NewCustomerEmail, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource PromoTextBox}" Margin="0,0,0,24"/>
                     
                     <Grid>
                         <Grid.ColumnDefinitions>
                             <ColumnDefinition Width="*"/>
                             <ColumnDefinition Width="*"/>
                         </Grid.ColumnDefinitions>
                         <Button Grid.Column="0" Content="Hủy" Command="{Binding CloseCustomerPopupsCommand}" Background="Transparent" Foreground="{StaticResource TextMutedBrush}" BorderThickness="0" FontWeight="SemiBold" Margin="0,0,8,0" Height="40" Cursor="Hand"/>
                         <Button Grid.Column="1" Content="Lưu khách hàng" Command="{Binding ConfirmCreateCustomerCommand}" Height="40">
                             <Button.Style>
                                 <Style TargetType="Button" BasedOn="{StaticResource CheckoutButton}">
                                     <Setter Property="IsEnabled" Value="True"/>
                                     <Style.Triggers>
                                         <DataTrigger Binding="{Binding IsLoading}" Value="True">
                                             <Setter Property="IsEnabled" Value="False"/>
                                         </DataTrigger>
                                     </Style.Triggers>
                                 </Style>
                             </Button.Style>
                         </Button>
                     </Grid>
                 </StackPanel>
             </Border>
         </Grid>
         
         <!-- Popup: Apply Promotion -->
         <Grid Background="#66000000" Panel.ZIndex="100" Grid.ColumnSpan="2" Visibility="{Binding IsPromoPopupOpen, Converter={StaticResource BooleanToVisibilityConverter}}">
             <Border Background="White" CornerRadius="12" Width="400" HorizontalAlignment="Center" VerticalAlignment="Center" Padding="24">
                 <StackPanel>
                     <TextBlock Text="Áp dụng mã khuyến mãi" FontSize="18" FontWeight="Bold" Foreground="#0F172A" Margin="0,0,0,16"/>
                     
                     <!-- Manual Input -->
                     <TextBlock Text="Nhập mã khuyến mãi" FontSize="12" FontWeight="SemiBold" Foreground="#64748B" Margin="0,0,0,4"/>
                     <Grid Margin="0,0,0,16">
                         <Grid.ColumnDefinitions>
                             <ColumnDefinition Width="*"/>
                             <ColumnDefinition Width="Auto"/>
                         </Grid.ColumnDefinitions>
                         <TextBox Text="{Binding PromoCodeInput, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource PromoTextBox}" Height="40">
                             <TextBox.InputBindings>
                                 <KeyBinding Key="Enter" Command="{Binding ApplyPromoCommand}" CommandParameter="{Binding Text, RelativeSource={RelativeSource AncestorType=TextBox}}"/>
                             </TextBox.InputBindings>
                         </TextBox>
                         <Button Grid.Column="1" Content="Áp dụng" Command="{Binding ApplyPromoCommand}" CommandParameter="{Binding PromoCodeInput}" Style="{StaticResource ApplyPromoButton}" Margin="8,0,0,0" Height="40"/>
                     </Grid>
                     
                     <!-- Suggestions -->
                     <TextBlock Text="Gợi ý mã đang hoạt động:" FontSize="12" FontWeight="SemiBold" Foreground="#64748B" Margin="0,0,0,8"/>
                     <ScrollViewer MaxHeight="200" VerticalScrollBarVisibility="Auto" Margin="0,0,0,16">
                         <ItemsControl ItemsSource="{Binding AvailablePromotions}">
                             <ItemsControl.ItemTemplate>
                                 <DataTemplate>
                                     <Border Background="#F1F5F9" CornerRadius="8" Padding="12,8" Margin="0,0,0,8">
                                         <Grid>
                                             <Grid.ColumnDefinitions>
                                                 <ColumnDefinition Width="*"/>
                                                 <ColumnDefinition Width="Auto"/>
                                             </Grid.ColumnDefinitions>
                                             <StackPanel Grid.Column="0">
                                                 <TextBlock Text="{Binding Code}" FontWeight="Bold" Foreground="#00288E" FontSize="14"/>
                                                 <TextBlock Text="{Binding Name}" Foreground="#64748B" FontSize="12" TextWrapping="Wrap" Margin="0,4,0,0"/>
                                             </StackPanel>
                                             <Button Grid.Column="1" Content="Dùng ngay" Command="{Binding DataContext.ApplyPromoCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}" CommandParameter="{Binding Code}" Style="{StaticResource CheckoutButton}" Height="32" Padding="12,0"/>
                                         </Grid>
                                     </Border>
                                 </DataTemplate>
                             </ItemsControl.ItemTemplate>
                         </ItemsControl>
                     </ScrollViewer>
                     
                     <!-- Cancel -->
                     <Button Content="Đóng" Command="{Binding ClosePromoPopupCommand}" Background="Transparent" Foreground="#64748B" BorderThickness="0" FontWeight="SemiBold" Height="40" Cursor="Hand"/>
                 </StackPanel>
             </Border>
         </Grid>
         
     </Grid>
</UserControl>
