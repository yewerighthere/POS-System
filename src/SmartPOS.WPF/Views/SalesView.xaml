<UserControl x:Class="SmartPOS.WPF.Views.SalesView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:SmartPOS.WPF.Views"
             xmlns:viewmodels="clr-namespace:SmartPOS.WPF.ViewModels"
             xmlns:converters="clr-namespace:SmartPOS.WPF.Converters"
             mc:Ignorable="d" 
             d:DataContext="{d:DesignInstance Type=viewmodels:SalesViewModel}"
             Background="#121214"
             Foreground="#F3F4F6"
             d:DesignHeight="768" d:DesignWidth="1024">
             
    <UserControl.Resources>
        <converters:NullOrEmptyToVisibilityConverter x:Key="NullOrEmptyToVisibilityConverter" />
        <converters:DecimalToVisibilityConverter x:Key="DecimalToVisibilityConverter" />
        <BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter" />
        <!-- Modern ScrollViewer style for clean UI -->
        <Style x:Key="ModernScrollViewer" TargetType="{x:Type ScrollViewer}">
            <Setter Property="VerticalScrollBarVisibility" Value="Auto"/>
            <Setter Property="HorizontalScrollBarVisibility" Value="Disabled"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type ScrollViewer}">
                        <Grid>
                            <ScrollContentPresenter x:Name="PART_ScrollContentPresenter" SnapsToDevicePixels="{TemplateBinding SnapsToDevicePixels}"/>
                            <ScrollBar x:Name="PART_VerticalScrollBar" 
                                       Value="{TemplateBinding VerticalOffset}" 
                                       Maximum="{TemplateBinding ScrollableHeight}" 
                                       ViewportSize="{TemplateBinding ViewportHeight}" 
                                       Visibility="{TemplateBinding ComputedVerticalScrollBarVisibility}" 
                                       HorizontalAlignment="Right" 
                                       Width="8"/>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Rounded Border Style -->
        <Style x:Key="CardBorder" TargetType="Border">
            <Setter Property="Background" Value="#1E1E24"/>
            <Setter Property="BorderBrush" Value="#2D2D35"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="8"/>
            <Setter Property="Margin" Value="4"/>
        </Style>

        <!-- Text Box Style -->
        <Style x:Key="ModernTextBox" TargetType="TextBox">
            <Setter Property="Background" Value="#17171B"/>
            <Setter Property="Foreground" Value="#F3F4F6"/>
            <Setter Property="BorderBrush" Value="#2D2D35"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="10,8"/>
            <Setter Property="CaretBrush" Value="#3B82F6"/>
            <Setter Property="SelectionBrush" Value="#3B82F6"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TextBox">
                        <Border Name="Border"
                                CornerRadius="6"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                Background="{TemplateBinding Background}">
                            <ScrollViewer x:Name="PART_ContentHost" Margin="0" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsFocused" Value="True">
                                <Setter TargetName="Border" Property="BorderBrush" Value="#3B82F6"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Modern Accent Button -->
        <Style x:Key="AccentButton" TargetType="Button">
            <Setter Property="Background" Value="#3B82F6"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="16,10"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Name="Border" 
                                CornerRadius="6" 
                                Background="{TemplateBinding Background}" 
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Border" Property="Background" Value="#2563EB"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="Border" Property="Background" Value="#4B5563"/>
                                <Setter Property="Foreground" Value="#9CA3AF"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Secondary Cancel Button -->
        <Style x:Key="SecondaryButton" TargetType="Button">
            <Setter Property="Background" Value="#EF4444"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="16,10"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Name="Border" 
                                CornerRadius="6" 
                                Background="{TemplateBinding Background}" 
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Border" Property="Background" Value="#DC2626"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </UserControl.Resources>

    <Grid Margin="12">
        <Grid.RowDefinitions>
            <!-- Top Header & Back to Shift Button -->
            <RowDefinition Height="Auto"/>
            <!-- Header bar / Error bar -->
            <RowDefinition Height="Auto"/>
            <!-- Main grid area -->
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Top Header Bar -->
        <Grid Grid.Row="0" Margin="4,0,4,8">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <TextBlock Text="🖥️ MÀN HÌNH BÁN HÀNG (POS)" Foreground="#F3F4F6" FontSize="18" FontWeight="Bold" VerticalAlignment="Center"/>
            <Button Grid.Column="1" 
                    Content="🔒 Đóng ca" 
                    Style="{StaticResource AccentButton}" 
                    Background="#DC2626"
                    Command="{Binding NavigateToShiftCommand}" 
                    Height="36" 
                    Padding="16,0"
                    VerticalAlignment="Center"/>
        </Grid>

        <!-- Notification / Error Messages -->
        <Grid Grid.Row="1" Margin="4,0,4,8" Visibility="{Binding ErrorMessage, Converter={StaticResource NullOrEmptyToVisibilityConverter}, FallbackValue=Collapsed}">
            <Border Background="#450A0A" BorderBrush="#991B1B" BorderThickness="1" CornerRadius="6" Padding="12,8">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Text="{Binding ErrorMessage}" Foreground="#FECACA" FontWeight="Medium" VerticalAlignment="Center" TextWrapping="Wrap"/>
                    <!-- Simple Close Button for Error -->
                    <Button Grid.Column="1" Content="✕" Foreground="#FCA5A5" Background="Transparent" BorderThickness="0" Command="{Binding ClearErrorMessageCommand}" VerticalAlignment="Center" Margin="8,0,0,0" Cursor="Hand"/>
                </Grid>
            </Border>
        </Grid>

        <!-- Main Workspace split (Left: Products/Scanning | Right: Cart Summary) -->
        <Grid Grid.Row="2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="3*"/>
                <ColumnDefinition Width="2*"/>
            </Grid.ColumnDefinitions>

            <!-- LEFT SIDE: Product search and scanning simulator -->
            <Grid Grid.Column="0">
                <Grid.RowDefinitions>
                    <!-- Scanning Barcode simulation -->
                    <RowDefinition Height="Auto"/>
                    <!-- Keyword search -->
                    <RowDefinition Height="Auto"/>
                    <!-- Products Grid -->
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <!-- 1. Barcode Simulator -->
                <Border Grid.Row="0" Style="{StaticResource CardBorder}" Padding="16,12">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center" Margin="0,0,12,0">
                            <TextBlock Text="📷" FontSize="18" VerticalAlignment="Center" Margin="0,0,6,0"/>
                            <TextBlock Text="Giả lập Barcode:" FontWeight="SemiBold" VerticalAlignment="Center" Foreground="#9CA3AF"/>
                        </StackPanel>
                        <TextBox Grid.Column="1" 
                                 Style="{StaticResource ModernTextBox}" 
                                 Text="{Binding BarcodeQuery, UpdateSourceTrigger=PropertyChanged}" 
                                 HorizontalAlignment="Stretch"
                                 VerticalAlignment="Center"
                                 ToolTip="Nhập mã vạch sản phẩm, số điện thoại khách hàng, hoặc mã khuyến mãi rồi nhấn Enter">
                            <TextBox.InputBindings>
                                <KeyBinding Key="Enter" Command="{Binding ScanBarcodeCommand}"/>
                            </TextBox.InputBindings>
                        </TextBox>
                        <Button Grid.Column="2" 
                                Content="Quét (Enter)" 
                                Style="{StaticResource AccentButton}" 
                                Command="{Binding ScanBarcodeCommand}" 
                                Margin="12,0,0,0" 
                                Height="36"/>
                    </Grid>
                </Border>

                <!-- 2. Product Search Box -->
                <Border Grid.Row="1" Style="{StaticResource CardBorder}" Padding="16,12" Margin="4,4,4,8">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBox Grid.Column="0" 
                                 Style="{StaticResource ModernTextBox}" 
                                 Text="{Binding SearchQuery, UpdateSourceTrigger=PropertyChanged}" 
                                 Padding="10,8"
                                 HorizontalAlignment="Stretch">
                            <TextBox.InputBindings>
                                <KeyBinding Key="Enter" Command="{Binding SearchProductsCommand}"/>
                            </TextBox.InputBindings>
                        </TextBox>
                        <Button Grid.Column="1" 
                                Content="Tìm sản phẩm" 
                                Style="{StaticResource AccentButton}" 
                                Command="{Binding SearchProductsCommand}" 
                                Margin="12,0,0,0"/>
                    </Grid>
                </Border>

                <!-- 3. Product Catalog Grid -->
                <Border Grid.Row="2" Style="{StaticResource CardBorder}" Padding="12">
                    <Grid>
                        <!-- Loader overlay -->
                        <ProgressBar IsIndeterminate="True" Height="4" VerticalAlignment="Top" Background="Transparent" Foreground="#3B82F6" Visibility="{Binding IsLoading, Converter={StaticResource BooleanToVisibilityConverter}, FallbackValue=Collapsed}"/>
                        
                        <ListBox ItemsSource="{Binding SearchResults}" 
                                 Background="Transparent" 
                                 BorderThickness="0" 
                                 ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                                 ScrollViewer.VerticalScrollBarVisibility="Auto">
                            <ListBox.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <WrapPanel />
                                </ItemsPanelTemplate>
                            </ListBox.ItemsPanel>
                            <ListBox.ItemTemplate>
                                <DataTemplate>
                                    <Border Width="190" Height="140" Background="#17171B" BorderBrush="#2D2D35" BorderThickness="1" CornerRadius="6" Margin="6" Padding="12">
                                        <Grid>
                                            <Grid.RowDefinitions>
                                                <RowDefinition Height="Auto"/>
                                                <RowDefinition Height="*"/>
                                                <RowDefinition Height="Auto"/>
                                            </Grid.RowDefinitions>
                                            
                                            <!-- Product Name & SKU -->
                                            <StackPanel Grid.Row="0">
                                                <TextBlock Text="{Binding Name}" FontWeight="Bold" FontSize="14" Foreground="#F3F4F6" TextTrimming="CharacterEllipsis"/>
                                                <TextBlock Text="{Binding Sku}" FontSize="11" Foreground="#9CA3AF" Margin="0,2,0,0"/>
                                            </StackPanel>

                                            <!-- Price & Stock -->
                                            <StackPanel Grid.Row="1" VerticalAlignment="Center" Margin="0,8,0,0">
                                                <TextBlock Text="{Binding UnitPrice, StringFormat='{}{0:N0} đ'}" FontSize="15" FontWeight="SemiBold" Foreground="#10B981"/>
                                                <TextBlock Text="{Binding LocalStockQuantity, StringFormat='Tồn kho: {0}'}" FontSize="12" Foreground="#9CA3AF"/>
                                            </StackPanel>

                                            <!-- Add Action -->
                                            <Button Grid.Row="2" 
                                                    Content="Thêm vào giỏ" 
                                                    Style="{StaticResource AccentButton}" 
                                                    Command="{Binding DataContext.AddToCartCommand, RelativeSource={RelativeSource AncestorType=UserControl}}" 
                                                    CommandParameter="{Binding Id}"
                                                    Padding="0,6"
                                                    Height="28"
                                                    FontSize="12"/>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ListBox.ItemTemplate>
                        </ListBox>
                    </Grid>
                </Border>
            </Grid>

            <!-- RIGHT SIDE: Cart Summary -->
            <Grid Grid.Column="1" Margin="8,0,0,0">
                <Grid.RowDefinitions>
                    <!-- Cart Title / Clear button -->
                    <RowDefinition Height="Auto"/>
                    <!-- Cart Items List -->
                    <RowDefinition Height="*"/>
                    <!-- Totals and Checkout -->
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <!-- 1. Cart Title -->
                <Border Grid.Row="0" Style="{StaticResource CardBorder}" Padding="16,12">
                    <Grid>
                        <TextBlock Text="🛒 Giỏ Hàng" FontSize="16" FontWeight="Bold" VerticalAlignment="Center" Foreground="#F3F4F6"/>
                        <Button Content="Xóa sạch" 
                                Background="Transparent" 
                                BorderThickness="0" 
                                Foreground="#FCA5A5" 
                                HorizontalAlignment="Right" 
                                Command="{Binding ClearCartCommand}" 
                                Cursor="Hand" 
                                VerticalAlignment="Center"/>
                    </Grid>
                </Border>

                <!-- 2. Cart Items ListView -->
                <Border Grid.Row="1" Style="{StaticResource CardBorder}" Padding="8">
                    <ListView ItemsSource="{Binding Cart.Items}" 
                              Background="Transparent" 
                              BorderThickness="0"
                              Foreground="#F3F4F6"
                              ScrollViewer.VerticalScrollBarVisibility="Auto">
                        <ListView.ItemContainerStyle>
                            <Style TargetType="ListViewItem">
                                <Setter Property="Background" Value="Transparent"/>
                                <Setter Property="BorderBrush" Value="#2D2D35"/>
                                <Setter Property="BorderThickness" Value="0,0,0,1"/>
                                <Setter Property="Padding" Value="8,10"/>
                                <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                            </Style>
                        </ListView.ItemContainerStyle>
                        <ListView.ItemTemplate>
                            <DataTemplate>
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <!-- Product Name & Unit Price -->
                                        <ColumnDefinition Width="*"/>
                                        <!-- Quantity Controls -->
                                        <ColumnDefinition Width="Auto"/>
                                        <!-- Subtotal -->
                                        <ColumnDefinition Width="80"/>
                                        <!-- Remove Button -->
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    
                                    <!-- Product Name & Price -->
                                    <StackPanel Grid.Column="0" VerticalAlignment="Center">
                                        <TextBlock Text="{Binding ProductName}" FontWeight="SemiBold" FontSize="13" Foreground="#F3F4F6"/>
                                        <TextBlock Text="{Binding UnitPrice, StringFormat='{}{0:N0} đ'}" FontSize="11" Foreground="#9CA3AF" Margin="0,2,0,0"/>
                                    </StackPanel>

                                    <!-- Quantity Adjustment ( - Quantity + ) -->
                                    <StackPanel Grid.Column="1" Orientation="Horizontal" Margin="12,0" VerticalAlignment="Center">
                                        <Button Content="-" 
                                                Background="#2D2D35" 
                                                BorderThickness="0" 
                                                Foreground="White" 
                                                Width="24" Height="24" 
                                                Command="{Binding DataContext.DecreaseQuantityCommand, RelativeSource={RelativeSource AncestorType=UserControl}}" 
                                                CommandParameter="{Binding}"
                                                Cursor="Hand"/>
                                        <TextBlock Text="{Binding Quantity}" 
                                                   VerticalAlignment="Center" 
                                                   HorizontalAlignment="Center" 
                                                   Width="30" 
                                                   TextAlignment="Center" 
                                                   FontWeight="Bold" 
                                                   Foreground="#F3F4F6"/>
                                        <Button Content="+" 
                                                Background="#2D2D35" 
                                                BorderThickness="0" 
                                                Foreground="White" 
                                                Width="24" Height="24" 
                                                Command="{Binding DataContext.IncreaseQuantityCommand, RelativeSource={RelativeSource AncestorType=UserControl}}" 
                                                CommandParameter="{Binding}"
                                                Cursor="Hand"/>
                                    </StackPanel>

                                    <!-- Subtotal -->
                                    <TextBlock Grid.Column="2" 
                                               Text="{Binding Subtotal, StringFormat='{}{0:N0} đ'}" 
                                               FontWeight="SemiBold" 
                                               VerticalAlignment="Center" 
                                               HorizontalAlignment="Right" 
                                               Foreground="#10B981"/>

                                    <!-- Remove Button -->
                                    <Button Grid.Column="3" 
                                            Content="🗑" 
                                            Background="Transparent" 
                                            BorderThickness="0" 
                                            Foreground="#EF4444" 
                                            Margin="8,0,0,0" 
                                            FontSize="14"
                                            Command="{Binding DataContext.RemoveItemCommand, RelativeSource={RelativeSource AncestorType=UserControl}}" 
                                            CommandParameter="{Binding}"
                                            Cursor="Hand"/>
                                </Grid>
                            </DataTemplate>
                        </ListView.ItemTemplate>
                    </ListView>
                </Border>

                <!-- 3. Cart Totals & Checkout -->
                <Border Grid.Row="2" Style="{StaticResource CardBorder}" Padding="16">
                    <StackPanel>
                        <!-- Row: Customer info -->
                        <Grid Margin="0,4">
                            <TextBlock Text="👤 Khách hàng:" Foreground="#9CA3AF"/>
                            <TextBlock Text="{Binding CustomerInfo}" HorizontalAlignment="Right" FontWeight="SemiBold" Foreground="#3B82F6"/>
                        </Grid>
                        <!-- Row: Promotion info -->
                        <Grid Margin="0,4">
                            <TextBlock Text="🏷️ Khuyến mãi:" Foreground="#9CA3AF"/>
                            <TextBlock Text="{Binding PromotionInfo}" HorizontalAlignment="Right" FontWeight="SemiBold" Foreground="#F59E0B"/>
                        </Grid>
                        
                        <Separator Background="#2D2D35" Margin="0,8"/>

                        <!-- Row 1: Subtotal -->
                        <Grid Margin="0,4">
                            <TextBlock Text="Tạm tính:" Foreground="#9CA3AF"/>
                            <TextBlock Text="{Binding Cart.Subtotal, StringFormat='{}{0:N0} đ'}" HorizontalAlignment="Right" FontWeight="SemiBold"/>
                        </Grid>
                        <!-- Row 2: Tax -->
                        <Grid Margin="0,4">
                            <TextBlock Text="Thuế:" Foreground="#9CA3AF"/>
                            <TextBlock Text="{Binding Cart.TaxAmount, StringFormat='{}{0:N0} đ'}" HorizontalAlignment="Right" FontWeight="SemiBold"/>
                        </Grid>
                        <!-- Row 3: Discount -->
                        <Grid Margin="0,4" Visibility="{Binding Cart.DiscountAmount, Converter={StaticResource DecimalToVisibilityConverter}, FallbackValue=Collapsed}">
                            <TextBlock Text="Khuyến mãi:" Foreground="#FCA5A5"/>
                            <TextBlock Text="{Binding Cart.DiscountAmount, StringFormat='-{0:N0} đ'}" HorizontalAlignment="Right" FontWeight="SemiBold" Foreground="#EF4444"/>
                        </Grid>

                        <Separator Background="#2D2D35" Margin="0,12"/>

                        <!-- Row 4: Total Amount -->
                        <Grid Margin="0,0,0,16">
                            <TextBlock Text="Tổng thanh toán:" FontSize="16" FontWeight="Bold" Foreground="#F3F4F6" VerticalAlignment="Center"/>
                            <TextBlock Text="{Binding Cart.TotalAmount, StringFormat='{}{0:N0} đ'}" FontSize="22" FontWeight="Bold" Foreground="#10B981" HorizontalAlignment="Right" VerticalAlignment="Center"/>
                        </Grid>

                        <!-- Row 5: Action buttons -->
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Button Grid.Column="0" 
                                    Content="Hủy Đơn" 
                                    Style="{StaticResource SecondaryButton}" 
                                    Command="{Binding CancelOrderCommand}" 
                                    Margin="0,0,6,0"
                                    Height="45"/>
                            <Button Grid.Column="1" 
                                    Content="Thanh Toán (F9)" 
                                    Style="{StaticResource AccentButton}" 
                                    Command="{Binding CheckoutCommand}" 
                                    Margin="6,0,0,0"
                                    Height="45"/>
                        </Grid>
                    </StackPanel>
                </Border>
            </Grid>
        </Grid>
    </Grid>
</UserControl>
