<UserControl x:Class="SmartPOS.WPF.Views.InvoiceView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:viewmodels="clr-namespace:SmartPOS.WPF.ViewModels"
             mc:Ignorable="d"
             d:DataContext="{d:DesignInstance Type=viewmodels:InvoiceViewModel}"
             Background="#F8FAFC"
             d:DesignHeight="720" d:DesignWidth="960">

    <UserControl.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis"/>
    </UserControl.Resources>

    <Grid Margin="24">
        <Border Background="White" CornerRadius="12" Padding="24" MaxWidth="760" HorizontalAlignment="Center" VerticalAlignment="Center">
            <Border.Effect>
                <DropShadowEffect BlurRadius="28" ShadowDepth="4" Opacity="0.12" Color="#000000"/>
            </Border.Effect>

            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <StackPanel Grid.Row="0">
                    <TextBlock Text="Hóa đơn" FontSize="22" FontWeight="Bold" Foreground="#0F172A"/>
                    <TextBlock Text="{Binding InvoiceStatus}" FontSize="13" Foreground="#64748B" Margin="0,4,0,0"/>
                </StackPanel>

                <Border Grid.Row="1" Margin="0,16,0,16" Background="#F8FAFC" BorderBrush="#E2E8F0" BorderThickness="1" CornerRadius="10" Padding="16">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel Margin="0,0,16,0">
                            <TextBlock Text="Số hóa đơn" Foreground="#64748B" FontSize="12"/>
                            <TextBlock Text="{Binding Invoice.InvoiceNumber}"
                                       Foreground="#0F172A"
                                       FontSize="15"
                                       FontWeight="SemiBold"
                                       TextWrapping="NoWrap"
                                       TextTrimming="CharacterEllipsis"/>
                        </StackPanel>
                        <StackPanel Grid.Column="1" HorizontalAlignment="Right">
                            <TextBlock Text="Tổng tiền" Foreground="#64748B" FontSize="12" HorizontalAlignment="Right"/>
                            <TextBlock Foreground="#0F172A" FontSize="16" FontWeight="SemiBold" HorizontalAlignment="Right">
                                <Run Text="{Binding Invoice.TotalAmount, StringFormat={}{0:N0}}"/>
                                <Run Text=" đ"/>
                            </TextBlock>
                        </StackPanel>
                    </Grid>
                </Border>

                <Border Grid.Row="2" Background="#F8FAFC" BorderBrush="#E2E8F0" BorderThickness="1" CornerRadius="10" Padding="16">
                    <StackPanel>
                        <TextBlock Text="Thông tin hóa đơn" FontSize="13" FontWeight="SemiBold" Foreground="#334155"/>
                        <TextBlock Margin="0,10,0,0" Foreground="#475569">
                            <Run Text="Mã đơn: "/>
                            <Run Text="{Binding Invoice.OrderId}"/>
                        </TextBlock>
                        <TextBlock Margin="0,6,0,0" Foreground="#475569">
                            <Run Text="Ngày phát hành: "/>
                            <Run Text="{Binding IssuedAtLocal, StringFormat={}{0:dd/MM/yyyy HH:mm:ss}}"/>
                        </TextBlock>
                    </StackPanel>
                </Border>

                <StackPanel Grid.Row="3" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,16,0,0">
                    <Button Content="Xem trước / In giả lập"
                            Command="{Binding PreviewCommand}"
                            Height="42"
                            MinWidth="160"
                            Padding="16,0"
                            Background="#0F766E"
                            Foreground="White"
                            BorderThickness="0"
                            Margin="0,0,10,0"/>
                    <Button Content="Đóng"
                            Height="42"
                            MinWidth="96"
                            Padding="16,0"
                            Background="#E2E8F0"
                            Foreground="#0F172A"
                            BorderThickness="0"
                            Command="{Binding CloseCommand}"/>
                </StackPanel>
            </Grid>
        </Border>

        <Border Background="#80000000" Visibility="{Binding IsPreviewVisible, Converter={StaticResource BoolToVis}}">
            <Border Width="420"
                    Background="White"
                    CornerRadius="14"
                    Padding="24"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Center">
                <Border.Effect>
                    <DropShadowEffect BlurRadius="32" ShadowDepth="6" Opacity="0.2" Color="#000000"/>
                </Border.Effect>
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>
                    <StackPanel>
                        <TextBlock Text="Xem trước hóa đơn"
                                   FontSize="20"
                                   FontWeight="Bold"
                                   Foreground="#0F172A"/>
                        <TextBlock Text="In giả lập thành công"
                                   FontSize="13"
                                   Foreground="#0F766E"
                                   Margin="0,4,0,14"/>
                    </StackPanel>
                    <Border Grid.Row="1"
                            Background="#F8FAFC"
                            BorderBrush="#CBD5E1"
                            BorderThickness="1"
                            CornerRadius="10"
                            Padding="16">
                        <ScrollViewer MaxHeight="360" VerticalScrollBarVisibility="Auto">
                            <TextBlock Text="{Binding ReceiptPreview}"
                                       FontFamily="Consolas"
                                       FontSize="13"
                                       Foreground="#0F172A"
                                       TextWrapping="Wrap"/>
                        </ScrollViewer>
                    </Border>
                    <Button Grid.Row="2"
                            Content="Đóng xem trước"
                            Command="{Binding ClosePreviewCommand}"
                            Height="42"
                            MinWidth="140"
                            HorizontalAlignment="Right"
                            Margin="0,16,0,0"
                            Background="#0F766E"
                            Foreground="White"
                            BorderThickness="0"/>
                </Grid>
            </Border>
        </Border>

        <Border Background="#80000000" Visibility="{Binding IsLoading, Converter={StaticResource BoolToVis}}" />
    </Grid>
</UserControl>
