<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- Shadow Effects — translated from style.css :root variables -->

    <!-- Glass Panel Shadow (subtle, for cards/panels) -->
    <DropShadowEffect x:Key="GlassShadowEffect"
                      BlurRadius="32"
                      ShadowDepth="8"
                      Opacity="0.07"
                      Color="#1F2687"
                      Direction="270"/>

    <!-- Button Shadow (primary buttons) -->
    <DropShadowEffect x:Key="ButtonShadowEffect"
                      BlurRadius="14"
                      ShadowDepth="4"
                      Opacity="0.39"
                      Color="#0062FF"
                      Direction="270"/>

    <!-- Card Shadow (standard elevation) -->
    <DropShadowEffect x:Key="CardShadowEffect"
                      BlurRadius="20"
                      ShadowDepth="4"
                      Opacity="0.10"
                      Color="#000000"
                      Direction="270"/>

    <!-- Modal Shadow (elevated dialogs) -->
    <DropShadowEffect x:Key="ModalShadowEffect"
                      BlurRadius="40"
                      ShadowDepth="8"
                      Opacity="0.20"
                      Color="#000000"
                      Direction="270"/>

    <!-- Hover Shadow (elevated on hover) -->
    <DropShadowEffect x:Key="HoverShadowEffect"
                      BlurRadius="24"
                      ShadowDepth="6"
                      Opacity="0.15"
                      Color="#000000"
                      Direction="270"/>

</ResourceDictionary>
