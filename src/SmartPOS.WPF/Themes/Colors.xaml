<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- Design Tokens — translated from style.css :root variables -->

    <!-- Background Colors -->
    <Color x:Key="BackgroundColor">#f4f6f8</Color>
    <Color x:Key="SurfaceColor">#FFFFFF</Color>
    <Color x:Key="PanelBackgroundColor">#B3FFFFFF</Color>
    <Color x:Key="PanelBorderColor">#80FFFFFF</Color>

    <!-- Brand Colors -->
    <Color x:Key="PrimaryColor">#0062FF</Color>
    <Color x:Key="PrimaryHoverColor">#0050d0</Color>
    <Color x:Key="PrimaryLightColor">#DBEAFE</Color>

    <!-- Text Colors -->
    <Color x:Key="TextPrimaryColor">#1d1d1f</Color>
    <Color x:Key="TextMutedColor">#86868b</Color>
    <Color x:Key="TextWhiteColor">#FFFFFF</Color>

    <!-- Semantic Colors -->
    <Color x:Key="SuccessColor">#00B050</Color>
    <Color x:Key="SuccessLightColor">#DCFCE7</Color>
    <Color x:Key="DangerColor">#ff3b30</Color>
    <Color x:Key="DangerLightColor">#FEE2E2</Color>
    <Color x:Key="WarningColor">#D97706</Color>
    <Color x:Key="WarningLightColor">#FEF3C7</Color>
    <Color x:Key="InfoColor">#0F766E</Color>

    <!-- Border Colors -->
    <Color x:Key="BorderColor">#e5e5ea</Color>
    <Color x:Key="BorderLightColor">#F1F5F9</Color>
    <Color x:Key="BorderMediumColor">#E2E8F0</Color>

    <!-- Sidebar Colors -->
    <Color x:Key="SidebarBackgroundColor">#1E1F28</Color>
    <Color x:Key="SidebarHoverColor">#2A2B35</Color>
    <Color x:Key="SidebarTextColor">#94A3B8</Color>
    <Color x:Key="SidebarActiveTextColor">#FFFFFF</Color>

    <!-- Overlay -->
    <Color x:Key="OverlayColor">#80000000</Color>

    <!-- SolidColorBrush Resources -->
    <SolidColorBrush x:Key="BackgroundBrush" Color="{StaticResource BackgroundColor}"/>
    <SolidColorBrush x:Key="SurfaceBrush" Color="{StaticResource SurfaceColor}"/>
    <SolidColorBrush x:Key="PanelBackgroundBrush" Color="{StaticResource PanelBackgroundColor}"/>
    <SolidColorBrush x:Key="PanelBorderBrush" Color="{StaticResource PanelBorderColor}"/>
    <SolidColorBrush x:Key="PrimaryBrush" Color="{StaticResource PrimaryColor}"/>
    <SolidColorBrush x:Key="PrimaryHoverBrush" Color="{StaticResource PrimaryHoverColor}"/>
    <SolidColorBrush x:Key="PrimaryLightBrush" Color="{StaticResource PrimaryLightColor}"/>
    <SolidColorBrush x:Key="TextPrimaryBrush" Color="{StaticResource TextPrimaryColor}"/>
    <SolidColorBrush x:Key="TextMutedBrush" Color="{StaticResource TextMutedColor}"/>
    <SolidColorBrush x:Key="TextWhiteBrush" Color="{StaticResource TextWhiteColor}"/>
    <SolidColorBrush x:Key="SuccessBrush" Color="{StaticResource SuccessColor}"/>
    <SolidColorBrush x:Key="SuccessLightBrush" Color="{StaticResource SuccessLightColor}"/>
    <SolidColorBrush x:Key="DangerBrush" Color="{StaticResource DangerColor}"/>
    <SolidColorBrush x:Key="DangerLightBrush" Color="{StaticResource DangerLightColor}"/>
    <SolidColorBrush x:Key="WarningBrush" Color="{StaticResource WarningColor}"/>
    <SolidColorBrush x:Key="WarningLightBrush" Color="{StaticResource WarningLightColor}"/>
    <SolidColorBrush x:Key="InfoBrush" Color="{StaticResource InfoColor}"/>
    <SolidColorBrush x:Key="BorderBrush" Color="{StaticResource BorderColor}"/>
    <SolidColorBrush x:Key="BorderLightBrush" Color="{StaticResource BorderLightColor}"/>
    <SolidColorBrush x:Key="BorderMediumBrush" Color="{StaticResource BorderMediumColor}"/>
    <SolidColorBrush x:Key="SidebarBackgroundBrush" Color="{StaticResource SidebarBackgroundColor}"/>
    <SolidColorBrush x:Key="SidebarHoverBrush" Color="{StaticResource SidebarHoverColor}"/>
    <SolidColorBrush x:Key="SidebarTextBrush" Color="{StaticResource SidebarTextColor}"/>
    <SolidColorBrush x:Key="SidebarActiveTextBrush" Color="{StaticResource SidebarActiveTextColor}"/>
    <SolidColorBrush x:Key="OverlayBrush" Color="{StaticResource OverlayColor}"/>

    <SolidColorBrush x:Key="SurfaceContainerLowBrush" Color="#F4F2FC"/>
    <SolidColorBrush x:Key="SecondaryContainerBrush" Color="#DAE2FD"/>
    <SolidColorBrush x:Key="OnSecondaryContainerBrush" Color="#5C647A"/>
</ResourceDictionary>
