<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:sys="clr-namespace:System;assembly=mscorlib">

    <!-- Typography — translated from style.css :root variables -->

    <!-- Font Families -->
    <FontFamily x:Key="MainFontFamily">Inter, Segoe UI, sans-serif</FontFamily>
    <FontFamily x:Key="MonoFontFamily">JetBrains Mono, Consolas, monospace</FontFamily>

    <!-- Font Sizes -->
    <sys:Double x:Key="FontSizeXS">10</sys:Double>
    <sys:Double x:Key="FontSizeSM">12</sys:Double>
    <sys:Double x:Key="FontSizeBase">14</sys:Double>
    <sys:Double x:Key="FontSizeMD">15</sys:Double>
    <sys:Double x:Key="FontSizeLG">16</sys:Double>
    <sys:Double x:Key="FontSizeXL">18</sys:Double>
    <sys:Double x:Key="FontSize2XL">20</sys:Double>
    <sys:Double x:Key="FontSize3XL">22</sys:Double>
    <sys:Double x:Key="FontSize4XL">24</sys:Double>
    <sys:Double x:Key="FontSize5XL">28</sys:Double>

</ResourceDictionary>
