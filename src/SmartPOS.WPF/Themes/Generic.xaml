<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- Generic.xaml — Master Merged Dictionary -->
    <!-- This file imports all theme resource dictionaries -->

    <ResourceDictionary.MergedDictionaries>
        <!-- Design Tokens (must be loaded first) -->
        <ResourceDictionary Source="Colors.xaml"/>
        <ResourceDictionary Source="Fonts.xaml"/>
        <ResourceDictionary Source="Spacing.xaml"/>
        <ResourceDictionary Source="Shadows.xaml"/>

        <!-- Component Styles -->
        <ResourceDictionary Source="ButtonStyles.xaml"/>
        <ResourceDictionary Source="TextBoxStyles.xaml"/>
        <ResourceDictionary Source="BorderStyles.xaml"/>
        <ResourceDictionary Source="BadgeStyles.xaml"/>
        <ResourceDictionary Source="ModalStyles.xaml"/>
        <ResourceDictionary Source="ScrollBarStyles.xaml"/>
        <ResourceDictionary Source="SidebarStyles.xaml"/>
        <ResourceDictionary Source="TableStyles.xaml"/>
    </ResourceDictionary.MergedDictionaries>

</ResourceDictionary>
