<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <ResourceDictionary.MergedDictionaries>
        <ResourceDictionary Source="Colors.xaml"/>
        <ResourceDictionary Source="Spacing.xaml"/>
        <ResourceDictionary Source="Shadows.xaml"/>
    </ResourceDictionary.MergedDictionaries>

    <!-- Border Styles — translated from style.css glass-panel, card classes -->

    <!-- Glass Panel (.glass-panel) -->
    <Style x:Key="GlassPanelStyle" TargetType="Border">
        <Setter Property="Background" Value="{StaticResource PanelBackgroundBrush}"/>
        <Setter Property="BorderBrush" Value="{StaticResource PanelBorderBrush}"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="CornerRadius" Value="{StaticResource RadiusMedium}"/>
        <Setter Property="Effect" Value="{StaticResource GlassShadowEffect}"/>
        <Setter Property="Padding" Value="{StaticResource PaddingMedium}"/>
    </Style>

    <!-- Card Style -->
    <Style x:Key="CardStyle" TargetType="Border">
        <Setter Property="Background" Value="{StaticResource SurfaceBrush}"/>
        <Setter Property="CornerRadius" Value="{StaticResource RadiusMedium}"/>
        <Setter Property="Effect" Value="{StaticResource CardShadowEffect}"/>
        <Setter Property="Padding" Value="{StaticResource PaddingMedium}"/>
    </Style>

    <!-- Sidebar Panel -->
    <Style x:Key="SidebarPanelStyle" TargetType="Border">
        <Setter Property="Background" Value="{StaticResource SidebarBackgroundBrush}"/>
        <Setter Property="CornerRadius" Value="{StaticResource RadiusLarge}"/>
        <Setter Property="Padding" Value="16"/>
    </Style>

    <!-- Surface Container (light background sections) -->
    <Style x:Key="SurfaceContainerStyle" TargetType="Border">
        <Setter Property="Background" Value="{StaticResource SurfaceBrush}"/>
        <Setter Property="BorderBrush" Value="{StaticResource BorderBrush}"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="CornerRadius" Value="{StaticResource RadiusMedium}"/>
        <Setter Property="Padding" Value="{StaticResource PaddingMedium}"/>
    </Style>

</ResourceDictionary>
